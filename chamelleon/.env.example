# Chamelleon — variáveis de ambiente (copie para .env)

FLASK_ENV=development
FLASK_DEBUG=1
DATABASE_URL=postgresql://user:password@localhost:5432/chamelleon

# AWS (Bedrock + SES) — mesma conta/região do PanelDX
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# E-mail (AWS SES) — remetente verificado no SES
EMAIL_SENDER=consultant@paneldx.com.br
CHAMELLEON_PUBLIC_URL=http://localhost:5173

# Webhooks Gemba (Diário de Obra → Chamelleon)
# Use a mesma chave em INTEGRATION_API_KEY no diario-obra-api.
GEMBA_WEBHOOK_API_KEY=
# Alternativa legada / fallback: JWT_SECRET_KEY

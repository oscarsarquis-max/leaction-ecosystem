<div class="min-h-screen bg-gray-50 py-8" id="meu-plano-page" data-id-clie="<%= (lead && lead.id_clie) || '' %>">

    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">



        <div class="text-center mb-12">

            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight sm:text-4xl">

                Sua Jornada de Transformação

            </h1>

            <p class="mt-3 max-w-2xl mx-auto text-xl text-gray-500 sm:mt-4">

                Acompanhe o progresso das Ondas e Sprints do seu projeto LeAction.

            </p>

            <% if (typeof checkoutUpgradeUrl !== 'undefined' && checkoutUpgradeUrl) { %>
            <div class="mt-8 flex justify-center">
                <a href="<%= checkoutUpgradeUrl %>"
                   class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-emerald-600 text-white font-bold shadow-lg hover:bg-emerald-700 transition">
                    <i class="fas fa-rocket"></i> Contratar / Fazer Upgrade
                </a>
            </div>
            <% } %>

        </div>



        <% if (!journey || journey.length === 0) { %>

            <div class="bg-white shadow rounded-lg p-10 text-center">

                <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-yellow-100 mb-4">

                    <i class="fas fa-magic text-yellow-600"></i>

                </div>

                <h3 class="text-lg leading-6 font-medium text-gray-900">Plano em Elaboração</h3>

                <p class="mt-2 text-sm text-gray-500">

                    Seu plano estratégico está sendo processado pela nossa Inteligência Artificial ou aguardando o acionamento da Gênese.

                </p>

                <div class="mt-6">

                    <a href="/projeto" class="text-blue-600 hover:text-blue-500 font-medium">Voltar ao Dashboard <span aria-hidden="true">&rarr;</span></a>

                </div>

            </div>

        <% } else { %>

            <!-- Blocos do Relatório no plano (carregado via API — botão Devolver) -->
            <div id="plano-relatorio-pipeline" class="mb-10" data-id-clie="<%= (lead && lead.id_clie) || '' %>">
                <div class="plano-pipeline-panel plano-pipeline-panel--loading">
                    <i class="fas fa-spinner fa-spin"></i> Verificando blocos do relatório no plano…
                </div>
            </div>

            <%

            function parseMetricsJourney(sprint) {

                var ms = sprint.metrics_scores;

                if (!ms) return {};

                if (typeof ms === 'string') {

                    try { return JSON.parse(ms); } catch (e) { return {}; }

                }

                return ms;

            }



            function statusNorm(sprint) {

                return String(sprint.status || sprint.stat_sprn || '').toLowerCase().trim().replace(/_/g, ' ');

            }



            function sprintDxMesa(sprint) {

                if (sprint.url_kanban === 'IMPORTACAO_JSON_DX') return true;

                var ms = parseMetricsJourney(sprint);

                if (ms.bloco_origem) return true;

                if (ms.tipo_mesa === 'organizacional' || ms.tipo_mesa === 'pedagogico' || ms.tipo_mesa === 'pedagogica') return true;

                var origem = String(ms.origem || '').toLowerCase();

                return origem.indexOf('mesa') >= 0;

            }



            function sprintPodeDevolver(sprint) {

                if (!sprintDxMesa(sprint)) return false;

                var st = statusNorm(sprint);

                return ['em analise', 'planejada', 'planejado', 'pendente', 'agendada', 'agendado'].indexOf(st) >= 0;

            }



            function mesaTipoLabel(sprint) {

                var ms = parseMetricsJourney(sprint);

                var tipo = String(ms.tipo_mesa || '').toLowerCase();

                if (tipo === 'organizacional' || ms.bloco_origem) return 'Mesa Organizacional (Relatório)';

                if (tipo === 'pedagogico' || tipo === 'pedagogica') return 'Mesa Pedagógica (Inovador)';

                return 'Mesa de Inovação DX';

            }



            var sprintsEmAnalise = [];

            var sprintsPlanejadasMesa = [];

            var idsMesaDestacados = {};

            var todasSprintsJornada = [];



            journey.forEach(function (onda) {

                (onda.sprints || []).forEach(function (s) {

                    todasSprintsJornada.push(s);

                    if (!sprintDxMesa(s)) return;

                    var id = s.id_sprn || s.id;

                    var st = statusNorm(s);

                    if (st === 'em analise' && id && !idsMesaDestacados[id]) {

                        idsMesaDestacados[id] = true;

                        sprintsEmAnalise.push(s);

                    } else if (['planejada', 'planejado', 'pendente', 'agendada', 'agendado'].indexOf(st) >= 0 && id && !idsMesaDestacados[id]) {

                        idsMesaDestacados[id] = true;

                        sprintsPlanejadasMesa.push(s);

                    }

                });

            });



            function renderCardMesaDx(sprint, modo) {

                var sprintId = sprint.id_sprn || sprint.id || '';

                var isAnalise = modo === 'analise';

            %>

                <div style="flex: 1 1 300px; max-width: 380px; background-color: white; border-radius: 12px; border-top: 5px solid #f97316; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); display: flex; flex-direction: column;" data-sprn-id="<%= sprintId %>">

                    <div style="padding: 20px; flex-grow: 1;">

                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; gap: 8px; flex-wrap: wrap;">

                            <div style="display: flex; gap: 6px; align-items: center; flex-wrap: wrap;">

                                <span style="font-size: 10px; font-weight: 900; background: #4f46e5; color: white; padding: 4px 8px; border-radius: 6px;">DX</span>

                                <span style="font-size: 10px; font-weight: bold; text-transform: uppercase; padding: 4px 8px; border-radius: 6px; background-color: #ffedd5; color: #c2410c;">

                                    <%= isAnalise ? 'EM ANÁLISE' : 'NO PLANO' %>

                                </span>

                            </div>

                            <span style="font-size: 10px; color: #9ca3af; font-family: monospace;">#<%= sprintId %></span>

                        </div>

                        <p style="font-size: 10px; font-weight: 700; color: #ea580c; text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 0.04em;">

                            <i class="fas fa-lightbulb"></i> <%= mesaTipoLabel(sprint) %>

                        </p>

                        <h3 style="font-size: 1.125rem; font-weight: 700; color: #111827; margin-bottom: 10px; line-height: 1.3;">

                            <%= sprint.nome || sprint.name_sprn %>

                        </h3>

                        <p style="font-size: 0.875rem; color: #4b5563; line-height: 1.5; margin-bottom: 0;">

                            <%= sprint.objetivo || sprint.desc_sprn || 'Sprint originada na Mesa de Inovação aguardando tratamento no Kanban.' %>

                        </p>

                    </div>

                    <div style="padding: 15px 20px; background-color: #fffaf5; border-top: 1px solid #ffedd5; border-radius: 0 0 12px 12px; display: flex; flex-direction: column; gap: 8px;">

                        <% if (isAnalise) { %>

                        <a href="/projeto/sprint-atual" style="display: block; text-align: center; padding: 10px; border-radius: 8px; border: 1px solid #fdba74; background: white; color: #ea580c; font-size: 12px; font-weight: 700; text-decoration: none;">

                            <i class="fas fa-columns"></i> Abrir Kanban para Planejar

                        </a>

                        <% } else { %>

                        <a href="/projeto/sprint-atual" style="display: block; text-align: center; padding: 10px; border-radius: 8px; border: 1px solid #d1d5db; background: white; color: #2563eb; font-size: 12px; font-weight: 700; text-decoration: none;">

                            <i class="fas fa-external-link-alt"></i> Ver no Kanban

                        </a>

                        <% } %>

                        <button type="button" class="btn-devolver-mesa-plano" data-sprn-id="<%= sprintId %>"

                                style="width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px dashed #fca5a5; background: #fef2f2; color: #b91c1c; font-size: 12px; font-weight: 700; cursor: pointer;">

                            <i class="fas fa-undo"></i> Devolver ao backlog do relatório

                        </button>

                    </div>

                </div>

            <% } %>



            <!-- Trilha de Inovação: Mesa Organizacional + Pedagógica (em análise) -->

            <div class="mb-16 p-6 bg-orange-50 border border-orange-200 rounded-2xl shadow-sm relative overflow-hidden">

                <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-orange-200 rounded-full opacity-40 blur-2xl"></div>



                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; position: relative; z-index: 10; flex-wrap: wrap; gap: 12px;">

                    <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 8px;">

                        <div style="background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); color: white; padding: 10px 25px; border-radius: 8px; font-weight: bold; box-shadow: 0 4px 6px rgba(234, 88, 12, 0.2); display: flex; align-items: center;">

                            <i class="fas fa-lightbulb text-yellow-200 mr-3"></i>

                            Trilha de Inovação (Em Análise)

                        </div>

                        <span style="font-size: 11px; color: #9a3412; font-weight: 600;">Mesa Organizacional · Mesa Pedagógica</span>

                    </div>

                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">

                        <a href="/projeto/mesa-inovacao" style="background: white; border: 2px solid #fdba74; color: #ea580c; font-weight: bold; padding: 8px 14px; border-radius: 10px; font-size: 11px; text-decoration: none;">

                            <i class="fas fa-door-open"></i> Mesa Organizacional

                        </a>

                        <a href="/projeto/sprint-atual" style="background: white; border: 2px dashed #fdba74; color: #ea580c; font-weight: bold; padding: 8px 14px; border-radius: 10px; font-size: 11px; text-decoration: none;">

                            <i class="fas fa-columns"></i> Kanban

                        </a>

                    </div>

                </div>



                <div style="display: flex; flex-wrap: wrap; gap: 20px; position: relative; z-index: 10;">

                    <% if (sprintsEmAnalise.length > 0) {

                        sprintsEmAnalise.forEach(function (sprintDx) { renderCardMesaDx(sprintDx, 'analise'); });

                    } else { %>

                        <div style="width: 100%; text-align: center; padding: 30px; color: #ea580c; font-style: italic; border: 1px dashed #fdba74; border-radius: 12px; background: rgba(255,255,255,0.6);">

                            <i class="fas fa-box-open" style="font-size: 2em; margin-bottom: 10px; opacity: 0.5; display: block;"></i>

                            Nenhuma sprint em análise. Envie blocos do Relatório de Contexto pela Mesa Organizacional — elas aparecerão aqui e no Kanban (coluna Inovação).

                        </div>

                    <% } %>

                </div>

            </div>



            <!-- Sprints da Mesa já planejadas (coluna Planejada do Kanban) -->

            <% if (sprintsPlanejadasMesa.length > 0) { %>

            <div class="mb-16 p-6 bg-amber-50 border border-amber-200 rounded-2xl shadow-sm">

                <div style="display: flex; align-items: center; margin-bottom: 20px; gap: 12px; flex-wrap: wrap;">

                    <div style="background: #d97706; color: white; padding: 10px 22px; border-radius: 8px; font-weight: bold; display: flex; align-items: center;">

                        <i class="fas fa-clipboard-list mr-2"></i>

                        Sprints no Plano (via Mesa)

                    </div>

                    <span style="font-size: 12px; color: #92400e;">Remova com um clique para devolver o bloco ao backlog do relatório.</span>

                </div>

                <div style="display: flex; flex-wrap: wrap; gap: 20px;">

                    <% sprintsPlanejadasMesa.forEach(function (sprintDx) { renderCardMesaDx(sprintDx, 'plano'); }); %>

                </div>

            </div>

            <% } %>



            <% journey.filter(function (onda) { return onda.id !== -999; }).forEach((onda, indexOnda) => { %>

                <%

                var sprintsOnda = (onda.sprints || []).filter(function (s) {

                    var id = s.id_sprn || s.id;

                    return !id || !idsMesaDestacados[id];

                });

                if (!sprintsOnda.length) return;

                %>



                <div class="mb-16">

                    <div style="display: flex; align-items: center; margin-bottom: 25px;">

                        <div style="background-color: #2563eb; color: white; padding: 10px 25px; border-radius: 8px; font-weight: bold; box-shadow: 0 4px 6px rgba(0,0,0,0.1); display: flex; align-items: center; z-index: 10;">

                            <i class="fas fa-water mr-3"></i>

                            <%= onda.nome %>

                        </div>

                        <div style="flex-grow: 1; height: 2px; background-color: #d1d5db; margin-left: -5px;"></div>

                    </div>



                    <div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: flex-start;">

                        <% sprintsOnda.forEach((sprint, indexSprint) => { %>

                            <%

                                let borderCol = "#d1d5db";

                                let badgeBg = "#f3f4f6";

                                let badgeText = "#374151";

                                let isAtiva = (sprint.status === 'ativa' || sprint.status === 'EM_PROGRESSO');

                                let isConcluida = (sprint.status === 'concluida' || sprint.status === 'CONCLUIDA');

                                let podeDevolverPlano = sprintPodeDevolver(sprint);

                                let sprintId = sprint.id_sprn || sprint.id;

                                let stLabel = String(sprint.status || sprint.stat_sprn || '').replace(/_/g, ' ');



                                if (isAtiva) {

                                    borderCol = "#3b82f6";

                                    badgeBg = "#dbeafe";

                                    badgeText = "#1e40af";

                                } else if (isConcluida) {

                                    borderCol = "#10b981";

                                    badgeBg = "#dcfce7";

                                    badgeText = "#166534";

                                }

                            %>



                            <div style="flex: 1 1 300px; max-width: 380px; background-color: white; border-radius: 12px; border-top: 5px solid <%= borderCol %>; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); display: flex; flex-direction: column;">

                                <div style="padding: 20px; flex-grow: 1;">

                                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">

                                        <span style="font-size: 10px; font-weight: bold; text-transform: uppercase; padding: 4px 8px; border-radius: 6px; background-color: <%= badgeBg %>; color: <%= badgeText %>;">

                                            <%= stLabel %>

                                        </span>

                                        <span style="font-size: 10px; color: #9ca3af; font-family: monospace;">#<%= sprint.id %></span>

                                    </div>

                                    <h3 style="font-size: 1.125rem; font-weight: 700; color: #111827; margin-bottom: 10px; line-height: 1.3;">

                                        <%= sprint.nome %>

                                    </h3>

                                    <p style="font-size: 0.875rem; color: #4b5563; line-height: 1.5; margin-bottom: 15px;">

                                        <%= sprint.objetivo || 'Objetivo estratégico definido para mitigação de gaps e aceleração digital.' %>

                                    </p>

                                </div>



                                <div style="padding: 15px 20px; background-color: #f9fafb; border-top: 1px solid #f3f4f6; border-radius: 0 0 12px 12px;">

                                    <% if (podeDevolverPlano) { %>

                                    <button type="button" class="btn-devolver-mesa-plano" data-sprn-id="<%= sprintId %>"

                                            style="width: 100%; margin-bottom: 10px; padding: 10px 12px; border-radius: 8px; border: 1px dashed #fca5a5; background: #fef2f2; color: #b91c1c; font-size: 12px; font-weight: 700; cursor: pointer;">

                                        <i class="fas fa-undo"></i> Devolver ao backlog do relatório

                                    </button>

                                    <% } %>

                                    <div style="display: flex; justify-content: space-between; align-items: center;">

                                        <button onclick="prepararAgendamento('<%= sprint.id %>', '<%= sprint.nome %>')"

                                                style="background: none; border: 1px solid #d1d5db; padding: 6px 10px; border-radius: 6px; cursor: pointer; display: flex; align-items: center; font-size: 11px; color: #4b5563;">

                                            <i class="far fa-calendar-alt mr-1.5" style="color: <%= borderCol %>"></i>

                                            <%= (sprint.data_inicio && sprint.data_inicio !== 'null') ? new Date(sprint.data_inicio).toLocaleDateString('pt-BR') : 'A DEFINIR' %>

                                        </button>

                                        <% if (isAtiva) { %>

                                            <a href="/projeto/sprint-atual" style="color: #2563eb; font-weight: 800; text-decoration: none; font-size: 11px;">

                                                VER KANBAN <i class="fas fa-external-link-alt ml-1.5"></i>

                                            </a>

                                        <% } else { %>

                                            <span style="color: #9ca3af; font-weight: 600; font-size: 11px;">

                                                <i class="fas fa-lock mr-1.5" style="font-size: 9px;"></i> KANBAN

                                            </span>

                                        <% } %>

                                    </div>

                                </div>

                            </div>

                        <% }) %>

                    </div>

                </div>

            <% }) %>



            <div style="position: relative; padding-top: 40px; margin-top: 40px; text-align: center;">

                <div style="position: absolute; top: 50%; left: 0; right: 0; border-top: 2px dashed #d1d5db; z-index: 1;"></div>

                <div style="position: relative; display: inline-block; background-color: #f9fafb; padding: 0 30px; z-index: 2;">

                    <span style="font-size: 0.75rem; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: 0.1em; display: flex; align-items: center;">

                        <i class="fas fa-flag text-blue-600 mr-2" style="font-size: 1.2rem;"></i>

                        Objetivo Final Alcançado

                    </span>

                </div>

            </div>



        <% } %>

    </div>

</div>



<div id="modalAgendamento" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9999; justify-content: center; align-items: center; backdrop-filter: blur(4px);">

    <div style="background: white; padding: 30px; border-radius: 16px; width: 90%; max-width: 400px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.2); border: 1px solid #e5e7eb;">

        <div style="text-align: center; margin-bottom: 20px;">

            <div style="background: #eff6ff; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">

                <i class="fas fa-calendar-check text-blue-600" style="font-size: 20px;"></i>

            </div>

            <h3 style="font-weight: 800; color: #111827; margin: 0;" id="modalTitulo">Agendar Sprint</h3>

            <p style="font-size: 13px; color: #6b7280; margin-top: 5px;">Escolha a data de início para esta sprint.</p>

        </div>

        <input type="hidden" id="modalIdSprn">

        <label style="display: block; font-size: 12px; font-weight: 700; color: #374151; margin-bottom: 8px; text-transform: uppercase;">Início da Sprint</label>

        <input type="date" id="modalDataInput" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #d1d5db; font-size: 14px; outline: none; margin-bottom: 25px;">

        <div style="display: flex; gap: 12px;">

            <button onclick="fecharModal()" style="flex: 1; padding: 12px; border-radius: 8px; border: 1px solid #e5e7eb; background: white; color: #4b5563; font-weight: 600; cursor: pointer;">Cancelar</button>

            <button onclick="salvarDataSprint()" style="flex: 2; padding: 12px; border-radius: 8px; border: none; background: #2563eb; color: white; font-weight: 700; cursor: pointer;">Confirmar</button>

        </div>

    </div>

</div>



<script>

function prepararAgendamento(id, nome) {

    document.getElementById('modalIdSprn').value = id;

    document.getElementById('modalTitulo').innerText = nome;

    document.getElementById('modalAgendamento').style.display = 'flex';

}



function fecharModal() {

    document.getElementById('modalAgendamento').style.display = 'none';

}



async function devolverSprintRelatorio(idSprn, btn) {

    if (!idSprn) return;

    var el = btn || null;

    var prev = el ? el.innerHTML : '';

    if (el) {

        el.disabled = true;

        el.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Devolvendo…';

    }

    try {

        var response = await fetch('/api/sprints/devolver-relatorio', {

            method: 'POST',

            headers: { 'Content-Type': 'application/json' },

            credentials: 'same-origin',

            body: JSON.stringify({ id_sprn: parseInt(idSprn, 10) })

        });

        var result = await response.json();

        if (response.ok && result.success) {

            window.location.reload();

            return;

        }

        if (el) {

            el.disabled = false;

            el.innerHTML = prev;

        }

        alert((result && result.error) || 'Não foi possível devolver ao backlog.');

    } catch (err) {

        if (el) {

            el.disabled = false;

            el.innerHTML = prev;

        }

        alert('Erro de conexão ao devolver ao backlog.');

    }

}



document.addEventListener('DOMContentLoaded', function () {

    document.querySelectorAll('.btn-devolver-mesa-plano').forEach(function (btn) {

        btn.addEventListener('click', function () {

            devolverSprintRelatorio(btn.getAttribute('data-sprn-id'), btn);

        });

    });

});



async function salvarDataSprint() {

    const id_sprn = document.getElementById('modalIdSprn').value;

    const data_inicio = document.getElementById('modalDataInput').value;

    if (!data_inicio) return alert("Por favor, selecione uma data!");

    try {

        const response = await fetch('/client/update-sprint-date', {

            method: 'POST',

            headers: { 'Content-Type': 'application/json' },

            body: JSON.stringify({ id_sprn, data_inicio })

        });

        const result = await response.json();

        if (result.success) {

            window.location.reload();

        } else {

            alert("Erro ao salvar data.");

        }

    } catch (err) {

        alert("Erro de conexão.");

    }

}

</script>


<div class="mesa-org execucao" id="execucao-root"
     data-id-member="<%= id_member || '' %>"
     data-position="<%= position || '' %>">
    <header class="mesa-org__hero execucao__topbar">
        <div>
            <h1><i class="fas fa-tasks" style="color: #fbbf24;"></i> Sala de Execução</h1>
            <p>Fila operacional — sem ruído gerencial. Foque nas suas atribuições.</p>
        </div>
        <div style="position: relative;">
            <button type="button" class="execucao__bell" id="btn-notificacoes" aria-label="Notificações">
                <i class="fas fa-bell"></i>
                <span class="execucao__bell-badge" id="notif-badge" hidden>0</span>
            </button>
            <div class="execucao__notif-panel" id="notif-panel"></div>
        </div>
    </header>

    <section class="mesa-card">
        <h2 class="mesa-card__title"><i class="fas fa-inbox"></i> Fila de Atribuições</h2>
        <div class="execucao__fila" id="fila-tarefas">
            <p class="mesa-empty-hint">Carregando tarefas…</p>
        </div>
    </section>
</div>

<div class="mesa-modal" id="modal-execucao" aria-hidden="true">
    <div class="mesa-modal__card execucao__modal-card">
        <h3 id="modal-exec-titulo">Execução de Sprint</h3>
        <form id="form-execucao">
            <input type="hidden" id="exec-id-ativ">
            <input type="hidden" id="exec-id-sprn">
            <div class="admin-esim__field">
                <label>Atividade</label>
                <p id="exec-nome" style="margin:0;font-weight:700;color:var(--dark-lilac);"></p>
            </div>
            <div class="admin-esim__field">
                <label for="exec-desc">Descrição / escopo</label>
                <textarea id="exec-desc" class="mesa-textarea" rows="4" readonly></textarea>
            </div>
            <div class="admin-esim__field">
                <label for="exec-status">Status</label>
                <select id="exec-status" class="mesa-select">
                    <option value="A Fazer">A Fazer</option>
                    <option value="Em Execução">Em Execução</option>
                    <option value="Entregue">Entregue</option>
                </select>
            </div>
            <div class="admin-esim__modal-actions">
                <button type="button" class="mesa-btn mesa-btn--ghost" id="btn-fechar-exec">Fechar</button>
                <button type="submit" class="mesa-btn mesa-btn--lilac">Salvar evolução</button>
            </div>
        </form>
    </div>
</div>

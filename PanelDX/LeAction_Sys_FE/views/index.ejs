<div id="dados-index-ponte"
     data-status-ia="<%= (locals.lead && lead.status_ia) ? lead.status_ia : '' %>"
     data-id-matu="<%= (locals.lead && lead.id_matu) ? lead.id_matu : '' %>"
     style="display: none;"></div>

<script>
    (function() {
        const ponte = document.getElementById('dados-index-ponte');
        const s = ponte ? ponte.getAttribute('data-status-ia') : '';
        console.group("--- VERIFICAÇÃO DE DADOS (INDEX) ---");
        console.log("STATUS RECEBIDO:", "[" + s + "]");
        console.groupEnd();
    })();
</script>

<%
    // --- Lógica de Negócio e Proteção de Dados ---
    const safeLead = locals.lead || locals.user || {};
    const statusIA = (safeLead.status_ia || "").toString().trim().toUpperCase();

    // --- MÁQUINA DE ESTADOS RECALIBRADA COM O STATUS INICIAL REAL ---
    const isAguardandoContexto = (statusIA === 'AGUARDANDO CONTEXTO');
    const isPreSurveyConcluido = (statusIA === 'PRESURVEY OK');
    const isProjetoOk = (statusIA === 'PROJETO OK');
    const isContextoOk = (statusIA === 'CONTEXTO OK');
    const isAvaliacaoCompletaOk = (statusIA === 'AVALIACAO OK');
    const isEmProcessamento = (statusIA === 'PENDENTE' || statusIA === 'PROCESSANDO');

    // Diretrizes de contexto exibidas durante a Gênese IA
    const geneseDiretrizesContexto = [];
    (function () {
        const tipo = safeLead.tipo_ensino || '';
        const segmentos = {
            'K12': 'Educação Básica (K12) — BNCC, PNED e segurança digital.',
            'Superior': 'Ensino Superior — LMS, retenção e empregabilidade.',
            'Tecnico': 'Ensino Técnico — laboratórios virtuais e simulações.',
            'Idiomas/Cursos Livres': 'Idiomas/Cursos Livres — UX e conversão digital.',
            'Educação Corporativa': 'Educação Corporativa — microlearning e SKAs.'
        };
        if (segmentos[tipo]) geneseDiretrizesContexto.push('Segmento: ' + segmentos[tipo]);
        if (safeLead.localizacao_sede) geneseDiretrizesContexto.push('Localização: ' + safeLead.localizacao_sede);
        if (safeLead.bairro_clie || safeLead.cidade_clie) {
            geneseDiretrizesContexto.push('Bairro/Cidade: ' + (safeLead.bairro_clie || '—') + ' / ' + (safeLead.cidade_clie || '—'));
        }
        if (safeLead.qtd_alunos) geneseDiretrizesContexto.push('Porte: ' + safeLead.qtd_alunos + ' alunos.');
        const eRede = safeLead.rede_ensino === true || safeLead.rede_ensino === 1 || safeLead.rede_ensino === 'true';
        geneseDiretrizesContexto.push('Estrutura: ' + (eRede ? 'Unidade de Rede' : 'Unidade Independente'));
        function excerpt(val, max) {
            const t = (val || '').trim();
            if (!t) return '';
            return t.length > max ? t.slice(0, max) + '…' : t;
        }
        const mercado = excerpt(safeLead.dados_mercado, 280);
        const etno = excerpt(safeLead.dados_etnograficos, 280);
        const clima = excerpt(safeLead.clima_organizacional, 220);
        if (mercado) geneseDiretrizesContexto.push('Mercado: ' + mercado);
        if (etno) geneseDiretrizesContexto.push('Comunidade: ' + etno);
        if (clima) geneseDiretrizesContexto.push('Clima organizacional: ' + clima);
        const modM = excerpt(safeLead.moderacao_dados_mercado, 200);
        const modE = excerpt(safeLead.moderacao_dados_etnograficos, 200);
        const modC = excerpt(safeLead.moderacao_clima_organizacional, 200);
        if (modM) geneseDiretrizesContexto.push('Insight moderador (mercado): ' + modM);
        if (modE) geneseDiretrizesContexto.push('Insight moderador (comunidade): ' + modE);
        if (modC) geneseDiretrizesContexto.push('Insight moderador (clima): ' + modC);
    })();

    const temSprintsKanban = Array.isArray(locals.journey) && locals.journey.some(function (onda) {
        return Array.isArray(onda.sprints) && onda.sprints.length > 0;
    });
    const isPlanoIaConcluido = (statusIA === 'CONCLUIDO' && temSprintsKanban)
        || safeLead.plano_ia_concluido === true;

    const isGenesisOk = isPlanoIaConcluido;
    const mostrarKanban = isPlanoIaConcluido;

    // Plano pago/ativado — esconde CTAs de contratação em qualquer tela
    const planoAtivado = safeLead.hasActiveProject === true
        || safeLead.hasActiveProject === 1
        || safeLead.hasActiveProject === 'true'
        || isProjetoOk
        || isContextoOk
        || isAvaliacaoCompletaOk
        || isEmProcessamento
        || isGenesisOk;

    // O fluxo inicial só é considerado "avaliado" após a Pre-Survey ser batida de fato
    const isAvaliado = isPreSurveyConcluido || isContextoOk || isAvaliacaoCompletaOk;

    // Home premium minimalista — antes do primeiro assessment gratuito
    const mostrarHomePremium = !isAvaliado && !isProjetoOk && !planoAtivado && !isEmProcessamento && !isGenesisOk;
    const urlAvaliacaoInicial = safeLead.id_matu ? '/avaliacoes/' + safeLead.id_matu : '/avaliacoes';

    const totalPresurveyHub = 28;

    // Hub pós mini-assessment — relatório central + bônus + compra do plano
    const presurveyData = locals.presurveyDashboard || null;
    const preDataHub = presurveyData && presurveyData.preData ? presurveyData.preData : null;
    const insightsHub = presurveyData && presurveyData.insights_ia ? presurveyData.insights_ia : {};
    const temRelatorioPresurvey = !!(preDataHub && safeLead.id_matu);
    const mostrarHubPosPresurvey = temRelatorioPresurvey && !isAvaliacaoCompletaOk && !isEmProcessamento && !isGenesisOk
        && (isPreSurveyConcluido || isContextoOk || isProjetoOk || planoAtivado);

    const dimensoesPresurvey = preDataHub ? [
        { label: 'Estratégica', p: preDataHub.score_estrat_p, f: preDataHub.score_estrat_f },
        { label: 'Humana', p: preDataHub.score_humana_p, f: preDataHub.score_humana_f },
        { label: 'Organizacional', p: preDataHub.score_organiz_p, f: preDataHub.score_organiz_f },
        { label: 'Pedagógica', p: preDataHub.score_pedag_p, f: preDataHub.score_pedag_f },
        { label: 'Tecnológica', p: preDataHub.score_tecno_p, f: preDataHub.score_tecno_f }
    ] : [];
    let pilarForteLabel = '—';
    if (dimensoesPresurvey.length) {
        let maxIdx = 0;
        dimensoesPresurvey.forEach(function (d, i) {
            if ((d.p || 0) > (dimensoesPresurvey[maxIdx].p || 0)) maxIdx = i;
        });
        pilarForteLabel = dimensoesPresurvey[maxIdx].label;
    }
    const whatsappUrl = (typeof whatsappCommunityUrl !== 'undefined' && whatsappCommunityUrl)
        ? whatsappCommunityUrl
        : 'https://chat.whatsapp.com/placeholder-paneldx-comunidade';
%>


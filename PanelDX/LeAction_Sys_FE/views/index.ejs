    /* Legado — mantido para compatibilidade */
    .cockpit-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;
    }
    .cockpit-canvas-wrap { position: relative; height: 260px; }
    .cockpit-state {
        position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
        text-align: center; color: #9ca3af; font-size: 0.85rem; padding: 0 10px;
    }

    /* Suporte discreto a modo escuro (imita dark:bg-gray-800 sem Tailwind) */

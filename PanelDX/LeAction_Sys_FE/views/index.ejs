    /* =================================================================
       INSIGHT GATE — Home premium pré-assessment (valor passivo)
       ================================================================= */
    .insight-gate {
        position: relative;
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 20px 56px;
        margin: -8px -4px 0;
        overflow: hidden;
        border-radius: 16px;
    }
    .insight-gate__backdrop {
        position: absolute;
        inset: -20px;
        background: linear-gradient(145deg, #f3f0ff 0%, #eef2ff 40%, #f8fafc 100%);
        z-index: 0;
    }
    .insight-gate__wireframe {
        position: absolute;
        inset: 24px 32px;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: auto repeat(3, 1fr);
        gap: 14px;
        opacity: 0.55;
        pointer-events: none;
    }
    .insight-gate__wf-bar {
        grid-column: 1 / -1;
        height: 42px;
        border-radius: 10px;
        background: linear-gradient(90deg, rgba(108,92,231,0.18), rgba(74,46,128,0.12));
    }
    .insight-gate__wf-kpi {
        grid-column: span 3;
        min-height: 72px;
        border-radius: 12px;
        background: rgba(255,255,255,0.7);
        border: 1px solid rgba(108,92,231,0.12);
        box-shadow: 0 8px 24px rgba(74,46,128,0.06);
    }
    .insight-gate__wf-chart {
        border-radius: 14px;
        background: rgba(255,255,255,0.65);
        border: 1px solid rgba(108,92,231,0.1);
        box-shadow: 0 12px 32px rgba(74,46,128,0.08);
    }
    .insight-gate__wf-chart--left { grid-column: span 4; grid-row: span 2; }
    .insight-gate__wf-chart--center { grid-column: span 4; grid-row: span 2; }
    .insight-gate__wf-chart--right { grid-column: span 4; grid-row: span 2; }
    .insight-gate__blur {
        position: absolute;
        inset: 0;
        backdrop-filter: blur(22px) saturate(1.1);
        -webkit-backdrop-filter: blur(22px) saturate(1.1);
        background: rgba(255, 255, 255, 0.52);
        z-index: 1;
    }
    .insight-gate__card {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 520px;
        padding: 40px 36px 32px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(74, 46, 128, 0.12), 0 1px 0 rgba(255,255,255,0.9) inset;
        text-align: center;
    }
    .insight-gate__insight {
        display: inline-flex;
        align-items: flex-start;
        gap: 10px;
        text-align: left;
        padding: 12px 14px;
        margin-bottom: 28px;
        background: #faf9ff;
        border-radius: 10px;
        border: 1px solid #ede9fe;
    }
    .insight-gate__insight-icon {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #a78bfa;
        font-size: 0.85rem;
    }
    .insight-gate__insight-text {
        margin: 0;
        font-size: 0.78rem;
        line-height: 1.55;
        color: #6b7280;
        font-weight: 500;
    }
    .insight-gate__insight-text strong {
        color: #4b5563;
        font-weight: 700;
    }
    .insight-gate__title {
        margin: 0 0 32px;
        font-size: clamp(1.35rem, 3.5vw, 1.65rem);
        font-weight: 800;
        line-height: 1.25;
        color: #1f2937;
        letter-spacing: -0.02em;
    }
    .insight-gate__cta {
        display: block;
        width: 100%;
        padding: 16px 24px;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 0.01em;
        color: #fff;
        text-decoration: none;
        cursor: pointer;
        background: linear-gradient(135deg, var(--dark-lilac) 0%, var(--brand-violet) 100%);
        box-shadow: 0 12px 28px rgba(108, 92, 231, 0.35);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .insight-gate__cta:hover {
        transform: translateY(-2px);

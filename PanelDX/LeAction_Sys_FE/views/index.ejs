        color: #fff;
    }
    .insight-gate__social {
        margin: 20px 0 0;
        font-size: 0.75rem;
        font-style: italic;
        line-height: 1.5;
        color: #9ca3af;
    }
    .insight-gate__bonus {
        margin-top: 28px;

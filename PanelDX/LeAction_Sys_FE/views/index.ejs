             BLOCO 1 — ESTRATÉGICO: Panorama Executivo (above the fold)
             ================================================================== -->
        <section id="panorama-executivo" class="panorama-exec dashboard-bloco-estrategico" data-id-matu="<%= safeLead.id_matu || '' %>">
            <div class="panorama-exec__header">
                <div>
                    <h2 class="section-title">Panorama Executivo</h2>
                    <p class="section-subtitle" style="margin-bottom:0;">
                        Visão consolidada de volume, metas estratégicas e alocação do time.
                    </p>
                </div>
            </div>

            <div class="panorama-toolbar" role="toolbar" aria-label="Filtros do panorama">
                <span class="panorama-toolbar__label">Filtros rápidos</span>
                <div class="panorama-toolbar__group">
                    <label for="panorama-filtro-ano" class="visually-hidden">Ano letivo</label>
                    <select id="panorama-filtro-ano" class="panorama-select" aria-label="Ano letivo"></select>
                </div>
                <div class="panorama-toolbar__group">
                    <label for="panorama-filtro-periodo" class="visually-hidden">Bimestre ou semestre</label>
                    <select id="panorama-filtro-periodo" class="panorama-select" aria-label="Bimestre ou semestre"></select>
                </div>
            </div>

            <div class="panorama-direcionadores-section">
                <div class="panorama-direcionadores-section__head">
                    <div>
                        <p class="panorama-col__title" style="margin-bottom:6px;">Direcionadores estratégicos</p>
                        <h3>Progresso por eixo</h3>
                        <p>Atingimento médio de implementação e meta financeira primária (receita ou custo)</p>
                    </div>
                    <div class="panorama-direcionadores-section__media" id="panorama-media-direcionadores" aria-live="polite">
                        Média geral: —
                    </div>
                </div>
                <div id="panorama-direcionadores-grid" class="panorama-direcionadores-grid" role="list" aria-label="Cards dos direcionadores estratégicos"></div>
            </div>

            <div class="panorama-grid panorama-grid--operacional">
                <!-- BLOCO — Volume e status -->
                <div class="panorama-col">
                    <p class="panorama-col__title">Volume e status</p>
                    <div class="panorama-kpi-grid">
                        <div class="panorama-kpi">
                            <div class="panorama-kpi__valor" id="kpi-sprints-ativas">—</div>
                            <div class="panorama-kpi__label">Sprints ativas</div>
                        </div>
                        <div class="panorama-kpi">
                            <div class="panorama-kpi__valor panorama-kpi__valor--alerta" id="kpi-tarefas-atrasadas">—</div>
                            <div class="panorama-kpi__label">Tarefas atrasadas</div>
                        </div>
                        <div class="panorama-kpi">
                            <div class="panorama-kpi__valor panorama-kpi__valor--ok" id="kpi-entregas-prazo">—</div>
                            <div class="panorama-kpi__label">Entregas no prazo</div>
                        </div>
                    </div>
                    <div class="panorama-chart-card">
                        <div class="panorama-chart-card__head">
                            <h3>Status das sprints</h3>
                            <p>Distribuição por estágio do ciclo</p>
                        </div>
                        <div class="panorama-chart-wrap panorama-chart-wrap--donut">
                            <canvas id="chartPanoramaDonut" aria-label="Gráfico de rosca — status das sprints"></canvas>
                        </div>
                    </div>
                </div>

                <!-- BLOCO — Alocação e gargalos -->
                <div class="panorama-col">
                    <p class="panorama-col__title">Alocação e gargalos</p>
                    <div class="panorama-chart-card">
                        <div class="panorama-chart-card__head">
                            <h3>Mapa de calor — carga por área escolar</h3>
                            <p class="panorama-heatmap-sub">Intensidade relativa por sprint e área operacional.</p>
                            <p class="panorama-heatmap-footnote">
                                <button type="button" class="panorama-heatmap-footnote__trigger" aria-describedby="heatmap-footnote-tip">
                                    <i class="fas fa-info-circle" aria-hidden="true"></i>
                                    O que define o percentual?
                                </button>
                                <span id="heatmap-footnote-tip" class="panorama-heatmap-footnote__tip" role="tooltip">
                                    O fator principal é o <strong>volume de atividades OKR</strong> vinculadas a cada sprint.
                                    A área escolar vem do eixo metodológico do bloco da sprint.
                                    O valor exibido é relativo: a célula com mais tarefas aparece como 100% e as demais são proporcionais.
                                    Cadastrar membros na squad, sem criar atividades, não altera o mapa.
                                </span>
                            </p>
                        </div>
                        <div id="chartPanoramaHeatmap" class="panorama-chart-wrap"></div>
                        <p id="heatmap-template-hint" class="panorama-heatmap-hint">
                            Exibindo template neutro — aguardando histórico de sprints e alocação por área escolar.
                        </p>
                        <div class="panorama-heatmap-legend">
                            <span><i style="background:#cbd5e1"></i> Aguardando (0–40%)</span>
                            <span><i style="background:#eab308"></i> Atenção (41–65%)</span>
                            <span><i style="background:#ef4444"></i> Sobrecarga (66–100%)</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <hr class="section-divider section-divider--zonas" aria-hidden="true">

        <!-- ==================================================================
             BLOCO 2 — OPERACIONAL: Agenda executiva e tarefas do dia
             ================================================================== -->
        <section id="dashboard-agenda" class="panel-card dashboard-bloco-operacional" data-id-matu="<%= safeLead.id_matu || '' %>">
            <p class="panel-card__label">Agenda executiva</p>
            <p class="panel-card__hint" style="margin-bottom: 16px;">
                Calendário mensal com eventos e bloco de notas por dia — organize reuniões e follow-ups da gestão.
            </p>
            <div class="agenda-widget">
                <div class="agenda-widget__cal">
                    <div class="agenda-widget__head">
                        <h3>Calendário</h3>
                        <div class="agenda-nav">
                            <button type="button" id="agenda-mes-prev" class="agenda-nav__btn" aria-label="Mês anterior">&lsaquo;</button>
                            <span id="agenda-mes-titulo" class="agenda-mes-titulo">—</span>
                            <button type="button" id="agenda-mes-next" class="agenda-nav__btn" aria-label="Próximo mês">&rsaquo;</button>
                        </div>
                    </div>
                    <div id="agenda-cal-grid" class="agenda-cal__grid" role="grid" aria-label="Calendário mensal"></div>
                </div>
                <div class="agenda-widget__lista">
                    <div class="agenda-lista__head">
                        <h4 id="agenda-dia-titulo" class="agenda-lista__titulo">Eventos do dia</h4>
                        <button type="button" id="agenda-btn-add" class="agenda-btn-add" title="Novo evento no dia selecionado" aria-label="Adicionar evento">+</button>
                    </div>
                    <div id="agenda-lista-eventos" class="agenda-lista__scroll"></div>
                </div>
            </div>
        </section>

        <!-- Modal Bloco de Notas -->
        <div id="agenda-modal-overlay" class="agenda-modal-overlay" aria-hidden="true" role="dialog" aria-labelledby="agenda-modal-titulo-label">
            <div class="agenda-modal">
                <div class="agenda-modal__header">
                    <h4 id="agenda-modal-titulo-label">Bloco de notas</h4>
                    <button type="button" id="agenda-modal-fechar" class="agenda-modal__fechar" aria-label="Fechar">&times;</button>
                </div>
                <div class="agenda-modal__body">
                    <div class="agenda-modal__field">
                        <label for="agenda-modal-titulo">Título do evento</label>
                        <input type="text" id="agenda-modal-titulo" maxlength="200" placeholder="Ex.: Reunião pedagógica">
                    </div>
                    <div class="agenda-modal__field">
                        <label for="agenda-modal-data">Data</label>
                        <input type="date" id="agenda-modal-data">
                    </div>
                    <div class="agenda-modal__field">
                        <label for="agenda-modal-nota">Notas</label>
                        <textarea id="agenda-modal-nota" placeholder="Registre decisões, pendências e próximos passos..."></textarea>
                    </div>
                </div>
                <div class="agenda-modal__footer">
                    <button type="button" id="agenda-modal-excluir" class="agenda-modal__btn agenda-modal__btn--danger" style="display:none;">Excluir</button>
                    <button type="button" id="agenda-modal-cancelar" class="agenda-modal__btn agenda-modal__btn--ghost">Cancelar</button>
                    <button type="button" id="agenda-modal-salvar" class="agenda-modal__btn agenda-modal__btn--primary">Salvar</button>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.45.2/dist/apexcharts.min.js" crossorigin="anonymous"></script>
        <script src="/js/panorama-executivo.js?v=9"></script>
        <script src="/js/agenda-widget.js?v=1"></script>
    </div>

<% } else { %>
    <div class="dashboard-container">
        <% if (mostrarHomePremium) { %>
        <!-- INSIGHT GATE — valor passivo antes do assessment gratuito -->
        <section class="insight-gate" aria-labelledby="insight-gate-title">
            <div class="insight-gate__backdrop" aria-hidden="true">
                <div class="insight-gate__wireframe">
                    <div class="insight-gate__wf-bar"></div>
                    <div class="insight-gate__wf-kpi"></div>
                    <div class="insight-gate__wf-kpi"></div>
                    <div class="insight-gate__wf-kpi"></div>
                    <div class="insight-gate__wf-kpi"></div>
                    <div class="insight-gate__wf-chart insight-gate__wf-chart--left"></div>
                    <div class="insight-gate__wf-chart insight-gate__wf-chart--center"></div>
                    <div class="insight-gate__wf-chart insight-gate__wf-chart--right"></div>
                </div>
            </div>
            <div class="insight-gate__blur" aria-hidden="true"></div>

            <div class="insight-gate__card">
                <div class="insight-gate__insight">
                    <span class="insight-gate__insight-icon" aria-hidden="true"><i class="fas fa-lightbulb"></i></span>
                    <p class="insight-gate__insight-text">
                        <strong>Insight:</strong> Escolas que revisam a alocação de professores antes do bimestre reduzem o estresse da equipe em até 40%.
                    </p>
                </div>

                <h1 id="insight-gate-title" class="insight-gate__title">
                    Descubra a saúde da gestão da sua escola hoje.
                </h1>

                <a href="<%= urlAvaliacaoInicial %>" class="insight-gate__cta">
                    🚀 Gerar Meu Relatório de Insights (3 min)
                </a>

                <p class="insight-gate__social">
                    "O relatório de insights me ajudou a reorganizar a equipe em menos de uma semana." — Diretora Sandra, Colégio Aldeota.
                </p>

                <p class="insight-gate__bonus">
                    🎁 Bônus: Ganhe acesso à nossa comunidade exclusiva no WhatsApp ao finalizar o assessment.
                </p>
            </div>
        </section>
        <% } else if (mostrarHubPosPresurvey) { %>
        <!-- HUB PÓS MINI-ASSESSMENT — relatório central + WhatsApp + compra do plano -->
        <section class="pos-presurvey-hub" aria-labelledby="pos-presurvey-title">
            <header class="pos-presurvey-hub__head">
                <p class="panel-card__label">Relatório de Insights</p>
                <h1 id="pos-presurvey-title" class="section-title">Seu diagnóstico inicial está pronto</h1>
                <p class="section-subtitle" style="margin-bottom:0;">
                    Avaliação <strong>restrita</strong> com <strong><%= totalPresurveyHub %> questões</strong> da 1ª aba — amostra reduzida para um primeiro panorama
                    <% if (safeLead.empresa_clie) { %> · <%= safeLead.empresa_clie %><% } %>
                </p>
            </header>

            <div class="pos-presurvey-hub__grid">
                <div class="panel-card">
                    <p class="panel-card__label">Panorama por dimensão</p>
                    <p class="panel-card__hint">Presente (roxo) vs. ambição futura (dourado translúcido)</p>
                    <div class="pos-presurvey-hub__forte">
                        <i class="fas fa-shield-alt" aria-hidden="true"></i>
                        Maior fortaleza: <%= pilarForteLabel %>
                    </div>
                    <% dimensoesPresurvey.forEach(function (dim) {
                        var pVal = Number(dim.p) || 0;
                        var fVal = Number(dim.f) || 0;
                        var pPct = Math.min(100, Math.round((pVal / 5) * 100));
                        var fPct = Math.min(100, Math.round((fVal / 5) * 100));
                    %>
                    <div class="pos-presurvey-hub__dim-row">
                        <div class="pos-presurvey-hub__dim-head">
                            <span><%= dim.label %></span>
                            <span class="pos-presurvey-hub__dim-scores">P <%= pVal.toFixed(1) %> · F <%= fVal.toFixed(1) %></span>
                        </div>
                        <div class="pos-presurvey-hub__dim-track">
                            <div class="pos-presurvey-hub__dim-bar-f" style="width:<%= fPct %>%"></div>
                            <div class="pos-presurvey-hub__dim-bar-p" style="width:<%= pPct %>%"></div>
                        </div>
                    </div>
                    <% }); %>
                    <a href="/diagnostico-inicial/<%= safeLead.id_matu %>" class="pos-presurvey-hub__link-report">
                        Abrir relatório preliminar com gráficos radar →
                    </a>
                </div>

                <div class="panel-card">
                    <p class="panel-card__label">Recomendações do Consultor LeAction</p>
                    <div class="pos-presurvey-hub__insight">
                        <div class="pos-presurvey-hub__insight-label"><i class="fas fa-rocket"></i> Prioridade de ambição</div>
                        <p class="pos-presurvey-hub__insight-title"><%= insightsHub.ambicao && insightsHub.ambicao.bloco ? insightsHub.ambicao.bloco : 'Definição Estratégica' %></p>
                        <p class="pos-presurvey-hub__insight-action"><%= insightsHub.ambicao && insightsHub.ambicao.derv ? insightsHub.ambicao.derv : 'Plano de Ação Digital' %></p>
                    </div>
                    <div class="pos-presurvey-hub__insight">
                        <div class="pos-presurvey-hub__insight-label"><i class="fas fa-chart-line"></i> Resposta ao mercado</div>
                        <p class="pos-presurvey-hub__insight-title"><%= insightsHub.mercado && insightsHub.mercado.bloco ? insightsHub.mercado.bloco : 'Adequação Competitiva' %></p>
                        <p class="pos-presurvey-hub__insight-action"><%= insightsHub.mercado && insightsHub.mercado.derv ? insightsHub.mercado.derv : 'Sprint de Ajuste' %></p>
                    </div>
                </div>
            </div>

            <div class="panel-card pos-presurvey-hub__whatsapp">
                <div>
                    <h3>🎁 Bônus liberado: Comunidade exclusiva no WhatsApp</h3>
                    <p>Você concluiu o mini-assessment. Entre no grupo de gestores LeAction para trocar experiências, receber dicas semanais e acompanhar cases de transformação digital.</p>
                </div>
                <a href="<%= whatsappUrl %>" target="_blank" rel="noopener noreferrer" class="btn-violet">
                    <i class="fab fa-whatsapp"></i> Entrar no grupo
                </a>
            </div>

            <% if (!planoAtivado) { %>
            <div class="panel-card panel-card--action pos-presurvey-hub__upgrade">
                <h3>Desbloqueie o plano completo de transformação</h3>
                <p>
                    Este relatório gratuito cobre apenas <strong><%= totalPresurveyHub %> questões</strong> da 1ª aba — um repertório intencionalmente reduzido.
                    Ao <strong>contratar o plano</strong>, você libera
                    162 indicadores, o Radar Consultor LeAction Master, sprints executáveis e o roadmap estratégico completo.
                </p>
                <% if (typeof checkoutPlanUrl !== 'undefined' && checkoutPlanUrl) { %>
                <a href="<%= checkoutPlanUrl %>" class="pos-presurvey-hub__cta" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
                    <i class="fas fa-shopping-cart"></i> Contratar Plano Completo
                </a>
                <% } else { %>
                <p style="margin-top:12px;color:#64748b;">Faça login para contratar o plano completo.</p>
                <% } %>
            </div>
            <% } else if (isContextoOk) { %>
            <div class="panel-card pos-presurvey-hub__next">
                <div class="plano-status-badge" style="margin-bottom:12px;">
                    <i class="fas fa-check-circle"></i> Plano contratado
                </div>
                <p>Contexto institucional validado. Use o menu lateral em <strong>Avaliação Inicial</strong> para concluir o diagnóstico completo (162 indicadores).</p>
            </div>
            <% } else if (planoAtivado && (isProjetoOk || safeLead.hasActiveProject)) { %>
            <div class="panel-card pos-presurvey-hub__next">
                <div class="plano-status-badge" style="margin-bottom:12px;">
                    <i class="fas fa-check-circle"></i> Plano contratado
                </div>
                <p>Próximo passo: preencha o <strong>contexto institucional</strong> (menu lateral → Meus Dados) para liberar o questionário completo.</p>
                <button type="button" onclick="abrirModalContexto()" class="pos-presurvey-hub__cta" style="margin-top:14px;">
                    <i class="fas fa-id-card"></i> Preencher contexto
                </button>
            </div>
            <% } %>
        </section>
        <% } else if (!isAvaliacaoCompletaOk) { %>
        <!-- Fallback raro — sem relatório de pré-survey disponível -->
        <div class="panel-card">
            <p class="panel-card__label">Próximo passo</p>
            <h2 class="section-title">Continue sua jornada de diagnóstico</h2>
            <p class="section-subtitle">Utilize o menu lateral para acessar a avaliação inicial.</p>
        </div>
        <% } %>

        <% if (isAvaliacaoCompletaOk) { %>
        <div id="dashboard-matrix-section" class="panel-card matrix-panel" style="margin-top: 0;" data-id-matu="<%= safeLead.id_matu %>">
            <p class="panel-card__label">Análise de Contexto</p>
            <h2 class="section-title" style="margin-bottom: 8px;">Matriz de Desempenho</h2>
            <p class="section-subtitle">Ambição vs. realidade ajustada — cor identifica o domínio; tamanho da bolha = fragmentação (CV / elo fraco).</p>

            <div class="matrix-container">
                <div id="dashboard-matrix-loading" class="matrix-loading">Carregando matriz de desempenho...</div>
                <canvas id="dashboardPrioritizationMatrix"></canvas>
                <span class="matrix-label matrix-label--vitoria"><b>Rumo à Vitória</b></span>
                <span class="matrix-label matrix-label--everest"><b>Escalada do Everest</b></span>
                <span class="matrix-label matrix-label--inercia"><b>Pico da Inércia</b></span>
                <span class="matrix-label matrix-label--morte"><b>Vale da Morte</b></span>
            </div>

            <div class="matrix-legend">
                <div class="matrix-legend__quadrant">
                    <strong>Rumo à Vitória</strong>
                    Realidade ajustada alta e ambição acima da mediana — evolução contínua.
                </div>
                <div class="matrix-legend__quadrant">
                    <strong>Escalada do Everest</strong>
                    Realidade ajustada baixa com alta ambição — maior esforço de transformação.
                </div>
                <div class="matrix-legend__quadrant">
                    <strong>Pico da Inércia</strong>
                    Maturidade relativamente ok, ambição abaixo da mediana — risco de estagnação.
                </div>
                <div class="matrix-legend__quadrant">
                    <strong>Vale da Morte</strong>
                    Baixa realidade ajustada e baixa ambição — prioridade crítica.
                </div>
            </div>
            <p class="section-subtitle" style="margin-top: 12px; font-size: 0.82rem;">
                Realidade ajustada = média presente − 0,4×CV − 0,25×(média − elo mais fraco).
                <strong>Cor</strong> = domínio · <strong>tamanho</strong> = fragmentação das respostas.
            </p>
            <div class="matrix-legend__domains">
                <strong>Domínios:</strong>
                <code>ds</code> Estratégia Digital · <code>bm</code> Modelo de Negócio · <code>ic</code> Cultura de Inovação ·
                <code>dcd</code> Cultura de Dados · <code>cc</code> Colaboração · <code>dg</code> Governança ·
                <code>dp</code> Plataformas · <code>dcp</code> Capacidades · <code>dm</code> Métricas
            </div>
        </div>
        <script>window.dashboardDiagnosticoReport = <%- JSON.stringify(locals.diagnosticoReport || null) %>;</script>
        <% } %>

        <% if ((isAvaliacaoCompletaOk || isEmProcessamento) && !isGenesisOk) { %>
            <div class="genesis-cta-panel">

                <% if (isEmProcessamento) { %>
                    <p style="color: #6b7280; font-size: 0.95em;">O Consultor LeAction Master está gerando seu plano. O painel de progresso abrirá automaticamente.</p>
                <% } else if (isAvaliacaoCompletaOk) { %>
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 10px 0;">
                        <h2><i class="fas fa-magic"></i> Avaliação Completa Registrada</h2>
                        <p style="margin-bottom: 25px; font-size: 1.05em; text-align: center; max-width: 560px;">
                            Revise a matriz acima e, quando estiver pronto, inicie o <b>Consultor LeAction Master</b> para gerar seu plano estratégico definitivo.
                        </p>

                        <button onclick="executarGeneseEstrategica()" class="btn-dash btn-violet-primary"
                                style="padding: 18px 48px; font-size: 1.15em; border-radius: 8px; transition: all 0.25s ease;">
                            GERAR PLANO DE TRANSFORMAÇÃO DIGITAL <i class="fas fa-rocket" style="margin-left: 10px;"></i>
                        </button>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
<% } %>

<!-- ==================================================================
     🔮 INCLUSÃO DO MÓDULO UNIFICADO COMPONENTIZADO (FLAT UX) - PROTEÇÃO ATIVA
     ================================================================== -->
<% if (!locals.clientesModalCarregado) {
    locals.clientesModalCarregado = true; %>
    <%- include('clientes_modal') %>
<% } %>

<input type="hidden" id="id_cliente_hidden" value="<%= safeLead.id_clie %>">

<script>
document.addEventListener('DOMContentLoaded', function() {
        const ponte = document.getElementById('dados-index-ponte');
        const statusIA = ponte ? ponte.getAttribute('data-status-ia') : '';

        // Modal obrigatório: aberto automaticamente via layout.ejs quando status = PROJETO OK

        const formCentral = document.getElementById('form-contexto-central');
        if (formCentral) {
            window._ctxSubmitAdmin = null;
        }
    });

    // --- Persistência do contexto (lead) — delegada ao modal; mantida para compatibilidade ---
    async function salvarContextoCliente(e) {
        if (typeof window.salvarContextoLeadModal === 'function') {
            return window.salvarContextoLeadModal(e);
        }
    }

    // Função manual do card caso o cliente reabra o modal
    function abrirModalContexto() {
        const inicialPayload = {
            id_clie: '<%= safeLead.id_clie || "" %>',
            empresa_clie: '<%= safeLead.empresa_clie || safeLead.empresa || "" %>',
            docu_clie: '<%= safeLead.docu_clie || safeLead.docu || "" %>',
            nome_clie: '<%= safeLead.nome_clie || safeLead.nome || "" %>',
            mail_clie: '<%= safeLead.mail_clie || safeLead.mail || safeLead.email || "" %>',
            fone_clie: '<%= safeLead.fone_clie || safeLead.fone || "" %>',
            adre_clie: '<%= safeLead.adre_clie || "" %>',
            zipn_clie: '<%= safeLead.zipn_clie || "" %>',
            bairro_clie: '<%= safeLead.bairro_clie || "" %>',
            cidade_clie: '<%= safeLead.cidade_clie || "" %>',
            estado_clie: '<%= safeLead.estado_clie || "" %>',
            tipo_ensino: '<%= safeLead.tipo_ensino || "" %>',
            qtd_alunos: '<%= safeLead.qtd_alunos || "" %>',
            qtd_colaboradores: '<%= safeLead.qtd_colaboradores || "" %>',
            qtd_unidades: '<%= safeLead.qtd_unidades || "" %>',
            localizacao_sede: '<%= safeLead.localizacao_sede || "" %>',
            dados_mercado: `<%- (safeLead.dados_mercado || '').trim().replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`,
            dados_etnograficos: `<%- (safeLead.dados_etnograficos || '').trim().replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`,
            clima_organizacional: `<%- (safeLead.clima_organizacional || '').trim().replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`,
            moderacao_dados_mercado: `<%- (safeLead.moderacao_dados_mercado || '').trim().replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`,
            moderacao_dados_etnograficos: `<%- (safeLead.moderacao_dados_etnograficos || '').trim().replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`,
            moderacao_clima_organizacional: `<%- (safeLead.moderacao_clima_organizacional || '').trim().replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`,
            rede_ensino: '<%= (safeLead.rede_ensino === true || safeLead.rede_ensino === 1 || safeLead.rede_ensino === "true") ? true : false %>' === 'true'
        };

        const statusIA = '<%= (safeLead.status_ia || "").toUpperCase() %>';
        const obrigatorio = statusIA === 'PROJETO OK';
        abrirModalContextoLeadGeral(inicialPayload, false, false, obrigatorio);
    }
</script>
<script>
    window.geneseDiretrizesContexto = <%- JSON.stringify(geneseDiretrizesContexto) %>;
    <% if (isEmProcessamento && safeLead.id_matu) { %>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof iniciarMonitoramentoGenese === 'function') {
            iniciarMonitoramentoGenese('<%= safeLead.id_matu %>', window.geneseDiretrizesContexto);
        }
    });
    <% } %>
</script>
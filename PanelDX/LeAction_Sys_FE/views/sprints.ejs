        // 1. Função para carregar o histórico (Chamar dentro de abrirPainelSprint)
    async function carregarHistoricoCerimonias(id_sprn) {
        const timeline = document.getElementById('timeline-cerimonias');
        timeline.innerHTML = '<div style="text-align:center; padding:20px;"><i class="fas fa-spinner fa-spin"></i></div>';

        try {
            const res = await fetch(`/api/cerimonias/${id_sprn}`);
            const dados = await res.json();

            if (!dados || dados.length === 0) {
                timeline.innerHTML = '<p style="text-align:center; color:#999; font-size:0.8em; margin-top:20px;">Nenhum rito registrado.</p>';
                return;
            }

            timeline.innerHTML = dados.map(c => {
                // Mantemos a nota escapada apenas para o parâmetro da função recuperarRito
                const notaEscapada = c.note_cermls.replace(/'/g, "\\'").replace(/\n/g, "\\n");

                return `
                    <div onclick="recuperarRito('${c.id_cermls}', '${c.tp_cermls}', '${c.dt_cermls}', '${notaEscapada}')"
                         title="Clique para carregar esta nota"
                         style="background:#fff; border:1px solid #e2e8f0; border-left:3px solid #6c5ce7;
                                padding:6px 10px; margin-bottom:5px; border-radius:4px; cursor:pointer;
                                display:flex; justify-content:space-between; align-items:center; transition:0.2s;"
                         onmouseover="this.style.borderColor='#6c5ce7'; this.style.background='#f8faff';"
                         onmouseout="this.style.borderColor='#e2e8f0'; this.style.background='#fff';">

                        <span style="font-size:0.75em; font-weight:700; color:#475569;">${c.tp_cermls}</span>
                        <span style="font-size:0.7em; color:#6c5ce7; font-family:monospace;">
                            ${new Date(c.dt_cermls).toLocaleDateString('pt-BR', {day:'2-digit', month:'2-digit'})}
                        </span>
                    </div>
                `;
            }).join('');

        } catch (e) {
            timeline.innerHTML = '<p style="color:red; font-size:0.8em;">Erro ao carregar ritos.</p>';
        }
    }

    function recuperarRito(id, tipo, data, nota) {
        // 1. Identifica o ID de edição
        const inputId = document.getElementById('edit_id_cermls');
        if (inputId) inputId.value = id;

        // 2. Preenche o Tipo
        const typeField = document.getElementById('cerm_tipo');
        if (typeField) typeField.value = tipo;

        // 3. TRATAMENTO DA DATA (O Pulo do Gato)
        // Garantimos que pegamos apenas os primeiros 10 caracteres (YYYY-MM-DD)
        // Mesmo que a data venha como "2023-10-25T14:30:00.000Z" ou "Wed Oct 25 2023..."
        try {
            let dataFormatada = "";
            if (data) {
                // Se for uma string de data completa ou ISO, extrai apenas a parte da data
                const d = new Date(data);
                if (!isNaN(d.getTime())) {
                    dataFormatada = d.toISOString().split('T')[0];
                } else {
                    // Caso falhe o parse, tenta pegar os primeiros 10 caracteres da string
                    dataFormatada = data.substring(0, 10);
                }
            }
            document.getElementById('cerm_data').value = dataFormatada;
        } catch (e) {
            console.error("Erro ao formatar data para edição:", e);
        }

        // 4. Preenche a Nota
        const noteField = document.getElementById('cerm_note');
        if (noteField) {
            noteField.value = nota;
            noteField.style.backgroundColor = "#fffbe6"; // Alerta visual de edição
            noteField.focus();
        }

        // 5. Gerenciamento dos Botões
        const btnSave = document.getElementById('btn-cerm-save');
        if (btnSave) {
            btnSave.innerHTML = '<i class="fas fa-sync-alt"></i> ATUALIZAR ESTE RITO';
            btnSave.style.background = "#d97706";
        }

        const btnCancel = document.getElementById('btn-cerm-cancel');
        if (btnCancel) {
            btnCancel.style.display = "inline-flex";
        }
    }


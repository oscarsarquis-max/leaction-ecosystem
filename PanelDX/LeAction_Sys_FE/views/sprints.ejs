<div class="main-content">
<link rel="stylesheet" href="/css/estrategia-okr.css?v=1">
<script src="/js/estrategia-okr.js?v=1"></script>
    <div class="header-section">
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 20px;">
            <div>
                <h1><i class="fas fa-running"></i> Gestão de Sprints e Roadmap</h1>
                <p style="color: #666; margin-top: 5px;">Configuração da Trilha de Aceleração (Metodologia LeAction).</p>
            </div>
            <button class="btn blue-btn" onclick="abrirModal()">
                <i class="fas fa-plus"></i> Nova Sprint Manual
            </button>
        </div>

        <div style="margin-bottom: 20px; background: #f8f9fa; padding: 20px; border-radius: 8px; border: 1px solid #eee; display: flex; gap: 20px; align-items: flex-end;">
            <div style="flex: 2;">
                <label style="font-weight: bold; display: block; margin-bottom: 8px; color: #34495e;">1. Selecione o Projeto / Diagnóstico:</label>
                <select id="projeto_selector" onchange="selecionarProjeto(this.value)" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #ccc;">
                    <option value="">-- Aguarde, carregando projetos... --</option>
                </select>
            </div>
            <div style="flex: 1;">
                <label style="font-weight: bold; display: block; margin-bottom: 8px; color: #34495e;">2. Busca Rápida na Trilha:</label>
                <input type="text" id="inputBusca" onkeyup="filtrarTabelaLocal()" placeholder="🔎 Filtrar por nome ou ID..." style="padding: 10px; border-radius: 6px; border: 1px solid #ccc; width: 100%;">
            </div>
        </div>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th style="width: 60px; text-align: center;">Onda</th>
                    <th>Sprint / Bloco Associado</th>
                    <th style="text-align: center;">Ordem</th>
                    <th style="text-align: center;">Duração</th>
                    <th style="text-align: center;">Meta Velocidade</th>
                    <th style="text-align: center;">Status</th>
                    <th style="text-align: center; width: 100px;">Ações</th>
                </tr>
            </thead>
            <tbody id="table-body">
                <tr><td colspan="7" style="text-align:center; padding:30px; color:#999;">Selecione um projeto acima para carregar o Roadmap.</td></tr>
            </tbody>
        </table>
    </div>
</div>

<<%//Este é o modal das sprints........%>
<div id="modal-sprint-exec" class="modal">
    <div class="modal-content" style="border-top: 5px solid #6c5ce7; width: 95%; max-width: 1400px; margin: 5vh auto; padding: 30px; position: relative;">
        <span class="close" onclick="fecharModalSprint()">&times;</span>

        <div style="text-align: center; margin-bottom: 25px;">
            <h2 style="color: #2c3e50; margin: 0;"><i class="fas fa-tasks" style="color: #6c5ce7;"></i> Painel de Execução Inteligente</h2>
            <p id="sprint-subtitle" style="color: #6c5ce7; font-weight: bold; margin-top: 5px;"></p>
        </div>

        <div id="dod-checklist-container" style="display:none; background: #f3f0ff; border: 1px solid #dcd3ff; padding: 20px; border-radius: 8px; margin-bottom: 25px;">
            <div style="text-align: center; margin-bottom: 15px;">
                <small style="font-weight: 800; color: #6c5ce7; font-size: 0.75em; text-transform: uppercase;">Critérios de Qualidade e Conformidade (DoD)</small>
            </div>
            <div style="display: flex; gap: 20px;">
                <div style="flex: 1; background: rgba(255,255,255,0.4); padding: 12px; border-radius: 6px;">
                    <h5 style="margin: 0 0 10px 0; font-size: 0.8em; color: #6c5ce7; border-bottom: 1px solid #dcd3ff;"><i class="fas fa-check-double"></i> REQUISITOS GERAIS</h5>
                    <div id="dod-items-gerais" style="display: flex; flex-direction: column; gap: 8px;"></div>
                </div>
                <div style="flex: 1; background: rgba(255,255,255,0.4); padding: 12px; border-radius: 6px;">
                    <h5 style="margin: 0 0 10px 0; font-size: 0.8em; color: #6c5ce7; border-bottom: 1px solid #dcd3ff;"><i class="fas fa-graduation-cap"></i> CONTEXTO EDUCACIONAL</h5>
                    <div id="dod-items-educacional" style="display: flex; flex-direction: column; gap: 8px;"></div>
                </div>
            </div>
        </div>

        <div class="framework-guide" style="border-left: 5px solid #6c5ce7; padding: 15px; background: #fafafa; margin-bottom: 25px;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                <div><small style="font-weight: 800; color: #6c5ce7; font-size: 0.7em;">DEFINIÇÃO</small><div id="guide-defi" style="font-size: 0.95em; color: #34495e;"></div></div>
                <div><small style="font-weight: 800; color: #6c5ce7; font-size: 0.7em;">COMPOSIÇÃO</small><div id="guide-comp" style="font-size: 0.95em; white-space: pre-wrap; color: #34495e;"></div></div>
            </div>
        </div>
        <div id="sprint-estrategia-okr" hidden></div>

        <form id="form-sprint-exec" onsubmit="salvarExecucaoSprint(event)" style="width: 100%;">
            <input type="hidden" id="exec_id_sprn">

            <div style="display: flex; flex-direction: column; gap: 30px; width: 100%;">

                <div style="display: flex; gap: 30px; width: 100%;">
                    <div style="flex: 1.2;">
                        <fieldset style="border-color: #dcd3ff; height: 100%;">
                            <legend style="color: #6c5ce7; font-weight: bold; padding: 0 10px;">Qualificação Estratégica</legend>
                            <div class="form-group" style="margin-bottom: 15px;">
                                <label style="font-weight: bold; color: #444;">Racional (SWOT)</label>
                                <select id="exec_swot_type" required style="width: 100%; padding: 10px; border: 1px solid #dcd3ff; border-radius: 4px;">
                                    <option value="">Selecione...</option>
                                    <option value="Fraqueza">Tratar Fraqueza</option>
                                    <option value="Oportunidade">Alavancar Oportunidade</option>
                                    <option value="Ameaça">Mitigar Ameaça</option>

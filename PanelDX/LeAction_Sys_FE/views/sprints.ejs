                                <label style="font-weight: bold; color: #6c5ce7; font-size: 0.85em;"><i class="fas fa-link"></i> Link da Evidência (Drive/Sharepoint)</label>
                                <input type="url" id="evid_url" placeholder="https://..." style="width: 100%; padding: 10px; border: 1px solid #dcd3ff; border-radius: 4px; margin-top: 5px;">
                            </div>

                            <div style="flex: 1;">
                                <label style="font-weight: bold; color: #6c5ce7; font-size: 0.85em;"><i class="fas fa-puzzle-piece"></i> Componente Relacionado</label>
                                <select id="evid_componente" style="width: 100%; padding: 10px; border: 1px solid #dcd3ff; border-radius: 4px; margin-top: 5px;">

<div class="mesa-org meu-contrato-page" id="meu-contrato-root">
    <header class="mesa-org__hero">
        <div>
            <h1><i class="fas fa-file-contract" style="color:#fbbf24;"></i> Meu Contrato</h1>
            <p>
                Plano comercial ativo, opções de alteração (upgrade / downgrade),
                pacotes extras e histórico de ativações da sua empresa.
            </p>
        </div>
        <div class="mesa-org__meta">
            <div><strong>Gestão comercial</strong></div>
            <div>Contrato · Planos · Pagamentos</div>
        </div>
    </header>

    <div id="mc-loading" class="meu-contrato__loading">
        <i class="fas fa-circle-notch fa-spin"></i> Carregando contrato…
    </div>
    <div id="mc-error" class="meu-contrato__error" hidden></div>

    <div id="mc-content" hidden>
        <section class="mesa-card meu-contrato__card" id="mc-contrato-card">
            <div class="meu-contrato__card-head">
                <h2><i class="fas fa-certificate"></i> Contrato vigente</h2>
                <span class="meu-contrato__badge" id="mc-status-badge">—</span>
            </div>
            <div class="meu-contrato__grid" id="mc-contrato-grid"></div>
            <div class="meu-contrato__actions" id="mc-contrato-actions"></div>
        </section>

        <section class="mesa-card meu-contrato__card">
            <div class="meu-contrato__card-head">
                <h2><i class="fas fa-users"></i> Uso de licenças</h2>
            </div>
            <div id="mc-cota" class="meu-contrato__cota"></div>
        </section>

        <section class="mesa-card meu-contrato__card">
            <div class="meu-contrato__card-head">
                <h2><i class="fas fa-layer-group"></i> Planos disponíveis</h2>
                <p class="admin-esim__field-hint" style="margin:0">
                    Altere para mais (upgrade) ou para menos (downgrade) via checkout seguro do Action Hub.
                </p>
            </div>
            <div class="meu-contrato__planos" id="mc-planos"></div>
        </section>

        <section class="mesa-card meu-contrato__card">
            <div class="meu-contrato__card-head">
                <h2><i class="fas fa-puzzle-piece"></i> Pacotes adicionais</h2>
            </div>
            <div id="mc-addons"></div>
        </section>

        <section class="mesa-card meu-contrato__card">
            <div class="meu-contrato__card-head">
                <h2><i class="fas fa-receipt"></i> Histórico comercial</h2>
                <p class="admin-esim__field-hint" style="margin:0">
                    Ativações no PanelDX. Detalhe de parcelas no gateway fica no painel do Action Hub.
                </p>
            </div>
            <div class="meu-contrato__table-wrap">
                <table class="admin-esim__table">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Item</th>
                            <th>Status</th>
                            <th>Valor</th>
                            <th>Referência</th>
                        </tr>
                    </thead>
                    <tbody id="mc-historico-body">
                        <tr><td colspan="5" class="admin-esim__empty">Sem registros.</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="meu-contrato__actions" style="margin-top:14px">
                <a id="mc-hub-dashboard" class="mesa-btn mesa-btn--ghost" href="#" target="_blank" rel="noopener">
                    <i class="fas fa-external-link-alt"></i> Ver pedidos / parcelas no Action Hub
                </a>
            </div>
        </section>
    </div>
</div>

<script>
    window.MEU_CONTRATO_CONFIG = {
        idClie: '<%= typeof idClie !== "undefined" ? idClie : "" %>',
        bffUrl: '/bff/led/meu-contrato',
        checkoutUpgradeUrl: '<%= typeof checkoutUpgradeUrl !== "undefined" ? checkoutUpgradeUrl : "" %>',
        checkoutAddonUrlTemplate: '<%= typeof checkoutAddonUrlTemplate !== "undefined" ? checkoutAddonUrlTemplate : "" %>',
        hubDashboardUrl: '<%= typeof hubDashboardUrl !== "undefined" ? hubDashboardUrl : "" %>'
    };
</script>

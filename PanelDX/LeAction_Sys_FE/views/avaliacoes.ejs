                background: #fef2f2;
                border-color: #ef4444;
                color: #b91c1c;
                box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
            }
            #evaluation-page .btn-voz-campo.mic-voz-ouvindo .mic-label {
                font-weight: 800;
            }
            #evaluation-page textarea.ditado-ativo,
            #evaluation-page #ia-master-input.ditado-ativo {
                border-color: #7c3aed !important;
                box-shadow: 0 0 0 0.2rem rgba(124, 58, 237, 0.12);
            }
            #evaluation-page textarea.ditado-recebeu,
            #evaluation-page #ia-master-input.ditado-recebeu {
                border-color: #059669 !important;
                box-shadow: 0 0 0 0.2rem rgba(5, 150, 105, 0.18);
            }
            #assessment-ditado-status {
                font-size: 0.78rem;
                color: #64748b;
                min-height: 1.2rem;
                margin: 0 0 6px;
            }
            #ditado-stop-bar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
                flex-wrap: wrap;
                padding: 10px 14px;
                margin: 0 0 12px;
                border-radius: 12px;
                background: linear-gradient(90deg, rgba(239, 68, 68, 0.1), rgba(108, 92, 231, 0.08));
                border: 1px solid rgba(239, 68, 68, 0.35);
                animation: ditado-pulse-bar 1.6s ease-in-out infinite;
            }
            #ditado-stop-bar[hidden] {
                display: none !important;
            }
            @keyframes ditado-pulse-bar {
                0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.15); }
                50%      { box-shadow: 0 0 0 6px rgba(239, 68, 68, 0.05); }
            }
            #ditado-stop-bar__hint {
                font-size: 0.82rem;
                color: #4A2E80;
                font-weight: 600;
            }
            #ditado-stop-bar__hint kbd {
                display: inline-block;
                padding: 2px 8px;
                border-radius: 6px;
                background: #fff;
                border: 1px solid #e2e8f0;
                font-size: 0.78rem;
                font-weight: 800;
                color: #b91c1c;
            }
            .btn-ditado-stop {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 8px 16px;
                border: none;
                border-radius: 999px;
                background: linear-gradient(135deg, #ef4444, #dc2626);
                color: #fff;
                font-weight: 800;
                font-size: 0.82rem;
                cursor: pointer;
                box-shadow: 0 4px 12px rgba(239, 68, 68, 0.35);
            }
            .btn-ditado-stop:hover {
                filter: brightness(1.05);
            }
            .quali-voz-toolbar {
                display: flex;
                justify-content: flex-end;
                margin-bottom: 6px;
            }
            .ia-master-voz-row {
                display: flex;
                justify-content: flex-end;
                margin-bottom: 6px;
            }
        </style>

        <div id="assessment-progress-dock" class="assessment-progress-dock" role="region" aria-label="Progresso do questionário" aria-live="polite">
            <div class="assessment-progress-dock__inner">
                <div class="assessment-progress-dock__head">
                    <div class="assessment-progress-dock__title">
                        <span id="assessment-progress-mode" class="assessment-progress-dock__badge assessment-progress-dock__badge--mini">
                            <i class="fas fa-bolt"></i> Mini diagnóstico
                        </span>
                    </div>
                    <div class="assessment-progress-dock__track" aria-hidden="true">
                        <div class="assessment-progress-dock__milestones">
                            <span style="left:25%"></span>
                            <span style="left:50%"></span>
                            <span style="left:75%"></span>
                        </div>
                        <div id="assessment-progress-fill" class="assessment-progress-dock__fill assessment-progress-dock__fill--mini"></div>
                    </div>
                    <div class="assessment-progress-dock__pct-wrap">
                        <span id="assessment-progress-pct" class="assessment-progress-dock__pct">0%</span>
                        <span id="assessment-progress-count" class="assessment-progress-dock__count">0 de <%= totalPresurvey %> questões</span>
                    </div>
                </div>
                <div class="assessment-progress-dock__footer">
                    <div class="assessment-gamify-strip">
                        <div id="assessment-gamify-badges" class="assessment-gamify-badges" aria-label="Conquistas"></div>
                        <div id="assessment-gamify-callout" class="assessment-gamify-callout">
                            <i class="fas fa-medal"></i>
                            <span id="assessment-gamify-callout-text">Responda a 1ª questão para desbloquear seu primeiro badge.</span>
                        </div>
                    </div>
                    <div class="assessment-progress-dock__meta">
                        <span><i class="fas fa-flag-checkered"></i> <span id="assessment-progress-status" class="assessment-progress-dock__status">Não iniciado</span></span>
                        <span><i class="fas fa-tachometer-alt"></i> <span id="assessment-progress-pace">Ritmo: aguardando 1ª resposta</span></span>
                        <span><i class="fas fa-clock"></i> <span id="assessment-progress-time">~3 min restantes</span></span>
                    </div>
                </div>
            </div>
        </div>

        <div id="evaluation-page-body" class="evaluation-page-body">

        <h2><%= modoRestrito ? 'Diagnóstico Inicial de Maturidade' : 'Questionário de Avaliação de Maturidade' %></h2>

        <div id="assessment-mode-toggle" class="assessment-mode-toggle" role="tablist">
            <button type="button" class="<%= chatIaMasterBloqueado ? '' : 'active' %><%= chatIaMasterBloqueado ? ' is-locked' : '' %>"
                    data-mode="chat" <%= chatIaMasterBloqueado ? 'disabled aria-disabled="true"' : '' %>>
                <i class="fas fa-comments"></i> Consultor LeAction Master — Conversacional
            </button>
            <button type="button" class="<%= chatIaMasterBloqueado ? 'active' : '' %>" data-mode="classic">
                <i class="fas fa-list-ul"></i> <%= modoRestrito ? ('Modo detalhado (' + totalPresurvey + ' questões — 1ª aba)') : 'Modo detalhado (162 indicadores)' %>
            </button>
        </div>

        <div id="ia-master-locked-panel" class="ia-master-locked-panel <%= chatIaMasterBloqueado ? 'is-visible' : '' %>">
            <h3><i class="fas fa-lock"></i> Modo conversacional indisponível</h3>
            <p>
                Seu <strong>relatório preliminar</strong> já foi gerado. O Consultor LeAction Master conversacional será liberado novamente
                após a <strong>contratação do plano</strong>, para o assessment completo (162 indicadores).
                Enquanto isso, consulte suas respostas no modo detalhado ou abra o relatório preliminar no menu.
            </p>
        </div>
        <div id="assessment-ditado-status" role="status" aria-live="polite"></div>
        <div id="ditado-stop-bar" hidden aria-hidden="true">
            <span id="ditado-stop-bar__hint">
                <i class="fas fa-circle" style="color:#ef4444;font-size:0.55rem;vertical-align:middle;"></i>
                Gravando — diga <kbd>fim</kbd> ou clique para parar
            </span>
            <button type="button" class="btn-ditado-stop" data-ditado-action="stop">
                <i class="fas fa-stop"></i> Parar ditado
            </button>
        </div>

        <div id="ia-master-chat"
             data-maturity-id="<%= maturityData.id_matu %>"
             data-is-mini="<%= modoRestrito ? 'true' : 'false' %>"
             data-chat-locked="<%= chatIaMasterBloqueado ? 'true' : 'false' %>"
             style="<%= chatIaMasterBloqueado ? 'display:none !important;' : '' %>">
            <div class="ia-master-chat__head">
                <h3><i class="fas fa-brain"></i> Consultor LeAction Master — Game Master Estratégico</h3>
                <div style="text-align:right;">
                    <span id="ia-master-badge">Preparando partida…</span>
                    <div id="ia-master-coverage-hint"><%= modoRestrito ? ('0 de ' + totalPresurvey + ' questões da 1ª aba') : '0 de 162 indicadores' %></div>
                </div>
            </div>
            <div id="ia-master-messages" aria-live="polite"></div>
            <div id="ia-master-deduction">
                <p id="ia-master-deduction-headline"></p>
                <p id="ia-master-deduction-count"></p>
                <div class="ia-master-deduction__actions">
                    <button type="button" id="ia-master-confirm"><i class="fas fa-check"></i> Acertou — registrar bloco</button>
                    <button type="button" id="ia-master-reject"><i class="fas fa-edit"></i> Ajustar realidade</button>
                </div>
            </div>
            <div class="ia-master-chat__footer">
                <div class="ia-master-voz-row">
                    <button type="button" class="btn-voz-campo" data-voz-target="ia-master-input" aria-label="Ditado por voz">
                        <i class="fas fa-microphone"></i>
                        <span class="mic-label">Ditado</span>
                    </button>
                </div>
                <div class="ia-master-chat__input-row">
                    <textarea id="ia-master-input" rows="2" placeholder="Sua resposta ao Consultor LeAction Master…"></textarea>
                    <button type="button" id="ia-master-send"><i class="fas fa-paper-plane"></i> Enviar</button>
                </div>
                <div class="ia-master-chat__finalize">
                    <% if (modoRestrito) { %>
                    <p style="font-size:0.78rem;color:#64748b;margin:0 0 8px;text-align:center;">
                        Após responder as <%= totalPresurvey %> questões da 1ª aba (modo detalhado), gere o relatório preliminar.
                        As demais abas permanecem bloqueadas até contratar o plano.
                    </p>
                    <button type="button" id="ia-master-finalize" disabled title="Complete as questões da 1ª aba no modo detalhado">
                        <i class="fas fa-magic"></i> Gerar diagnóstico preliminar
                    </button>
                    <% } else { %>
                    <button type="button" id="ia-master-finalize" disabled title="Complete todos os indicadores antes de finalizar">
                        <i class="fas fa-flag-checkered"></i> Finalizar assessment (100% obrigatório)
                    </button>
                    <% } %>
                </div>
            </div>
        </div>

        <div id="evaluation-classic-panel" style="<%= chatIaMasterBloqueado ? 'display:block;' : 'display:none;' %>">

        <div class="wizard-progress">
            <div class="step-indicator active" data-step="0">Como Estou Agora?</div>
            <div class="step-indicator <%= modoRestrito ? 'locked' : '' %>" data-step="1">1. Educação</div>
            <div class="step-indicator <%= modoRestrito ? 'locked' : '' %>" data-step="2">2. Estratégia/Pessoas</div>
            <div class="step-indicator <%= modoRestrito ? 'locked' : '' %>" data-step="3">3. Estrutura/Tecnologia</div>
            <div class="step-indicator <%= modoRestrito ? 'locked' : '' %>" data-step="4">4. Visão Geral</div>
        </div>

        <form id="evaluationForm"
              data-maturity-id="<%= maturityData.id_matu %>"
              data-restricted="<%= modoRestrito %>"
              data-mini-total="<%= questions.filter(q => q.presurvey_ques === true || q.presurvey_ques === 'true').length %>"
              data-full-total="162"
              data-saved-ids="<%= Object.keys(savedAnswers || {}).join(',') %>">
            <% if (questions && questions.length > 0) { %>
                <%
                   let visualNumber = 1;
                   const renderQuestion = (question) => {
                       const rawPrefu = (question.prefu_ques || '').toString().trim().toUpperCase();
                       const tipoText = (rawPrefu === 'P') ? 'Pres' : 'Fut';

                       const saved = savedAnswers[question.id_ques] || { grad: null, text: '', hasAnswer: false };

                       const temRubricas = question.rubricas && question.rubricas.length > 0;
                       const isPreSurvey = question.presurvey_ques === true || question.presurvey_ques === 'true';
                       const instrucaoQuali = question.quali_ques && question.quali_ques.trim() !== '';
                %>
                    <div class="question-item"
                         data-question-id="<%= question.id_ques %>"
                         data-dim-id="<%= question.id_dime %>"
                         data-doma-id="<%= question.id_doma %>"
                         data-prefu="<%= rawPrefu %>"
                         data-presurvey="<%= isPreSurvey ? 'true' : 'false' %>">

                        <h4><%= visualNumber++ %>. <%= question.desc_ques %>
                            <span style="font-weight: normal; color: <%= rawPrefu === 'F' ? '#b45309' : '#64748b' %>; font-size: 0.75rem;">[<%= tipoText %>]</span>
                        </h4>

                        <% if (temRubricas) { %>
                        <div class="rubricas-grid">
                            <% question.rubricas.forEach(rubrica => { %>
                                <label class="rubrica-option">
                                    <input type="radio"
                                           name="question-<%= question.id_ques %>"
                                           value="<%= rubrica.grad_rubr %>"
                                           <%= (saved.hasAnswer && Number(saved.grad) === Number(rubrica.grad_rubr)) ? 'checked' : '' %>
                                           required>
                                    <span class="label-text"><%= rubrica.label_rubr %></span>
                                    <div class="rubrica-tooltip">
                                        <strong><%= rubrica.label_rubr %>:</strong><br>
                                        <%= rubrica.desc_rubr %>
                                    </div>
                                </label>
                            <% }); %>

                            <label class="rubrica-option">
                                <input type="radio" name="question-<%= question.id_ques %>" value="na" <%= (saved.grad === null && saved.hasAnswer) ? 'checked' : '' %>>
                                <span class="label-text" style="color: #94a3b8; font-style: italic;">N/A (Não se aplica)</span>
                                <div class="rubrica-tooltip">Informação indisponível ou processo inexistente.</div>
                            </label>
                        </div>
                        <% } %>

                        <%
                           if (!isPreSurvey && (!temRubricas || instrucaoQuali)) {
                        %>
                            <div class="qualitative-box">
                                <label style="font-size: 0.85rem; font-weight: bold; color: #6c5ce7; display: block; margin-bottom: 5px;">
                                    <i class="fas fa-edit"></i> Evidências e Contexto:
                                    <span style="font-weight: normal; color: #64748b; font-style: italic;">
                                        (Palavras-chave: <%= question.insight_chave || 'Geral' %>)
                                    </span>
                                </label>
                                <% if (instrucaoQuali) { %>
                                    <p style="font-size: 0.75rem; color: #64748b; margin-bottom: 8px;"><%= question.quali_ques %></p>
                                <% } %>
                                <div class="quali-voz-toolbar">
                                    <button type="button" class="btn-voz-campo"
                                            data-voz-target="quali-field-<%= question.id_ques %>"
                                            aria-label="Ditado por voz para evidências">
                                        <i class="fas fa-microphone"></i>
                                        <span class="mic-label">Ditado</span>
                                    </button>
                                </div>
                                <textarea
                                    id="quali-field-<%= question.id_ques %>"
                                    name="quali_ques-<%= question.id_ques %>"
                                    class="quali-textarea"
                                    placeholder="Descreva aqui os detalhes práticos para análise do Consultor LeAction…"><%= saved.text %></textarea>
                            </div>
                        <% } %>
                    </div>
                <% } %>

                <div class="wizard-step active" id="step-0">
                    <h3 style="margin-bottom: 15px; font-size: 1.2rem; color: #4A2E80;">Diagnóstico Inicial (Pre-Survey)</h3>
                    <% questions.filter(q => q.presurvey_ques === true || q.presurvey_ques === 'true').forEach(renderQuestion); %>

                    <div style="text-align:right; margin-top: 25px;">
                        <% if (modoRestrito) { %>
                            <button type="button" class="submit-btn btn-conversion"
                                    onclick="finalizarEGerarDiagnosticoInicial('<%= maturityData.id_matu %>', this)">
                                <i class="fas fa-magic"></i> FINALIZAR E GERAR DIAGNÓSTICO PRELIMINAR &rarr;
                            </button>
                        <% } else { %>
                            <button type="button" class="next-btn submit-btn">Próximo Passo</button>
                        <% } %>
                    </div>
                </div>

                <div class="wizard-step" id="step-1" style="display:none;">
                    <h3 style="margin-bottom: 15px; font-size: 1.2rem;">1. Aprendizagem em Ação</h3>
                    <% questions.filter(q => {
                        const isPS = q.presurvey_ques === true || q.presurvey_ques === 'true';
                        return !isPS && Number(q.id_dime) === 4;
                    }).forEach(renderQuestion); %>
                    <div style="display:flex; justify-content:space-between; margin-top: 25px;">
                        <button type="button" class="prev-btn submit-btn" style="background:#64748b;">Anterior</button>
                        <button type="button" class="next-btn submit-btn">Próximo Passo</button>
                    </div>
                </div>

                <div class="wizard-step" id="step-2" style="display:none;">
                    <h3 style="margin-bottom: 15px; font-size: 1.2rem;">2. Estratégia e Pessoas</h3>
                    <% questions.filter(q => {
                        const isPS = q.presurvey_ques === true || q.presurvey_ques === 'true';
                        const setor = (q.setor_ques || '').toString().trim().toUpperCase();
                        const dim = Number(q.id_dime);
                        return !isPS && setor === 'EDUCACAO' && (dim === 1 || dim === 2) && dim !== 4;
                    }).forEach(renderQuestion); %>
                    <div style="display:flex; justify-content:space-between; margin-top: 25px;">
                        <button type="button" class="prev-btn submit-btn" style="background:#64748b;">Anterior</button>
                        <button type="button" class="next-btn submit-btn">Próximo Passo</button>
                    </div>
                </div>

                <div class="wizard-step" id="step-3" style="display:none;">
                    <h3 style="margin-bottom: 15px; font-size: 1.2rem;">3. Estrutura e Tecnologia</h3>
                    <% questions.filter(q => {
                        const isPS = q.presurvey_ques === true || q.presurvey_ques === 'true';
                        const setor = (q.setor_ques || '').toString().trim().toUpperCase();
                        const dim = Number(q.id_dime);
                        return !isPS && setor === 'EDUCACAO' && (dim === 3 || dim === 5) && dim !== 4;
                    }).forEach(renderQuestion); %>
                    <div style="display:flex; justify-content:space-between; margin-top: 25px;">
                        <button type="button" class="prev-btn submit-btn" style="background:#64748b;">Anterior</button>
                        <button type="button" class="next-btn submit-btn">Próximo Passo</button>
                    </div>
                </div>

                <div class="wizard-step" id="step-4" style="display:none;">
                    <h3 style="margin-bottom: 15px; font-size: 1.2rem;">4. Visão Geral e Fundamentos</h3>
                    <% questions.filter(q => {
                        const isPS = q.presurvey_ques === true || q.presurvey_ques === 'true';
                        const dim = Number(q.id_dime);
                        const setor = (q.setor_ques || '').toString().trim().toUpperCase();
                        return !isPS && setor !== 'EDUCACAO' && dim !== 4;
                    }).forEach(renderQuestion); %>

                    <div id="statusFuture" style="margin-bottom: 10px; font-weight: bold;"></div>

                    <div style="display:flex; justify-content:space-between; margin-top: 25px;">
                        <button type="button" class="prev-btn submit-btn" style="background:#64748b;">Anterior</button>
                        <button type="button" class="submit-btn future-submit-btn">Finalizar e Gerar Diagnóstico</button>
                    </div>
                </div>
            <% } %>
        </form>
        </div><!-- /evaluation-classic-panel -->

        </div><!-- /evaluation-page-body -->

        <script src="/js/voz-ditado.js"></script>
        <script src="/js/assessment-ia-master.js" defer></script>
        <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.initPanelDxVozDitado) {
                initPanelDxVozDitado('assessment', {
                    root: '#evaluation-page',
                    statusEl: '#assessment-ditado-status',
                    stopBarEl: '#ditado-stop-bar',
                    onError: function (msg) {
                        var el = document.getElementById('assessment-ditado-status');
                        if (el) el.textContent = msg;
                    }
                });
            }
        });
        </script>
    </div>
</div>

<div id="modalContexto">
    <div class="modal-content-wrap">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
            <h3 style="margin:0;">Meus Dados - Análise de Contexto</h3>
            <button type="button" onclick="document.getElementById('modalContexto').style.display='none'" style="background:none; border:none; font-size:24px; cursor:pointer;">&times;</button>
        </div>
        <hr>
        <form id="formContexto" onsubmit="submeterContexto(event)">
             <p class="text-sm text-gray-600 mb-4">Confirme as informações básicas da instituição para análise da IA.</p>
             <div style="text-align:right; margin-top: 20px;">
                 <button type="submit" class="submit-btn">Salvar Alterações</button>
             </div>
        </form>
    </div>
</div>

<script>
async function submeterContexto(event) {
    event.preventDefault();
    const form = document.getElementById('formContexto');
    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
        const res = await fetch('/api/client/update-context', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        if (!res.ok) throw new Error("Falha ao salvar dados de contexto.");

        alert("Dados salvos com sucesso!");
        document.getElementById('modalContexto').style.display = 'none';
    } catch (err) {
        console.error(err);
        alert("Erro ao salvar. Verifique sua conexão.");
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('evaluationForm');
    const isRestricted = form.getAttribute('data-restricted') === 'true';

    if (isRestricted) {
        const nextButtons = document.querySelectorAll('.next-btn');
        nextButtons.forEach(btn => {
            btn.addEventListener('click', function(e) {
                const currentStep = this.closest('.wizard-step').id;
                if (currentStep === 'step-0') {
                    e.stopImmediatePropagation();
                }
            }, true);
        });
    }
});
</script>
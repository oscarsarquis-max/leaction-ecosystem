<div class="main-content" id="evaluation-page">
    <div class="form-container">
        <%
           // 1. CAPTURA O STATUS BUSCANDO EM MÚLTIPLOS ESCOPOS PARA GARANTIR SEGURANÇA
           let statusIA_Raw = "";
           if (typeof maturityData !== 'undefined' && maturityData && maturityData.status_ia) {
               statusIA_Raw = maturityData.status_ia;
           } else if (locals.lead && lead.status_ia) {
               statusIA_Raw = lead.status_ia;
           } else if (locals.status_ia) {
               statusIA_Raw = locals.status_ia;
           }

           const statusIA = statusIA_Raw.toString().trim().toUpperCase();

           // 2. REGRA DE DESTRAVAMENTO SEQUENCIAL NATIVO
           // Se o status for 'AGUARDANDO CONTEXTO' ou 'PENDENTE', o modoRestrito é TRUE (trava tudo).
           // O modo restrito cai (vira false) se o status for CONTEXTO OK, AVALIACAO OK, etc.
           const modoRestrito = statusIA === 'AGUARDANDO CONTEXTO' || statusIA === 'PENDENTE' || (!statusIA.includes('CONTEXTO') && !statusIA.includes('AVALIACAO') && !statusIA.includes('CONCLU'));

           const presurveyRelatorioPronto = statusIA === 'PRESURVEY OK';
           const planoContratado = !!(locals.lead && (lead.hasActiveProject === true || lead.hasActiveProject === 1 || lead.hasActiveProject === 'true'))
               || statusIA === 'PROJETO OK' || statusIA === 'CONTEXTO OK' || statusIA === 'AVALIACAO OK'
               || statusIA === 'PENDENTE' || statusIA === 'PROCESSANDO' || statusIA.includes('CONCLU');
           const chatIaMasterBloqueado = modoRestrito && presurveyRelatorioPronto && !planoContratado;
           const totalPresurvey = (questions && questions.length)
               ? questions.filter(q => q.presurvey_ques === true || q.presurvey_ques === 'true').length
               : 28;
        %>


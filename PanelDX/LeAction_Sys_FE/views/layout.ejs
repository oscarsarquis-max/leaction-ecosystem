    <script>
        var _leadData = {};
        try {
            _leadData = JSON.parse('<%- JSON.stringify(locals.lead || locals.user || {}).replace(/\\/g, "\\\\").replace(/\'/g, "\\\'") %>');
        } catch (e) { console.error("Erro JSON:", e); }

        // Mapeia e redireciona os gatilhos de layout para o novo parcial inteligente unificado
        function ehPapelClienteLead() {
            // Contexto de escola/projeto é exclusivo do Cliente (lead). Executor/consultor/sysadmin não devem ser bloqueados.
            const role = String(
                (_leadData && (_leadData.system_role || _leadData.role))
                || '<%= (typeof system_role !== "undefined" && system_role) ? system_role : "" %>'
                || ''
            ).toLowerCase();
            if (role === 'executor' || role === 'consultor' || role === 'sysadmin' || role === 'admin') {
                return false;
            }
            <% if (locals.isExecutor || locals.isConsultor || locals.isAdmin) { %>
            return false;
            <% } %>
            return true;
        }

        function abrirModalContextoLead() {
            if (!_leadData || !ehPapelClienteLead()) return;

            const statusMacro = (_leadData.status_ia || "").toUpperCase();
            // Só trava edição quando o plano/Kanban já existe — status CONCLUIDO sozinho não basta.
            const jaBloqueadoPeloPlano = !!(
                _leadData.plano_ia_concluido === true
                || _leadData.plano_ia_concluido === 1
                || _leadData.plano_ia_concluido === 'true'
                || (statusMacro === 'CONCLUIDO' && !!_leadData.data_geracao_plano)
            );
            const projetoAtivo = !!(
                _leadData.hasActiveProject === true
                || _leadData.hasActiveProject === 1
                || _leadData.hasActiveProject === 'true'
                || _leadData.has_active_project === true
            );
            const contextoOk = !!((_leadData.clima_organizacional || '').trim().length > 5);
            // Após contratação, contexto é obrigatório antes da gênese (mesmo se status permanecer AVALIACAO OK).
            const obrigatorio = projetoAtivo && !contextoOk && !jaBloqueadoPeloPlano;

            abrirModalContextoLeadGeral(_leadData, jaBloqueadoPeloPlano, false, obrigatorio);
        }

        document.addEventListener('DOMContentLoaded', function () {
            if (typeof abrirModalContextoLeadGeral !== 'function' || !_leadData) return;
            if (!ehPapelClienteLead()) return;
            const statusMacro = (_leadData.status_ia || '').toUpperCase();
            const projetoAtivo = !!(
                _leadData.hasActiveProject === true
                || _leadData.hasActiveProject === 1
                || _leadData.hasActiveProject === 'true'
                || _leadData.has_active_project === true
            );
            const contextoOk = !!((_leadData.clima_organizacional || '').trim().length > 5);
            const planoPronto = statusMacro === 'CONCLUIDO' || statusMacro.indexOf('CONCLU') !== -1;
            if (projetoAtivo && !contextoOk && !planoPronto) {
                setTimeout(function () {
                    abrirModalContextoLeadGeral(_leadData, false, false, true);
                }, 500);
            }
        });

        async function dispararGeneseLayout(event) {
            if (event) event.preventDefault();
            if (typeof executarGeneseEstrategica === 'function') {
                return executarGeneseEstrategica();
            }
            if (!confirm("Deseja iniciar o processamento da Gênese com o Consultor LeAction?")) return;
            try {
                await fetch('/client/generate-ai-plan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id_matu: _leadData.id_matu })
                });
                window.location.reload();
            } catch (err) { window.location.reload(); }
        }

        async function h_verificarEmail() {
            const email = document.getElementById('h-email').value.trim();
            if (!email) return alert("Digite seu e-mail");

            try {
                const res = await fetch('/verificar-email', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ email })
                });
                const data = await res.json();

                if (res.ok) {
                    document.getElementById('h-step-1').style.display = 'none';
                    document.getElementById('h-step-2').style.display = 'flex';
                    document.getElementById('h-email-display').innerText = email.split('@')[0];

                    const inputCred = document.getElementById('h-credential');
                    inputCred.placeholder = (data.type === 'TEAM') ? "Senha Admin" : "Código";
                    inputCred.focus();
                } else {
                    alert(data.error || "E-mail não encontrado.");
                }
            } catch (e) { console.error(e); }
        }

        async function h_realizarLogin() {
            const email = document.getElementById('h-email').value;
            const credential = document.getElementById('h-credential').value.trim();

            try {
                const res = await fetch('/login', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ email: email, codigo: credential })
                });
                const data = await res.json();

                if (res.ok && data.success) {
                    window.location.href = data.redirect;
                } else {
                    alert(data.error || data.message || "Credenciais inválidas.");
                }
            } catch (e) { console.error(e); }
        }

        function h_voltar() {
            document.getElementById('h-step-1').style.display = 'flex';
            document.getElementById('h-step-2').style.display = 'none';
        }

    </script>


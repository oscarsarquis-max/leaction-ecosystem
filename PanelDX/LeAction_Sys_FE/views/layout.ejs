<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'LeAction Panel' %></title>
    <% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
    <meta name="description" content="<%= metaDescription %>">
    <% } %>
    <% if (typeof metaKeywords !== 'undefined' && metaKeywords) { %>
    <meta name="keywords" content="<%= metaKeywords %>">
    <% } %>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/password-toggle.css?v=2">
    <% if (typeof pageStylesheets !== 'undefined' && pageStylesheets && pageStylesheets.length) { %>
    <% pageStylesheets.forEach(function(href) { %>
    <link rel="stylesheet" href="<%= href %>">
    <% }); %>
    <% } else if (typeof pageStylesheet !== 'undefined' && pageStylesheet) { %>
    <link rel="stylesheet" href="<%= pageStylesheet %>">
    <% } %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

    <script>
        const API_BASE_URL = '<%= typeof API_BASE_URL !== "undefined" ? API_BASE_URL : "" %>';
    </script>

    <style>
        :root {
            --sidebar-bg: #111827;
            --header-bg: #4A2E80;
            --header-gradient: linear-gradient(90deg, #2d1555 0%, #4A2E80 38%, #6c5ce7 72%, #9d8df2 100%);
            --header-gradient-3d: linear-gradient(180deg, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0.05) 22%, rgba(0, 0, 0, 0) 48%, rgba(0, 0, 0, 0.28) 100%), var(--header-gradient);
            --header-shadow-3d:
                inset 0 1px 0 rgba(255, 255, 255, 0.28),
                inset 0 -2px 0 rgba(0, 0, 0, 0.22),
                0 3px 0 #1a0d33,
                0 6px 14px rgba(26, 13, 51, 0.45),
                0 12px 28px rgba(45, 21, 85, 0.38);
            --footer-gradient-3d: linear-gradient(0deg, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.04) 24%, rgba(0, 0, 0, 0) 52%, rgba(0, 0, 0, 0.26) 100%), var(--header-gradient);
            --footer-shadow-3d:
                inset 0 2px 0 rgba(0, 0, 0, 0.24),
                inset 0 -1px 0 rgba(255, 255, 255, 0.26),
                0 -3px 0 #1a0d33,
                0 -6px 14px rgba(26, 13, 51, 0.45),
                0 -12px 28px rgba(45, 21, 85, 0.38);
            --accent-violet: #6c5ce7;
            --accent-blue: #60a5fa;
            --accent-gold: #d97706;
            --text-muted: #9ca3af;
            --sidebar-width: 260px;
            --sidebar-width-collapsed: 70px;
        }

        /* Acessibilidade / SEO — conteúdo legível por leitores de tela e crawlers, oculto visualmente */
        .sr-only,
        .visually-hidden {
            position: absolute !important;
            width: 1px !important;
            height: 1px !important;
            padding: 0 !important;
            margin: -1px !important;
            overflow: hidden !important;
            clip: rect(0, 0, 0, 0) !important;
            white-space: nowrap !important;
            border: 0 !important;
        }

        /* GERAL */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background: #f3f4f6; }
        main { display: flex; min-height: 100vh; padding-top: 60px; }

        /* HEADER */
        .main-header {
            position: fixed; top: 0; left: 0; width: 100%; height: 60px;
            background: var(--header-gradient-3d);
            color: white; z-index: 1000;
            display: flex; align-items: center; padding: 0 20px; box-sizing: border-box;
            border-bottom: 2px solid rgba(20, 10, 40, 0.9);
            box-shadow: var(--header-shadow-3d);
            isolation: isolate;
        }
        .main-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.16) 0%, transparent 38%);
            pointer-events: none;
            z-index: 0;
        }
        .main-header::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            bottom: -1px;
            height: 4px;
            background: linear-gradient(90deg, rgba(0, 0, 0, 0.45) 0%, rgba(255, 255, 255, 0.1) 50%, rgba(0, 0, 0, 0.4) 100%);
            pointer-events: none;
            z-index: 0;
            opacity: 0.85;
        }
        .main-header > div {
            position: relative;
            z-index: 1;
            width: 100%;
        }
        .main-header h2,
        .main-header .header-logo {
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.35);
        }
        .main-header .header-logo {
            box-shadow:
                inset 0 1px 0 rgba(255, 255, 255, 0.35),
                0 3px 8px rgba(0, 0, 0, 0.35);
        }

        /* FOOTER — mesmo padrão 3D do header (espelhado) */
        .main-footer {
            position: relative;
            background: var(--footer-gradient-3d);
            color: #f8fafc;
            text-align: center;
            padding: 14px 20px;
            margin-top: auto;
            border-top: 2px solid rgba(20, 10, 40, 0.9);
            box-shadow: var(--footer-shadow-3d);
            isolation: isolate;
        }
        .main-footer::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(0deg, rgba(255, 255, 255, 0.12) 0%, transparent 42%);
            pointer-events: none;
            z-index: 0;
        }
        .main-footer::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            top: -1px;
            height: 4px;
            background: linear-gradient(90deg, rgba(0, 0, 0, 0.45) 0%, rgba(255, 255, 255, 0.1) 50%, rgba(0, 0, 0, 0.4) 100%);
            pointer-events: none;
            z-index: 0;
            opacity: 0.85;
        }
        .main-footer p {
            margin: 0;
            position: relative;
            z-index: 1;
            font-size: 0.88rem;
            font-weight: 500;
            letter-spacing: 0.02em;
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.35);
        }

        /* LOGIN COMPACTO HEADER */
        .login-header-form { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.05); padding: 5px 15px; border-radius: 50px; }
        .login-header-form input { background: white; border: none; border-radius: 20px; padding: 6px 12px; font-size: 0.85em; width: 160px; }
        .btn-violet-dark { background: var(--accent-violet); color: white; border: none; border-radius: 20px; padding: 6px 15px; cursor: pointer; font-weight: bold; font-size: 0.85em; transition: 0.3s; }
        .btn-violet-dark:hover { background: #5a4bcf; }

        .header-right {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-left: auto;
        }

        .header-logout-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid rgba(248, 113, 113, 0.85);
            background: rgba(220, 38, 38, 0.22);
            color: #fecaca;
            font-size: 0.88rem;
            font-weight: 700;
            text-decoration: none;
            white-space: nowrap;
            transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        }
        .header-logout-btn:hover {
            background: #dc2626;
            border-color: #fca5a5;
            color: #fff;
            transform: translateY(-1px);
        }
        .header-logout-btn i {
            font-size: 1rem;
        }

        /* SIDEBAR MODERNA - ESTRUTURA PRESERVADA */
        .sidebar-menu {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            position: fixed;
            top: 60px;
            height: calc(100vh - 60px);
            overflow-x: hidden;
            overflow-y: auto;
            z-index: 50;
            display: flex;
            flex-direction: column;
            transition: width 0.3s ease;
        }
        .sidebar-menu ul {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }
        body.sidebar-collapsed .sidebar-menu {
            width: var(--sidebar-width-collapsed);
        }
        body.sidebar-collapsed .sidebar-menu .sidebar-label,
        body.sidebar-collapsed .sidebar-menu hr,
        body.sidebar-collapsed .sidebar-menu .submenu,
        body.sidebar-collapsed .sidebar-menu #btnDouradoLayout span {
            display: none !important;
        }
        body.sidebar-collapsed .sidebar-menu a {
            justify-content: center !important;
            padding: 12px 0 !important;
            font-size: 0 !important;
        }
        body.sidebar-collapsed .sidebar-menu a i {
            font-size: 1.1rem !important;
            margin-right: 0 !important;
        }
        body.sidebar-collapsed .sidebar-menu li[style*="padding: 0 15px"] {
            padding: 0 8px !important;
        }
        body.sidebar-collapsed .sidebar-menu #btnDouradoLayout {
            padding: 10px 8px !important;
            justify-content: center !important;
        }
        body.sidebar-collapsed .sidebar-menu #btnDouradoLayout i {
            margin-right: 0 !important;
        }

        /* UNIFORMIZAÇÃO DOS LINKS (AQUI ESTÁ A MÁGICA) */
        .sidebar-menu a {
            display: flex !important;
            align-items: center !important;
            padding: 10px 20px !important;
            text-decoration: none !important;
            font-size: 0.9rem !important;
            transition: 0.2s !important;
            /* FORÇA O CINZA EM TODOS OS TEXTOS, IGNORANDO O STYLE INLINE */
            color: var(--text-muted) !important;
            font-weight: 500 !important;
        }

        .sidebar-menu a:hover {
            background: #1f2937 !important;
            color: white !important;
        }

        /* Grupos do lead: itens em bold, subitens normal, sem ícones */
        .sidebar-menu .nav-group > a.submenu-toggle {
            font-weight: 700 !important;
            letter-spacing: 0.01em;
            color: #e5e7eb !important;
        }
        .sidebar-menu .nav-group .submenu a {
            font-weight: 400 !important;
            font-size: 0.84rem !important;
            padding: 8px 16px 8px 28px !important;
            color: #9ca3af !important;
        }
        .sidebar-menu .nav-group .submenu a.is-active {
            color: #fff !important;
            background: rgba(79, 172, 254, 0.14) !important;
            font-weight: 600 !important;
        }
        .sidebar-menu .nav-group .submenu a:hover {
            color: #fff !important;
        }
        body.sidebar-collapsed .sidebar-menu .nav-group > a.submenu-toggle {
            font-size: 0.62rem !important;
            padding: 10px 4px !important;
            justify-content: center !important;
            text-align: center;
            line-height: 1.15;
        }
        body.sidebar-collapsed .sidebar-menu .nav-group > a.submenu-toggle .sidebar-label {
            display: block !important;
            white-space: normal;
            font-size: 0.58rem !important;
        }

        /* Sem ícones Font Awesome na sidebar (exceto seletor dedicado do chevron CSS) */
        #sidebar-menu i,
        #sidebar-menu [class^="fa-"],
        #sidebar-menu [class*=" fa-"] {
            display: none !important;
            width: 0 !important;
            height: 0 !important;
            margin: 0 !important;
            font-size: 0 !important;
        }

        .sidebar-menu .nav-link-italic {
            font-style: italic !important;
            font-weight: 400 !important;
            font-size: 0.82rem !important;
            color: #9ca3af !important;
            padding-top: 14px !important;
            padding-bottom: 8px !important;
        }
        .sidebar-menu .nav-link-italic:hover {
            color: #e5e7eb !important;
        }
        .sidebar-menu .nav-link-italic i {
            display: none !important;
        }
        body.sidebar-collapsed .sidebar-menu .nav-link-italic .sidebar-label {
            display: none !important;
        }

        /* SUBMENUS — ocultos até clicar no item superior */
        .sidebar-menu .menu-item > .submenu {
            display: none !important;
            padding-left: 8px !important;
            background: rgba(0, 0, 0, 0.2);
            margin: 0;
            list-style: none;
            overflow: hidden;
        }
        .sidebar-menu .menu-item.is-open > .submenu {
            display: block !important;
        }
        .sidebar-menu .menu-item.has-children > a.submenu-toggle {
            cursor: pointer;
            position: relative;
            padding-right: 36px !important;
        }
        .sidebar-menu .menu-item.has-children > a.submenu-toggle::after {
            content: '';
            position: absolute;
            right: 18px;
            top: 50%;
            width: 6px;
            height: 6px;
            border-right: 1.5px solid rgba(255, 255, 255, 0.45);
            border-bottom: 1.5px solid rgba(255, 255, 255, 0.45);
            transform: translateY(-60%) rotate(45deg);
            transition: transform 0.2s ease, border-color 0.2s ease;
        }
        .sidebar-menu .menu-item.is-open > a.submenu-toggle::after {
            transform: translateY(-20%) rotate(225deg);
            border-color: rgba(255, 255, 255, 0.85);
        }
        .sidebar-menu .menu-item.is-open > a.submenu-toggle {
            background: #1f2937 !important;
            color: #fff !important;
        }
        .sidebar-menu .submenu a {
            font-size: 0.85rem !important;
        }
        body.sidebar-collapsed .sidebar-menu .menu-item.has-children > a.submenu-toggle::after {
            display: none;
        }

        /* BOTÃO GÊNESE (MANTÉM O ESTILO DOURADO) */
        #btnDouradoLayout {
            background: linear-gradient(135deg, #FFD700 0%, #B8860B 100%) !important;
            color: #000 !important;
            border: 1px solid #DAA520 !important;
            border-radius: 6px !important;
            padding: 10px !important;
            font-weight: bold !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
        }

        /* MODAL E CONTEÚDO */
        .modal { display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); }
        .modal-content { background: white; padding: 30px; border-radius: 12px; width: 800px; max-width: 90%; max-height: 90vh; overflow-y: auto; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); }

        /* Ações CRUD — ícones sem moldura; editar laranja, excluir vermelho */
        .action-btn {
            border: none !important;
            background: transparent !important;
            box-shadow: none !important;
            outline: none !important;
            padding: 4px;
            margin: 0 2px;
            line-height: 1;
            border-radius: 0;
            cursor: pointer;
            font-size: 1.1em;
            appearance: none;
            -webkit-appearance: none;
            transition: color 0.15s ease, transform 0.15s ease;
        }
        .action-btn:hover,
        .action-btn:focus,
        .action-btn:focus-visible,
        .action-btn:active {
            background: transparent !important;
            box-shadow: none !important;
            outline: none !important;
        }
        .action-btn:hover {
            transform: scale(1.08);
        }
        .action-btn.btn-edit,
        .action-btn.btn-edit i {
            color: #e67e22 !important;
        }
        .action-btn.btn-edit:hover,
        .action-btn.btn-edit:hover i {
            color: #d35400 !important;
        }
        .action-btn.btn-delete,
        .action-btn.btn-delete i {
            color: #e74c3c !important;
        }
        .action-btn.btn-delete:hover,
        .action-btn.btn-delete:hover i {
            color: #c0392b !important;
        }
        .content {
            flex-grow: 1;
            margin-left: var(--sidebar-width);
            padding: 30px;
            box-sizing: border-box;
            transition: margin-left 0.3s ease;
        }
        body.sidebar-collapsed .content {
            margin-left: var(--sidebar-width-collapsed);
        }
        .context-bar__inner {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-left: var(--sidebar-width);
            transition: margin-left 0.3s ease;
        }
        body.sidebar-collapsed .context-bar__inner {
            margin-left: var(--sidebar-width-collapsed);
        }

        /* Ícones Font Awesome ocultos na sidebar — tipografia só texto */
        .sidebar-menu i,
        .sidebar-menu [class^="fa-"],
        .sidebar-menu [class*=" fa-"] {
            display: none !important;
            width: 0 !important;
            height: 0 !important;
            margin: 0 !important;
            font-size: 0 !important;
            color: transparent !important;
        }

        /* Isso remove qualquer cor específica que tenha sobrado nos links */
        .sidebar-menu a {
            color: var(--text-muted) !important;
        }

        /* Remove o espaçamento excessivo quando a barra de contexto está ativa */
        .context-bar + main .content {
            padding-top: 10px !important;
        }

        /* Garante que o main não empurre o conteúdo para baixo se a barra já estiver lá */
        main.with-context {
            padding-top: 0 !important;
        }

        /* 🏛️ Modo Gestor da Rede — cockpit com visual executivo preservado */
        body.holding-mode main {
            background: #f4f2f8 !important;
        }
        body.holding-mode .context-bar {
            display: none !important;
        }
        body.holding-mode .content {
            padding: 20px 0 0 0 !important;
            margin-left: var(--sidebar-width);
            background: #f4f2f8 !important;
            min-height: calc(100vh - 60px);
        }
        body.holding-mode.sidebar-collapsed .content {
            margin-left: var(--sidebar-width-collapsed);
        }
        body.holding-mode .header-logo {
            height: 46px !important;
            margin-top: 0 !important;
            border-width: 2px;
        }
        body.holding-mode .content h1,
        body.holding-mode .content #cockpit-page h1 {
            border-bottom: none !important;
            padding-bottom: 0 !important;
            margin-bottom: 0 !important;
        }
        body.holding-mode .content #cockpit-page .cockpit-footer,
        body.holding-mode .content #cockpit-page .cockpit-footer p,
        body.holding-mode .content #cockpit-page .cockpit-footer strong {
            color: #475569 !important;
        }
        body.holding-mode .content #cockpit-page .cockpit-footer strong,
        body.holding-mode .content #cockpit-page .cockpit-footer-gestor {
            color: #312e81 !important;
        }
        body.holding-mode .sidebar-menu a[href="/cockpit-rede"] {
            color: #fbbf24 !important;
            font-weight: 700 !important;
        }

        /* Cockpit da Rede — enquadrado na área .content (Sysadmin e Holding) */
        .content .main-content #cockpit-page {
            min-height: auto !important;
        }
        .content .main-content #cockpit-page .cockpit-header h1 {
            border-bottom: none !important;
            padding-bottom: 0 !important;
            margin-bottom: 10px !important;
        }

        /* Sidebar retrátil — prioridade máxima sobre style.css legado */
        body.sidebar-collapsed .sidebar-menu,
        #sidebar-menu.is-collapsed {
            width: 70px !important;
        }
        body.sidebar-collapsed .content,
        body.sidebar-collapsed main .content {
            margin-left: 70px !important;
        }
        body.sidebar-collapsed .context-bar__inner {
            margin-left: 70px !important;
        }
        body.holding-mode.sidebar-collapsed .content {
            margin-left: 70px !important;
        }
        body.sidebar-collapsed .sidebar-menu a,
        #sidebar-menu.is-collapsed a {
            font-size: 0 !important;
            justify-content: center !important;
            padding: 12px 0 !important;
        }
        body.sidebar-collapsed .sidebar-menu a i,
        #sidebar-menu.is-collapsed a i {
            font-size: 1.1rem !important;
            margin-right: 0 !important;
            width: auto !important;
        }
        body.sidebar-collapsed .sidebar-menu .submenu,
        body.sidebar-collapsed .sidebar-menu hr,
        body.sidebar-collapsed .sidebar-menu #btnDouradoLayout span,
        body.sidebar-collapsed .sidebar-menu .sidebar-label,
        #sidebar-menu.is-collapsed .submenu,
        #sidebar-menu.is-collapsed hr,
        #sidebar-menu.is-collapsed #btnDouradoLayout span,
        #sidebar-menu.is-collapsed .sidebar-label {
            display: none !important;
        }

        .header-sidebar-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            margin-right: 4px;
            border: 1px solid rgba(255, 255, 255, 0.28);
            border-radius: 8px;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.04) 100%);
            color: #f8fafc;
            cursor: pointer;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22), 0 2px 4px rgba(0, 0, 0, 0.25);
            transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
        }
        .header-sidebar-toggle:hover {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0.08) 100%);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3), 0 3px 8px rgba(0, 0, 0, 0.3);
        }

    </style>
</head>
<body class="<%= locals.isHolding ? 'holding-mode' : '' %>">
<script>
(function () {
    try {
        if (localStorage.getItem('sidebarState') === 'collapsed') {
            document.body.classList.add('sidebar-collapsed');
            var sb = document.getElementById('sidebar-menu');
            if (sb) sb.classList.add('is-collapsed');
        }
    } catch (e) { /* ignore */ }
})();
</script>


<header class="main-header">
    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">

        <div style="display: flex; align-items: center; gap: 8px;">
            <button type="button" class="header-sidebar-toggle" data-sidebar-toggle aria-label="Recolher menu lateral" title="Recolher menu" aria-expanded="true">
                <i class="fas fa-bars" aria-hidden="true"></i>
            </button>
            <a href="/" title="Home / Dashboard" style="color: white; text-decoration: none; padding: 5px; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-home" style="font-size: 1.2rem;"></i>
                <h2 style="margin: 0; font-size: 1.1rem; white-space: nowrap;">Panel DX (<i>LeActionSys</i>)</h2>
            </a>
        </div>

        <div class="header-right">

            <% if (locals.isLoggedIn) { %>
                <a href="/logout" class="header-logout-btn" title="Encerrar sessão e sair do Panel DX">
                    <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
                    <span>Sair</span>
                </a>
            <% } else { %>
                <div class="login-header-form" id="header-login-container">

                    <i class="fas fa-sign-in-alt" style="color: rgba(255,255,255,0.7); margin-right: 5px;"></i>

                    <div id="h-step-1" style="display: flex; gap: 8px;">
                        <input type="email" id="h-email" placeholder="Seu e-mail corporativo">
                        <button type="button" onclick="h_verificarEmail()" class="btn-login-header btn-violet-dark">Próximo</button>
                    </div>

                    <div id="h-step-2" style="display: none; gap: 8px; align-items: center;">
                        <span id="h-email-display" style="color: white; font-size: 0.8em; font-weight: bold; margin-right: 5px;"></span>

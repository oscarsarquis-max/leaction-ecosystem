                <div class="fab-success-icon"><i class="fas fa-circle-check"></i></div>
                <p style="font-size:0.95rem; color:#333; font-weight:700; margin:0 0 14px 0;">Tudo pronto! Uma nova Sprint foi alocada no seu Backlog.</p>
                <a href="/projeto/sprint-atual" class="fab-btn-primary" style="display:inline-block; text-decoration:none; text-align:center; box-sizing:border-box;">
                    <i class="fas fa-table-columns"></i> Ir para o Quadro Kanban
                </a>
            </div>
        </div>
    </div>

    <script>
        (function() {
            function fabSetState(stateId) {
                ['fab-state-input', 'fab-state-loading', 'fab-state-success'].forEach(id => {
                    document.getElementById(id).classList.toggle('active', id === stateId);
                });
            }
            window.fabToggle = function() {
                const pop = document.getElementById('fab-consultor-popover');
                const abrindo = !pop.classList.contains('open');
                if (!abrindo && typeof window.pararDitadoPanelDx === 'function') {
                    window.pararDitadoPanelDx();
                }
                pop.classList.toggle('open');
                if (pop.classList.contains('open')) fabSetState('fab-state-input');
            };
            window.fabGerarSprint = async function() {
                if (typeof window.pararDitadoPanelDx === 'function') window.pararDitadoPanelDx();
                const txt = document.getElementById('fab-textarea').value.trim();
                if (txt.length < 10) { alert('Conte um pouco mais sobre o seu desafio (mínimo 10 caracteres).'); return; }

                const idClie = (_leadData && (_leadData.id_clie || _leadData.id)) || null;
                const idMatu = (_leadData && _leadData.id_matu) || null;
                if (!idClie || !idMatu) { alert('Não foi possível identificar seu contexto. Recarregue a página.'); return; }

                fabSetState('fab-state-loading');
                try {
                    const res = await fetch('/api/consultor-interno/gerar-sprint-avulsa', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ problema: txt, id_clie: idClie, id_matu: idMatu })
                    });
                    const json = await res.json();
                    if (res.ok && json.success) {
                        fabSetState('fab-state-success');
                    } else {
                        throw new Error(json.error || 'Falha ao gerar a sprint.');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Não foi possível gerar a sprint agora. Tente novamente em instantes.');
                    fabSetState('fab-state-input');
                }
            };
        })();
    </script>

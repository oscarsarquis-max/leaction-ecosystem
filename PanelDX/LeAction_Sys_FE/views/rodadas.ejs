<div id="rodadas-page">
    <h1>Gerenciar Rodadas de Questionários TD</h1>

    <h2>Adicionar Nova Rodada</h2>
    <form id="rodadas-form">
        <div class="form-group">
            <label for="id_dime">Dimensão:</label>
            <input type="text" id="id_dime" name="id_dime" required>
        </div>
        <div class="form-group">
            <label for="name_roun">Nome Rodada:</label>
            <input type="text" id="name_roun" name="name_roun" required>
        </div>
        <div class="form-group">
            <label for="desc_roun">Descrição da Rodada:</label>
            <textarea id="desc_roun" name="desc_roun"></textarea>
        </div>
        <div class="form-group">
            <label for="ordr_roun">Ordem Rodada:</label>
            <input type="text" id="ordr_roun" name="ordr_roun" required>
        </div>

        <button type="submit" id="saveOrAddButton">Adicionar</button>

    </form>

    <h2>Buscar Rodadas de Iteração</h2>
    <div class="search-container">
        <input type="text" id="search-input" placeholder="Digite 5+ caracteres para buscar...">
        <button id="search-btn">Buscar</button>
    </div>

    <h2>Lista de Rodadas</h2>
    <table id="rodadas-table">
        <thead>
        <tr>
            <th>ID</th>
            <th>Dimensão</th>
            <th>Nome Rodada</th>
            <th>Descrição da Rodada</th>
            <th>Ordem Rodada</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td colspan="5">Use a busca acima para encontrar rodadas de iteração.</td>
        </tr>
        </tbody>
    </table>
</div>

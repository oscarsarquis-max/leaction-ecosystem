# =====================================================================
# Prodinx — Variáveis de Ambiente
# Copie para .env na raiz do projeto e preencha com valores reais.
# NUNCA faça commit do arquivo .env preenchido.
# =====================================================================

# ---------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# ---------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Cmgv6190!@
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=prodinx

# ---------------------------------------------------------------------
# PORTAS
# ---------------------------------------------------------------------
PORT=3002

# ---------------------------------------------------------------------
# AWS — Bedrock (Claude), mesmo padrão do PanelDX
# ---------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIA_sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_access_key
AWS_DEFAULT_REGION=us-east-1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# 1 (default) | 0 para desativar verificação SSL em dev
BEDROCK_SSL_VERIFY=1

# ---------------------------------------------------------------------
# INGESTÃO JSON (servicos/)
# ---------------------------------------------------------------------
# JSON_IMPORT_DIR=
# JSON_PROCESSED_DIR=
# JSON_FAILED_DIR=
# DISABLE_JSON_WATCHER=0

# Banco de dados (desenvolvimento local)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=MAtivas
DB_USER=postgres
DB_PASSWORD=
DB_SSLMODE=disable

# API Flask
PORT=5001
FLASK_DEBUG=1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Área administrativa
ADMIN_PASSWORD=altere-esta-senha
JWT_SECRET=altere-este-segredo-jwt
JWT_EXPIRES_HOURS=24

# SMTP (legado — opcional; o envio padrão usa Amazon SES)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@metodologiasinovativas.com.br
# SMTP_FROM_NAME=Metodologias Inov-ativas
SITE_URL=https://metodologiasinovativas.com.br

# Amazon SES (envio de roteiro — região us-east-2 / Ohio)
# O remetente padrão é roteiro@metodologiasinovativas.com.br (domínio verificado).
# Em produção, use credenciais AWS via IAM role da EC2 ou variáveis padrão do boto3.
# AWS_DEFAULT_REGION=us-east-2
# EMAIL_LOGO_URL=https://metodologiasinovativas.com.br/brand/logo.png
# EMAIL_CAPA_LIVRO_URL=https://metodologiasinovativas.com.br/assets/capa-livro.png

# inove4us — Postgres local (Docker leaction_db), DB dedicado
# Bootstrap: infra/scripts/bootstrap-inove4us-db.ps1
# Credenciais iguais ao PanelDX; banco separado (năo usa LeAction_SysF).

DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=inove4us
DB_USER=admin
DB_PASS=password123
DB_SSLMODE=disable

FLASK_PORT=5010
SECRET_KEY=troque-esta-chave-em-producao
CORS_ORIGINS=http://localhost:5174
FRONTEND_ORIGIN=http://localhost:5174

# 1 = loga o código no servidor (local). 0 = só SES.
EMAIL_DEV_MODE=1
EMAIL_SENDER=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


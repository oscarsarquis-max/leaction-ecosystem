# inove4us � Postgres local (Docker leaction_db), DB dedicado
# Bootstrap: infra/scripts/bootstrap-inove4us-db.ps1
# Credenciais iguais ao PanelDX; banco separado (n�o usa LeAction_SysF).

DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=inove4us
DB_USER=admin
DB_PASS=Cmgv6190!@
DB_SSLMODE=disable

FLASK_PORT=5010

# Bedrock / wizard (fase 1 ranking + fase 2 cards em paralelo)
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# WIZARD_BEDROCK_MODEL_ID=
# BEDROCK_MAX_TOKENS=2500
# BEDROCK_CARDS_MAX_TOKENS=3500
# WIZARD_REF_LIMIT=3
SECRET_KEY=troque-esta-chave-em-producao
CORS_ORIGINS=http://localhost:5174
FRONTEND_ORIGIN=http://localhost:5174

# 1 = loga o c�digo no servidor (local). 0 = s� SES.
EMAIL_DEV_MODE=1
EMAIL_SENDER=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Action Hub � entitlements (mesmo valor de app_registry.webhook_secret)
ACTION_HUB_APP_ID=inove4us
ACTION_HUB_APP_SECRET=
ACTION_HUB_API_URL=http://localhost:4001
# Secret JWT do outbox Action Hub (= app_registry.webhook_secret)
ACTIONHUB_WEBHOOK_SECRET=
# Action-Sponge (mesmo CRM_TRACKING_SECRET do leaction-platform)
CRM_TRACKING_SECRET=
ACTION_HUB_CRM_TRACKING_URL=http://127.0.0.1:4001/api/crm/tracking/receber
# SKU real do catalog_plans quando o FE manda o alias golive-50
ACTION_HUB_DEFAULT_SKU=
# Extrato no cartão (máx. 22 chars) — branding white-label da demandante
MP_STATEMENT_DESCRIPTOR=INOVE4US
FRONTEND_ORIGIN=http://localhost:5174


# Gatekeeper (mesmo padrao mudaedu/PanelDX)
# PRODUCTION_MASTER_KEY=
# GATEKEEPER_ALLOW_DEV=true

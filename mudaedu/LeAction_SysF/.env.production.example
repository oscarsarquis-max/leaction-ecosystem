# =====================================================================
# PanelDX Backend (Flask + workers) — PRODUÇÃO
# Copie para LeAction_SysF/.env nas task definitions ECS ou Secrets Manager.
# NUNCA commitar o .env preenchido.
# =====================================================================

# --- AWS RDS (paneldx-database) ---
DB_TYPE=postgres
DB_HOST=[ENDPOINT_RDS_PANELDX_DATABASE]
DB_PORT=5432
DB_NAME=LeAction_SysF
DB_USER=[USER_RDS]
DB_PASS=[PASSWORD_RDS]
DB_SSLMODE=require

FLASK_PORT=5000

# --- AWS (Bedrock, SES, S3) — preferir IAM role da task ECS em producao ---
AWS_DEFAULT_REGION=us-east-2
BEDROCK_REGION=us-east-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# AWS_ACCESS_KEY_ID=        # omitir se usar task role
# AWS_SECRET_ACCESS_KEY=

FLASK_SECRET_KEY=[GERE_SEGREDO_FORTE]

# --- E-mail (SES) ---
MAIL_USERNAME=no-reply@mudaedu.com.br
EMAIL_SENDER=consultant@mudaedu.com.br

# --- URLs publicas ---
PANELDX_PUBLIC_URL=https://mudaedu.com.br
MUDAEDU_PUBLIC_URL=https://mudaedu.com.br

# --- Integracao Action Hub ---
HUB_JWT_SECRET=[MESMO_VALOR_DO_JWT_SECRET_DO_ACTION_HUB]
HUB_API_URL=https://api.actionhub.com.br
HUB_PUBLIC_URL=https://actionhub.com.br
HUB_WEBHOOK_URL=https://mudaedu.com.br/api/hub/payment-webhook

# Microsservico de calculo (rede interna ECS, se aplicavel)
# CALC_MICROSERVICE_URL=http://calc-service:5001

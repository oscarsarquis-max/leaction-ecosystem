<div class="main-content" id="presurvey-report">
    <%
        /* TRAVA DE SEGURANÇA E MAPEAMENTO SEGURO
           Buscamos os dados diretamente de dentro de preData onde o seu log provou
           que as informações de hover (desc_b e desc_d) e blocos residem.
        */
        var ia = (typeof insights_ia !== 'undefined' && insights_ia && insights_ia.ambicao) ? insights_ia : ((preData && preData.json_insights && preData.json_insights.recomendas) ? preData.json_insights.recomendas : {});
        var setor = (typeof refSetor !== 'undefined') ? refSetor : (locals.refSetor || {});
        var scores_domas = (preData && preData.json_insights && preData.json_insights.scores_dominios) ? preData.json_insights.scores_dominios : {};
        var totalPresurvey = 28;
    %>

    <style>
        .report-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            padding: 40px;
            margin-bottom: 30px;
            border-top: 6px solid #d4af37;
        }
        .dimension-badge {
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: bold;
            padding: 4px 12px;
            border-radius: 50px;
            background: #e0f2fe;
            color: #0369a1;
        }
        .insight-box {
            padding: 20px;
            border-radius: 12px;
            height: 100%;
            transition: transform 0.3s;
        }
        .insight-box:hover { transform: translateY(-5px); }
        .bg-gap { background: #fff8e1; border-left: 5px solid #f1c40f; }
        .bg-strength { background: #f0fdf4; border-left: 5px solid #22c55e; }
        .bg-urgent { background: #fef2f2; border-left: 5px solid #ef4444; }

        /* Estilos para Recomendações Dinâmicas */
        .bg-ambicao { background: #eff6ff; border-left: 5px solid #3b82f6; }
        .bg-mercado { background: #fff1f2; border-left: 5px solid #e11d48; }
        .tech-info { cursor: help; border-bottom: 1px dashed #94a3b8; }

        .presurvey-chart-wrap {
            position: relative;
            width: 100%;
        }
        .presurvey-chart-wrap--dims {
            height: 320px;
            min-height: 280px;
        }
        .presurvey-chart-wrap--domas {
            height: 380px;
            min-height: 320px;
        }
        .presurvey-chart-wrap canvas {
            display: block;
            width: 100% !important;
            height: 100% !important;
            max-height: none;
        }
        @media (max-width: 960px) {
            .presurvey-report-grid {
                grid-template-columns: 1fr !important;
            }
        }
        @media print {
            .sidebar-menu, .main-header, .context-bar, .btn-print { display: none !important; }
            .report-card { box-shadow: none; border: 1px solid #ddd; }
        }
    </style>

    <div id="dados-dominios-ponte" data-scores="<%- JSON.stringify(scores_domas).replace(/"/g, '&quot;') %>" style="display: none;"></div>

    <div class="report-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; border-bottom: 1px solid #f1f5f9; padding-bottom: 20px;">
            <div>
                <h1 style="color: #1e293b; margin: 0; font-size: 2rem;">Diagnóstico Preliminar de Maturidade Digital</h1>
                <p style="color: #64748b; font-size: 0.9rem; margin: 6px 0 0;">
                    Avaliação <strong>restrita</strong> com <%= totalPresurvey %> questões da 1ª aba — amostra reduzida para um primeiro panorama. O relatório completo (162 indicadores) será liberado após contratar o plano.
                </p>
                <p style="color: #64748b; font-size: 1.1rem; margin: 8px 0;">
                    <i class="fas fa-university"></i> <%= lead.empresa_clie %>
                </p>
            </div>
            <div style="text-align: right;">
                <div style="text-align: center; margin: 30px 0;">
                    <button id="exportPdfBtn"
                            style="
                                padding: 15px 40px;
                                font-size: 1.1rem;
                                font-weight: 800;
                                cursor: pointer;
                                background: linear-gradient(135deg, #f1c40f 0%, #d4af37 100%);
                                color: #000000;
                                border-radius: 50px;
                                border: none;
                                box-shadow: 0 4px 15px rgba(0,0,0,0.15);
                                display: inline-flex;
                                align-items: center;
                                gap: 10px;
                                transition: all 0.3s ease;
                            "
                            onmouseover="this.style.transform='scale(1.03)'; this.style.boxShadow='0 6px 20px rgba(0,0,0,0.2)';"
                            onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.15)';"
                    >
                        <i class="fas fa-file-pdf"></i> EXPORTAR RELATÓRIO PARA PDF
                    </button>
                </div>
                <div class="dimension-badge" style="display: block;">Relatório preliminar</div>
            </div>
        </div>

        <div class="presurvey-report-grid" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; margin-bottom: 40px;">

            <div style="background: #f8fafc; padding: 30px; border-radius: 20px; border: 1px solid #e2e8f0; display: flex; flex-direction: column; gap: 30px;">
                <div>
                    <h3 style="text-align: center; color: #334155; margin-bottom: 20px;">Equilíbrio Competitivo (P vs F vs Mercado)</h3>
                    <div class="presurvey-chart-wrap presurvey-chart-wrap--dims">
                        <canvas id="radarChartPresurvey"></canvas>
                    </div>
                </div>
                <div style="border-top: 1px solid #e2e8f0; padding-top: 20px;">
                    <h3 style="text-align: center; color: #334155; margin-bottom: 20px;">Visão Detalhada por Domínios de Transformação</h3>
                    <div class="presurvey-chart-wrap presurvey-chart-wrap--domas">
                        <canvas id="radarChartDominios"></canvas>
                    </div>

                    <div id="legenda-dimensoes-radar" style="margin-top: 20px; background: #f3e8ff; padding: 15px; border-radius: 12px; border: 1px solid #d8b4fe; font-size: 0.8rem; line-height: 1.5; color: #5b21b6;">
                        <span style="font-weight: 800; color: #7060F0; display: block; margin-bottom: 8px; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">
                            <i class="fas fa-th-large"></i> Guia de Referência das Dimensões:
                        </span>
                        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px 10px;">
                            <div><b>Estratégica:</b> Alinhamento Institucional</div>
                            <div><b>Humana:</b> Pessoas e Competências</div>
                            <div><b>Organizacional:</b> Estrutura e Processos</div>
                            <div><b>Pedagógica:</b> Práticas Educacionais</div>
                            <div><b>Tecnológica:</b> Infraestrutura e Ferramentas</div>
                        </div>
                    </div>

                    <div id="legenda-dominios-radar" style="margin-top: 12px; background: #ffffff; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; font-size: 0.8rem; line-height: 1.5; color: #475569;">
                        <span style="font-weight: 800; color: #1e293b; display: block; margin-bottom: 8px; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">
                            <i class="fas fa-map-signs"></i> Guia de Referência dos Domínios:
                        </span>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px 20px;">
                            <div><b>Dom 1:</b> Estratégia Digital</div>
                            <div><b>Dom 2:</b> Modelo de Negócio Digital</div>
                            <div><b>Dom 3:</b> Cultura de Inovação</div>
                            <div><b>Dom 4:</b> Cultura de Dados</div>
                            <div><b>Dom 5:</b> Cultura de Colaboração</div>
                            <div><b>Dom 6:</b> Governança Digital</div>
                            <div><b>Dom 7:</b> Plataformas Digitais</div>
                            <div><b>Dom 8:</b> Capacidades Digitais</div>
                            <div><b>Dom 9:</b> Métricas Digitais</div>
                        </div>
                    </div>
                </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 20px;">
                <div class="insight-box bg-strength">
                    <h4 style="margin: 0; color: #166534;"><i class="fas fa-shield-alt"></i> Maior Fortaleza</h4>
                    <p style="font-size: 1.2rem; font-weight: bold; margin: 10px 0; color: #064e3b;" id="strPilarForte">--</p>
                    <small style="color: #166534;">Este é o pilar que sustenta sua operação atual. Essa análise se baseia no comportamento da organização em relação às 5 dimensões de TD.</small>
                </div>

                <div class="insight-box bg-ambicao">
                    <h4 style="margin: 0; color: #1e40af; font-size: 0.85rem; text-transform: uppercase;">
                        <i class="fas fa-rocket"></i> Prioridade de Ambição
                    </h4>
                    <p style="font-size: 0.95rem; color: #1e3a8a; margin: 10px 0;">
                        Bloco: <strong class="tech-info" title="<%= (ia.ambicao && ia.ambicao.desc_b) || 'Ação prioritária baseada na ambição digital' %>">
                            <%= (ia.ambicao && ia.ambicao.bloco) || 'Definição Estratégica' %>
                        </strong>
                    </p>
                    <div style="background: #ffffff; padding: 10px; border-radius: 8px; border: 1px dashed #3b82f6;">
                        <span style="font-size: 0.65rem; color: #3b82f6; font-weight: 900; display: block;">AÇÃO SUGERIDA:</span>
                        <span class="tech-info" style="font-size: 0.95rem; font-weight: 800; color: #1e3a8a;" title="<%= (ia.ambicao && ia.ambicao.desc_d) || 'Detalhes do plano de ação' %>">
                            <%= (ia.ambicao && ia.ambicao.derv) || 'Plano de Ação Digital' %> <i class="fas fa-info-circle" style="font-size: 0.7rem;"></i>
                        </span>
                    </div>
                </div>

                <div class="insight-box bg-mercado">
                    <h4 style="margin: 0; color: #9f1239; font-size: 0.85rem; text-transform: uppercase;">
                        <i class="fas fa-chart-line"></i> Resposta ao Mercado
                    </h4>
                    <p style="font-size: 0.95rem; color: #881337; margin: 10px 0;">
                        Bloco: <strong class="tech-info" title="<%= (ia.mercado && ia.mercado.desc_b) || 'Foco em competitividade setorial' %>">
                            <%= (ia.mercado && ia.mercado.bloco) || 'Adequação Competitiva' %>
                        </strong>
                    </p>
                    <div style="background: #ffffff; padding: 10px; border-radius: 8px; border: 1px dashed #e11d48;">
                        <span style="font-size: 0.65rem; color: #e11d48; font-weight: 900; display: block;">AÇÃO RECOMENDADA:</span>
                        <span class="tech-info" style="font-size: 0.95rem; font-weight: 800; color: #881337;" title="<%= (ia.mercado && ia.mercado.desc_d) || 'Detalhes da ação sugerida' %>">
                            <%= (ia.mercado && ia.mercado.derv) || 'Sprint de Ajuste' %> <i class="fas fa-info-circle" style="font-size: 0.7rem;"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div style="border-top: 1px solid #f1f5f9; padding-top: 30px; margin-top: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3 style="color: #1e293b; margin: 0; font-weight: 800;">Análise Comparativa por Dimensão</h3>
                <span style="font-size: 0.8rem; color: #4c51bf; background: #eef2ff; padding: 6px 14px; border-radius: 20px; font-weight: 700; border: 1px solid #e0e7ff;">
                    <i class="fas fa-chart-line"></i> Benchmark: Setor Educação 2026
                </span>
            </div>

            <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px;">
                <%
                    const dimKeys = ['estrat', 'organiz', 'humana', 'pedag', 'tecno'];
                    const dimNames = ['Estratégica', 'Organizacional', 'Humana', 'Pedagógica', 'Tecnológica'];

                    dimNames.forEach((name, i) => {
                        const key = dimKeys[i];
                        const idDime = (i + 1).toString();

                        const valP = parseFloat(preData['score_' + key + '_p']) || 0;
                        const valF = parseFloat(preData['score_' + key + '_f']) || 0;
                        const clienteMedia = (valP + valF) / 2;

                        const mercadoMedia = parseFloat(setor[idDime]) || 0;
                        const gapMercado = clienteMedia - mercadoMedia;
                %>
                    <div style="text-align: center; padding: 20px 10px; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">

                        <span style="font-size: 0.7rem; color: #64748b; font-weight: 800; display: block; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px;">
                            <%= name %>
                        </span>

                        <div style="font-size: 1.8rem; font-weight: 900; color: #4c51bf; line-height: 1;">
                            <%= clienteMedia.toFixed(1) %>
                        </div>

                        <div style="margin: 10px 0 0; font-size: 0.72rem; color: #64748b; line-height: 1.5;">
                            <span style="color:#4c51bf;font-weight:700;">P <%= valP.toFixed(1) %></span>
                            &nbsp;·&nbsp;
                            <span style="color:#d4af37;font-weight:700;">F <%= valF.toFixed(1) %></span>
                        </div>

                        <div style="margin: 12px 0; height: 1px; background: #f1f5f9; width: 60%; margin-left: 20%;"></div>

                        <div style="font-size: 0.8rem; color: #475569; font-weight: 600;">
                            Mercado: <span style="color: #1e293b;"><%= mercadoMedia.toFixed(1) %></span>
                        </div>

                        <div style="margin-top: 5px; font-size: 0.75rem; font-weight: bold; display: inline-flex; align-items: center; gap: 4px; color: <%= gapMercado >= 0 ? '#10b981' : '#ef4444' %>;">
                            <i class="fas <%= gapMercado >= 0 ? 'fa-caret-up' : 'fa-caret-down' %>"></i>
                            <%= (gapMercado >= 0 ? '+' : '') + gapMercado.toFixed(1) %>
                        </div>
                    </div>
                <% }) %>
            </div>

            <p style="margin-top: 20px; font-size: 0.8rem; color: #94a3b8; font-style: italic; text-align: right;">
                * O benchmark utiliza dados médios agregados de instituições do setor educacional no Brasil (2025/2026).
            </p>
        </div>

        <div style="margin-top: 24px; padding: 24px 28px; border-radius: 16px; background: #f0fdf4; border: 1px solid #bbf7d0; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
            <div>
                <h3 style="margin: 0 0 6px; color: #166534; font-size: 1.05rem;">🎁 Bônus: Comunidade exclusiva no WhatsApp</h3>
                <p style="margin: 0; color: #4b5563; font-size: 0.9rem; max-width: 560px; line-height: 1.5;">
                    Mini-assessment concluído! Entre no grupo de gestores LeAction para networking e conteúdos exclusivos.
                </p>
            </div>
            <a href="<%= typeof whatsappCommunityUrl !== 'undefined' ? whatsappCommunityUrl : 'https://chat.whatsapp.com/placeholder-mudaedu-comunidade' %>"
               target="_blank" rel="noopener noreferrer"
               style="display:inline-flex;align-items:center;gap:8px;padding:12px 22px;background:#22c55e;color:#fff;font-weight:700;border-radius:8px;text-decoration:none;">
                <i class="fab fa-whatsapp"></i> Entrar no grupo
            </a>
        </div>

        <%
            const statusIAReport = (lead && lead.status_ia) ? String(lead.status_ia).trim().toUpperCase() : '';
            const planoJaAtivado = (lead && (lead.hasActiveProject === true || lead.hasActiveProject === 1 || lead.hasActiveProject === 'true'))
                || statusIAReport === 'PROJETO OK'
                || statusIAReport === 'CONTEXTO OK'
                || statusIAReport === 'AVALIACAO OK'
                || statusIAReport === 'PENDENTE'
                || statusIAReport === 'PROCESSANDO'
                || statusIAReport === 'CONCLUIDO'
                || (typeof temProjetoAtivo !== 'undefined' && temProjetoAtivo === true);
        %>

        <% if (!planoJaAtivado) { %>
        <div style="margin-top: 50px; background: linear-gradient(135deg, #2c3e50 0%, #4c51bf 100%); padding: 45px; border-radius: 24px; text-align: center; color: #ffffff; box-shadow: 0 10px 25px rgba(76, 81, 191, 0.2);">

            <h2 style="margin: 0; font-size: 2rem; color: #ffffff; font-weight: 800; letter-spacing: -0.025em;">
                Desbloqueie o Roadmap Completo
            </h2>

            <p style="color: #e0e7ff; margin: 20px auto; max-width: 650px; font-size: 1.1rem; line-height: 1.6;">
                Este diagnóstico inicial é <b>restrito</b>: reflete apenas as <b><%= totalPresurvey %> questões</b> da 1ª aba — um repertório intencionalmente reduzido, não o assessment completo.
                <strong>Contrate o plano</strong> para liberar os 162 indicadores detalhados, o Radar IA Master e as Sprints de Transformação Digital.
            </p>

            <div style="margin-top: 30px;">
                <% if (typeof checkoutPlanUrl !== 'undefined' && checkoutPlanUrl) { %>
                <a href="<%= checkoutPlanUrl %>" id="btn-contratar-hub" class="btn-dash btn-gold"
                   style="padding: 18px 60px; font-size: 1.25rem; border-radius: 50px; display: inline-flex; align-items: center; gap: 12px; transition: transform 0.2s ease; font-weight: bold; background: linear-gradient(135deg, #d4af37 0%, #f1c40f 100%); color: #1a202c; border: none; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3); text-decoration: none;">
                    <i class="fas fa-shopping-cart"></i> Contratar Plano Completo
                </a>
                <% } else { %>
                <p style="color: #fecaca; font-size: 0.95rem;">Faça login novamente para contratar o plano.</p>
                <% } %>
            </div>

            <p style="margin-top: 20px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">
                ID de Maturidade: <%= lead.id_matu %> | Status: <%= lead.status_ia %>
            </p>
        </div>
        <% } else { %>
        <div style="margin-top: 50px; padding: 32px 40px; border-radius: 20px; text-align: center; background: #f0fdf4; border: 1px solid #bbf7d0;">
            <div style="display: inline-flex; align-items: center; gap: 10px; color: #166534; font-weight: 800; font-size: 1.05rem;">
                <i class="fas fa-check-circle" style="color: #22c55e;"></i>
                Plano estratégico ativado
            </div>
            <p style="margin: 14px 0 0; color: #4b5563; font-size: 0.95rem; max-width: 560px; margin-left: auto; margin-right: auto;">
                Sua subscrição está confirmada. O questionário completo e o roadmap executivo já estão liberados no seu painel.
            </p>
            <a href="/projeto" class="btn-dash btn-gold" style="display: inline-block; margin-top: 20px; padding: 14px 36px; text-decoration: none;">
                IR PARA O PAINEL <i class="fas fa-arrow-right" style="margin-left: 8px;"></i>
            </a>
        </div>
        <% } %>

    </div>
</div>

<script type="application/json" id="presurvey-chart-data"><%- JSON.stringify({
    labels: ['Estratégica', 'Organizacional', 'Humana', 'Pedagógica', 'Tecnológica'],
    pData: [
        parseFloat(preData.score_estrat_p) || 0,
        parseFloat(preData.score_organiz_p) || 0,
        parseFloat(preData.score_humana_p) || 0,
        parseFloat(preData.score_pedag_p) || 0,
        parseFloat(preData.score_tecno_p) || 0
    ],
    fData: [
        parseFloat(preData.score_estrat_f) || 0,
        parseFloat(preData.score_organiz_f) || 0,
        parseFloat(preData.score_humana_f) || 0,
        parseFloat(preData.score_pedag_f) || 0,
        parseFloat(preData.score_tecno_f) || 0
    ],
    mData: [
        parseFloat(setor['1']) || 0,
        parseFloat(setor['2']) || 0,
        parseFloat(setor['3']) || 0,
        parseFloat(setor['4']) || 0,
        parseFloat(setor['5']) || 0
    ],
    dominios: scores_domas || {}
}) %></script>
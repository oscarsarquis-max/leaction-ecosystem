                <div class="cms-card" style="margin-bottom: 0; box-shadow: none;">
                    <h3 class="cms-card__title">Insight 3</h3>
                    <div class="cms-field">
                        <label for="insight3-title">Título do Insight</label>
                        <input type="text" id="insight3-title">
                    </div>
                    <div class="cms-field">
                        <label for="insight3-summary">Resumo</label>
                        <textarea id="insight3-summary" rows="3"></textarea>
                    </div>
                    <div class="cms-field">
                        <label for="insight3-link">Link de Leitura</label>
                        <input type="text" id="insight3-link" placeholder="https://...">
                    </div>
                    <div class="cms-field">

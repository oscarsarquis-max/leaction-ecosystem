<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>

<style>
    #admin-cms-page {
        --cms-bg: #f6f8fb;
        --cms-border: #e3e8ef;
        --cms-text: #0a2540;
        --cms-muted: #475569;
        --cms-accent: #635bff;
        --cms-accent-hover: #4f46e5;
        max-width: 1080px;
        margin: 0 auto;
        padding: 24px;
        background: var(--cms-bg);
        border-radius: 12px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        color: var(--cms-text);
    }

    /* Sobrescreve .content h1 global (style.css) que conflita com o banner */
    .content #admin-cms-page .cms-top h1 {
        margin: 0 !important;
        font-size: 1.5rem !important;
        font-weight: 700 !important;
        color: #ffffff !important;
        letter-spacing: -0.02em;
        border: none !important;
        padding: 0 !important;
    }

    #admin-cms-page .cms-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 16px;
        margin: -24px -24px 24px;
        padding: 22px 28px;
        background: linear-gradient(135deg, #1e3a5f 0%, #0f2744 100%);
        border-radius: 12px 12px 0 0;
        border-bottom: none;
    }
    #admin-cms-page .cms-top h1 i {
        color: #93c5fd !important;
        margin-right: 8px;
    }
    #admin-cms-page .cms-top p {
        margin: 6px 0 0;
        color: rgba(255, 255, 255, 0.88);
        font-size: 0.88rem;
    }
    #admin-cms-page .cms-meta {
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.78);
        text-align: right;
    }
    #admin-cms-page .cms-meta span {
        color: #ffffff;
        font-weight: 600;
    }

    #admin-cms-page .cms-tabs {
        display: flex;
        gap: 4px;
        border-bottom: 1px solid var(--cms-border);
        margin-bottom: 24px;
    }
    #admin-cms-page .cms-tab {
        padding: 10px 18px;
        border: none;
        background: transparent;
        color: var(--cms-muted);
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: color 0.15s, border-color 0.15s;
    }
    #admin-cms-page .cms-tab:hover { color: var(--cms-text); }
    #admin-cms-page .cms-tab.is-active {
        color: var(--cms-accent);
        border-bottom-color: var(--cms-accent);
    }

    #admin-cms-page .cms-panel { display: none; }
    #admin-cms-page .cms-panel.is-active { display: block; }

    #admin-cms-page .cms-card {
        background: #fff;
        border: 1px solid var(--cms-border);
        border-radius: 10px;
        padding: 22px 24px;
        margin-bottom: 18px;
        box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
    }
    #admin-cms-page .cms-card__title {
        margin: 0 0 4px;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--cms-text);
    }
    #admin-cms-page .cms-card__hint {
        margin: 0 0 16px;
        font-size: 0.8rem;
        color: var(--cms-muted);
    }

    #admin-cms-page .cms-grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }
    @media (max-width: 900px) {
        #admin-cms-page .cms-grid-3 { grid-template-columns: 1fr; }
    }

    #admin-cms-page .cms-field { margin-bottom: 14px; }
    #admin-cms-page .cms-field label {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--cms-muted);
        margin-bottom: 6px;
    }
    #admin-cms-page .cms-field input,
    #admin-cms-page .cms-field textarea {
        width: 100%;
        box-sizing: border-box;
        padding: 10px 12px;
        border: 1px solid var(--cms-border);
        border-radius: 8px;
        font-size: 0.9rem;
        color: var(--cms-text);
        background: #fff;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    #admin-cms-page .cms-field input:focus,
    #admin-cms-page .cms-field textarea:focus {
        outline: none;
        border-color: var(--cms-accent);
        box-shadow: 0 0 0 3px rgba(99, 91, 255, 0.12);
    }
    #admin-cms-page .cms-field textarea { min-height: 88px; resize: vertical; }
    #admin-cms-page .cms-field input[type="color"] {
        height: 42px;
        padding: 4px 8px;
        cursor: pointer;
    }
    #admin-cms-page .cms-field select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.92rem;
        background: #fff;
        color: #1e293b;
    }
    #admin-cms-page .cms-field select:focus {
        outline: none;
        border-color: var(--cms-accent);
        box-shadow: 0 0 0 3px rgba(91, 53, 217, 0.12);
    }
    #admin-cms-page .cms-visibility-hint {
        font-size: 0.8rem;
        color: #64748b;
        margin-top: 4px;
    }
    #admin-cms-page .cms-upload-row {
        display: flex;
        gap: 8px;
        align-items: stretch;
    }
    #admin-cms-page .cms-upload-row input[type="text"] {
        flex: 1;
        min-width: 0;
    }
    #admin-cms-page .btn-cms-upload {
        flex-shrink: 0;
        padding: 10px 14px;
        border: 1px solid var(--cms-border);
        border-radius: 8px;
        background: #f8fafc;
        color: var(--cms-text);
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.15s, border-color 0.15s;
    }
    #admin-cms-page .btn-cms-upload:hover:not(:disabled) {
        background: #eef2ff;
        border-color: #c4b5fd;
    }
    #admin-cms-page .btn-cms-upload:disabled {
        opacity: 0.6;
        cursor: wait;
    }
    #admin-cms-page .cms-upload-input {
        display: none;
    }
    #admin-cms-page .cms-toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        padding: 12px 18px;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        color: #fff;
        background: #059669;
        box-shadow: 0 8px 24px rgba(5, 150, 105, 0.35);
        opacity: 0;
        transform: translateY(12px);
        pointer-events: none;
        transition: opacity 0.25s, transform 0.25s;
    }
    #admin-cms-page .cms-toast.is-visible {
        opacity: 1;
        transform: translateY(0);
    }
    #admin-cms-page .cms-toast.is-error {
        background: #dc2626;
        box-shadow: 0 8px 24px rgba(220, 38, 38, 0.35);
    }

    #admin-cms-page .cms-reserved {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        padding: 12px 14px;
        margin-bottom: 14px;
        font-size: 0.82rem;
        color: #475569;
        line-height: 1.5;
    }
    #admin-cms-page .cms-reserved strong { color: #334155; }

    #admin-cms-page .cms-image-notice {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        background: #fffbeb;
        border: 1px solid #fcd34d;
        border-left: 4px solid #f59e0b;
        border-radius: 10px;
        padding: 16px 18px;
        margin-bottom: 18px;
        font-size: 0.84rem;
        color: #78350f;
        line-height: 1.55;
    }
    #admin-cms-page .cms-image-notice > i {
        color: #d97706;
        font-size: 1.15rem;
        margin-top: 2px;
        flex-shrink: 0;
    }
    #admin-cms-page .cms-image-notice strong { color: #92400e; }
    #admin-cms-page .cms-image-notice ul {
        margin: 8px 0 0;
        padding-left: 18px;
    }
    #admin-cms-page .cms-image-notice li { margin-bottom: 4px; }
    #admin-cms-page .cms-video-preview {
        margin-top: 10px;
        aspect-ratio: 16 / 9;
        max-height: 220px;
        background: #0f172a;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--cms-border);
    }
    #admin-cms-page .cms-video-preview iframe {
        width: 100%;
        height: 100%;
        border: 0;
        display: block;
    }
    #admin-cms-page .cms-video-hint {
        font-size: 0.8rem;
        color: var(--cms-muted);
        margin-top: 6px;
        line-height: 1.45;
    }
    #admin-cms-page .cms-image-notice code {
        font-size: 0.8rem;
        background: rgba(255, 255, 255, 0.65);
        padding: 1px 5px;
        border-radius: 4px;
    }

    #admin-cms-page #quill-instrucoes {
        min-height: 360px;
        background: #fff;
        font-size: 0.95rem;
    }
    #admin-cms-page #quill-instrucoes .ql-editor { min-height: 320px; }

    #admin-cms-page #quill-versao-detalhes {
        min-height: 280px;
        background: #fff;
        font-size: 0.95rem;
    }
    #admin-cms-page #quill-versao-detalhes .ql-editor { min-height: 240px; }

    #admin-cms-page .cms-version-card {
        border: 1px solid #bfdbfe;
        background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
    }
    #admin-cms-page .cms-version-card .cms-card__title { color: #1e40af; }

    #admin-cms-page .cms-blog-preview {
        font-size: 0.84rem;
        color: #475569;
        line-height: 1.55;
    }
    #admin-cms-page .cms-blog-preview strong {
        display: block;
        color: #1e293b;
        margin-bottom: 6px;
        font-size: 0.92rem;
    }
    #admin-cms-page .cms-blog-preview img {
        width: 100%;
        max-height: 120px;
        object-fit: contain;
        background: #f1f5f9;
        border-radius: 8px;
        margin-bottom: 10px;
    }

    #admin-cms-page .cms-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--cms-border);
    }
    #admin-cms-page .btn-cms-primary {
        padding: 11px 22px;
        border: none;
        border-radius: 8px;
        background: var(--cms-accent);
        color: #fff;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
        transition: background 0.15s;
    }
    #admin-cms-page .btn-cms-primary:hover { background: var(--cms-accent-hover); }
    #admin-cms-page .btn-cms-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    #admin-cms-page .cms-status {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--cms-muted);
    }
    #admin-cms-page .cms-status.is-ok { color: #059669; }
    #admin-cms-page .cms-status.is-err { color: #dc2626; }
</style>

<div id="admin-cms-page">
    <header class="cms-top">
        <div>
            <h1><i class="fas fa-pen-nib"></i> Gestão de Conteúdo (CMS)</h1>
            <p>Micro-CMS interno — Landing Page e Instruções de Uso</p>
        </div>
        <div class="cms-meta">
            Última atualização:<br>
            <span id="cms-updated-at">—</span>
        </div>
    </header>

    <nav class="cms-tabs" role="tablist">
        <button type="button" class="cms-tab is-active" data-tab="landing" role="tab">Página Inicial (Grid Hero)</button>
        <button type="button" class="cms-tab" data-tab="instrucoes" role="tab">Página de Instruções</button>
    </nav>

    <!-- ABA 1: LANDING -->
    <section id="panel-landing" class="cms-panel is-active" role="tabpanel">
        <div class="cms-image-notice" role="note">
            <i class="fas fa-camera" aria-hidden="true"></i>
            <div>
                <strong>Aviso — fotos e imagens das colunas</strong>
                <p style="margin: 6px 0 0;">
                    Na home, cada imagem das demais colunas é exibida <strong>por inteiro</strong> dentro da faixa superior do card
                    (proporção <strong>16:9</strong>). A <strong>Coluna 2</strong> usa <strong>vídeo do YouTube</strong> nessa mesma faixa.
                </p>
                <ul>
                    <li><strong>Tamanho recomendado:</strong> <code>1280 × 720 px</code> ou <code>1600 × 900 px</code> (mínimo sugerido: <code>960 × 540 px</code>).</li>
                    <li><strong>Proporção ideal:</strong> horizontal (16:9) — preenche toda a faixa, sem barras laterais ou superiores.</li>
                    <li><strong>Outras proporções:</strong> também são aceitas; podem aparecer faixas cinza-claras nas laterais ou em cima/embaixo até a foto caber por completo.</li>
                    <li><strong>Enquadramento:</strong> centralize logos, textos e elementos importantes na imagem.</li>
                    <li><strong>Formato e peso:</strong> JPG ou WebP, boa nitidez, preferencialmente até <strong>500 KB</strong> por arquivo.</li>
                    <li><strong>URL:</strong> caminho público acessível pelo navegador (ex.: <code>/images/nome-da-foto.jpg</code>) ou use <strong>Fazer Upload</strong>.</li>
                </ul>
            </div>
        </div>

        <div class="cms-grid-3">
            <!-- Banner Hero CTA 3D — Consultor IA -->
            <div class="cms-card" style="grid-column: 1 / -1; border-color: #312e81; background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 8%, #ffffff 8%);">
                <h2 class="cms-card__title" style="color: #fff; margin-bottom: 4px;">
                    <i class="fas fa-bolt"></i> Configuração do Banner Hero CTA — Consultor IA
                </h2>
                <p class="cms-card__hint" style="color: rgba(255,255,255,0.75); margin-bottom: 16px;">
                    Banner 3D do Consultor IA — primeiro destaque na home (topo).
                </p>
                <div class="cms-grid-3" style="grid-template-columns: 1fr 1fr;">
                    <div class="cms-field">
                        <label for="hero-cta-visible">Exibição na landing</label>
                        <select id="hero-cta-visible">
                            <option value="true">Visível</option>
                            <option value="false">Oculto</option>
                        </select>
                    </div>
                    <div class="cms-field">
                        <label for="hero-cta-badge">Tag / Pill (ex: Novo Agent IA)</label>
                        <input type="text" id="hero-cta-badge" placeholder="Novo Agent IA">
                    </div>
                    <div class="cms-field" style="grid-column: 1 / -1;">
                        <label for="hero-cta-title">Título do Banner</label>
                        <input type="text" id="hero-cta-title" placeholder="Descubra como resolver seu maior desafio...">
                    </div>
                    <div class="cms-field" style="grid-column: 1 / -1;">
                        <label for="hero-cta-subtitle">Subtítulo / Texto de apoio</label>
                        <textarea id="hero-cta-subtitle" rows="2" placeholder="Consultor IA 100% Gratuito — ..."></textarea>
                        <p class="cms-visibility-hint">A palavra &quot;Gratuito&quot; será destacada em laranja automaticamente.</p>
                    </div>
                    <div class="cms-field">
                        <label for="hero-cta-button">Texto do Botão</label>
                        <input type="text" id="hero-cta-button" placeholder="Falar com Consultor IA">
                    </div>
                    <div class="cms-field">
                        <label for="hero-cta-url">URL do Botão</label>
                        <input type="text" id="hero-cta-url" placeholder="/consultor-leaction">
                    </div>
                    <div class="cms-field" style="grid-column: 1 / -1;">
                        <label for="hero-cta-image">Imagem Tech/Edu (lado direito do banner)</label>
                        <div class="cms-upload-row">
                            <input type="text" id="hero-cta-image" placeholder="/images/sua-ilustracao-3d.png">
                            <button type="button" class="btn-cms-upload" data-upload-target="hero-cta-image" data-upload-input="file-hero-cta-image">📤 Fazer Upload</button>
                            <input type="file" id="file-hero-cta-image" class="cms-upload-input" accept="image/*">
                        </div>
                        <p class="cms-visibility-hint">Upload via Multer (<code>/node/admin/cms/upload</code>). Recomendado: PNG/WebP isométrico.</p>
                    </div>
                </div>
            </div>

            <!-- Configuração da Coluna 1 - Banner Mesa de Inovação -->
            <div id="cms-col1-banner-section" class="cms-card" style="grid-column: 1 / -1; border-color: #312e81; background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 8%, #ffffff 8%);">
                <h2 class="cms-card__title" style="color: #fff; margin-bottom: 4px;">
                    <i class="fas fa-lightbulb"></i> Configuração da Coluna 1 - Banner Mesa de Inovação
                </h2>
                <p class="cms-card__hint" style="color: rgba(255,255,255,0.75); margin-bottom: 16px;">
                    Mesmo layout 3D do Consultor IA — exibido na <strong>primeira célula do grid</strong> da home (ao lado da Coluna 2).
                </p>
                <div class="cms-grid-3" style="grid-template-columns: 1fr 1fr;">
                    <div class="cms-field">
                        <label for="col1-visible">Visibilidade (exibir na landing)</label>
                        <select id="col1-visible" aria-label="Toggle de visibilidade da Coluna 1">
                            <option value="true">Visível</option>
                            <option value="false">Oculto</option>
                        </select>
                    </div>
                    <div class="cms-field">
                        <label for="col1-pill">Pill Text (tag laranja)</label>
                        <input type="text" id="col1-pill" placeholder="✨ Mesa de Inovação">
                    </div>
                    <div class="cms-field" style="grid-column: 1 / -1;">
                        <label for="col1-title">Título</label>
                        <input type="text" id="col1-title" placeholder="Leve sua escola ao próximo nível">
                    </div>
                    <div class="cms-field" style="grid-column: 1 / -1;">
                        <label for="col1-subtitle">Subtítulo</label>
                        <textarea id="col1-subtitle" rows="2" placeholder="Transforme o plano gratuito em um Roadmap executável"></textarea>
                        <p class="cms-visibility-hint">Palavras como &quot;Gratuito&quot; ou &quot;Gratuita&quot; são destacadas em laranja na home.</p>
                    </div>
                    <div class="cms-field">
                        <label for="col1-cta-text">Texto do Botão (CTA)</label>
                        <input type="text" id="col1-cta-text" placeholder="Agendar Mesa Gratuita">
                    </div>
                    <div class="cms-field">
                        <label for="col1-cta-url">URL do Botão (CTA)</label>
                        <input type="text" id="col1-cta-url" placeholder="https://leaction.com.br/contato">
                    </div>
                    <div class="cms-field" style="grid-column: 1 / -1;">
                        <label for="col1-image">Imagem Tech/Edu (lado direito do banner)</label>
                        <div class="cms-upload-row">
                            <input type="text" id="col1-image" placeholder="/images/sua-ilustracao-mesa.png" aria-describedby="col1-image-hint">
                            <button type="button" class="btn-cms-upload" data-upload-target="col1-image" data-upload-input="file-col1-image">📤 Fazer Upload</button>
                            <input type="file" id="file-col1-image" class="cms-upload-input" accept="image/*">
                        </div>
                        <p id="col1-image-hint" class="cms-visibility-hint">
                            Mesmo upload Multer do Consultor IA (<code>/node/admin/cms/upload</code>).
                            A imagem ocupa toda a altura do banner ao lado da Coluna 2.
                        </p>
                    </div>
                    <div class="cms-field" style="grid-column: 1 / -1; margin-top: 8px;">
                        <label class="cms-card__title" style="font-size: 0.9rem; margin-bottom: 10px;">Cores do banner</label>
                    </div>
                    <div class="cms-field">
                        <label for="col1-bg-start">Fundo — gradiente início</label>
                        <input type="color" id="col1-bg-start" value="#0b0c10">
                    </div>
                    <div class="cms-field">
                        <label for="col1-bg-end">Fundo — gradiente fim</label>
                        <input type="color" id="col1-bg-end" value="#1a0b2e">
                    </div>
                    <div class="cms-field">
                        <label for="col1-border-color">Borda (hex ou rgba)</label>
                        <input type="text" id="col1-border-color" placeholder="rgba(0, 191, 255, 0.2)">
                    </div>
                    <div class="cms-field">
                        <label for="col1-title-color">Cor do título</label>
                        <input type="color" id="col1-title-color" value="#ffffff">
                    </div>
                    <div class="cms-field">
                        <label for="col1-subtitle-color">Cor do subtítulo (hex ou rgba)</label>
                        <input type="text" id="col1-subtitle-color" placeholder="rgba(255, 255, 255, 0.82)">
                    </div>
                    <div class="cms-field">
                        <label for="col1-pill-bg">Fundo da pill</label>
                        <input type="color" id="col1-pill-bg" value="#FF6B00">
                    </div>
                    <div class="cms-field">
                        <label for="col1-pill-text">Texto da pill</label>
                        <input type="color" id="col1-pill-text" value="#ffffff">
                    </div>
                    <div class="cms-field">
                        <label for="col1-accent-color">Destaque (ex: &quot;Gratuito&quot;)</label>
                        <input type="color" id="col1-accent-color" value="#FF6B00">
                    </div>
                    <div class="cms-field">
                        <label for="col1-btn-bg">Fundo do botão CTA</label>
                        <input type="color" id="col1-btn-bg" value="#FF6B00">
                    </div>
                    <div class="cms-field">
                        <label for="col1-btn-text">Texto do botão CTA</label>
                        <input type="color" id="col1-btn-text" value="#ffffff">
                    </div>
                    <div class="cms-field">
                        <label for="col1-btn-shadow">Sombra 3D do botão</label>
                        <input type="color" id="col1-btn-shadow" value="#b34700">
                    </div>
                </div>
            </div>

            <!-- Coluna 2 — Vídeo YouTube -->
            <div class="cms-card">
                <h2 class="cms-card__title">Coluna 2 — Vídeo</h2>
                <div class="cms-field">
                    <label for="col2-visible">Exibição na landing</label>
                    <select id="col2-visible">
                        <option value="true">Visível</option>
                        <option value="false">Oculto</option>
                    </select>
                    <p class="cms-visibility-hint">Segunda coluna do grid principal — player de vídeo do YouTube.</p>
                </div>
                <div class="cms-field">
                    <label for="col2-video-url">URL do vídeo (YouTube)</label>
                    <input type="url" id="col2-video-url" placeholder="https://www.youtube.com/watch?v=XXXXXXXXXXX">
                    <p class="cms-video-hint">
                        Aceita links <code>youtube.com/watch?v=...</code>, <code>youtu.be/...</code>, <code>youtube.com/shorts/...</code> ou o ID de 11 caracteres.
                        Proporção exibida na home: <strong>16:9</strong> (faixa superior do card).
                    </p>

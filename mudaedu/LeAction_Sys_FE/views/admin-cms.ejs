    <div class="cms-actions">
        <button type="button" id="btn-salvar-cms" class="btn-cms-primary">
            <i class="fas fa-save"></i> Salvar alterações
        </button>
        <span id="cms-save-status" class="cms-status"></span>
    </div>

    <div id="cms-upload-toast" class="cms-toast" role="status" aria-live="polite"></div>
</div>

<script>
(function () {
    let cmsState = { landing_page_data: {}, instructions_data: '' };
    let quillInstrucoes = null;
    let quillVersao = null;
    let cmsToastTimer = null;

    function showCmsToast(message, isError) {
        var el = document.getElementById('cms-upload-toast');
        if (!el) return;
        el.textContent = message;
        el.classList.toggle('is-error', !!isError);
        el.classList.add('is-visible');
        clearTimeout(cmsToastTimer);
        cmsToastTimer = setTimeout(function () {
            el.classList.remove('is-visible');
        }, 2800);
    }

    var CMS_UPLOAD_ENDPOINTS = ['/node/admin/cms/upload', '/admin/cms/upload'];

    async function uploadCmsImage(formData) {
        var lastError = null;
        for (var i = 0; i < CMS_UPLOAD_ENDPOINTS.length; i++) {
            var url = CMS_UPLOAD_ENDPOINTS[i];
            var res = await fetch(url, {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            });
            if (res.status === 404) {
                lastError = new Error('Rota de upload não encontrada (' + url + '). Reinicie o servidor Node.');
                continue;
            }
            var json = {};
            try {
                json = await res.json();
            } catch (parseErr) {
                throw new Error('Resposta inválida do servidor (HTTP ' + res.status + ').');
            }
            if (!res.ok || !json.success) {
                throw new Error(json.error || ('Falha no upload (HTTP ' + res.status + ').'));
            }
            return json;
        }
        throw lastError || new Error('Upload indisponível.');
    }

    function initCmsImageUploads() {
        document.querySelectorAll('#admin-cms-page .btn-cms-upload').forEach(function (btn) {
            var targetId = btn.getAttribute('data-upload-target');
            var inputId = btn.getAttribute('data-upload-input');
            var fileInput = document.getElementById(inputId);
            var textInput = document.getElementById(targetId);
            if (!fileInput || !textInput) return;

            btn.addEventListener('click', function () {
                fileInput.click();
            });

            fileInput.addEventListener('change', async function () {
                var file = fileInput.files && fileInput.files[0];
                fileInput.value = '';
                if (!file) return;

                var formData = new FormData();
                formData.append('imagem', file);
                var originalLabel = btn.textContent;
                btn.disabled = true;
                btn.textContent = 'Enviando...';

                try {
                    var json = await uploadCmsImage(formData);
                    textInput.value = json.url;
                    showCmsToast('Imagem enviada!');
                } catch (err) {
                    showCmsToast(err.message || 'Erro no upload.', true);
                } finally {
                    btn.disabled = false;
                    btn.textContent = originalLabel;
                }
            });
        });
    }

    initCmsImageUploads();

    function youtubeVideoIdFromUrl(url) {
        if (!url || typeof url !== 'string') return '';
        var raw = url.trim();
        var m = raw.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/|live\/))([\w-]{11})/i);
        if (m) return m[1];
        if (/^[\w-]{11}$/.test(raw)) return raw;
        return '';
    }

    function refreshCol2VideoPreview() {
        var input = document.getElementById('col2-video-url');
        var preview = document.getElementById('col2-video-preview');
        if (!input || !preview) return;
        var videoId = youtubeVideoIdFromUrl(input.value);
        if (!videoId) {
            preview.hidden = true;
            preview.innerHTML = '';
            return;
        }
        preview.hidden = false;
        preview.innerHTML =
            '<iframe src="https://www.youtube.com/embed/' + videoId + '?rel=0&modestbranding=1" ' +
            'title="Pré-visualização do vídeo da Coluna 2" loading="lazy" ' +
            'allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" ' +
            'allowfullscreen></iframe>';
    }

    var col2VideoInput = document.getElementById('col2-video-url');
    if (col2VideoInput) {
        col2VideoInput.addEventListener('input', refreshCol2VideoPreview);
        col2VideoInput.addEventListener('change', refreshCol2VideoPreview);
    }

    document.querySelectorAll('#admin-cms-page .cms-tab').forEach(function (tab) {
        tab.addEventListener('click', function () {
            document.querySelectorAll('#admin-cms-page .cms-tab').forEach(function (t) {
                t.classList.remove('is-active');
            });
            document.querySelectorAll('#admin-cms-page .cms-panel').forEach(function (p) {
                p.classList.remove('is-active');
            });
            tab.classList.add('is-active');
            document.getElementById('panel-' + tab.dataset.tab).classList.add('is-active');
            if (tab.dataset.tab === 'instrucoes' && !quillInstrucoes) {
                initQuill();
            }
        });
    });

    function initQuillVersao() {
        if (quillVersao || typeof Quill === 'undefined') return;
        quillVersao = new Quill('#quill-versao-detalhes', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ list: 'ordered' }, { list: 'bullet' }],
                    [{ align: [] }],
                    ['link', 'blockquote'],
                    ['clean']
                ]
            }
        });
        const landing = cmsState.landing_page_data || {};
        const versao = landing.app_version || {};
        if (versao.details_html) {
            quillVersao.clipboard.dangerouslyPasteHTML(versao.details_html);
        }
    }

    function initQuill() {
        if (quillInstrucoes || typeof Quill === 'undefined') return;
        quillInstrucoes = new Quill('#quill-instrucoes', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ list: 'ordered' }, { list: 'bullet' }],
                    [{ align: [] }],
                    ['link', 'blockquote'],
                    ['clean']
                ]
            }
        });
        if (cmsState.instructions_data) {
            quillInstrucoes.clipboard.dangerouslyPasteHTML(cmsState.instructions_data);
        }
    }

    function setUpdatedAt(val) {
        const el = document.getElementById('cms-updated-at');
        if (!val) { el.textContent = '—'; return; }
        try {
            el.textContent = new Date(val).toLocaleString('pt-BR');
        } catch (e) {
            el.textContent = val;
        }
    }

    function renderBlogPreview(landing) {
        const cols = (landing && landing.columns) || [];
        const sync = landing && landing.blog_sync;
        const meta = document.getElementById('blog-sync-meta');
        if (meta) {
            if (sync && sync.synced_at) {
                try {
                    meta.textContent = 'Última sincronização: ' + new Date(sync.synced_at).toLocaleString('pt-BR');
                } catch (e) {
                    meta.textContent = 'Sincronizado com o blog LeAction.';
                }
            } else {
                meta.textContent = 'Aguardando sincronização com o blog LeAction.';
            }
        }

        function htmlPreview(col, fallback) {
            if (!col || !col.title) {
                return '<em>' + fallback + '</em>';
            }
            var img = col.image_url
                ? '<img src="' + col.image_url.replace(/"/g, '&quot;') + '" alt="">'
                : '';
            var link = col.link_url
                ? '<br><a href="' + col.link_url.replace(/"/g, '&quot;') + '" target="_blank" rel="noopener">' +
                  (col.link_text || 'Leia mais →') + '</a>'
                : '';
            return img + '<strong>' + col.title + '</strong><p style="margin:6px 0 0">' +
                (col.description || '') + '</p>' + link;
        }

        var p1 = document.getElementById('blog-preview-1');
        var p2 = document.getElementById('blog-preview-2');
        if (p1) p1.innerHTML = htmlPreview(cols[2], 'Nenhum post disponível.');
        if (p2) p2.innerHTML = htmlPreview(cols[3], 'Nenhum post disponível.');
    }

    function populateForm(data) {
        const landing = data.landing_page_data || {};
        const hero = landing.hero || {};
        const cols = landing.columns || [];
        const c1 = landing.coluna1 || cols[0] || {};
        const c2 = cols[1] || {};
        const versao = landing.app_version || {};
        const heroCta = landing.hero_cta || landing.cta_consultor || {};

        document.getElementById('hero-leaction').value = hero.leaction_title || '';
        document.getElementById('hero-paneldx').value = hero.paneldx_title || '';
        document.getElementById('hero-subtitle').value = hero.subtitle || '';
        document.getElementById('hero-desc').value = hero.description || '';

        document.getElementById('col1-visible').value =
            (c1.visibility !== false && c1.visible !== false) ? 'true' : 'false';
        document.getElementById('col1-pill').value = c1.pill_text || c1.badge_text || '✨ Mesa de Inovação';
        document.getElementById('col1-title').value = c1.title || '';
        document.getElementById('col1-subtitle').value = c1.subtitle || c1.description || '';
        document.getElementById('col1-cta-text').value = c1.cta_text || c1.button_text || '';
        document.getElementById('col1-cta-url').value = c1.cta_url || c1.button_url || '';
        document.getElementById('col1-image').value = c1.image_path || c1.image_url || '';
        setCol1ColorField('col1-bg-start', c1.bg_color_start, '#0b0c10');
        setCol1ColorField('col1-bg-end', c1.bg_color_end, '#1a0b2e');
        document.getElementById('col1-border-color').value = c1.border_color || 'rgba(0, 191, 255, 0.2)';
        setCol1ColorField('col1-title-color', c1.title_color, '#ffffff');
        document.getElementById('col1-subtitle-color').value = c1.subtitle_color || 'rgba(255, 255, 255, 0.82)';
        setCol1ColorField('col1-pill-bg', c1.pill_bg_color, '#FF6B00');
        setCol1ColorField('col1-pill-text', c1.pill_text_color, '#ffffff');
        setCol1ColorField('col1-accent-color', c1.accent_color, '#FF6B00');
        setCol1ColorField('col1-btn-bg', c1.button_bg_color, '#FF6B00');
        setCol1ColorField('col1-btn-text', c1.button_text_color, '#ffffff');
        setCol1ColorField('col1-btn-shadow', c1.button_shadow_color, '#b34700');

        document.getElementById('col2-video-url').value = c2.video_url || c2.image_url || '';
        document.getElementById('col2-title').value = c2.title || '';
        document.getElementById('col2-desc').value = c2.description || '';
        document.getElementById('col2-visible').value = c2.visible === false ? 'false' : 'true';
        refreshCol2VideoPreview();

        renderBlogPreview(landing);

        document.getElementById('versao-label').value = versao.version_label || '';
        document.getElementById('versao-image').value = versao.image_url || '';
        document.getElementById('versao-title').value = versao.title || '';
        document.getElementById('versao-summary').value = versao.summary || '';
        document.getElementById('versao-link-text').value = versao.link_text || '';

        document.getElementById('hero-cta-visible').value = heroCta.visible === false ? 'false' : 'true';
        document.getElementById('hero-cta-badge').value = heroCta.badge_text || 'Novo Agent IA';
        document.getElementById('hero-cta-title').value = heroCta.title || '';
        document.getElementById('hero-cta-subtitle').value = heroCta.subtitle || '';
        document.getElementById('hero-cta-button').value = heroCta.button_text || '';
        document.getElementById('hero-cta-url').value = heroCta.button_url || '/consultor-leaction';
        document.getElementById('hero-cta-image').value = heroCta.image_url || '';

        var insightsSection = landing.insights_section || {};
        document.getElementById('insights-title').value = insightsSection.title || '';
        document.getElementById('insights-subtitle').value = insightsSection.subtitle || '';
        var insights = landing.insights || [];
        [1, 2, 3].forEach(function (n) {
            var item = insights[n - 1] || {};
            document.getElementById('insight' + n + '-title').value = item.title || '';
            document.getElementById('insight' + n + '-summary').value = item.summary || '';
            document.getElementById('insight' + n + '-link').value = item.link_url || '';
            document.getElementById('insight' + n + '-link-text').value = item.link_text || '';
        });

        cmsState.instructions_data = data.instructions_data || '';
        if (quillInstrucoes) {
            quillInstrucoes.clipboard.dangerouslyPasteHTML(cmsState.instructions_data);
        }
        initQuillVersao();
        if (quillVersao) {
            quillVersao.clipboard.dangerouslyPasteHTML(versao.details_html || '');
        }
        setUpdatedAt(data.updated_at);
    }

    function setCol1ColorField(id, value, fallback) {
        var el = document.getElementById(id);
        if (!el) return;
        var v = (value || fallback || '').trim();
        if (/^#[0-9a-fA-F]{6}$/.test(v) || /^#[0-9a-fA-F]{3}$/.test(v)) {
            el.value = v.length === 4
                ? '#' + v[1] + v[1] + v[2] + v[2] + v[3] + v[3]
                : v;
        } else {
            el.value = fallback;
        }
    }

    function readCol1ThemePayload() {
        return {
            bg_color_start: document.getElementById('col1-bg-start').value,
            bg_color_end: document.getElementById('col1-bg-end').value,
            border_color: document.getElementById('col1-border-color').value.trim(),
            title_color: document.getElementById('col1-title-color').value,
            subtitle_color: document.getElementById('col1-subtitle-color').value.trim(),
            pill_bg_color: document.getElementById('col1-pill-bg').value,
            pill_text_color: document.getElementById('col1-pill-text').value,
            accent_color: document.getElementById('col1-accent-color').value,
            button_bg_color: document.getElementById('col1-btn-bg').value,
            button_text_color: document.getElementById('col1-btn-text').value,
            button_shadow_color: document.getElementById('col1-btn-shadow').value
        };
    }

    function collectPayload() {
        const col1Visible = document.getElementById('col1-visible').value === 'true';
        const col1Image = document.getElementById('col1-image').value.trim();
        const col1Title = document.getElementById('col1-title').value.trim();
        const col1Subtitle = document.getElementById('col1-subtitle').value.trim();
        const col1Pill = document.getElementById('col1-pill').value.trim() || '✨ Mesa de Inovação';
        const col1CtaText = document.getElementById('col1-cta-text').value.trim();
        const col1CtaUrl = document.getElementById('col1-cta-url').value.trim();
        const col1Theme = readCol1ThemePayload();
        const landing = {
            hero: {
                leaction_title: document.getElementById('hero-leaction').value.trim(),
                paneldx_title: document.getElementById('hero-paneldx').value.trim(),
                subtitle: document.getElementById('hero-subtitle').value.trim(),
                description: document.getElementById('hero-desc').value.trim()
            },
            coluna1: {
                visibility: col1Visible,
                pill_text: col1Pill,
                title: col1Title,
                subtitle: col1Subtitle,
                cta_text: col1CtaText,
                cta_url: col1CtaUrl,
                image_path: col1Image,
                bg_color_start: col1Theme.bg_color_start,

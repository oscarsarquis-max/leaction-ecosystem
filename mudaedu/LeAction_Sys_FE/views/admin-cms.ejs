                return {
                    title: document.getElementById('insight' + n + '-title').value.trim(),
                    summary: document.getElementById('insight' + n + '-summary').value.trim(),
                    link_url: document.getElementById('insight' + n + '-link').value.trim(),
                    link_text: document.getElementById('insight' + n + '-link-text').value.trim() || 'Leia mais →'
                };
            })
        };
        const instructions = quillInstrucoes
            ? quillInstrucoes.root.innerHTML
            : cmsState.instructions_data;
        return { landing_page_data: landing, instructions_data: instructions };
    }

    async function carregarCms() {
        const status = document.getElementById('cms-save-status');
        status.textContent = 'Carregando...';
        status.className = 'cms-status';
        try {
            const res = await fetch('/api/admin/cms');
            const json = await res.json();
            if (!res.ok || !json.success) throw new Error(json.error || 'Falha ao carregar');
            cmsState = json;
            populateForm(json);
            status.textContent = '';
        } catch (err) {
            status.textContent = 'Erro ao carregar: ' + err.message;
            status.className = 'cms-status is-err';
        }
    }

    document.getElementById('btn-salvar-cms').addEventListener('click', async function () {
        const btn = this;
        const status = document.getElementById('cms-save-status');
        btn.disabled = true;
        status.textContent = 'Salvando...';
        status.className = 'cms-status';
        try {
            const payload = collectPayload();
            const res = await fetch('/api/admin/cms', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const json = await res.json();
            if (!res.ok || !json.success) throw new Error(json.error || 'Falha ao salvar');
            cmsState = json;
            setUpdatedAt(json.updated_at);
            status.textContent = 'Salvo com sucesso.';
            status.className = 'cms-status is-ok';
        } catch (err) {
            status.textContent = 'Erro: ' + err.message;
            status.className = 'cms-status is-err';
        } finally {
            btn.disabled = false;
        }
    });

    carregarCms();
})();
</script>

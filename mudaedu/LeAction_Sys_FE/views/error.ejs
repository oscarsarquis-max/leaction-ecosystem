<div class="page-header text-center p-8">
    <h1 class="text-4xl font-bold text-red-600 mb-4">
        <%= typeof title !== 'undefined' ? title : 'Ocorreu um Erro!' %>
    </h1>
    <p class="text-lg text-gray-700">
        <%= typeof message !== 'undefined' ? message : 'Não foi possível carregar a página devido a um problema.' %>
    </p>
    <% if (typeof contractStatus !== 'undefined' && contractStatus) { %>
    <p class="mt-2 text-sm text-gray-500">Status do contrato: <strong><%= contractStatus %></strong></p>
    <% } %>
    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center items-center">
        <% if (typeof checkoutUpgradeUrl !== 'undefined' && checkoutUpgradeUrl) { %>
        <a href="<%= checkoutUpgradeUrl %>"
           class="inline-block px-6 py-3 text-white bg-emerald-600 rounded-lg shadow hover:bg-emerald-700 transition-colors font-bold">
            <i class="fas fa-arrow-up"></i> Contratar / Fazer Upgrade
        </a>
        <% } %>
        <a href="/" class="inline-block px-6 py-3 text-white bg-blue-500 rounded-lg shadow hover:bg-blue-600 transition-colors">
            Voltar para a Página Inicial
        </a>
    </div>
</div>

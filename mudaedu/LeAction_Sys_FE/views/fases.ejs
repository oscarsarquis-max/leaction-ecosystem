<div id="fases-page">
    <h1>Gerenciar Fases</h1>

    <h2>Adicionar Nova Fase</h2>
    <form id="fases-form">
        <div class="form-group">
            <label for="name_phase">Nome da Fase:</label>
            <input type="text" id="name_phase" name="name_phase" required>
        </div>
        <div class="form-group">
            <label for="desc_phase">Descrição da Fase:</label>
            <textarea id="desc_phase" name="desc_phase"></textarea>
        </div>

        <button type="submit" id="saveOrAddButton">Adicionar</button>

    </form>

    <h2>Buscar Blocos</h2>
    <div class="search-container">
        <input type="text" id="search-input" placeholder="Digite 5+ caracteres para buscar...">
        <button id="search-btn">Buscar</button>
    </div>

    <h2>Lista de Fases</h2>
    <table id="fases-table">
        <thead>
        <tr>
            <th>ID</th>
            <th>Nome</th>
            <th>Descrição</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td colspan="5">Use a busca acima para encontrar blocos.</td>
        </tr>
        </tbody>
    </table>
</div>

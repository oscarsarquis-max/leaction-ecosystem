<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MudaEdu - QG do Inovador</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root {
            --dark-lilac: #5B35D9;
            --lilac: #7060F0;
            --brand-gold: #d97706;
            --gold-soft: #fbbf24;
            --wb-bg: #f8fafc;
            --wb-card: #ffffff;
            --wb-border: #e2e8f0;
            --wb-ink: #1e293b;
            --wb-muted: #64748b;
        }
        body {
            background: var(--wb-bg);
            background-image:
                radial-gradient(circle at 12% 8%, rgba(112, 96, 240,0.06), transparent 42%),
                radial-gradient(circle at 90% 95%, rgba(217,119,6,0.06), transparent 42%);
            min-height: 100vh;
            color: var(--wb-ink);
        }
        /* Whiteboard card: branco, borda sutil, sombra leve */
        .wb-card {
            background: var(--wb-card);
            border: 1px solid var(--wb-border);
            box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 10px 30px rgba(15,23,42,0.05);
        }
        .wb-soft { background: #f8fafc; border: 1px solid var(--wb-border); }
        .wb-input {
            background: #ffffff; border: 1px solid var(--wb-border); color: var(--wb-ink);
            transition: border-color .15s, box-shadow .15s;
        }
        .wb-input::placeholder { color: #94a3b8; }
        .wb-input:focus { outline: none; border-color: var(--lilac); box-shadow: 0 0 0 3px rgba(112, 96, 240,0.12); }
        .title-lilac { color: var(--dark-lilac); }
        .accent-gold { color: var(--brand-gold); }
        .btn-lilac { background: linear-gradient(135deg, var(--dark-lilac), var(--lilac)); color: #fff; transition: filter .15s, transform .15s; }
        .btn-lilac:hover { filter: brightness(1.08); transform: translateY(-1px); }
        .btn-gold { background: linear-gradient(135deg, var(--brand-gold), #f59e0b); color: #fff; transition: filter .15s, transform .15s; }
        .btn-gold:hover { filter: brightness(1.06); transform: translateY(-1px); }
        .btn-ghost { background: #fff; border: 1px solid var(--wb-border); color: var(--dark-lilac); transition: background .15s; }
        .btn-ghost:hover { background: #f1f5f9; }

        .pulse-mic { animation: pulse 1.5s infinite; }
        @keyframes pulse {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.55); }
            70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

        [contenteditable][data-placeholder]:empty:before {
            content: attr(data-placeholder);
            color: #94a3b8;
        }
        /* Scrollbar suave no tema claro */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* Elementos exclusivos do relatório impresso (escondidos na tela) */
        .print-only { display: none; }
        /* Deck do Pitch Elevator: oculto na tela, só aparece na impressão dedicada */
        #pitch-deck { display: none; }

        /* =====================================================================
           📄 RELATÓRIO EXECUTIVO — Print CSS (@media print)
           Fluxo: Cabeçalho → Justificativa/Impacto → 4 Pilares → Experimentos
           ===================================================================== */
        @media print {
            @page { size: A4; margin: 1.5cm; }

            html, body {
                background: #ffffff !important;
                color: #111111 !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            /* Esconde TODA a interface operacional (distrações) */
            header,
            #left-column,
            #ia-empty-state,
            #cmu-block,
            #bloco-block,
            #panel-experimentacao,
            #escolas-block,
            #export-json-block,
            #footer-actions,
            #card-cmu-selecionado,
            #social-card-molde,
            #toast-feedback,
            .no-print,
            button {
                display: none !important;
            }

            /* Mostra os blocos exclusivos do relatório */
            .print-only { display: block !important; }

            /* Container principal ocupa a folha inteira, sem molduras */
            main {
                display: block !important;
                max-width: 100% !important;
                width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                gap: 0 !important;
            }
            #mesa-section {
                box-shadow: none !important;
                border: none !important;
                border-radius: 0 !important;
                padding: 0 !important;
                margin: 0 !important;
                width: 100% !important;
                max-width: 100% !important;
                display: block !important;
            }
            /* Título interno "Mesa de Lapidação..." some na impressão */
            #mesa-section > h2 { display: none !important; }

            /* Remove a moldura tracejada e libera o painel de resultado */
            #result-wrap {
                border: none !important;
                background: #fff !important;
                padding: 0 !important;
                min-height: 0 !important;
            }
            #ia-result-panel {
                display: block !important;
                max-height: none !important;
                overflow: visible !important;
                padding: 0 !important;
            }

            /* Cabeçalho do relatório */
            #print-report-header {
                border-bottom: 3px solid #000;
                padding-bottom: 12px;
                margin-bottom: 22px;
            }
            #print-report-header .rep-kicker {
                font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
                color: #444; font-weight: 700; margin: 0 0 6px;
            }
            #print-report-header .rep-title {
                font-size: 22px; font-weight: 800; color: #000; margin: 0 0 8px; line-height: 1.25;
            }
            #print-report-header .rep-meta {
                font-size: 12px; color: #333; margin: 0;
            }

            /* Títulos de seção corporativos */
            .rep-heading {
                font-size: 13px !important;
                font-weight: 800 !important;
                text-transform: uppercase !important;
                letter-spacing: 0.5px !important;
                color: #000 !important;
                border-bottom: 2px solid #000 !important;
                padding-bottom: 5px !important;
                margin: 22px 0 12px !important;
                display: block !important;
                page-break-after: avoid;
            }

            /* Cartões de conteúdo no modo leitura (alto contraste, sem sombra) */
            #ia-result-panel .p-3,
            #ia-result-panel .p-4 {
                box-shadow: none !important;
                background: #fff !important;
                border: 1px solid #ccc !important;
                border-radius: 4px !important;
                page-break-inside: avoid;
                margin-bottom: 10px;
            }
            #ia-result-panel span,
            #ia-result-panel p,
            #ia-result-panel h4,
            #ia-result-panel strong { color: #111 !important; }
            #ia-result-panel span[class*="text-[9px]"] { font-size: 10px !important; color: #555 !important; }

            #res-titulo { font-size: 16px !important; color: #000 !important; }
            #res-justificativa, #res-impacto { font-size: 12px !important; line-height: 1.5 !important; }

            /* Cada um dos 4 Pilares: nunca cortar no meio da página */
            #res-composicao > div {
                page-break-inside: avoid;
                border: 1px solid #ccc !important;
                border-left: 4px solid #5B35D9 !important;
                background: #fafafa !important;
                padding: 8px 10px !important;
                margin-bottom: 8px;
                font-size: 12px !important;
            }
            #res-composicao strong { color: #000 !important; }

            /* Seção de Experimentos (impressa) */
            #print-experimentos-wrap { margin-top: 18px; }
            .print-exp-card {
                page-break-inside: avoid;
                border: 1px solid #ccc !important;
                border-radius: 4px;
                padding: 10px 12px;
                margin-bottom: 10px;
            }
            .print-exp-card .exp-num {
                font-weight: 800; color: #5B35D9; font-size: 12px; margin-bottom: 4px; display: block;
            }
            .print-exp-card .exp-line { font-size: 12px; color: #111; margin: 3px 0; line-height: 1.45; }
            .print-exp-card .exp-line b { color: #000; }

            /* Rodapé institucional repetido */
            #print-report-footer {
                margin-top: 26px; padding-top: 8px; border-top: 1px solid #999;
                font-size: 10px; color: #666; text-align: center;
            }

            /* Em modo relatório, o deck do pitch nunca aparece */
            #pitch-deck { display: none !important; }
        }

        /* =====================================================================
           🎤 PITCH ELEVATOR — impressão dedicada (paisagem, 1 slide por página)
           Ativada por body.printing-pitch (window.print disparado pelo botão)
           ===================================================================== */
        @page pitch-page { size: A4 landscape; margin: 0; }

        @media print {
            body.printing-pitch * { visibility: hidden !important; }
            body.printing-pitch #pitch-deck,
            body.printing-pitch #pitch-deck * { visibility: visible !important; }

            body.printing-pitch main,
            body.printing-pitch header,
            body.printing-pitch #social-studio-modal,
            body.printing-pitch #social-card-molde,
            body.printing-pitch #toast-feedback { display: none !important; }

            body.printing-pitch #pitch-deck {
                display: block !important;
                position: absolute; left: 0; top: 0; width: 100%;
            }

            .pitch-slide {
                page: pitch-page;
                page-break-after: always;
                break-after: page;
                box-sizing: border-box;
                width: 297mm; height: 209mm;
                padding: 20mm 24mm;
                display: flex; flex-direction: column;
                background: #ffffff; color: #0f172a;
                overflow: hidden;
                -webkit-print-color-adjust: exact; print-color-adjust: exact;
            }
            .pitch-slide:last-child { page-break-after: auto; break-after: auto; }

            .pitch-kicker {
                font-size: 13pt; font-weight: 800; letter-spacing: 1px; text-transform: uppercase;
                color: #5B35D9; margin-bottom: 8mm;
            }
            .pitch-kicker-light { color: #fde68a; }
            .pitch-h2 { font-size: 30pt; font-weight: 900; color: #0f172a; margin: 0 0 10mm; line-height: 1.15; }
            .pitch-h2-light { color: #ffffff; }
            .pitch-body { font-size: 16pt; line-height: 1.55; color: #1e293b; margin: 0; }
            .pitch-body-light { color: rgba(255,255,255,0.95); }

            /* Slide 1 — Capa */
            .pitch-cover {
                justify-content: center; text-align: center; align-items: center;
                background: linear-gradient(135deg, #5B35D9 0%, #6d28d9 48%, #d97706 100%) !important;
                color: #ffffff;
            }
            .pitch-badge {
                background: rgba(255,255,255,0.18); color: #fde68a; font-weight: 800; font-size: 13pt;
                padding: 5mm 11mm; border-radius: 999px; margin-bottom: 12mm;
            }
            .pitch-cover-title { font-size: 40pt; font-weight: 900; color: #fff; margin: 0 0 8mm; line-height: 1.12; }
            .pitch-cover-sub { font-size: 17pt; color: rgba(255,255,255,0.9); max-width: 210mm; margin: 0; }
            .pitch-cover-foot {
                position: absolute; bottom: 16mm; left: 0; right: 0;
                display: flex; align-items: center; justify-content: center; gap: 5mm;
                font-size: 12pt; color: rgba(255,255,255,0.92);
            }
            .pitch-dx {
                width: 12mm; height: 12mm; border-radius: 3mm; background: #fff; color: #5B35D9;
                font-weight: 900; font-size: 14pt; display: inline-flex; align-items: center; justify-content: center;
            }

            /* Slide 3 — Grid dos 4 Pilares */
            .pitch-pilares-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8mm; margin-top: 2mm; }
            .pitch-pilar {
                border: 1px solid #cbd5e1; border-left: 5px solid #5B35D9; border-radius: 3mm;
                padding: 6mm 7mm; background: #f8fafc !important;
            }
            .pitch-pilar h3 { font-size: 13pt; font-weight: 800; color: #5B35D9; margin: 0 0 3mm; }
            .pitch-pilar p { font-size: 11.5pt; line-height: 1.4; color: #334155; margin: 0; }

            /* Slide 4 — Impacto */
            .pitch-impact {
                background: linear-gradient(135deg, #0a2540 0%, #5B35D9 100%) !important;
                color: #ffffff; justify-content: flex-start;
            }
            .pitch-validacao { font-size: 13pt; color: #bae6fd; margin: 8mm 0 0; }
            .pitch-cta {
                margin-top: auto; font-size: 18pt; font-weight: 800; color: #fde68a;
                border-top: 1px solid rgba(255,255,255,0.25); padding-top: 8mm;
            }
        }
    </style>

</head>
<body class="text-slate-700 font-sans">

    <!-- 📱 MOLDE INVISÍVEL DO SOCIAL CARD (renderizado pelo html2canvas) -->
    <div id="social-card-molde" style="position: absolute; left: -9999px; top: 0; width: 800px; height: 800px;
        background: linear-gradient(135deg, #5B35D9 0%, #6d28d9 45%, #d97706 100%);
        font-family: 'Segoe UI', Arial, sans-serif; color: #ffffff; box-sizing: border-box;
        padding: 70px 64px; display: flex; flex-direction: column; justify-content: space-between;
        overflow: hidden;">
        <div style="position: absolute; top: -120px; right: -120px; width: 360px; height: 360px;
            border-radius: 50%; background: rgba(255,255,255,0.07);"></div>
        <div style="position: absolute; bottom: -140px; left: -90px; width: 320px; height: 320px;
            border-radius: 50%; background: rgba(251,191,36,0.12);"></div>

        <div style="position: relative;">
            <span style="display: inline-block; background: rgba(255,255,255,0.16); color: #fde68a;
                font-size: 22px; font-weight: 800; letter-spacing: 0.5px; padding: 12px 24px;
                border-radius: 999px;">💡 Nova Ideia de Inovação Educacional</span>
        </div>

        <div style="position: relative; flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 24px 0;">
            <h1 id="sc-titulo" style="font-size: 60px; line-height: 1.12; font-weight: 900; margin: 0 0 24px;
                color: #ffffff; text-shadow: 0 4px 18px rgba(0,0,0,0.25);">Inovação Educacional</h1>
            <p id="sc-resumo" style="font-size: 27px; line-height: 1.5; font-weight: 400; margin: 0;
                color: rgba(255,255,255,0.92); white-space: pre-line;"></p>
            <div id="sc-selo" style="display: none; margin-top: 26px; align-self: flex-start;
                background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.35);
                border-radius: 999px; padding: 12px 24px; font-size: 22px; font-weight: 700; color: #ffffff;">
                <span style="color:#fde68a;">Inovação liderada por:</span> <span id="sc-selo-nome"></span>
            </div>
        </div>

        <div style="position: relative; border-top: 2px solid rgba(255,255,255,0.25); padding-top: 26px;
            display: flex; align-items: center; gap: 16px;">
            <div style="width: 56px; height: 56px; border-radius: 14px; background: #ffffff; color: #5B35D9;
                font-weight: 900; font-size: 24px; display: flex; align-items: center; justify-content: center;">DX</div>
            <div>
                <div style="font-size: 24px; font-weight: 800;">Gerado via <span style="color:#ffffff;">Muda</span><span style="color:#20B0F0;">Edu</span></div>
                <div style="font-size: 19px; color: #fde68a;">O Motor da Transformação CTDI</div>
            </div>
        </div>
    </div>

    <!-- 🎨 SOCIAL STUDIO MODAL -->
    <div id="social-studio-modal" class="no-print" style="display:none; position: fixed; inset: 0; z-index: 9998;
        background: rgba(15,23,42,0.65); backdrop-filter: blur(4px); align-items: center; justify-content: center; padding: 24px;">
        <div class="wb-card" style="background:#fff; border-radius: 20px; width: 100%; max-width: 940px; max-height: 92vh;
            overflow: hidden; display: flex; flex-direction: column;">
            <!-- Header -->
            <div style="display:flex; justify-content: space-between; align-items: center; padding: 18px 24px;
                border-bottom: 1px solid var(--wb-border);">
                <div>
                    <h3 class="title-lilac" style="font-size: 1.1rem; font-weight: 800; margin: 0;">
                        <i class="fa-solid fa-wand-magic-sparkles accent-gold"></i> Social Studio
                    </h3>
                    <p style="font-size: 0.75rem; color: var(--wb-muted); margin: 2px 0 0;">Personalize sua postagem antes de levar para as redes</p>
                </div>
                <button type="button" onclick="fecharSocialStudio()" class="text-slate-400 hover:text-rose-500 text-xl px-2">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <!-- Body: 2 colunas -->
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 22px; padding: 22px 24px; overflow-y: auto;">
                <!-- Coluna Esquerda: Preview -->
                <div>
                    <span class="title-lilac" style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: .5px; display:block; margin-bottom: 8px;">Pré-visualização</span>
                    <div style="background:#f1f5f9; border:1px solid var(--wb-border); border-radius: 14px; padding: 14px; display:flex; align-items:center; justify-content:center; aspect-ratio: 1/1;">
                        <div id="sc-preview-loading" style="text-align:center; color: var(--wb-muted); font-size: 0.8rem;">
                            <i class="fa-solid fa-spinner fa-spin" style="font-size: 1.4rem;"></i>
                            <p style="margin-top:8px;">Gerando preview...</p>
                        </div>
                        <img id="sc-preview-img" alt="Preview do card" style="display:none; width:100%; height:auto; border-radius: 10px; box-shadow: 0 8px 24px rgba(15,23,42,0.18);">
                    </div>
                </div>

                <!-- Coluna Direita: Editor -->
                <div style="display:flex; flex-direction: column; gap: 14px;">
                    <div>
                        <label class="title-lilac" style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing:.5px; display:block; margin-bottom: 6px;">Nome do Perfil</label>
                        <input type="text" id="sc-input-perfil" class="wb-input rounded-xl p-2.5 text-sm w-full" placeholder="Ex: @colegioinovador" oninput="onPerfilInput()">
                    </div>

                    <div>
                        <label class="title-lilac" style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing:.5px; display:block; margin-bottom: 6px;">Rede Social</label>
                        <select id="sc-select-rede" class="wb-input rounded-xl p-2.5 text-sm w-full" onchange="onRedeChange()">
                            <option value="Instagram">Instagram</option>
                            <option value="LinkedIn">LinkedIn</option>
                        </select>
                    </div>

                    <div style="flex:1; display:flex; flex-direction:column;">
                        <label class="title-lilac" style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing:.5px; display:block; margin-bottom: 6px;">Chamada de Colaboração</label>
                        <textarea id="sc-textarea-legenda" rows="6" class="wb-input rounded-xl p-3 text-sm w-full" style="resize: vertical; flex:1; min-height: 150px;" oninput="onLegendaInput()"></textarea>
                        <span style="font-size: 0.68rem; color: var(--wb-muted); margin-top: 6px; display:block;">
                            <i class="fa-solid fa-circle-info"></i> Este texto aparece no card e também é copiado para a legenda da postagem.
                        </span>
                    </div>
                </div>
            </div>

            <!-- Footer: ação primária -->
            <div style="padding: 16px 24px; border-top: 1px solid var(--wb-border);">
                <button type="button" id="btn-finalizar-social" onclick="finalizarECopiar()" class="btn-gold w-full py-3.5 rounded-xl text-sm font-bold uppercase tracking-wide flex items-center justify-center gap-2">
                    <i class="fa-solid fa-circle-check"></i> Finalizar e Copiar
                </button>
            </div>
        </div>
    </div>

    <!-- 🎤 PITCH ELEVATOR DECK (4 slides) — renderizado apenas na impressão dedicada -->
    <div id="pitch-deck" aria-hidden="true">
        <!-- Slide 1 — Capa -->
        <section class="pitch-slide pitch-cover">
            <div class="pitch-badge">🎤 Pitch de Inovação · Elevator Pitch</div>
            <h1 id="pitch-titulo" class="pitch-cover-title">Inovação Educacional</h1>
            <p id="pitch-sub" class="pitch-cover-sub">Uma tese de transformação digital com o aluno no centro.</p>
            <div class="pitch-cover-foot">
                <span class="pitch-dx">DX</span>
                <span>MudaEdu · Metodologia CTDI &nbsp;·&nbsp; <span id="pitch-data"></span></span>
            </div>
        </section>

        <!-- Slide 2 — A Tese / O Porquê -->
        <section class="pitch-slide">
            <div class="pitch-kicker">01 · A Tese Pedagógica</div>
            <h2 class="pitch-h2">Qual problema estamos resolvendo</h2>
            <p id="pitch-justificativa" class="pitch-body"></p>
        </section>

        <!-- Slide 3 — Como Executamos (4 Pilares) -->
        <section class="pitch-slide">
            <div class="pitch-kicker">02 · Como Executamos</div>
            <h2 class="pitch-h2">Os 4 Pilares de Execução</h2>
            <div id="pitch-pilares" class="pitch-pilares-grid"></div>
        </section>

        <!-- Slide 4 — Impacto & Próximos Passos -->
        <section class="pitch-slide pitch-impact">
            <div class="pitch-kicker pitch-kicker-light">03 · Impacto &amp; Validação</div>
            <h2 class="pitch-h2 pitch-h2-light">Por que isso importa</h2>
            <p id="pitch-impacto" class="pitch-body pitch-body-light"></p>
            <p id="pitch-validacao" class="pitch-validacao"></p>
            <div class="pitch-cta">Vamos colaborar para colocar essa ideia em prática? 🚀</div>
        </section>
    </div>

    <!-- ✅ Toast de feedback -->
    <div id="toast-feedback" style="position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(140%);
        background: #059669; color: #fff; padding: 14px 22px; border-radius: 12px; font-size: 14px; font-weight: 600;
        box-shadow: 0 12px 32px rgba(5,150,105,0.4); z-index: 9999; opacity: 0; transition: transform .35s ease, opacity .35s ease;
        max-width: 420px; text-align: center;"></div>


    <header class="border-b border-slate-200 bg-white/80 backdrop-blur px-8 py-4 flex justify-between items-center shadow-sm sticky top-0 z-40">
        <div class="flex items-center gap-3">
            <div class="p-2 rounded-lg text-xl font-bold text-white btn-lilac">DX</div>
            <div>
                <h1 class="text-lg font-extrabold title-lilac">Oficina do Inovador</h1>
                <p class="text-xs text-slate-500">Espaço criativo de captura e operação pedagógica</p>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <div class="text-xs px-3 py-1.5 rounded-lg wb-soft text-slate-600">
                Cliente Ativo ID: <strong class="title-lilac" id="lbl-cliente-id">{{ id_clie }}</strong>
            </div>

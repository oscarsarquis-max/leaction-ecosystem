        function resetMesaDeLapidacao(mensagem = "Processando alquimia...") {
            document.getElementById('ia-empty-state').classList.add('hidden');
            document.getElementById('ia-result-panel').classList.remove('hidden');
            document.getElementById('res-titulo').innerText = mensagem;
            document.getElementById('res-justificativa').innerText = "";
            document.getElementById('res-impacto').innerText = "";
            document.getElementById('res-composicao').innerHTML = "";

            listaSubtasksLocais = []; // Limpa cache de subtasks
            cacheExperimentosLocais = []; // Evita que o relatório PDF herde experimentos de outra inovação
            renderizarSubtasksLocais();
        }

        async function gerenciarCliquePostIt(idNota, statusNota, event) {
            if (event.target.type === 'checkbox' || event.target.closest('button')) return;
            if (statusNota === 'Incubada') {
                document.querySelectorAll('.chk-nota').forEach(cb => cb.checked = false);
                resetMesaDeLapidacao("Buscando projeto estocado na base...");
                try {
                    const response = await fetch(`/inovador/api/acoes?id_nota=${idNota}`);
                    const resData = await response.json();
                    if (resData.status === 'success' && resData.data) {
                        const acao = resData.data;
                        document.getElementById('hdn-id-acao').value = acao.id_acao;
                        document.getElementById('select-bloco').value = acao.bloco_leaction;
                        document.getElementById('res-titulo').innerText = acao.nome_acao;
                        document.getElementById('res-justificativa').innerText = acao.justificativa_pedagogica;
                        document.getElementById('res-impacto').innerText = acao.impacto_negocio;
                        const schoolsInput = document.getElementById('txt-escolas-ref');
                        if (schoolsInput) schoolsInput.value = acao.codigos_escolas_ref || '';

                        if (acao.id_prob) {
                            cmuSelecionadoLocal = {
                                id_prob: acao.id_prob, grupo_prob: acao.grupo_prob,
                                categoria_prob: acao.categoria_prob, desc_prob: acao.desc_prob,
                                razoes_prob: acao.razoes_prob, solucoes_prob: acao.solucoes_prob
                            };
                            document.getElementById('txt-busca-cmu').value = acao.categoria_prob;
                            mostrarCmuNoPainelBusca(cmuSelecionadoLocal);
                            exibirCardCMUAcoplado();
                        } else { removerClassificacaoCMU(); }

                        rotasMetodologicasSalvas = acao.rotas_metodologicas || [];

                        // 🎯 CARREGA O VETOR DE SUBTASKS E RENDERIZA NA TELA
                        listaSubtasksLocais = acao.subtasks_list || [];
                        renderizarSubtasksLocais();

                        const comp = acao.composicao_estruturada || {};
                        let htmlPilares = '';
                        ORDEM_PILARES.forEach(pilarKey => {
                            // Aceita tanto a chave nova (contencao...) quanto a legada (item_1...)
                            const legada = Object.keys(MAPA_LEGADO).find(k => MAPA_LEGADO[k] === pilarKey);
                            const valor = comp[pilarKey] !== undefined ? comp[pilarKey] : (legada ? comp[legada] : '');
                            if (valor === undefined || valor === null) return;
                            htmlPilares += `<div class="p-2.5 bg-slate-50 rounded-lg border-l-4 border-[#7060F0]"><strong class="title-lilac">${PILARES_FIXOS[pilarKey].label}:</strong> <span contenteditable="true" data-key="${pilarKey}" class="pilar-editavel focus:outline-none px-1 text-slate-700">${valor || ''}</span></div>`;
                        });
                        document.getElementById('res-composicao').innerHTML = htmlPilares;
                        document.getElementById('panel-experimentacao').classList.remove('hidden');
                        carregarHistoricoExperimentos(acao.id_acao);

                        btnSprint.disabled = false; btnSprint.innerText = "Atualizar Projeto / Vínculos";
                        btnSprint.className = "bg-gradient-to-r from-teal-600 to-indigo-600 text-white text-xs font-bold uppercase tracking-wider px-6 rounded-xl shadow-lg cursor-pointer transition-all";
                        btnSprint.onclick = () => dispararLançamentoOuAtualizacao(acao.id_acao, acao.bloco_leaction);
                    }
                } catch (err) { console.error(err); }
            } else {
                const chk = event.currentTarget.querySelector('.chk-nota'); if (chk) chk.checked = !chk.checked;
            }
        }


                            <input type="checkbox" value="${n.id_nota}" ${n.status_nota !== 'Pendente' ? 'disabled' : ''} class="chk-nota accent-[#7060F0] w-3.5 h-3.5 rounded">
                        </div>
                        <div class="flex-1 overflow-hidden mt-2">
                            <span class="text-[8px] bg-white/70 border border-slate-200 px-1.5 py-0.5 rounded text-slate-500 block w-max mb-1 truncate">${n.aula_contexto || 'Sem contexto'}</span>
                            <p class="text-[11px] font-medium leading-relaxed line-clamp-4">${n.conteudo_bruto}</p>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('lbl-cmu-sintoma').innerText = `Sintoma: ${cmuSelecionadoLocal.desc_prob}`;
            document.getElementById('lbl-cmu-remedio').innerHTML = `<strong>Estratégia CMU:</strong> ${cmuSelecionadoLocal.solucoes_prob}`;

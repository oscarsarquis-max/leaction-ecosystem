                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ bloco_leaction: bloco, ids_notas: selecionadas, id_prob_cmu: cmuSelecionadoLocal ? cmuSelecionadoLocal.id_prob : null })
                });
                const resData = await response.json();
                if (resData.status === 'success') {
                    const rascunho = resData.rascunho;
                    const pilares = rascunho.pilares || {};
                    document.getElementById('res-titulo').innerText = rascunho.nome_acao || '';
                    document.getElementById('res-justificativa').innerText = rascunho.justificativa_pedagogica || '';
                    document.getElementById('res-impacto').innerText = rascunho.impacto_negocio || '';

                    // Sempre os 4 pilares fixos, na ordem, com rótulos em português
                    let htmlPilares = '';
                    ORDEM_PILARES.forEach(pilarKey => {
                        const valor = pilares[pilarKey] || '';
                        htmlPilares += `<div class="p-2.5 bg-slate-50 rounded-lg border-l-4 border-[#d97706]"><strong class="title-lilac">${PILARES_FIXOS[pilarKey].label}:</strong> <span contenteditable="true" data-key="${pilarKey}" class="pilar-editavel focus:outline-none px-1 text-slate-700">${valor}</span></div>`;
                    });
                    document.getElementById('res-composicao').innerHTML = htmlPilares; exibirCardCMUAcoplado();

                    btnSprint.disabled = false; btnSprint.innerText = "Lançar Sprint";
                    btnSprint.className = "btn-gold text-xs font-bold uppercase tracking-wider px-6 rounded-xl shadow-lg cursor-pointer transition-all";
                    btnSprint.onclick = () => dispararLançamentoOuAtualizacao(null, bloco);
                } else {
                    // Sem fallback feio: avisamos e devolvemos o painel ao estado inicial
                    alert(resData.message || 'Não foi possível gerar a inovação agora. Tente novamente.');
                    document.getElementById('ia-result-panel').classList.add('hidden');
                    document.getElementById('ia-empty-state').classList.remove('hidden');
                }
            } catch (e) {
                console.error(e);
                alert('Falha de comunicação ao gerar a inovação. Verifique sua conexão e tente novamente.');
                document.getElementById('ia-result-panel').classList.add('hidden');
                document.getElementById('ia-empty-state').classList.remove('hidden');
            } finally { btnIncubar.disabled = false; btnIncubar.innerText = "Lapidar com Consultor LeAction"; }
        });

        if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition; const rec = new SpeechRecognition(); rec.lang = 'pt-BR';
            btnMic.addEventListener('click', () => { btnMic.classList.contains('pulse-mic') ? rec.stop() : rec.start(); });
            rec.onstart = () => { btnMic.classList.add('pulse-mic', 'from-red-500', 'to-rose-600'); micIcon.className = 'fa-solid fa-stop'; };
            rec.onend = () => { btnMic.classList.remove('pulse-mic', 'from-red-500', 'to-rose-600'); micIcon.className = 'fa-solid fa-microphone'; };
            rec.onresult = (e) => { txtNota.value = e.results[0][0].transcript; };
        }

        window.onload = inicializarDashboard;

        function executarLogout() {
            if (confirm("Deseja encerrar a sessão na Oficina do Inovador?")) {
                window.location.href = '/inovador/logout';
            }
        }

        // 🖨️ Gera o Relatório Executivo (PDF) via janela nativa de impressão
        function exportarRelatorioPDF() {
            const painel = document.getElementById('ia-result-panel');
            if (!painel || painel.classList.contains('hidden')) {
                return alert("Abra ou gere uma inovação na Mesa de Lapidação antes de exportar o relatório.");
            }

            // Cabeçalho do relatório
            const titulo = (document.getElementById('res-titulo').innerText || '').trim();
            document.getElementById('print-rep-titulo').innerText = titulo || 'Inovação sem título';
            document.getElementById('print-rep-data').innerText = new Date().toLocaleDateString('pt-BR', {
                day: '2-digit', month: 'long', year: 'numeric'
            });

            // Monta a seção de Experimentos de Validação a partir do cache carregado
            const wrap = document.getElementById('print-experimentos-wrap');
            const body = document.getElementById('print-experimentos-body');
            const experimentos = Array.isArray(cacheExperimentosLocais) ? cacheExperimentosLocais : [];

            if (experimentos.length === 0) {
                body.innerHTML = '<p class="exp-line" style="color:#666;">Nenhum experimento de validação registrado para esta inovação.</p>';
            } else {
                body.innerHTML = experimentos.map((exp, i) => `
                    <div class="print-exp-card">
                        <span class="exp-num">Experimento ${i + 1}</span>
                        <p class="exp-line"><b>Hipótese:</b> ${(exp.hipo_espex || '—')}</p>
                        <p class="exp-line"><b>Experimentação:</b> ${(exp.desc_espex || '—')}</p>
                        <p class="exp-line"><b>Resultados:</b> ${(exp.result_espex || '—')}</p>
                    </div>
                `).join('');
            }
            // A seção sempre compõe o documento (mesmo vazia, registra a validação)
            wrap.classList.remove('hidden');

            window.print();
        }

        // 🎤 Gera um Pitch Elevator (PDF, até 4 slides) com os dados da inovação atual
        function gerarPitchPDF() {
            const painel = document.getElementById('ia-result-panel');
            if (!painel || painel.classList.contains('hidden')) {
                return alert("Abra ou gere uma inovação na Mesa de Lapidação antes de gerar o pitch.");
            }

            const titulo = (document.getElementById('res-titulo').innerText || '').trim() || 'Inovação Educacional';
            const justificativa = (document.getElementById('res-justificativa').innerText || '').trim();
            const impacto = (document.getElementById('res-impacto').innerText || '').trim();

            // Slide 1 — Capa
            document.getElementById('pitch-titulo').innerText = titulo;
            document.getElementById('pitch-data').innerText = new Date().toLocaleDateString('pt-BR', {
                day: '2-digit', month: 'long', year: 'numeric'
            });

            // Slide 2 — A Tese (justificativa pedagógica)
            document.getElementById('pitch-justificativa').innerText =
                justificativa || 'Justificativa pedagógica ainda não preenchida.';

            // Slide 3 — Os 4 Pilares (lê o conteúdo vivo já editado na composição)
            const comp = {};
            document.querySelectorAll('#res-composicao .pilar-editavel').forEach(el => {
                comp[normalizarChavePilar(el.getAttribute('data-key'))] = (el.innerText || '').trim();
            });
            document.getElementById('pitch-pilares').innerHTML = ORDEM_PILARES.map(key => `
                <div class="pitch-pilar">
                    <h3>${PILARES_FIXOS[key].label}</h3>
                    <p>${comp[key] || '—'}</p>
                </div>
            `).join('');

            // Slide 4 — Impacto & Validação
            document.getElementById('pitch-impacto').innerText =
                impacto || 'Impacto no negócio ainda não preenchido.';
            const qtdExp = Array.isArray(cacheExperimentosLocais) ? cacheExperimentosLocais.length : 0;
            document.getElementById('pitch-validacao').innerText = qtdExp > 0
                ? `Validação em andamento: ${qtdExp} experimento(s) desenhado(s) para testar esta tese.`
                : 'Próximo passo: desenhar experimentos de validação para testar a tese na prática.';

            // Ativa o modo de impressão dedicado do pitch (paisagem) e restaura ao fim
            document.body.classList.add('printing-pitch');
            const restaurar = () => {
                document.body.classList.remove('printing-pitch');
                window.removeEventListener('afterprint', restaurar);
            };
            window.addEventListener('afterprint', restaurar);
            setTimeout(() => window.print(), 60);
        }

        // ✅ Toast de feedback (verde por padrão)
        function mostrarToast(mensagem, cor = '#059669') {
            const toast = document.getElementById('toast-feedback');
            if (!toast) return;
            toast.style.background = cor;
            toast.innerText = mensagem;
            toast.style.transform = 'translateX(-50%) translateY(0)';
            toast.style.opacity = '1';
            clearTimeout(window._toastTimer);
            window._toastTimer = setTimeout(() => {
                toast.style.transform = 'translateX(-50%) translateY(140%)';
                toast.style.opacity = '0';
            }, 4200);
        }

        // ✂️ Resume um texto preservando SENTENÇAS INTEIRAS (sempre termina em pontuação, sem "...")
        function resumoPorSentencas(texto, limite = 300) {
            texto = (texto || '').replace(/\s+/g, ' ').trim();
            if (!texto) return '';

            // Quebra em sentenças mantendo a pontuação final (. ! ? …)
            const sentencas = texto.match(/[^.!?…]+[.!?…]+/g);
            if (!sentencas) {
                // Texto sem pontuação: devolve inteiro e garante um ponto final
                return /[.!?…]$/.test(texto) ? texto : texto + '.';
            }

            let resultado = '';
            for (const s of sentencas) {
                const candidato = (resultado ? resultado + ' ' : '') + s.trim();
                // Para antes de estourar o limite, mas nunca corta uma sentença pela metade
                if (resultado && candidato.length > limite) break;
                resultado = candidato;
            }
            // Garante ao menos a primeira sentença inteira, mesmo que seja maior que o limite
            return (resultado || sentencas[0].trim());
        }

        // ====================================================================
        // 🎨 SOCIAL STUDIO — preview, customização e exportação do card social
        // ====================================================================
        const TEMAS_REDE = {
            Instagram: {
                fundo: 'linear-gradient(135deg, #5B35D9 0%, #6d28d9 45%, #d97706 100%)',
                acento: '#fde68a'
            },
            LinkedIn: {
                fundo: 'linear-gradient(135deg, #0a2540 0%, #0e76a8 55%, #5B35D9 100%)',
                acento: '#bae6fd'
            }
        };
        let _previewTimer = null;

        function legendaPadrao(titulo) {
            return `Acabo de estruturar uma nova tese de inovação educacional focada no nosso aluno: ${titulo}. `
                + `Estou usando a Metodologia CTDI e a inteligência do MudaEdu para lapidar isso. `
                + `Rede, o que vocês acham dessa abordagem? Toda colaboração é bem-vinda! 👇 `
                + `#TransformacaoDigital #Educacao #MudaEdu`;
        }

        // Define o título do card a partir da inovação atual (tipografia adaptativa)
        function prepararMoldeBase() {
            const titulo = (document.getElementById('res-titulo').innerText || '').trim() || 'Nova Inovação Educacional';
            const elTitulo = document.getElementById('sc-titulo');
            elTitulo.innerText = titulo;
            elTitulo.style.fontSize = titulo.length > 60 ? '44px' : (titulo.length > 38 ? '52px' : '60px');
            return titulo;
        }

        // Escreve no corpo do card EXATAMENTE o texto editado pelo usuário (com fonte adaptativa)
        function aplicarTextoCard(texto) {
            const elResumo = document.getElementById('sc-resumo');
            const t = (texto || '').trim();
            elResumo.innerText = t;
            const n = t.length;
            let fonte = '29px';
            if (n > 420) fonte = '17px';
            else if (n > 300) fonte = '19px';
            else if (n > 220) fonte = '22px';
            else if (n > 140) fonte = '25px';
            elResumo.style.fontSize = fonte;
        }

        function aplicarTemaRede(rede) {
            const tema = TEMAS_REDE[rede] || TEMAS_REDE.Instagram;
            const molde = document.getElementById('social-card-molde');
            molde.style.background = tema.fundo;
            // Acentos (selo "liderada por" e subtítulo do rodapé) acompanham a rede
            document.querySelectorAll('#sc-selo span:first-child').forEach(el => el.style.color = tema.acento);
        }

        function aplicarSelo(nome) {
            const selo = document.getElementById('sc-selo');
            const nomeEl = document.getElementById('sc-selo-nome');
            const limpo = (nome || '').trim();
            if (limpo) {
                nomeEl.innerText = limpo;
                selo.style.display = 'inline-block';
            } else {
                selo.style.display = 'none';
            }
        }

        async function renderizarCanvasCard() {
            const molde = document.getElementById('social-card-molde');
            return await html2canvas(molde, {
                width: 800, height: 800, scale: 2,
                backgroundColor: null, useCORS: true, logging: false
            });
        }

        // Re-renderiza o preview no modal (debounced para digitação fluida)
        function atualizarPreview() {
            clearTimeout(_previewTimer);
            _previewTimer = setTimeout(async () => {
                const loading = document.getElementById('sc-preview-loading');
                const img = document.getElementById('sc-preview-img');
                try {
                    const canvas = await renderizarCanvasCard();
                    img.src = canvas.toDataURL('image/png');
                    img.style.display = 'block';
                    loading.style.display = 'none';
                } catch (e) {
                    console.error('Erro ao gerar preview:', e);
                    loading.innerHTML = '<p style="color:#dc2626;">Falha ao gerar preview.</p>';
                }
            }, 220);
        }

        function onPerfilInput() {
            aplicarSelo(document.getElementById('sc-input-perfil').value);
            atualizarPreview();
        }

        function onLegendaInput() {
            aplicarTextoCard(document.getElementById('sc-textarea-legenda').value);
            atualizarPreview();
        }

        function onRedeChange() {
            aplicarTemaRede(document.getElementById('sc-select-rede').value);
            atualizarPreview();
        }

        function abrirSocialStudio() {
            const painel = document.getElementById('ia-result-panel');
            if (!painel || painel.classList.contains('hidden')) {
                return alert("Abra ou gere uma inovação na Mesa de Lapidação antes de compartilhar.");
            }
            if (typeof html2canvas === 'undefined') {
                return alert("A biblioteca de geração de imagem ainda está carregando. Tente novamente em instantes.");
            }

            const titulo = prepararMoldeBase();

            // Reseta estado do estúdio
            document.getElementById('sc-input-perfil').value = '';
            document.getElementById('sc-select-rede').value = 'Instagram';
            const legenda = legendaPadrao(titulo);
            document.getElementById('sc-textarea-legenda').value = legenda;
            aplicarTextoCard(legenda); // incorpora o texto da legenda no card desde o início
            aplicarSelo('');
            aplicarTemaRede('Instagram');

            // Mostra modal + estado de loading do preview
            const img = document.getElementById('sc-preview-img');
            img.style.display = 'none';
            document.getElementById('sc-preview-loading').style.display = 'block';
            document.getElementById('social-studio-modal').style.display = 'flex';

            atualizarPreview();
        }

        function fecharSocialStudio() {
            document.getElementById('social-studio-modal').style.display = 'none';
        }

        async function finalizarECopiar() {
            const btn = document.getElementById('btn-finalizar-social');
            const textoOriginal = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processando...';

            const rede = document.getElementById('sc-select-rede').value;
            const legenda = document.getElementById('sc-textarea-legenda').value;

            try {
                const canvas = await renderizarCanvasCard();

                // Download do PNG
                const link = document.createElement('a');
                link.href = canvas.toDataURL('image/png');
                link.download = 'minha_inovacao_mudaedu.png';
                document.body.appendChild(link);
                link.click();
                link.remove();

                // Copia o texto EXATO editado pelo usuário
                let copiou = true;
                try {
                    await navigator.clipboard.writeText(legenda);
                } catch (clipErr) {
                    copiou = false;
                    console.warn('Clipboard indisponível:', clipErr);
                }

                fecharSocialStudio();
                if (copiou) {
                    mostrarToast(`Pronto! A imagem foi salva e seu texto copiado. Abra seu ${rede} e cole!`);
                } else {
                    mostrarToast(`Imagem salva! Copie a legenda manualmente (clipboard bloqueado pelo navegador).`, '#d97706');
                }
            } catch (e) {
                console.error('Erro ao finalizar o social card:', e);
                mostrarToast('Não foi possível gerar a imagem agora. Tente novamente.', '#dc2626');
            } finally {
                btn.disabled = false;
                btn.innerHTML = textoOriginal;
            }
        }

        document.getElementById('btn-exportar-json').addEventListener('click', () => {
            const nomeSprint = document.getElementById('res-titulo').innerText.trim() || "Sprint de Inovacao";
            const justificativa = document.getElementById('res-justificativa').innerText.trim() || "";
            const impacto = document.getElementById('res-impacto').innerText.trim() || "";
            const idMesa = document.getElementById('hdn-id-acao').value || "mesa_preview_" + Math.floor(Math.random() * 10000);
            const formato = document.getElementById('combo-formato-destino').value;
            let nomeArquivo = document.getElementById('txt-nome-arquivo-export').value.trim() || "sprint_exportada";
            if (!nomeArquivo.toLowerCase().endsWith('.json')) nomeArquivo += '.json';

            const bloco = document.getElementById('select-bloco').value;

            // Rótulos/pesos derivados dos 4 pilares fixos (com compatibilidade legada)
            const labelsMap = {};
            const prioridadesMap = {};
            const esforceMap = {};
            Object.keys(PILARES_FIXOS).forEach(k => {
                labelsMap[k] = PILARES_FIXOS[k].label;
                prioridadesMap[k] = PILARES_FIXOS[k].prioridade;
                esforceMap[k] = PILARES_FIXOS[k].esforco;
            });
            Object.keys(MAPA_LEGADO).forEach(legada => {
                const nova = MAPA_LEGADO[legada];
                labelsMap[legada] = PILARES_FIXOS[nova].label;
                prioridadesMap[legada] = PILARES_FIXOS[nova].prioridade;
                esforceMap[legada] = PILARES_FIXOS[nova].esforco;
            });

            let payload = {};

            if (formato === 'Universal') {
                let backlogItens = [];
                document.querySelectorAll('.pilar-editavel').forEach(el => {
                    const key = el.getAttribute('data-key');
                    if (el.innerText.trim()) {

                        // 🎯 FILTRA DO VETOR LOCAL SÓ AS SUBTASKS PERTENCENTES A ESSE PILAR ESPECÍFICO
                        let subtasksDestePilar = listaSubtasksLocais
                            .filter(st => st.pilar_subtask === key)
                            .map(st => ({ "subtask_title": st.desc_subtask }));

                        backlogItens.push({
                            "id_item": `st_${idMesa}_${key.replace('item_', '')}`,
                            "pilar_original": key,
                            "titulo": `Fase: ${labelsMap[key] || key}`,
                            "descricao": el.innerText.trim(),
                            "pontos_esforco_scrum": esforceMap[key] || 5,
                            "prioridade": prioridadesMap[key] || "Media",
                            "status_inicial": "To Do",
                            "subtasks": subtasksDestePilar // 🎯 ARRAY INJETADO DIRETAMENTE NO BACKLOG ITEM
                        });
                    }
                });

                payload = {
                    "metadados": { "origem": "Mesa de Inovação - MudaEdu", "schema_versao": "1.0.0", "gerado_em": new Date().toISOString() },
                    "sprint_exportada": { "id_origem_mesa": idMesa, "nome_sprint": nomeSprint, "meta_da_sprint": `Justificativa Pedagógica: ${justificativa} | Impacto no Negócio: ${impacto}`, "duracao_sugerida_semanas": 2, "backlog_itens": backlogItens }
                };
            } else if (formato === 'Jira') {
                let issues = [];
                document.querySelectorAll('.pilar-editavel').forEach(el => {
                    const key = el.getAttribute('data-key');
                    if (el.innerText.trim()) {

                        // 🎯 FILTRA DO VETOR PARA O JIRA
                        let subtasksDestePilar = listaSubtasksLocais
                            .filter(st => st.pilar_subtask === key)
                            .map(st => ({ "subtask_title": st.desc_subtask }));

                        issues.push({
                            "projectKey": "PROJ", "issueType": "Story", "summary": `[Mesa Inovação] ${labelsMap[key] || key}: ${nomeSprint}`,
                            "description": el.innerText.trim(), "storyPoints": esforceMap[key] || 5,
                            "priority": prioridadesMap[key] === 'Critica' ? 'Highest' : (prioridadesMap[key] === 'Alta' ? 'High' : 'Medium'),
                            "labels": ["mesa-inovacao", bloco],
                            "subtasks": subtasksDestePilar
                        });
                    }
                });
                payload = { "sprint": { "name": nomeSprint, "goal": `Justificativa: ${justificativa} | Impacto: ${impacto}`, "id_origem_mesa": idMesa }, "issues": issues };
            } else if (formato === 'Trello') {
                let cards = [];
                document.querySelectorAll('.pilar-editavel').forEach(el => {
                    const key = el.getAttribute('data-key');
                    if (el.innerText.trim()) {

                        // 🎯 FILTRA DO VETOR PARA O TRELLO
                        let subtasksDestePilar = listaSubtasksLocais
                            .filter(st => st.pilar_subtask === key)
                            .map(st => ({ "subtask_title": st.desc_subtask }));

                        cards.push({
                            "name": `${labelsMap[key] || key} - ${nomeSprint}`,
                            "desc": `Descrição do Backlog:\n${el.innerText.trim()}\n\nPontos de Esforço Scrum: ${esforceMap[key] || 5}`,
                            "labels": [prioridadesMap[key] || "Media"], "pos": "top",
                            "subtasks": subtasksDestePilar
                        });
                    }
                });
                payload = { "list": { "name": nomeSprint }, "cards": cards };
            }

            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(payload, null, 2));
            const downloadAnchorNode = document.createElement('a');
            downloadAnchorNode.setAttribute("href", dataStr);
            downloadAnchorNode.setAttribute("download", nomeArquivo);
            document.body.appendChild(downloadAnchorNode);
            downloadAnchorNode.click();
            downloadAnchorNode.remove();
        });

    </script>
</body>

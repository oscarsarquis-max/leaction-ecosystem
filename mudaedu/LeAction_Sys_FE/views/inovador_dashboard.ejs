        async function executarBuscaMetodologia(termo) {
            const dropdown = document.getElementById('dropdown-resultados-metodo');
            if (termo.trim().length < 2) { dropdown.classList.add('hidden'); cacheMetodologiasAtivas = []; return; }
            try {
                const res = await fetch(`/inovador/api/metodologias/buscar?q=${encodeURIComponent(termo)}`);
                const resData = await res.json();
                if (resData.status === 'success' && resData.data.length > 0) {
                    cacheMetodologiasAtivas = resData.data;
                    dropdown.classList.remove('hidden');
                    dropdown.innerHTML = resData.data.map(item => `
                        <div onclick="selecionarMetodologiaAtivaPorId(${item.id_meta})" class="p-2 border-b border-slate-100 hover:bg-slate-50 cursor-pointer text-left transition-all">
                            <div class="text-[10px] title-lilac font-bold uppercase"><i class="fa-solid fa-graduation-cap mr-1"></i>${item.cate_metodo}</div>
                            <div class="text-xs text-slate-700 mt-0.5 font-semibold">${item.prop_pratico}</div>
                        </div>
                    `).join('');
                } else {
                    dropdown.classList.remove('hidden');
                    dropdown.innerHTML = '<div class="p-2 text-xs text-slate-400 italic">Nenhum catálogo encontrado.</div>';
                }
            } catch(e) { console.error(e); }
        }

        async function selecionarMetodologiaAtivaPorId(idMeta) {
            const meta = cacheMetodologiasAtivas.find(m => m.id_meta === idMeta);
            if (!meta) return;

            document.getElementById('dropdown-resultados-metodo').classList.add('hidden');
            document.getElementById('txt-busca-metodo').value = meta.cate_metodo;

            try {
                const res = await fetch(`/inovador/api/metodologias/praticas?id_meta=${idMeta}`);
                const resData = await res.json();
                if (resData.status === 'success' && resData.data.length > 0) {
                    cachePraticasAtivas = resData.data;
                    const selectPratica = document.getElementById('select-pratica-ativa');

                    selectPratica.innerHTML = '<option value="">-- Escolha uma Prática Ativa --</option>' +
                        resData.data.map(p => `<option value="${p.id_prat}">${p.estra_pratica}</option>`).join('');

                    document.getElementById('wrapper-select-pratica').classList.remove('hidden');

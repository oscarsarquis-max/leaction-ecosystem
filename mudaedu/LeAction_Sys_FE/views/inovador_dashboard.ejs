                const rotation = index % 2 === 0 ? "rotate-1" : "-rotate-1";
                return `
                    <div onclick="gerenciarCliquePostIt(${n.id_nota}, '${n.status_nota}', event)" class="group relative aspect-square p-4 rounded-xl border ${postItColor} ${rotation} shadow-sm flex flex-col justify-between cursor-pointer transition-all duration-200 hover:scale-105 hover:rotate-0 hover:shadow-md">

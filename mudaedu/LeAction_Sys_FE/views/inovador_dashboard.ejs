            cmuSelecionadoLocal = itemEncontrado;
            document.getElementById('dropdown-resultados-cmu').classList.add('hidden');
            document.getElementById('txt-busca-cmu').value = itemEncontrado.categoria_prob;

            mostrarCmuNoPainelBusca(itemEncontrado);
            if (!document.getElementById('ia-result-panel').classList.contains('hidden')) {
                exibirCardCMUAcoplado();

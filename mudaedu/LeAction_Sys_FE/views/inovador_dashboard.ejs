        function renderizarSubtasksLocais() {
            const container = document.getElementById('lista-subtasks-adicionadas');
            if (!container) return;
            if (listaSubtasksLocais.length === 0) {
                container.innerHTML = '<div class="text-[9px] text-slate-500 italic mt-1">Nenhuma subtask vinculada no momento.</div>';
                return;
            }
            container.innerHTML = listaSubtasksLocais.map((st, idx) => `
                <div class="flex justify-between items-center p-2 bg-white border border-slate-200 rounded shadow-sm">
                    <div class="text-[10px] text-slate-600 leading-tight pr-2"><strong class="accent-gold uppercase">[${rotuloPilar(st.pilar_subtask)}]</strong> ${st.desc_subtask}</div>
                    <button type="button" onclick="removerSubtaskLocal(${idx})" class="text-rose-500 hover:text-rose-400 px-2 flex-shrink-0 transition-colors" title="Excluir subtask"><i class="fa-solid fa-trash-can"></i></button>
                </div>
            `).join('');
        }

        function adicionarSubtaskNaLista() {
            if (listaSubtasksLocais.length >= 4) return alert("O limite máximo de planejamento é de 4 subtasks.");
            const txtEl = document.getElementById('txt-nova-subtask');
            const texto = txtEl.innerText.trim();
            if (!texto) return alert("Por favor, descreva a subtask antes de tentar vinculá-la.");

            const radioPilar = document.querySelector('input[name="rd_pilar_subtask"]:checked');
            const pilarVal = radioPilar ? radioPilar.value : 'contencao';

            listaSubtasksLocais.push({ pilar_subtask: pilarVal, desc_subtask: texto });
            txtEl.innerText = ''; // Limpa a caixa após adicionar
            renderizarSubtasksLocais();
        }

        function removerSubtaskLocal(idx) {
            listaSubtasksLocais.splice(idx, 1);
            renderizarSubtasksLocais();
        }


        async function carregarHistoricoExperimentos(idAcao) {
            const container = document.getElementById('container-experimentos-lista');
            if(!container) return; container.innerHTML = '<div class="text-[11px] text-slate-500 italic">Atualizando laboratório...</div>';
            try {
                const res = await fetch(`/inovador/api/experimentos?id_acao=${idAcao}`);
                const resData = await res.json();
                if (resData.status === 'success' && resData.data && resData.data.length > 0) {
                    cacheExperimentosLocais = resData.data;
                    container.innerHTML = resData.data.map(exp => `
                        <div onclick="carregarExperimentoParaEdicao(${exp.id_espex})" class="p-2 bg-white border border-slate-200 rounded-md flex justify-between items-center cursor-pointer hover:bg-slate-50 transition-all" title="Clique para editar">
                            <span class="text-xs text-slate-600 truncate"><i class="fa-solid fa-flask accent-gold mr-2"></i>Exp: ${exp.hipo_espex.substring(0, 50)}...</span>
                            <span class="text-[10px] title-lilac"><i class="fa-solid fa-pen"></i></span>
                        </div>
                    `).join('');
                } else {
                    cacheExperimentosLocais = [];
                    container.innerHTML = '<div class="text-[11px] text-slate-400 italic">Nenhum experimento registrado.</div>';
                }
            } catch(e) { console.error(e); }
        }

        function carregarExperimentoParaEdicao(idEspex) {
            const exp = cacheExperimentosLocais.find(e => e.id_espex === idEspex);
            if(!exp) return;
            document.getElementById('hdn-id-espex').value = exp.id_espex;
            document.getElementById('txt-hipo-espex').innerText = exp.hipo_espex;
            document.getElementById('txt-desc-espex').innerText = exp.desc_espex;
            document.getElementById('txt-result-espex').innerText = exp.result_espex;
            document.getElementById('btn-salvar-experimento').innerText = "Atualizar Experimento";
        }

        async function adicionarExperimentoDescritivo() {
            const idAcao = document.getElementById('hdn-id-acao').value;
            if(!idAcao) return alert("Lance a Sprint ou selecione uma ação incubada antes!");

            const idEspexEdicao = document.getElementById('hdn-id-espex').value;
            const hipo = document.getElementById('txt-hipo-espex').innerText.trim();
            const desc = document.getElementById('txt-desc-espex').innerText.trim();
            const result = document.getElementById('txt-result-espex').innerText.trim();

            if(!hipo || !desc || !result) return alert("Preencha todos os campos do experimento!");

            try {
                const metodo = idEspexEdicao ? 'PUT' : 'POST';
                const payload = { id_acao: parseInt(idAcao), hipo_espex: hipo, desc_espex: desc, result_espex: result };
                if(idEspexEdicao) payload.id_espex = parseInt(idEspexEdicao);

                const response = await fetch('/inovador/api/experimentos', {
                    method: metodo, headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if((await response.json()).status === 'success') {
                    document.getElementById('hdn-id-espex').value = '';
                    document.getElementById('txt-hipo-espex').innerText = '';
                    document.getElementById('txt-desc-espex').innerText = '';
                    document.getElementById('txt-result-espex').innerText = '';
                    document.getElementById('btn-salvar-experimento').innerText = "Adicionar Experimento";
                    carregarHistoricoExperimentos(parseInt(idAcao));
                }
            } catch(e) { console.error(e); }
        }

        async function dispararLançamentoOuAtualizacao(idAcaoOpcional = null, blocoForcado = null) {
            const bloco = blocoForcado || document.getElementById('select-bloco').value;
            let pilaresFinais = {};
            document.querySelectorAll('.pilar-editavel').forEach(el => { pilaresFinais[el.getAttribute('data-key')] = el.innerText.trim(); });
            const selecionadas = Array.from(document.querySelectorAll('.chk-nota:checked')).map(cb => parseInt(cb.value));
            const schoolsInput = document.getElementById('txt-escolas-ref');
            const codigosEsf = schoolsInput ? schoolsInput.value.trim() : "";

            try {
                const response = await fetch('/inovador/api/acoes/salvar', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id_acao: idAcaoOpcional,
                        id_clie: idClieReal,
                        bloco_leaction: bloco,
                        ids_notas: selecionadas,
                        nome_acao: document.getElementById('res-titulo').innerText.trim(),
                        justificativa_pedagogica: document.getElementById('res-justificativa').innerText.trim(),
                        impacto_negocio: document.getElementById('res-impacto').innerText.trim(),
                        composicao_estruturada: pilaresFinais,

        function renderizarNotas() {
            document.getElementById('contador-notas').innerText = notasLocais.length;
            if(notasLocais.length === 0) { containerNotas.innerHTML = `<div class="col-span-2 text-center text-slate-400 text-xs py-8">Nenhum post-it.</div>`; return; }
            containerNotas.innerHTML = notasLocais.map((n, index) => {
                let postItColor = "bg-amber-50 border-amber-200 text-amber-900";

// ==================================================================
// 🔮 RENDERIZAÇÃO INTELIGENTE DO CONSOLE COGNITIVO DO MODULADOR
// ==================================================================
async function carregarListaEvidencias(id_sprn) {
    const corpoTabela = document.getElementById('lista-evidencias-corpo');
    const msgGlobal = document.getElementById('modulador-message-global');
    const statusBox = document.getElementById('modulador-status-global');

    if (!corpoTabela) return;

    try {
        const response = await fetch(`/api/evidencias/${id_sprn}`);
        if (!response.ok) throw new Error(`Erro: ${response.status}`);
        const evidencias = await response.json();

        // Armazena no barramento global para o clique do olho ler instantaneamente
        window.evidenciasCarregadasGlobal = evidencias;

        corpoTabela.innerHTML = '';
        if (evidencias.length === 0) {
            corpoTabela.innerHTML = '<tr><td colspan="4" style="text-align:center; color: #999; padding: 20px;">Nenhum documento comprobatório anexado.</td></tr>';
            if (msgGlobal) msgGlobal.innerHTML = "Aguardando consolidação das comprovações para apoio à auditoria...";
            if (moduladorTimer) { clearTimeout(moduladorTimer); moduladorTimer = null; }
            return;
        }

        let ultimaAnaliseValida = null;
        let precisarAcompanharBackground = false;

        evidencias.forEach(ev => {
            let analise = null;
            if (ev.analise_ia) {
                analise = typeof ev.analise_ia === 'string' ? JSON.parse(ev.analise_ia) : ev.analise_ia;
                if (analise && analise.status_validacao) { ultimaAnaliseValida = analise; }
            }

            let badgeHTML = '';
            let botaoOlhoHTML = '';
            const statusAtual = (ev.status_modulador || 'Pendente').trim();

            // 🚨 SOLUÇÃO: Se estiver Pendente OU Processando, mantém o cronômetro ativo dibrando o delay local
            if (statusAtual === 'Pendente' || statusAtual === 'Processando') {
                precisarAcompanharBackground = true;
            }

            if (statusAtual === 'Pendente') {
                badgeHTML = `<span style="background: #f1f5f9; color: #64748b; padding: 4px 8px; border-radius: 12px; font-size: 0.8em; font-weight: bold;"><i class="fas fa-clock"></i> Pendente</span>`;
            } else if (statusAtual === 'Processando') {
                badgeHTML = `<span style="background: var(--light-lilac); color: var(--dark-lilac); padding: 4px 8px; border-radius: 12px; font-size: 0.8em; font-weight: bold;"><i class="fas fa-sync fa-spin"></i> Analisando...</span>`;
            } else if (statusAtual === 'Avaliado') {
                const corSelo = analise?.status_validacao === 'APROVADO' ? '#27ae60' : '#e67e22';
                const bgSelo = analise?.status_validacao === 'APROVADO' ? '#e8f5e9' : '#fdf5e6';
                badgeHTML = `<span style="background: ${bgSelo}; color: ${corSelo}; padding: 4px 8px; border-radius: 12px; font-size: 0.8em; font-weight: bold;"><i class="fas fa-robot"></i> ${analise?.status_validacao || 'AVALIADO'}</span>`;

                // Botão do olho amarrando o ID limpo
                botaoOlhoHTML = `<button type="button" class="btn-action" style="background: var(--light-lilac); color: var(--dark-lilac); width: auto; display: inline-flex; padding: 5px 10px; margin-right: 4px;" onclick="visualizarAnaliseEspecifica(${ev.id_evid})" title="Ver diagnóstico desta entrega"><i class="fas fa-eye"></i></button>`;
            } else {
                badgeHTML = `<span style="background: #fdedec; color: #e74c3c; padding: 4px 8px; border-radius: 12px; font-size: 0.8em; font-weight: bold;"><i class="fas fa-exclamation-circle"></i> Erro</span>`;
            }

            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td style="padding: 10px; border-bottom: 1px solid #eee;"><strong>${ev.componente_vinculado}</strong></td>
                <td style="padding: 10px; border-bottom: 1px solid #eee;"><a href="${ev.url_evid}" target="_blank" style="color: var(--dark-lilac); font-weight:bold; text-decoration:none;"><i class="fas fa-external-link-alt"></i> Ver Link</a></td>
                <td style="padding: 10px; border-bottom: 1px solid #eee; text-align: center;">${badgeHTML}</td>
                <td style="padding: 10px; border-bottom: 1px solid #eee; text-align: center; display:flex; justify-content:center;">
                    ${botaoOlhoHTML}
                    <button type="button" class="btn-action" style="background: #fdedec; color: #e74c3c; width: auto; display: inline-flex; padding: 5px 10px;" onclick="excluirEvidencia(event, ${ev.id_evid})">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </td>`;
            corpoTabela.appendChild(tr);
        });

        // Atualização do Console do Modulador
        if (msgGlobal && statusBox) {
            if (precisarAcompanharBackground) {
                statusBox.style.background = "var(--light-lilac)"; statusBox.style.borderColor = "var(--dark-lilac)";
                msgGlobal.innerHTML = `<span style="color: var(--dark-lilac); font-weight: 700;"><i class="fas fa-spinner fa-spin"></i> O Modulador identificou novas entradas operacionais. Sincronizando com os agentes assíncronos...</span>`;
            } else if (ultimaAnaliseValida) {
                renderizarPainelCognitivo(ultimaAnaliseValida, msgGlobal, statusBox);
            }
        }

        // Loop Reativo de Polling
        if (precisarAcompanharBackground) {
            if (!moduladorTimer) {
                moduladorTimer = setTimeout(() => {
                    moduladorTimer = null;
                    carregarListaEvidencias(id_sprn);
                }, 3000);
            }
        } else if (moduladorTimer) {
            clearTimeout(moduladorTimer);
            moduladorTimer = null;
        }

    } catch (error) { console.error(error); }
}

async function excluirEvidencia(event, id_evid) {
    if (event) { event.preventDefault(); event.stopPropagation(); }
    if (!confirm("Tem certeza que deseja remover este vínculo?")) return;

    try {
        const response = await fetch(`/api/evidencias/${id_evid}`, { method: 'DELETE' });
        if (response.ok) {
            alert("Vínculo removido com sucesso!");
            const hiddenId = document.getElementById('exec_id_sprn').value;
            carregarListaEvidencias(hiddenId);
        } else { alert("Erro ao excluir."); }
    } catch (error) { alert("Erro de conexão."); }
}

function escapeHtml(str) {
    return String(str == null ? '' : str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

function nomeArquivoDeUrl(url) {
    try {
        const clean = String(url || '').split('?')[0];
        const parts = clean.split('/').filter(Boolean);
        const last = parts[parts.length - 1] || clean;
        return decodeURIComponent(last);
    } catch (_) {
        return String(url || 'documento');
    }
}

function dispararUploadMetrica(btn) {
    const card = btn.closest('.metric-proof-card');
    const input = card?.querySelector('.metric-doc-file');
    if (input) input.click();
}

async function uploadDocumentoMetrica(input) {
    const file = input.files && input.files[0];
    if (!file) return;
    const card = input.closest('.metric-proof-card');
    if (!card) return;
    const btn = card.querySelector('.metric-doc-upload-btn');
    const nameEl = card.querySelector('.metric-doc-name');
    const hidden = card.querySelector('.metric-doc-url');
    const original = btn ? btn.innerHTML : '';
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
    }
    try {
        const fd = new FormData();
        fd.append('documento', file);
        const res = await fetch('/api/sprints/metricas/upload', { method: 'POST', body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.url) {
            throw new Error(data.error || 'Falha no upload do documento.');
        }
        if (hidden) hidden.value = data.url;
        const label = data.filename || nomeArquivoDeUrl(data.url);
        if (nameEl) {
            const a = document.createElement('a');
            a.className = 'metric-doc-name';
            a.href = data.url;
            a.target = '_blank';
            a.rel = 'noopener';
            a.style.cssText = 'font-size:0.82em; color:var(--dark-lilac); font-weight:600; word-break:break-all;';
            a.innerHTML = `<i class="fas fa-paperclip"></i> ${escapeHtml(label)}`;
            nameEl.replaceWith(a);
        }
    } catch (err) {
        alert(err.message || 'Erro ao enviar arquivo.');
        input.value = '';
    } finally {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = original;
        }
    }
}

function renderMetricProofCard(entrega, isConcluida) {
    const id = entrega.id_metrica || entrega.id;
    const status = entrega.status || 'pendente_envio';
    const label = entrega.status_label || status;
    const doc = entrega.documento_url || '';
    const dep = entrega.depoimento || '';
    const temNota = entrega.nota_qualidade != null && entrega.nota_qualidade !== '';
    const nota = temNota ? Math.round(Number(entrega.nota_qualidade)) : 0;
    const readonlyAttr = isConcluida ? 'disabled' : '';
    const temProva = !!(doc || dep);

    // Nota ao lado do nome da métrica
    const notaBadge = temNota
        ? `<span class="metric-nota-badge" style="margin:0;"><i class="fas fa-star"></i> ${nota}%</span>`
        : `<span class="metric-nota-empty" style="margin:0;">Sem nota</span>`;

    const podeRevisarAgora = PODE_AVALIAR_METRICAS && REVISAO_CONSULTOR_ATIVA;

    let evidenciaHtml = '';
    if (PODE_AVALIAR_METRICAS) {
        evidenciaHtml = temProva ? `
            <div style="background:#fff; border:1px solid var(--border-lilac); border-radius:8px; padding:10px 12px; font-size:0.84em; color:#334155;">
                <small style="font-weight:800; color:var(--dark-lilac); text-transform:uppercase; font-size:0.7em; display:block; margin-bottom:6px;">Comprovação do Cliente</small>
                ${doc ? `<div><strong>Documento:</strong> <a href="${escapeHtml(doc)}" target="_blank" rel="noopener">${escapeHtml(doc)}</a></div>` : ''}
                ${dep ? `<div style="margin-top:6px;"><strong>Depoimento:</strong> ${escapeHtml(dep)}</div>` : ''}
            </div>
        ` : `<div style="font-size:0.84em; color:#94a3b8; padding:8px 0;">Aguardando comprovação do Cliente nesta métrica.</div>`;
    } else {
        evidenciaHtml = `
            <div style="display:grid; gap:8px;">
                <div>
                    <label style="font-size:0.75em; font-weight:700;">Anexar Documento</label>
                    <input type="hidden" class="metric-doc-url" value="${escapeHtml(doc)}">
                    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-top:4px;">
                        <button type="button" class="btn-action btn-purple-dark metric-doc-upload-btn"
                                style="height:36px; font-size:0.82em; padding:0 14px;"
                                onclick="dispararUploadMetrica(this)" ${readonlyAttr}>
                            <i class="fas fa-upload"></i> Enviar arquivo
                        </button>
                        <input type="file" class="metric-doc-file" style="display:none;"
                               accept=".pdf,.png,.jpg,.jpeg,.webp,.gif,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,application/pdf,image/*"
                               onchange="uploadDocumentoMetrica(this)" ${readonlyAttr}>
                        ${doc
                            ? `<a class="metric-doc-name" href="${escapeHtml(doc)}" target="_blank" rel="noopener"
                                  style="font-size:0.82em; color:var(--dark-lilac); font-weight:600; word-break:break-all;">
                                   <i class="fas fa-paperclip"></i> ${escapeHtml(nomeArquivoDeUrl(doc))}
                               </a>`
                            : `<span class="metric-doc-name" style="font-size:0.82em; color:#94a3b8;">Nenhum arquivo</span>`
                        }
                    </div>
                </div>
                <div>
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px; gap:8px;">
                        <label style="font-size:0.75em; font-weight:700; margin:0;">Registrar Depoimento (Texto)</label>
                        <button type="button" class="btn-voice-depoimento" onclick="alternarVozDepoimentoMetrica(${id})"
                                style="background:#fff; border:1px solid var(--border-lilac); color:var(--dark-lilac); cursor:pointer; display:flex; align-items:center; gap:6px; padding:4px 10px; border-radius:20px;"
                                ${readonlyAttr}>
                            <i class="fas fa-microphone mic-icon-depoimento"></i>
                            <small class="mic-status-depoimento" style="font-weight:800; text-transform:uppercase; font-size:0.7em; color:var(--text-gray);">Ditado Desligado</small>
                        </button>
                    </div>
                    <textarea class="metric-depoimento" rows="3" placeholder="Clique no microfone para ditar ou digite o depoimento..." ${readonlyAttr}>${escapeHtml(dep)}</textarea>
                </div>
                ${!isConcluida ? `
                    <button type="button" class="btn-action btn-purple-dark" style="height:40px; font-size:0.88em;"
                            onclick="submeterMetricaParaAnalise(${id}, this)">
                        <i class="fas fa-gavel"></i> Submeter esta métrica para análise
                    </button>` : ''}
            </div>
        `;
    }

    let revisaoHtml = '';
    if (podeRevisarAgora) {
        revisaoHtml = `
            <div style="border-top:1px solid var(--border-lilac); padding-top:12px; margin-top:2px; display:grid; gap:10px;">
                <small style="font-weight:800; color:#c2410c; text-transform:uppercase; font-size:0.72em;">
                    Revisão excepcional (solicitada pelo Cliente)
                </small>
                <div style="display:flex; align-items:center; gap:10px;">
                    <label style="font-size:0.78em; font-weight:700; white-space:nowrap;">Revisar nota 0–100</label>
                    <input type="range" class="metric-mod-range" data-id-metrica="${id}"
                           value="${nota}" min="0" max="100" style="flex:1;" ${readonlyAttr}
                           ${(!temProva || isConcluida) ? 'disabled' : ''}
                           oninput="this.nextElementSibling.innerText = this.value + '%'">
                    <span style="font-size:0.9em; font-weight:bold; color:#c2410c; width:44px; text-align:right;">${nota}%</span>
                </div>
                ${!isConcluida ? `
                    <button type="button" class="btn-action" style="background:#c2410c; color:#fff; height:40px;"
                            ${!temProva ? 'disabled' : ''}
                            onclick="salvarAvaliacaoMetrica(${id}, this)">
                        <i class="fas fa-user-tie"></i> Revisar nota desta métrica
                    </button>` : ''}
            </div>
        `;
    }

    return `
        <div class="metric-proof-card" data-id-metrica="${id}" style="opacity:${isConcluida ? '0.75' : '1'}; border:1px solid var(--border-lilac); background:#fff;">
            <div style="display:flex; justify-content:space-between; gap:10px; align-items:center; flex-wrap:wrap;">
                <label style="font-size:0.92em; font-weight:800; color:var(--text-dark); margin:0;">${escapeHtml(entrega.metrica_rotulo || '')}</label>
                <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                    ${notaBadge}
                    <span class="metric-status-badge ${status}">${escapeHtml(label)}</span>
                </div>
            </div>
            ${evidenciaHtml}
            ${revisaoHtml}
        </div>
    `;
}

function atualizarUIRevisaoConsultor(data) {
    const solicitada = !!(data && data.revisao_consultor_solicitada);
    REVISAO_CONSULTOR_ATIVA = solicitada;

    const barra = document.getElementById('barra-revisao-consultor');
    const btnSolicitar = document.getElementById('btn-solicitar-revisao');
    const btnFinalizar = document.getElementById('btn-finalizar-revisao');
    const statusEl = document.getElementById('status-revisao-consultor');
    const avisoCom = document.getElementById('aviso-consultor-revisao');
    const avisoSem = document.getElementById('aviso-consultor-sem-pedido');

    if (barra) {
        // Cliente vê a barra quando há progresso/nota do modulador (ou sempre, para poder pedir)
        barra.style.display = PODE_ENCERRAR_SPRINT ? 'block' : 'none';
    }
    if (btnSolicitar) btnSolicitar.style.display = (PODE_ENCERRAR_SPRINT && !solicitada) ? 'inline-flex' : 'none';
    if (btnFinalizar) btnFinalizar.style.display = (PODE_ENCERRAR_SPRINT && solicitada) ? 'inline-flex' : 'none';
    if (statusEl) {
        statusEl.textContent = solicitada
            ? ('Revisão solicitada' + (data.revisao_consultor_motivo ? `: ${data.revisao_consultor_motivo}` : '. Aguardando consultor.'))
            : '';
    }
    if (avisoCom) avisoCom.style.display = (PODE_AVALIAR_METRICAS && solicitada) ? 'block' : 'none';
    if (avisoSem) avisoSem.style.display = (PODE_AVALIAR_METRICAS && !solicitada) ? 'block' : 'none';
}

async function solicitarRevisaoConsultor() {
    if (!PODE_ENCERRAR_SPRINT) return alert('Apenas o Cliente solicita revisão do consultor.');
    const id = document.getElementById('exec_id_sprn')?.value;
    if (!id) return;
    const motivo = (document.getElementById('motivo-revisao-consultor')?.value || '').trim();
    try {
        const res = await fetch('/api/sprints/revisao-consultor/solicitar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_sprn: parseInt(id, 10), motivo: motivo || null })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Falha ao solicitar revisão');
        alert('Revisão do consultor solicitada. Ele poderá ajustar a nota do Modulador.');
        await abrirPainelSprint(id);
    } catch (err) {
        alert(err.message || 'Erro ao solicitar revisão.');
    }
}

async function finalizarRevisaoConsultor() {
    const id = document.getElementById('exec_id_sprn')?.value;
    if (!id) return;
    try {
        const res = await fetch('/api/sprints/revisao-consultor/finalizar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_sprn: parseInt(id, 10) })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Falha ao finalizar revisão');
        alert('Ciclo de revisão encerrado. A pontuação vigente permanece a última registrada.');
        await abrirPainelSprint(id);
    } catch (err) {
        alert(err.message || 'Erro ao finalizar revisão.');
    }
}

function mostrarFeedbackFechamento(msg) {
    const box = document.getElementById('fechamento-feedback');
    if (!box) return;
    if (!msg) {
        box.style.display = 'none';
        box.textContent = '';
        return;
    }
    box.style.display = 'block';
    box.textContent = msg;
}

function atualizarProgresso(valor) {
    let media = 0;
    if (valor != null && valor !== '') {
        media = Math.round(parseFloat(String(valor).replace('%', '')) || 0);
    } else {
        const label = document.getElementById('progress-label');
        media = parseInt((label?.innerText || '0').replace('%', ''), 10) || 0;
    }
    const bar = document.getElementById('progress-bar-exec');
    const lab = document.getElementById('progress-label');
    if (bar) bar.style.width = media + '%';
    if (lab) lab.innerText = media + '%';
}

async function submeterMetricaParaAnalise(idMetrica, btn) {
    if (!PODE_ENCERRAR_SPRINT) {
        return alert('Apenas o Cliente submete métricas para análise.');
    }
    const card = btn.closest('.metric-proof-card');
    if (!card) return;
    const documento_url = (card.querySelector('.metric-doc-url')?.value || '').trim();
    const depoimento = (card.querySelector('.metric-depoimento')?.value || '').trim();
    if (!documento_url && !depoimento) {
        return alert('Informe ao menos um documento (link) ou um depoimento para esta métrica.');
    }
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Registrando comprovação...';
    try {
        const res = await fetch('/api/sprints/metricas/submeter-analise', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_metrica: idMetrica, documento_url, depoimento })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Falha na análise da métrica');
        if (data.progresso_qualidade != null) atualizarProgresso(data.progresso_qualidade);
        const idSprn = document.getElementById('exec_id_sprn')?.value;
        if (idSprn) await abrirPainelSprint(idSprn);
        else alert(`Nota da métrica: ${data.nota}%`);
    } catch (err) {
        alert(err.message || 'Erro ao submeter métrica para análise.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = original;
    }
}

async function salvarComprovacaoMetrica(idMetrica, btn) {
    // Mantido por compatibilidade — preferir submeterMetricaParaAnalise
    return submeterMetricaParaAnalise(idMetrica, btn);
}

async function salvarAvaliacaoMetrica(idMetrica, btn) {
    const card = btn.closest('.metric-proof-card');
    const range = card?.querySelector('.metric-mod-range');
    const nota = parseInt(range?.value || '0', 10);
    btn.disabled = true;
    try {
        const res = await fetch('/api/sprints/metricas/avaliar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_metrica: idMetrica, nota_qualidade: nota })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Falha ao avaliar');
        atualizarProgresso(data.progresso_qualidade);
        const idSprn = document.getElementById('exec_id_sprn')?.value;
        if (idSprn) await abrirPainelSprint(idSprn);
        else alert('Avaliação salva.');
    } catch (err) {
        alert(err.message || 'Erro ao salvar avaliação.');
    } finally {
        btn.disabled = false;
    }
}

function coletarDodItensDoDom() {
    return Array.from(document.querySelectorAll('.dod-checkbox')).map((cb) => ({
        id: cb.dataset.dodId ? parseInt(cb.dataset.dodId, 10) : null,
        criterio_chave: cb.dataset.dodChave || null,
        concluido: !!cb.checked,
    }));
}

async function adicionarEvidencia() {
    const url = document.getElementById('evid_url').value;
    const comp = document.getElementById('evid_componente').value;

    if (!url || !comp) return alert("Selecione o componente e cole o link do arquivo.");
    if (!url.includes("drive.google.com") && !url.includes("sharepoint.com")) {
        if (!confirm("O link não parece ser do Drive ou SharePoint. Deseja vincular mesmo assim?")) return;
    }
    salvarVinculoNoBanco(url, comp);
}

async function salvarVinculoNoBanco(url, comp) {
    const id_sprn = document.getElementById('exec_id_sprn').value;
    try {
        const response = await fetch('/api/evidencias/vincular', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_sprn: id_sprn, url_evidencia: url, componente: comp })
        });
        const result = await response.json();
        if (response.ok) {
            alert("✅ Evidência vinculada com sucesso!");
            document.getElementById('evid_url').value = "";
            carregarListaEvidencias(id_sprn);
        } else { throw new Error(result.error); }
    } catch (err) { alert("Erro ao salvar vínculo: " + err.message); }
}


// --- FUNÇÃO DO OLHO: CARREGA O PAYLOAD DO DOCUMENTO SELECIONADO NO CARD LATERAL ---
function visualizarAnaliseEspecifica(idEvid) {
    console.log("🔍 [OLHO] Evento de clique disparado para a Evidência ID:", idEvid);

    const msgGlobal = document.getElementById('modulador-message-global');
    const statusBox = document.getElementById('modulador-status-global');

    if (!window.evidenciasCarregadasGlobal) {
        console.error("❌ [OLHO] Erro: A memória global window.evidenciasCarregadasGlobal está vazia.");
        return alert("Erro: O barramento de memória global das evidências não foi inicializado.");
    }

    // Busca flexível (==) para dibrar divergências latentes de String vs Number
    const ev = window.evidenciasCarregadasGlobal.find(item => item.id_evid == idEvid);

    if (!ev) {
        console.error("❌ [OLHO] Erro: Evidência não localizada na lista em memória para o ID:", idEvid);
        return alert("Inconsistência: O registro clicado não foi encontrado na memória ativa da página.");
    }

    console.log("📄 [OLHO] Registro localizado com sucesso no front-end:", ev);

    if (!ev.analise_ia) {
        console.warn("⚠️ [OLHO] Aviso: O campo analise_ia está nulo ou vazio no banco para este ID.");
        return alert("Este documento ainda não possui um parecer técnico consolidado pelo Agente Modulador.");
    }

    try {
        console.log("🔮 [OLHO] Tentando decodificar o payload de analise_ia...");
        // Se já for um objeto por conta do serializer do Flask, usa direto; senão, faz o parse do JSON string
        const analise = typeof ev.analise_ia === 'string' ? JSON.parse(ev.analise_ia) : ev.analise_ia;

        console.log("✅ [OLHO] JSON parseado com sucesso! Chamando renderizador...", analise);
        renderizarPainelCognitivo(analise, msgGlobal, statusBox);

    } catch (jsonErr) {
        console.error("❌ [OLHO CRÍTICO] Erro de parser no JSON enviado pelo Claude:", jsonErr);
        console.error("📦 Conteúdo problemático bruto encontrado:", ev.analise_ia);
        alert("Erro de Formatação: O parecer gerado pelo Consultor LeAction contém quebras de linha ou caracteres que corromperam o JSON. Verifique o console F12.");
    }
}

// --- RENDERIZADOR DO CONSOLE COGNITIVO LATERAL ---
function renderizarPainelCognitivo(analise, msgGlobal, statusBox) {
    if (!analise || !msgGlobal || !statusBox) {
        console.error("❌ [RENDERIZADOR] Elementos visuais da árvore DOM não encontrados.");
        return;
    }

    console.log("🧠 [MODULADOR UI] Injetando dados de auditoria na interface do Console.");

    const statusValidado = analise.status_validacao || "REVISÃO_NECESSÁRIA";
    const isAprovado = statusValidado === 'APROVADO';

    // Altera dinamicamente as cores com base no pilar de conformidade
    statusBox.style.background = isAprovado ? "#e8f5e9" : "#fdf5e6";
    statusBox.style.borderColor = isAprovado ? "#27ae60" : "#e67e22";

    const feedback = analise.feedback_conversacional || "Documentação avaliada com sucesso.";
    const valorFinanceiro = analise.impacto_financeiro_estimado?.retorno_financeiro_mensal || 0;
    const paybackEstimado = analise.impacto_financeiro_estimado?.roi_presumido_projeto || "Em apuração.";

    msgGlobal.innerHTML = `
        <div style="margin-top: 2px;">
            <span style="font-size: 1.05em; color: var(--text-dark); display: block; line-height: 1.4; font-weight: 500; margin-bottom: 15px; font-style: italic;">
                "${feedback}"
            </span>
            <div style="display: grid; grid-template-columns: 1fr; gap: 10px; border-top: 1px dashed rgba(0,0,0,0.1); padding-top: 12px;">
                <div style="background: var(--pure-white); padding: 12px; border-radius: 6px; border:1px solid var(--border-lilac);">
                    <small style="font-weight: 900; color: #27ae60; font-size: 0.7em; text-transform: uppercase; display: block;"><i class="fas fa-money-bill-wave"></i> Eficiência Mapeada</small>
                    <strong style="font-size: 1.3em; color: #27ae60; display:block; margin-top:2px;">
                        + R$ ${valorFinanceiro.toLocaleString('pt-BR', {minimumFractionDigits: 2})} <span style="font-size:0.6em; color:var(--text-gray);">/mês</span>
                    </strong>
                </div>
                <div style="background: var(--pure-white); padding: 10px; border-radius: 6px; border:1px solid #eee;">
                    <small style="font-weight: 900; color: var(--text-dark); font-size: 0.7em; text-transform: uppercase; display: block;"><i class="fas fa-chart-line"></i> ROI / Payback</small>
                    <span style="font-size: 0.88em; color: var(--text-dark); font-weight: 700; display: block; margin-top: 2px;">
                        ${paybackEstimado}
                    </span>
                </div>
            </div>
        </div>`;
}

function fecharModalSprint() {
    if (moduladorTimer) {
        clearTimeout(moduladorTimer);
        moduladorTimer = null;
    }
    document.getElementById('modal-sprint-exec').style.display = 'none';
}

async function salvarExecucaoSprint(e) {
    if (e) e.preventDefault();
    if (!PODE_ENCERRAR_SPRINT) {
        return alert('Apenas o Cliente salva a evolução operacional e solicita o encerramento. O Moderador apenas pontua as métricas.');
    }
    const id = document.getElementById('exec_id_sprn')?.value;
    if (!id) return alert("Erro: ID da sprint não encontrado.");

    const dodItens = coletarDodItensDoDom();
    const payload = {
        id_sprn: id,
        swot_type: document.getElementById('exec_swot_type')?.value || "Fraqueza",
        swot_justification: document.getElementById('exec_swot_justification')?.value || "Atualização unificada via painel do modulador.",
        evidence_url: document.getElementById('exec_evidence_url')?.value || "",
        exec_notes: document.getElementById('exec_notes')?.value || "Processamento via esteira de inteligência.",
        dod_itens: dodItens,
        status: 'em_andamento'
    };

    try {
        const res = await fetch('/api/ctdi_sprn/update-strategic', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const errData = await res.json().catch(() => ({}));
        if (res.ok) {
            alert("Evolução Salva com Sucesso!");
            if (errData.progresso_qualidade != null) atualizarProgresso(errData.progresso_qualidade);
        } else {
            alert("Erro ao salvar: " + (errData.error || "Erro desconhecido"));
        }
    } catch (err) { alert("Erro de comunicação com o servidor."); }
}

async function encerrarSprintCliente() {
    if (!PODE_ENCERRAR_SPRINT) {
        return alert('Apenas o Cliente pode encerrar a Sprint.');
    }
    const id = document.getElementById('exec_id_sprn')?.value;
    if (!id) return alert("Erro: ID da sprint não encontrado.");

    const checkboxes = document.querySelectorAll('.dod-checkbox');
    const temCheckboxes = checkboxes.length > 0;
    const todosMarcados = temCheckboxes && Array.from(checkboxes).every(cb => cb.checked);
    if (temCheckboxes && !todosMarcados) {
        mostrarFeedbackFechamento('Para encerrar a Sprint, 100% dos critérios DoD precisam estar marcados.');
        return alert('Marque todos os critérios DoD antes de encerrar.');
    }

    const notaAtual = parseInt(document.getElementById('progress-label').innerText.replace('%', ''), 10) || 0;
    if (notaAtual < 80) {
        mostrarFeedbackFechamento(MSG_QUALIDADE_ABAIXO_80);
        return alert(MSG_QUALIDADE_ABAIXO_80);
    }

    if (!confirm('Confirma o encerramento desta Sprint? Requisitos: DoD 100% e qualidade média ≥ 80%.')) return;

    const btn = document.getElementById('btn-encerrar-sprint');
    if (btn) btn.disabled = true;
    try {
        const res = await fetch('/api/sprints/fechar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                id_sprn: id,
                dod_itens: coletarDodItensDoDom(),
            })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
            const msg = data.error || data.mensagem || 'Não foi possível encerrar a Sprint.';
            if (data.codigo === 'qualidade_abaixo' || (data.qualidade_ok === false) || /abaixo de 80/i.test(msg)) {
                mostrarFeedbackFechamento(MSG_QUALIDADE_ABAIXO_80);
                alert(MSG_QUALIDADE_ABAIXO_80);
            } else {
                mostrarFeedbackFechamento(msg);
                alert(msg);
            }
            return;
        }
        alert('Sprint encerrada com sucesso!');
        location.reload();
    } catch (err) {
        alert('Erro de comunicação com o servidor.');
    } finally {
        if (btn) btn.disabled = false;
    }
}


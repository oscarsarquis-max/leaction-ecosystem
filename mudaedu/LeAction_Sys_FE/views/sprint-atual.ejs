<script>
function normStatKanbanClient(s) {
    return String(s || '').toLowerCase().trim().replace(/\s+/g, '_');
}
function isStatConcluidaClient(s) {
    const n = normStatKanbanClient(s);
    return ['concluida', 'concluido', 'finalizada'].indexOf(n) >= 0;
}

// 🎯 GATILHOS DA MESA DE INOVAÇÃO (MÓDULO DE GESTÃO)

/** Consome sprint pendente da Mesa de Inovação Organizacional (sessionStorage). */
async function consumirSprintMesaOrganizacional() {
    let raw;
    try {
        raw = sessionStorage.getItem('paneldx_mesa_org_sprint');
    } catch (e) {
        return;
    }
    if (!raw) return;

    try {
        const body = JSON.parse(raw);
        const idClieAtual = document.getElementById('id_cliente_hidden')?.value
            || document.getElementById('id_matu_hidden')?.value
            || '<%= lead.id_clie || "" %>';

        const response = await fetch('/api/sprints/importar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                id_clie: parseInt(body.id_clie, 10) || parseInt(idClieAtual, 10) || 0,
                payload_sprint: body.payload_sprint || body
            })
        });
        const result = await response.json();
        sessionStorage.removeItem('paneldx_mesa_org_sprint');

        if (response.ok && (result.success || result.status === 'success')) {
            window.location.reload();
        } else {
            console.warn('Falha ao materializar sprint da mesa org:', result);
        }
    } catch (err) {
        console.error('Erro ao consumir sprint da mesa org:', err);
    }
}

document.addEventListener('DOMContentLoaded', function () {
    const params = new URLSearchParams(window.location.search);
    if (params.get('origem') === 'mesa-org' && params.get('criada') === '1') {
        return; // Sprint já criada via POST direto da mesa
    }
    consumirSprintMesaOrganizacional();
});

function iniciarImportacaoDX() {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';

    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = async (event) => {
            try {
                const jsonCarregado = JSON.parse(event.target.result);

                const idClieAtual = document.getElementById('id_cliente_hidden') ?
                                    document.getElementById('id_cliente_hidden').value : '999';

                const response = await fetch('/api/sprints/importar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id_clie: parseInt(idClieAtual),
                        payload_sprint: jsonCarregado
                    })
                });

                const result = await response.json();

                if (response.ok && (result.success || result.status === 'success')) {
                    alert("✅ Sprint de Inovação importada com sucesso!");
                    window.location.reload();
                } else {
                    alert("Erro ao importar a Sprint: " + (result.error || result.message));
                }
            } catch (err) {
                alert("Erro crítico: O arquivo não é um JSON válido da Mesa de Inovação.");
                console.error(err);
            }
        };

        reader.readAsText(file);
    };

    input.click();
}

async function devolverSprintRelatorio(idSprn, btn) {
    if (window.PanelRelatorioBlocos && typeof window.PanelRelatorioBlocos.devolverAoBacklog === 'function') {
        return window.PanelRelatorioBlocos.devolverAoBacklog(idSprn, btn);
    }
    if (!idSprn) return;
    const el = btn || null;
    if (el) {
        el.disabled = true;
        el.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Devolvendo…';
    }
    try {
        const response = await fetch('/api/sprints/devolver-relatorio', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_sprn: parseInt(idSprn, 10) })
        });
        const result = await response.json();
        if (response.ok && result.success) {
            window.location.reload();
        } else {
            if (el) el.disabled = false;
            alert(result.error || 'Não foi possível devolver ao backlog.');
        }
    } catch (err) {
        if (el) el.disabled = false;
        alert('Erro de conexão ao devolver ao backlog.');
    }
}

function fecharModalPlanejamentoDX() {
    const modal = document.getElementById('modal-planejamento-dx');
    if (modal) {
        modal.style.display = 'none';
        modal.classList.remove('is-open');
    }
}

let cacheResultadosBlocoDX = [];
let buscaBlocoTimerDX = null;

async function fetchOkrConsolidadoRows(idClie) {
    const urls = [
        `/api/okr/consolidado?id_clie=${encodeURIComponent(idClie)}`,
        `/api/okr/consolidado/${encodeURIComponent(idClie)}`
    ];
    let ultimoErro = null;
    for (let i = 0; i < urls.length; i++) {
        try {
            const res = await fetch(urls[i], { credentials: 'same-origin' });
            const data = await res.json();
            if (!res.ok) {
                ultimoErro = new Error(data.error || ('HTTP ' + res.status));
                continue;
            }
            if (!Array.isArray(data)) {
                ultimoErro = new Error(data.error || 'Resposta OKR inválida');
                continue;
            }
            return data;
        } catch (err) {
            ultimoErro = err;
        }
    }
    throw ultimoErro || new Error('Não foi possível carregar os KRs estratégicos.');
}

async function carregarOpcoesPlanejamentoDX() {
    const idClie = document.getElementById('id_cliente_hidden')?.value || '<%= lead.id_clie %>';
    const selectSquad = document.getElementById('dx-plan-id-squad');
    const selectKr = document.getElementById('dx-plan-id-kr');

    selectSquad.innerHTML = '<option value="NEW" selected>✨ Criar Squad Específica</option>';
    selectKr.innerHTML = '<option value="">Carregando KRs...</option>';

    try {
        const [resSquad, rowsOkr] = await Promise.all([
            fetch(`/api/squads/cliente?id_clie=${encodeURIComponent(idClie)}`, { credentials: 'same-origin' }),
            fetchOkrConsolidadoRows(idClie)
        ]);

        const squadPayload = await resSquad.json();

        const squads = squadPayload.data || squadPayload || [];
        if (Array.isArray(squads) && squads.length > 0) {
            squads.forEach(s => {
                selectSquad.innerHTML += `<option value="${s.id_squad}">${s.nome_squad}</option>`;
            });
        }

        const vistos = new Set();
        let htmlKr = '<option value="">Selecione o KR Estratégico...</option>';
        rowsOkr.forEach(row => {
            if (row.id_kr && !vistos.has(row.id_kr)) {
                vistos.add(row.id_kr);
                const direc = row.nome_direc ? row.nome_direc.substring(0, 24) : 'Direcionador';
                const obj = row.nome_obj ? row.nome_obj.substring(0, 28) : 'Objetivo';
                htmlKr += `<option value="${row.id_kr}">[${direc} › ${obj}] ${row.nome_kr}</option>`;
            }
        });
        if (vistos.size === 0) {
            htmlKr = '<option value="">Nenhum KR cadastrado — acesse Planejamento Estratégico (OKR)</option>';
        }
        selectKr.innerHTML = htmlKr;

    } catch (err) {
        console.error('Erro ao carregar opções do planejamento DX:', err);
        selectKr.innerHTML = '<option value="">Erro ao carregar KRs — tente recarregar a página</option>';
    }
}

async function buscarBlocosDX(termo) {
    const dropdown = document.getElementById('dropdown-resultados-bloco');
    // Toda nova digitação invalida a seleção anterior até o usuário clicar de novo
    document.getElementById('planejamento_id_bloc').value = '';

    if (!termo || termo.trim().length < 3) {
        dropdown.classList.add('hidden');
        cacheResultadosBlocoDX = [];
        return;
    }

    clearTimeout(buscaBlocoTimerDX);
    buscaBlocoTimerDX = setTimeout(async () => {
        try {
            const res = await fetch(`/api/blocos/buscar?q=${encodeURIComponent(termo.trim())}`);
            const resData = await res.json();
            const lista = resData.data || [];
            cacheResultadosBlocoDX = lista;

            dropdown.classList.remove('hidden');
            if (lista.length === 0) {
                dropdown.innerHTML = '<div class="dx-autocomplete-empty">Nenhum bloco encontrado para este termo.</div>';
                return;
            }
            dropdown.innerHTML = lista.map(b => `
                <div class="dx-bloco-item" onclick="selecionarBlocoDX(${b.id_bloc})">
                    <div class="dx-bloco-nome"><i class="fas fa-cube" style="color:#a78bfa; margin-right:6px;"></i>${b.name_bloc}</div>
                    ${b.desc_bloc ? `<div class="dx-bloco-desc">${b.desc_bloc}</div>` : ''}
                </div>
            `).join('');
        } catch (e) {
            console.error('Erro na busca de blocos DX:', e);
            dropdown.classList.remove('hidden');
            dropdown.innerHTML = '<div class="dx-autocomplete-empty">Erro ao buscar blocos.</div>';
        }
    }, 250);
}

function selecionarBlocoDX(idBloc) {
    const bloco = cacheResultadosBlocoDX.find(b => b.id_bloc === idBloc);
    if (!bloco) return;
    document.getElementById('planejamento_id_bloc').value = bloco.id_bloc;
    document.getElementById('txt-busca-bloco').value = bloco.name_bloc;
    document.getElementById('dropdown-resultados-bloco').classList.add('hidden');
}

async function abrirPlanejamentoInovacao(id) {
    if (!id) return alert('ID da sprint não identificado.');

    document.getElementById('dx-plan-id-sprn').value = id;
    document.getElementById('dx-plan-dtini').value = new Date().toISOString().split('T')[0];

    // Reset do autocomplete de bloco a cada abertura
    document.getElementById('txt-busca-bloco').value = '';
    document.getElementById('planejamento_id_bloc').value = '';
    document.getElementById('dropdown-resultados-bloco').classList.add('hidden');
    cacheResultadosBlocoDX = [];

    const modal = document.getElementById('modal-planejamento-dx');
    modal.classList.add('is-open');
    modal.style.display = 'flex';

    await carregarOpcoesPlanejamentoDX();
}

async function submeterPlanejamentoDX() {
    const id_sprn = document.getElementById('dx-plan-id-sprn').value;
    const id_bloc = document.getElementById('planejamento_id_bloc').value;
    const id_squad = document.getElementById('dx-plan-id-squad').value;
    const id_kr = document.getElementById('dx-plan-id-kr').value;
    const dtini_sprn = document.getElementById('dx-plan-dtini').value;
    const id_matu = document.getElementById('id_matu_hidden')?.value || '<%= lead.id_matu %>';
    const id_clie = document.getElementById('id_cliente_hidden')?.value || '<%= lead.id_clie %>';

    if (!id_sprn || !id_bloc || !id_squad || !id_kr || !dtini_sprn) {
        return alert('Preencha todos os campos. Lembre de selecionar um Bloco Metodológico na lista de busca.');
    }

    const btn = document.getElementById('btn-confirmar-planejamento-dx');
    const textoOriginal = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ACOPLANDO...';

    try {
        const response = await fetch('/api/sprints/planejar-dx', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                id_sprn: parseInt(id_sprn),
                id_bloc: parseInt(id_bloc),
                id_squad: id_squad,
                id_kr: parseInt(id_kr),
                dtini_sprn,
                id_matu: id_matu ? parseInt(id_matu) : null,
                id_clie: id_clie ? parseInt(id_clie) : null
            })
        });

        const result = await response.json();

        if (response.ok && (result.success || result.status === 'success')) {
            alert(`✅ Sprint planejada com sucesso! ${result.atividades_criadas || 0} atividade(s) tática(s) criada(s).`);
            window.location.reload();
        } else {
            alert('Erro ao planejar a Sprint: ' + (result.error || result.message || 'Falha desconhecida'));
        }
    } catch (err) {
        console.error(err);
        alert('Erro de comunicação ao planejar a Sprint DX.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = textoOriginal;
    }
}

let idSprintAtivaGlobal = null;
let idSquadAtivaGlobal = null;
let cascataOkrAtividadeCache = [];
let atividadesSprintCache = [];
let squadAtividadeVazia = false;
let moduladorTimer = null;
const PODE_AVALIAR_METRICAS = <%= JSON.stringify(!!(typeof podeAvaliarMetricas !== 'undefined' ? podeAvaliarMetricas : false)) %>;
const PODE_ENCERRAR_SPRINT = <%= JSON.stringify(typeof podeEncerrarSprint !== 'undefined' ? !!podeEncerrarSprint : !(typeof podeAvaliarMetricas !== 'undefined' && podeAvaliarMetricas)) %>;
const MSG_QUALIDADE_ABAIXO_80 = 'A qualidade média das entregas avaliadas pela moderação está abaixo de 80%. Melhore as entregas pendentes para concluir a Sprint.';
/** Exceção: consultor só revisa nota do Modulador se o Cliente pediu. */
let REVISAO_CONSULTOR_ATIVA = false;

// --- SISTEMA DE CAPTURA VOCAL NATIVO (WEB SPEECH API NATIVA) ---
let motorReconhecimentoVoz = null;
let estáGravandoVoz = false;
let vozAlvoAtual = null; // { icon, status, textarea, placeholderOff }

function obterSpeechRecognition() {
    return window.SpeechRecognition || window.webkitSpeechRecognition || null;
}

function garantirMotorVoz() {
    const SpeechRecognition = obterSpeechRecognition();
    if (!SpeechRecognition) return null;
    if (motorReconhecimentoVoz) return motorReconhecimentoVoz;

    motorReconhecimentoVoz = new SpeechRecognition();
    motorReconhecimentoVoz.lang = 'pt-BR';
    motorReconhecimentoVoz.continuous = true;
    motorReconhecimentoVoz.interimResults = false;

    motorReconhecimentoVoz.onstart = () => {
        estáGravandoVoz = true;
        const alvo = vozAlvoAtual;
        if (!alvo) return;
        if (alvo.icon) alvo.icon.classList.add('mic-ativo');
        if (alvo.status) {
            alvo.status.innerText = 'Ouvindo... Fale agora';
            alvo.status.style.color = '#e74c3c';
        }
        if (alvo.textarea) {
            alvo.textarea.style.borderColor = 'var(--dark-lilac)';
            alvo.textarea.placeholder = 'Escutando a sua voz... Fale de forma clara.';
        }
    };

    motorReconhecimentoVoz.onresult = (event) => {
        const alvo = vozAlvoAtual;
        if (!alvo || !alvo.textarea) return;
        let textoCapturado = '';
        for (let i = event.resultIndex; i < event.results.length; ++i) {
            if (event.results[i].isFinal) textoCapturado += event.results[i][0].transcript;
        }
        if (textoCapturado) {
            const espaco = alvo.textarea.value.length > 0 ? ' ' : '';
            alvo.textarea.value += espaco + textoCapturado.trim();
            alvo.textarea.scrollTop = alvo.textarea.scrollHeight;
        }
    };

    motorReconhecimentoVoz.onerror = (err) => {
        console.error(err.error);
        desativarInterfaceMicrofone();
    };

    motorReconhecimentoVoz.onend = () => {
        desativarInterfaceMicrofone();
    };

    return motorReconhecimentoVoz;
}

function desativarInterfaceMicrofone() {
    estáGravandoVoz = false;
    const alvo = vozAlvoAtual;
    if (!alvo) return;
    if (alvo.icon) alvo.icon.classList.remove('mic-ativo');
    if (alvo.status) {
        alvo.status.innerText = 'Ditado Desligado';
        alvo.status.style.color = 'var(--text-gray)';
    }
    if (alvo.textarea) {
        alvo.textarea.style.borderColor = '#dddddd';
        alvo.textarea.placeholder = alvo.placeholderOff || 'Clique no microfone para ditar ou digite...';
    }
}

function alternarVozCampo({ icon, status, textarea, placeholderOff }) {
    if (!obterSpeechRecognition()) {
        return alert('⚠️ O seu navegador atual não suporta a API de ditado por voz. Recomendamos usar o Google Chrome ou Microsoft Edge.');
    }
    if (!textarea) return;

    const motor = garantirMotorVoz();
    if (!motor) return;

    // Se já está gravando neste mesmo campo → para
    if (estáGravandoVoz && vozAlvoAtual && vozAlvoAtual.textarea === textarea) {
        motor.stop();
        return;
    }

    // Se está gravando em outro campo → para e troca o alvo
    if (estáGravandoVoz) {
        try { motor.stop(); } catch (_) { /* ignore */ }
    }

    vozAlvoAtual = { icon, status, textarea, placeholderOff };
    try {
        motor.start();
    } catch (err) {
        console.error(err);
        desativarInterfaceMicrofone();
    }
}

function alternarVozRito() {
    alternarVozCampo({
        icon: document.getElementById('mic-icon-cerm'),
        status: document.getElementById('mic-status-cerm'),
        textarea: document.getElementById('cerm_note'),
        placeholderOff: 'Clique no microfone para ditar ou digite as notas do rito...'
    });
}

function alternarVozDepoimentoMetrica(idMetrica) {
    const card = document.querySelector(`.metric-proof-card[data-id-metrica="${idMetrica}"]`);
    if (!card) return;
    alternarVozCampo({
        icon: card.querySelector('.mic-icon-depoimento'),
        status: card.querySelector('.mic-status-depoimento'),
        textarea: card.querySelector('.metric-depoimento'),
        placeholderOff: 'Clique no microfone para ditar ou digite o depoimento...'
    });
}

let estáGravandoVozRito = false; // legado — mantido para não quebrar refs antigas

function definirConclusaoAgora() {
    const campo = document.getElementById('ativ_dt_concl');
    if (!campo) return;
    campo.value = dataHojeParaInputDatetimeLocal();
    const statusEl = document.getElementById('ativ_status');
    if (statusEl) statusEl.value = 'Entregue';
}

function dataHojeParaInputDatetimeLocal() {
    const agora = new Date();
    const tzOffset = agora.getTimezoneOffset() * 60000;
    return (new Date(agora - tzOffset)).toISOString().slice(0, 16);
}

function isStatusConcluido(status) {
    const s = (status || '').toLowerCase().trim();
    return ['entregue', 'feito', 'concluído', 'concluido', 'concluída', 'concluida'].includes(s);
}

function normalizarStatusAtiv(status) {
    return isStatusConcluido(status) ? 'Entregue' : (status || 'A Fazer');
}

function formatarDataParaInputLocal(dbDate) {
    if (!dbDate) return '';
    const d = new Date(dbDate);
    if (Number.isNaN(d.getTime())) return '';
    const tzOffset = d.getTimezoneOffset() * 60000;
    return (new Date(d - tzOffset)).toISOString().slice(0, 16);
}

let toastEvolucaoTimer = null;
function mostrarToastEvolucao(mensagem, tipo) {
    const toast = document.getElementById('toast-evolucao-atividade');
    if (!toast) return;
    toast.className = tipo === 'error' ? 'toast-error' : 'toast-success';
    toast.innerHTML = `<i class="fas fa-${tipo === 'error' ? 'exclamation-circle' : 'check-circle'}"></i> ${mensagem}`;
    toast.style.display = 'flex';
    if (toastEvolucaoTimer) clearTimeout(toastEvolucaoTimer);
    toastEvolucaoTimer = setTimeout(() => { toast.style.display = 'none'; }, 3500);
}

function aoMudarStatusNovaAtividade() {
    const statusEl = document.getElementById('ativ_status');
    const dtEl = document.getElementById('ativ_dt_concl');
    if (statusEl && dtEl && isStatusConcluido(statusEl.value) && !dtEl.value) {
        dtEl.value = dataHojeParaInputDatetimeLocal();
    }
}

function aoMudarStatusAtiv(idAtiv) {
    const select = document.getElementById(`ativ-st-${idAtiv}`);
    const dtInput = document.getElementById(`ativ-dt-${idAtiv}`);
    if (select && dtInput && isStatusConcluido(select.value) && !dtInput.value) {
        dtInput.value = dataHojeParaInputDatetimeLocal();
    }
}

async function carregarAtividadesDaSprint(idSprn) {
    idSprintAtivaGlobal = idSprn;
    const container = document.getElementById('lista-atividades-sprint');
    if (!container) return;

    container.innerHTML = '<p style="color:#999; font-size:0.85rem; text-align:center;"><i class="fas fa-spinner fa-spin"></i> Buscando tarefas operacionais...</p>';

    try {
        const res = await fetch(`/api/okr/atividades?id_sprn=${idSprn}`);
        const atividades = await res.json();

        atividadesSprintCache = Array.isArray(atividades) ? atividades : [];

        if (!atividadesSprintCache.length) {
            container.innerHTML = '<p style="color: #94a3b8; font-size: 0.85rem; text-align:center; margin: 15px 0;">Nenhuma atividade metodológica atrelada a esta sprint.</p>';
            return;
        }

        container.innerHTML = atividadesSprintCache.map(ativ => {
            const dtLocal = formatarDataParaInputLocal(ativ.data_conclusao);
            const statusAtual = ativ.status_ativ || 'A Fazer';
            const nomeSafe = String(ativ.nome_ativ || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const descSafe = ativ.desc_ativ ? String(ativ.desc_ativ).replace(/</g, '&lt;').replace(/>/g, '&gt;') : '';
            const obsSafe = ativ.obs_encaminhamentos ? String(ativ.obs_encaminhamentos).replace(/</g, '&lt;').replace(/>/g, '&gt;') : '';
            return `
            <div style="background: #fdfdfd; padding: 12px; border-radius: 6px; border: 1px solid #eee; display:flex; flex-direction:column; gap:10px; margin-bottom:5px;">
                <div style="min-width:0;">
                    <div style="font-size:0.9rem; font-weight:700; color:var(--pure-black);">${nomeSafe}</div>
                    ${descSafe ? `<div style="color:var(--text-gray); font-size:0.82rem; margin-top:6px; line-height:1.45; white-space:pre-wrap; word-break:break-word;">${descSafe}</div>` : ''}
                    ${obsSafe ? `<div style="margin-top:8px; padding:8px 10px; background:#faf5ff; border:1px solid var(--border-lilac); border-radius:6px; font-size:0.8rem; color:#4c1d95; white-space:pre-wrap; word-break:break-word;"><strong style="display:block; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.04em; margin-bottom:4px;">Observações / encaminhamentos</strong>${obsSafe}</div>` : ''}
                </div>
                <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                    <button type="button" onclick="abrirSubModalAtividadeEditar(${ativ.id_ativ})" class="btn-action btn-purple-light" style="width:auto; padding:5px 12px; font-size:0.7rem; height:auto;">
                        <i class="fas fa-pen"></i> Editar
                    </button>
                    <input type="datetime-local" id="ativ-dt-${ativ.id_ativ}" value="${dtLocal}" title="Data de Término" style="font-size:0.75rem; padding:4px; border-radius:4px; border:1px solid #cbd5e1;">
                    <select id="ativ-st-${ativ.id_ativ}" onchange="aoMudarStatusAtiv(${ativ.id_ativ})" style="font-size:0.75rem; padding:4px; border-radius:4px; border:1px solid #cbd5e1; background:#fff; width:auto;">
                        <option value="A Fazer" ${statusAtual === 'A Fazer' ? 'selected' : ''}>A Fazer</option>
                        <option value="Em Execução" ${statusAtual === 'Em Execução' ? 'selected' : ''}>Em Execução</option>
                        <option value="Entregue" ${statusAtual === 'Entregue' ? 'selected' : ''}>Feito (Entregue)</option>
                    </select>
                    <button type="button" onclick="salvarEvolucaoAtividade(${ativ.id_ativ}, this)" class="btn-action btn-purple-dark" style="width:auto; padding:5px 12px; font-size:0.7rem; height:auto;">
                        <i class="fas fa-save"></i> Salvar
                    </button>
                </div>
            </div>
        `;
        }).join('');
    } catch (err) {
        console.error(err);
        container.innerHTML = '<p style="color:red; font-size:0.85rem;">Erro ao listar cronograma tático.</p>';
    }
}

function ativarAbaAtividade(aba) {
    const abas = ['detalhes', 'estrategico'];
    abas.forEach(function (nome) {
        const pane = document.getElementById('ativ-pane-' + nome);
        const btn = document.getElementById('ativ-tab-btn-' + nome);
        const ativo = nome === aba;
        if (pane) pane.classList.toggle('active', ativo);
        if (btn) {
            btn.classList.toggle('active', ativo);
            btn.setAttribute('aria-selected', ativo ? 'true' : 'false');
        }
    });
}

function resetarSelectsCascataOkr() {
    const selObj = document.getElementById('ativ_sel_objetivo');
    const selKr = document.getElementById('ativ_sel_kr');
    if (selObj) {
        selObj.innerHTML = '<option value="">Selecione o direcionador primeiro…</option>';
        selObj.disabled = true;
        selObj.value = '';
    }
    if (selKr) {
        selKr.innerHTML = '<option value="">Selecione o objetivo primeiro…</option>';
        selKr.disabled = true;
        selKr.value = '';
    }
}

function aoMudarDirecionadorAtividade() {
    const selDirec = document.getElementById('ativ_sel_direc');
    const selObj = document.getElementById('ativ_sel_objetivo');
    const selKr = document.getElementById('ativ_sel_kr');
    if (!selDirec || !selObj || !selKr) return;

    resetarSelectsCascataOkr();
    const idDirec = parseInt(selDirec.value, 10);
    if (!idDirec) return;

    const direc = cascataOkrAtividadeCache.find(function (d) { return d.id_direc === idDirec; });
    const objetivos = (direc && direc.objetivos) ? direc.objetivos : [];

    if (!objetivos.length) {
        selObj.innerHTML = '<option value="">Nenhum objetivo disponível para este direcionador</option>';
        selObj.disabled = true;
        return;
    }

    let html = '<option value="">Selecione o objetivo…</option>';
    objetivos.forEach(function (o) {
        html += '<option value="' + o.id_obj_dt + '">' + (o.titulo || ('Objetivo ' + o.id_obj_dt)) + '</option>';
    });
    selObj.innerHTML = html;
    selObj.disabled = false;
}

function aoMudarObjetivoAtividade() {
    const selDirec = document.getElementById('ativ_sel_direc');
    const selObj = document.getElementById('ativ_sel_objetivo');
    const selKr = document.getElementById('ativ_sel_kr');
    if (!selDirec || !selObj || !selKr) return;

    selKr.innerHTML = '<option value="">Selecione o objetivo primeiro…</option>';
    selKr.disabled = true;
    selKr.value = '';

    const idDirec = parseInt(selDirec.value, 10);
    const idObj = selObj.value;
    if (!idDirec || !idObj) return;

    const direc = cascataOkrAtividadeCache.find(function (d) { return d.id_direc === idDirec; });
    const objetivo = direc && direc.objetivos
        ? direc.objetivos.find(function (o) { return String(o.id_obj_dt) === String(idObj); })
        : null;
    const krs = (objetivo && objetivo.krs) ? objetivo.krs : [];

    if (!krs.length) {
        selKr.innerHTML = '<option value="">Nenhum KR disponível para este objetivo</option>';
        return;
    }

    let html = '<option value="">Selecione o Key Result…</option>';
    krs.forEach(function (kr) {
        html += '<option value="' + kr.id_kr + '">' + (kr.titulo || ('KR ' + kr.id_kr)) + '</option>';
    });
    selKr.innerHTML = html;
    selKr.disabled = false;
}

function preencherCascataPorKr(idKr) {
    if (!idKr) return;
    const krId = parseInt(idKr, 10);
    for (let i = 0; i < cascataOkrAtividadeCache.length; i++) {
        const d = cascataOkrAtividadeCache[i];
        for (let j = 0; j < (d.objetivos || []).length; j++) {
            const o = d.objetivos[j];
            const kr = (o.krs || []).find(function (k) { return k.id_kr === krId; });
            if (kr) {
                const selDirec = document.getElementById('ativ_sel_direc');
                const selObj = document.getElementById('ativ_sel_objetivo');
                const selKr = document.getElementById('ativ_sel_kr');
                if (selDirec) selDirec.value = String(d.id_direc);
                aoMudarDirecionadorAtividade();
                if (selObj) selObj.value = String(o.id_obj_dt);
                aoMudarObjetivoAtividade();
                if (selKr) selKr.value = String(kr.id_kr);
                return;
            }
        }
    }
}

function atualizarEstadoSubmitAtividade() {
    const btn = document.getElementById('ativ-btn-submit');
    const alerta = document.getElementById('ativ-squad-vazia-alert');
    const selTeam = document.getElementById('ativ_id_team');
    if (alerta) alerta.classList.toggle('is-visible', squadAtividadeVazia);
    if (selTeam) {
        selTeam.disabled = squadAtividadeVazia;
        if (squadAtividadeVazia) selTeam.removeAttribute('required');
        else selTeam.setAttribute('required', 'required');
    }
    if (btn) btn.disabled = squadAtividadeVazia;
}

function montarCascataDeKrsFlat(listaKrs) {
    const mapaDirec = new Map();
    (listaKrs || []).forEach(function (kr) {
        const nomeDirec = kr.direcionador_nome || 'Direcionador';
        const tituloObj = kr.objetivo_titulo || 'Objetivo';
        const chaveObj = (kr.dx_objetivo_id || '') + '::' + tituloObj;
        if (!mapaDirec.has(nomeDirec)) {
            mapaDirec.set(nomeDirec, { nome: nomeDirec, objetivos: new Map() });
        }
        const direc = mapaDirec.get(nomeDirec);
        if (!direc.objetivos.has(chaveObj)) {
            direc.objetivos.set(chaveObj, {
                id_obj_dt: kr.dx_objetivo_id || chaveObj,
                titulo: tituloObj,
                dx_objetivo_id: kr.dx_objetivo_id,
                krs: []
            });
        }
        direc.objetivos.get(chaveObj).krs.push({
            id_kr: kr.id_kr,
            titulo: kr.descricao || kr.nome_kr || ('KR ' + kr.id_kr)
        });
    });
    let idx = 1;
    return Array.from(mapaDirec.values()).map(function (d) {
        return {
            id_direc: idx++,
            nome: d.nome,
            objetivos: Array.from(d.objetivos.values())
        };
    });
}

async function carregarCascataOkrAtividade() {
    const selDirec = document.getElementById('ativ_sel_direc');
    if (!selDirec) return;
    selDirec.innerHTML = '<option value="">Carregando direcionadores…</option>';
    resetarSelectsCascataOkr();

    try {
        const idClie = document.getElementById('id_cliente_hidden')?.value || '<%= lead.id_clie %>';
        if (!idClie) {
            selDirec.innerHTML = '<option value="">Cliente não identificado — recarregue a página</option>';
            return;
        }

        const urlCascata = '/api/estrategia/cascata-okr-atividade?id_sprn=' + encodeURIComponent(idSprintAtivaGlobal) + '&id_clie=' + encodeURIComponent(idClie);
        const res = await fetch(urlCascata);
        const data = await res.json().catch(function () { return {}; });

        var cascata = (res.ok && Array.isArray(data.direcionadores)) ? data.direcionadores : [];
        var temKrs = cascata.some(function (d) {
            return (d.objetivos || []).some(function (o) { return (o.krs || []).length > 0; });
        });

        if (!temKrs) {
            const resKrs = await fetch('/api/estrategia/krs-por-sprint?id_sprn=' + encodeURIComponent(idSprintAtivaGlobal) + '&id_clie=' + encodeURIComponent(idClie));
            const dataKrs = await resKrs.json().catch(function () { return {}; });
            if (!resKrs.ok) {
                selDirec.innerHTML = '<option value="">' + (dataKrs.error || data.error || 'Erro ao carregar matriz OKR') + '</option>';
                return;
            }
            cascata = montarCascataDeKrsFlat(dataKrs.krs || []);
        }

        cascataOkrAtividadeCache = cascata;

        if (!cascataOkrAtividadeCache.length) {
            selDirec.innerHTML = '<option value="">Nenhum KR ativo nesta sprint — ajuste na Matriz OKR</option>';
            return;
        }

        let html = '<option value="">Selecione o direcionador…</option>';
        cascataOkrAtividadeCache.forEach(function (d) {
            html += '<option value="' + d.id_direc + '">' + (d.nome || ('Direcionador ' + d.id_direc)) + '</option>';
        });
        selDirec.innerHTML = html;

        // Auto-seleciona quando a sprint já filtra um único caminho (direcionador → objetivo → KRs)
        if (cascataOkrAtividadeCache.length === 1) {
            selDirec.value = String(cascataOkrAtividadeCache[0].id_direc);
            aoMudarDirecionadorAtividade();
            var objs = cascataOkrAtividadeCache[0].objetivos || [];
            if (objs.length === 1) {
                var selObj = document.getElementById('ativ_sel_objetivo');
                if (selObj) {
                    selObj.value = String(objs[0].id_obj_dt);
                    aoMudarObjetivoAtividade();
                }
            }
        }
    } catch (err) {
        console.error(err);
        selDirec.innerHTML = '<option value="">Erro ao carregar direcionadores</option>';
    }
}

async function carregarSquadAtividadeModal() {
    const selectTeam = document.getElementById('ativ_id_team');
    if (!selectTeam) return;
    selectTeam.innerHTML = '<option value="">Filtrando integrantes da Squad...</option>';
    squadAtividadeVazia = false;

    try {
        const resTeam = await fetch('/api/ctdi_team?id_squad=' + idSquadAtivaGlobal);
        const membrosDaSquad = await resTeam.json();

        if (!Array.isArray(membrosDaSquad) || membrosDaSquad.length === 0) {
            squadAtividadeVazia = true;
            selectTeam.innerHTML = '<option value="">Nenhum profissional alocado nesta Squad...</option>';
        } else {
            let htmlTeam = '<option value="">Selecione o Responsável...</option>';
            membrosDaSquad.forEach(function (m) {
                htmlTeam += '<option value="' + m.id_member + '">' + m.nome + ' (' + (m.position || 'Consultor') + ')</option>';
            });
            selectTeam.innerHTML = htmlTeam;
        }
    } catch (err) {
        console.error(err);
        selectTeam.innerHTML = '<option value="">Erro ao carregar integrantes</option>';
    }
    atualizarEstadoSubmitAtividade();
}

document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
        const modal = document.getElementById('subModalAtividade');
        if (modal && modal.classList.contains('is-open')) fecharSubModalAtividade();
    }
});

async function abrirSubModalAtividadeEditar(idAtiv) {
    const ativ = atividadesSprintCache.find(function (a) { return a.id_ativ === idAtiv; });
    if (!ativ) return;
    abrirSubModalAtividade(ativ);
}

async function abrirSubModalAtividade(atividadeEdicao) {
    if (!idSprintAtivaGlobal || !idSquadAtivaGlobal) {
        return alert('Contexto ou Squad da Sprint não mapeados corretamente.');
    }

    const modal = document.getElementById('subModalAtividade');
    const form = document.getElementById('formAtividade');
    const titulo = document.getElementById('ativ-modal-titulo-texto');
    const btnTexto = document.getElementById('ativ-btn-submit-texto');
    const hiddenId = document.getElementById('ativ_id_ativ');
    const isEdicao = !!(atividadeEdicao && atividadeEdicao.id_ativ);

    if (form) form.reset();
    if (hiddenId) hiddenId.value = isEdicao ? String(atividadeEdicao.id_ativ) : '';
    if (titulo) titulo.textContent = isEdicao ? 'Editar Atividade Operacional' : 'Vincular Nova Atividade Operacional';
    if (btnTexto) btnTexto.textContent = isEdicao ? 'SALVAR ALTERAÇÕES' : 'VINCULAR TAREFA';

    ativarAbaAtividade('detalhes');
    document.getElementById('ativ_dt_plan').value = new Date().toISOString().split('T')[0];

    await Promise.all([carregarCascataOkrAtividade(), carregarSquadAtividadeModal()]);

    if (isEdicao) {
        document.getElementById('ativ_nome').value = atividadeEdicao.nome_ativ || '';
        document.getElementById('ativ_desc').value = atividadeEdicao.desc_ativ || '';
        const ativObs = document.getElementById('ativ_obs');
        if (ativObs) ativObs.value = atividadeEdicao.obs_encaminhamentos || '';
        if (atividadeEdicao.data_planejamento) {
            const dp = String(atividadeEdicao.data_planejamento).slice(0, 10);
            document.getElementById('ativ_dt_plan').value = dp;
        }
        document.getElementById('ativ_dt_concl').value = formatarDataParaInputLocal(atividadeEdicao.data_conclusao);
        document.getElementById('ativ_status').value = normalizarStatusAtiv(atividadeEdicao.status_ativ);
        const executorId = atividadeEdicao.executor_id || atividadeEdicao.id_team;
        if (executorId) document.getElementById('ativ_id_team').value = String(executorId);
        if (atividadeEdicao.id_kr) preencherCascataPorKr(atividadeEdicao.id_kr);
    }

    if (modal) modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
}

function fecharSubModalAtividade() {
    const modal = document.getElementById('subModalAtividade');
    if (modal) modal.classList.remove('is-open');
    document.body.style.overflow = '';
    const form = document.getElementById('formAtividade');
    if (form) form.reset();
    document.getElementById('ativ_id_ativ').value = '';
    ativarAbaAtividade('detalhes');
    resetarSelectsCascataOkr();
    squadAtividadeVazia = false;
    atualizarEstadoSubmitAtividade();
}

async function salvarAtividadeSprint(e) {
    e.preventDefault();
    if (squadAtividadeVazia) {
        mostrarToastEvolucao('Aloque membros na squad antes de vincular atividades.', 'error');
        ativarAbaAtividade('detalhes');
        return;
    }

    const idAtivEdicao = parseInt(document.getElementById('ativ_id_ativ').value, 10);
    const isEdicao = !Number.isNaN(idAtivEdicao) && idAtivEdicao > 0;
    const idKr = parseInt(document.getElementById('ativ_sel_kr').value, 10);
    if (!idKr) {
        mostrarToastEvolucao('Selecione o Key Result alvo na aba Alinhamento Estratégico.', 'error');
        ativarAbaAtividade('estrategico');
        return;
    }

    const statusEl = document.getElementById('ativ_status');
    let status = normalizarStatusAtiv(statusEl ? statusEl.value : 'A Fazer');
    let dtConclValue = document.getElementById('ativ_dt_concl').value;

    if (isStatusConcluido(status) && !dtConclValue) {
        dtConclValue = dataHojeParaInputDatetimeLocal();
        document.getElementById('ativ_dt_concl').value = dtConclValue;
    }

    const payload = {
        id_kr: idKr,
        id_sprn: idSprintAtivaGlobal,
        id_team: parseInt(document.getElementById('ativ_id_team').value, 10),
        nome_ativ: document.getElementById('ativ_nome').value.trim(),
        desc_ativ: document.getElementById('ativ_desc').value.trim(),
        obs_encaminhamentos: (document.getElementById('ativ_obs')?.value || '').trim(),
        data_planejamento: document.getElementById('ativ_dt_plan').value,
        data_conclusao: dtConclValue ? dtConclValue.replace('T', ' ') + ':00' : null,
        status_ativ: status
    };

    const btn = document.getElementById('ativ-btn-submit');
    if (btn) { btn.disabled = true; btn.style.opacity = '0.6'; }

    try {
        const url = isEdicao ? ('/api/okr/atividades/' + idAtivEdicao) : '/api/okr/atividades';
        const res = await fetch(url, {
            method: isEdicao ? 'PUT' : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json().catch(function () { return {}; });
        if (res.ok) {
            mostrarToastEvolucao(isEdicao ? 'Atividade atualizada!' : 'Evolução salva!', 'success');
            fecharSubModalAtividade();
            carregarAtividadesDaSprint(idSprintAtivaGlobal);
        } else {
            mostrarToastEvolucao(data.error || 'Falha ao persistir atividade operacional.', 'error');
        }
    } catch (err) {
        console.error(err);
        mostrarToastEvolucao('Erro de comunicação com o servidor.', 'error');
    } finally {
        if (btn) { btn.disabled = squadAtividadeVazia; btn.style.opacity = '1'; }
    }
}

async function salvarEvolucaoAtividade(idAtiv, btn) {
    const select = document.getElementById(`ativ-st-${idAtiv}`);
    const dtInput = document.getElementById(`ativ-dt-${idAtiv}`);
    if (!select) return;

    let status = normalizarStatusAtiv(select.value);
    let dataConclusao = dtInput ? dtInput.value : '';

    if (isStatusConcluido(status) && !dataConclusao) {
        dataConclusao = dataHojeParaInputDatetimeLocal();
        if (dtInput) dtInput.value = dataConclusao;
    }

    const payload = { status_ativ: status };
    if (dataConclusao) {
        payload.data_conclusao = dataConclusao.replace('T', ' ') + ':00';
    }

    if (btn) { btn.disabled = true; btn.style.opacity = '0.6'; }

    try {
        const res = await fetch(`/api/okr/atividades/${idAtiv}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok && data.success !== false) {
            mostrarToastEvolucao(data.message || 'Evolução salva!', 'success');
            if (select.value !== status) select.value = status;
            if (data.kr_atualizado) {
                console.info('KR atualizado — valor_atual:', data.valor_atual_kr);
            }
        } else {
            mostrarToastEvolucao(data.error || 'Não foi possível salvar a evolução.', 'error');
        }
    } catch (err) {
        console.error(err);
        mostrarToastEvolucao('Erro de comunicação com o servidor.', 'error');
    } finally {
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
    }
}

async function carregarHistoricoCerimonias(id_sprn) {
    const timeline = document.getElementById('timeline-cerimonias');
    timeline.innerHTML = '<div style="text-align:center; padding:20px;"><i class="fas fa-spinner fa-spin"></i></div>';

    try {
        const res = await fetch(`/api/cerimonias/${id_sprn}`);
        const dados = await res.json();

        if (!dados || dados.length === 0) {
            timeline.innerHTML = '<p style="text-align:center; color:#999; font-size:0.8em; margin-top:20px;">Nenhum rito registrado.</p>';
            return;
        }

        timeline.innerHTML = dados.map(c => {
            const notaEscapada = c.note_cermls.replace(/'/g, "\\'").replace(/\n/g, "\\n");
            return `
                <div onclick="recuperarRito('${c.id_cermls}', '${c.tp_cermls}', '${c.dt_cermls}', '${notaEscapada}')"
                     title="Clique para carregar esta nota"
                     style="background:#fff; border:1px solid #eee; border-left:3px solid var(--dark-lilac);
                            padding:8px 10px; margin-bottom:5px; border-radius:4px; cursor:pointer;
                            display:flex; justify-content:space-between; align-items:center; transition:0.2s;"
                     onmouseover="this.style.borderColor='var(--dark-lilac)'; this.style.background='var(--light-lilac)';"
                     onmouseout="this.style.borderColor='#eee'; this.style.background='#fff';">
                    <span style="font-size:0.78em; font-weight:800; color:var(--pure-black);">${c.tp_cermls}</span>
                    <span style="font-size:0.75em; color:var(--dark-lilac); font-family:monospace;">
                        ${new Date(c.dt_cermls).toLocaleDateString('pt-BR', {day:'2-digit', month:'2-digit'})}
                    </span>
                </div>
            `;
        }).join('');
    } catch (e) { timeline.innerHTML = '<p style="color:red; font-size:0.8em;">Erro ao carregar ritos.</p>'; }
}

function recuperarRito(id, tipo, data, nota) {
    if (document.getElementById('edit_id_cermls')) document.getElementById('edit_id_cermls').value = id;
    if (document.getElementById('cerm_tipo')) document.getElementById('cerm_tipo').value = tipo;

    try {
        let dataFormatada = "";
        if (data) {
            const d = new Date(data);
            if (!isNaN(d.getTime())) { dataFormatada = d.toISOString().split('T')[0]; }
            else { dataFormatada = data.substring(0, 10); }
        }
        document.getElementById('cerm_data').value = dataFormatada;
    } catch (e) { console.error(e); }

    const noteField = document.getElementById('cerm_note');
    if (noteField) {
        noteField.value = nota;
        noteField.style.backgroundColor = "var(--light-lilac)";
        noteField.focus();
    }

    const btnSave = document.getElementById('btn-cerm-save');
    if (btnSave) { btnSave.innerHTML = '<i class="fas fa-sync-alt"></i> Atualizar Rito'; btnSave.style.background = "#d97706"; }
    if (document.getElementById('btn-cerm-cancel')) document.getElementById('btn-cerm-cancel').style.display = "inline-flex";
}

function limparFormCerimonia() {
    if (document.getElementById('edit_id_cermls')) document.getElementById('edit_id_cermls').value = "";
    const noteField = document.getElementById('cerm_note');
    if (noteField) { noteField.value = ""; noteField.style.backgroundColor = "var(--pure-white)"; }
    const btnSave = document.getElementById('btn-cerm-save');
    if (btnSave) { btnSave.innerHTML = '<i class="fas fa-save"></i> Registrar Rito'; btnSave.style.background = "var(--pure-black)"; }

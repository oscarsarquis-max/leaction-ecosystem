let quillEvidencia = null;

function inicializarQuillModulador() {
    const alvo = document.getElementById('quill-evidencia');
    if (!alvo || typeof Quill === 'undefined' || alvo.__quillReady) return;
    quillEvidencia = new Quill('#quill-evidencia', {
        theme: 'snow',
        placeholder: 'Cole aqui as evidências fáticas: URLs dos documentos publicados, links de pastas, ou a cópia/transcrição dos e-mails de aprovação...',
        modules: {
            toolbar: [
                [{ header: [1, 2, 3, false] }],
                ['bold', 'italic', 'underline'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['link', 'blockquote', 'code-block'],
                ['clean']
            ]
        }
    });
    alvo.__quillReady = true;
}

async function submeterParaModulador() {
    if (!PODE_ENCERRAR_SPRINT) {
        return mostrarToastEvolucao('Apenas o Cliente submete evidência ao Modulador.', 'error');
    }
    const idSprn = document.getElementById('exec_id_sprn')?.value;
    if (!idSprn) { return mostrarToastEvolucao('ID da sprint não encontrado.', 'error'); }
    if (!quillEvidencia) { inicializarQuillModulador(); }

    const evidenciaHtml = quillEvidencia ? quillEvidencia.root.innerHTML : '';
    const evidenciaTexto = quillEvidencia ? quillEvidencia.getText().trim() : '';

    if (evidenciaTexto.length < 10) {
        return mostrarToastEvolucao('Descreva a evidência com mais detalhes antes de submeter.', 'error');
    }

    const btn = document.getElementById('btn-submeter-modulador');
    const htmlOriginal = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> O Modulador está analisando...';

    try {
        const res = await fetch('/api/modulador/avaliar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_sprn: parseInt(idSprn, 10), evidencia: evidenciaHtml })
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok && data.success) {
            renderizarVeredito(data);
            const prog = data.progresso_qualidade != null ? data.progresso_qualidade : data.nota;
            if (prog != null) atualizarProgresso(prog);
            mostrarToastEvolucao('Avaliação do Modulador concluída! A nota alimenta o progresso. O Cliente pode encerrar quando DoD e qualidade (≥80%) estiverem ok.', 'success');
            // Recarrega cards para exibir "Nota do Moderador" por métrica
            if (typeof abrirPainelSprint === 'function') {
                await abrirPainelSprint(idSprn);
            }
        } else {
            mostrarToastEvolucao(data.error || 'Falha na avaliação do Modulador.', 'error');
        }
    } catch (err) {
        console.error(err);
        mostrarToastEvolucao('Erro de comunicação com o Modulador.', 'error');
    } finally {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = htmlOriginal;
        }
    }
}

function renderizarVeredito(data) {
    const box = document.getElementById('modulador-resultado');
    const aprovado = data.status === 'Aprovado';

    box.className = 'modulador-resultado ' + (aprovado ? 'res-aprovado' : 'res-revisao');
    document.getElementById('res-icone').className = 'fas ' + (aprovado ? 'fa-circle-check' : 'fa-circle-exclamation');
    const notaTxt = (data.nota !== undefined && data.nota !== null) ? ` — Nota ${data.nota}/100` : '';
    document.getElementById('res-titulo').innerText = (aprovado ? 'Entrega Aprovada' : 'Revisão Necessária') + notaTxt;
    document.getElementById('res-badge').innerText = data.status || '—';
    document.getElementById('res-feedback').innerText = data.feedback || 'Sem parecer textual.';

    const fortes = document.getElementById('res-pontos-fortes');
    const pend = document.getElementById('res-pendencias');
    const renderLista = (el, itens, vazio) => {
        if (Array.isArray(itens) && itens.length) {
            el.innerHTML = itens.map(i => `<li>${i}</li>`).join('');
        } else {
            el.innerHTML = `<li style="list-style:none; margin-left:-18px; font-style:italic;">${vazio}</li>`;
        }
    };
    renderLista(fortes, data.pontos_fortes, 'Nenhum ponto forte destacado.');
    renderLista(pend, data.pendencias, 'Nenhuma pendência apontada.');

    box.style.display = 'block';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
</script>

<!-- 🎯 DRAG & DROP DO KANBAN (SortableJS) -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    if (typeof Sortable === 'undefined') {
        console.warn('SortableJS não carregou — Drag & Drop desabilitado.');
        return;
    }

    const dropzones = document.querySelectorAll('.kanban-dropzone');
    dropzones.forEach(zone => {
        new Sortable(zone, {
            group: 'sprints-kanban',
            animation: 150,
            ghostClass: 'bg-gray-100',
            // Só elementos com data-sprn-id podem ser arrastados (ignora dicas de coluna vazia)
            draggable: '.task-card',
            onEnd: async function (evt) {
                const itemEl = evt.item;
                const toZone = evt.to;

                if (evt.from === evt.to) return;

                const sprintId = itemEl.getAttribute('data-sprn-id');
                const novoStatus = toZone.getAttribute('data-status-alvo');

                if (!sprintId || !novoStatus) return;

                try {
                    const res = await fetch('/api/sprints/status-dnd', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id_sprn: sprintId, status: novoStatus })
                    });
                    const result = await res.json().catch(() => ({}));
                    if (!res.ok || !(result.success || result.status === 'success')) {
                        throw new Error("Falha na API");
                    }

                    // Recarrega para o EJS re-renderizar a nova coluna com os botoes
                    // e datas condicionais corretos do banco (ex.: 'Gerenciar Execucao').
                    window.location.reload();

                } catch (err) {
                    console.error(err);
                    alert("Erro ao mover card. A página será recarregada.");
                    window.location.reload();
                }
            }
        });
    });
});
</script>
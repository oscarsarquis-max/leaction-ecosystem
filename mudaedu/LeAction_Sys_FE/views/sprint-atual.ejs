<%
    // --- CONSOLIDAÇÃO DE ESTRUTURA HORIZONTAL ---
    let todasAsSprints = [];
    if (locals.journey && journey.length > 0) {
        journey.forEach(onda => {
            if (onda.sprints) {
                onda.sprints.forEach(s => {
                    s.nome_onda = onda.nome;
                    todasAsSprints.push(s);
                });
            }
        });
    }

    function blocoOrigemRelatorioKey(sprint) {
        let ms = sprint.metrics_scores;
        if (!ms) return null;
        if (typeof ms === 'string') {
            try { ms = JSON.parse(ms); } catch (e) { return null; }
        }
        const bo = ms.bloco_origem;
        if (!bo || typeof bo !== 'object') return null;
        const key = String(bo.id_bloc || bo.nome || '').trim();
        return key || null;
    }

    function normStatKanban(s) {
        return String(s || '').toLowerCase().trim().replace(/\s+/g, '_');
    }
    function isStatEmAnalise(s) {
        const n = normStatKanban(s);
        return n === 'em_analise' || n === 'em analise'.replace(' ', '_');
    }
    function isStatBacklog(s) {
        const n = normStatKanban(s);
        return ['planejada_backlog', 'planejada', 'planejado', 'pendente', 'agendada', 'agendado', ''].indexOf(n) >= 0;
    }
    function isStatAndamento(s) {
        const n = normStatKanban(s);
        return ['em_andamento', 'ativa', 'em_progresso', 'executando'].indexOf(n) >= 0;
    }
    function isStatConcluida(s) {
        const n = normStatKanban(s);
        return ['concluida', 'concluido', 'finalizada'].indexOf(n) >= 0;
    }

    function isSprintDxDoRelatorio(sprint) {
        if (sprint.url_kanban === 'IMPORTACAO_JSON_DX') return true;
        let ms = sprint.metrics_scores;
        if (!ms) return false;
        if (typeof ms === 'string') {
            try { ms = JSON.parse(ms); } catch (e) { return false; }
        }
        if (ms.bloco_origem) return true;
        const origem = String(ms.origem || '').toLowerCase();
        return origem.includes('mesa') && origem.includes('panel');
    }
%>


<div class="main-content">
<style>
    #cockpit-page {
        --dark-lilac: #5B35D9;
        --lilac: #6d28d9;
        --brand-gold: #d97706;
        --bg: #f4f2f8;
        --card: #ffffff;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: var(--bg) !important;
        color: var(--text) !important;
        width: 100%;
        box-sizing: border-box;
        border-radius: 12px;
    }
    #cockpit-page *, #cockpit-page *::before, #cockpit-page *::after {
        box-sizing: border-box;
    }
    #cockpit-page .cockpit-wrap {
        max-width: 1280px;
        margin: 0 auto;
        padding: 20px 24px 40px;
    }
    #cockpit-page .cockpit-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 32px;
        padding: 26px 30px;
        background: #ffffff !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(91, 53, 217, 0.08);
        position: relative;
        z-index: 2;
    }
    #cockpit-page .cockpit-header-text {
        flex: 1;
        min-width: 220px;
    }
    #cockpit-page .cockpit-eyebrow {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #b45309 !important;
        margin-bottom: 10px;
        display: block;
    }
    #cockpit-page .cockpit-header h1 {
        font-size: 1.85rem;
        font-weight: 900;
        color: #312e81 !important;
        line-height: 1.25;
        margin: 0 0 10px 0;
        border: none !important;
        padding: 0 !important;
    }
    #cockpit-page .cockpit-header p,
    #cockpit-page #subtitulo-rede {
        color: #475569 !important;
        margin: 0;
        font-size: 0.95rem;
        font-weight: 500;
        line-height: 1.45;
    }
    #cockpit-page .cockpit-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }
    #cockpit-page .badge-rede {
        background: linear-gradient(135deg, var(--dark-lilac), var(--lilac)) !important;
        color: #fff !important;
        font-weight: 700;
        font-size: 0.78rem;
        padding: 8px 16px;
        border-radius: 999px;
        letter-spacing: 0.5px;
    }
    #cockpit-page .badge-mock {
        background: rgba(217, 119, 6, 0.12) !important;
        color: var(--brand-gold) !important;
        border: 1px solid rgba(217, 119, 6, 0.35);
        font-size: 0.72rem;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 8px;
        display: none;
        align-items: center;
        gap: 6px;
    }
    #cockpit-page .aviso-rede {
        display: none;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 24px;
        padding: 14px 18px;
        background: #fffbeb !important;
        border: 1px solid #fcd34d;
        border-radius: 12px;
        color: #92400e !important;
        font-size: 0.9rem;
        line-height: 1.45;
    }
    #cockpit-page .aviso-rede i {
        margin-top: 2px;
        flex-shrink: 0;
    }
    #cockpit-page .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 36px;
    }
    #cockpit-page .kpi-card {
        background: var(--card) !important;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid var(--border) !important;
        box-shadow: 0 4px 20px rgba(91, 53, 217, 0.06);
        position: relative;
        overflow: hidden;
    }
    #cockpit-page .kpi-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--dark-lilac), var(--brand-gold));
    }
    #cockpit-page .kpi-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(91, 53, 217,0.12), rgba(109,40,217,0.08)) !important;
        color: var(--dark-lilac) !important;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 14px;
    }
    #cockpit-page .kpi-icon i {
        color: var(--dark-lilac) !important;
    }
    #cockpit-page .kpi-label {
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted) !important;
        margin-bottom: 6px;
    }
    #cockpit-page .kpi-value {
        font-size: 2.1rem;
        font-weight: 900;
        color: var(--dark-lilac) !important;
        line-height: 1;
    }
    #cockpit-page .kpi-unit {
        font-size: 0.85rem;
        color: var(--muted) !important;
        margin-top: 4px;
    }
    #cockpit-page .section-title {
        font-size: 0.74rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #64748b !important;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    #cockpit-page .section-title::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
    }
    #cockpit-page .units-panel {
        background: var(--card) !important;
        border-radius: 16px;
        border: 1px solid var(--border) !important;
        box-shadow: 0 4px 20px rgba(91, 53, 217, 0.05);
        overflow: hidden;
    }
    #cockpit-page .units-table {
        width: 100%;
        border-collapse: collapse;
        background: #fff !important;
    }
    #cockpit-page .units-table th {
        text-align: left;
        padding: 14px 20px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted) !important;
        background: #faf9fc !important;
        border-bottom: 1px solid var(--border) !important;
    }
    #cockpit-page .units-table td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border) !important;
        font-size: 0.9rem;
        color: var(--text) !important;
        background: #fff !important;
    }
    #cockpit-page .units-table tr:last-child td { border-bottom: none !important; }
    #cockpit-page .units-table tr:hover td { background: rgba(91, 53, 217, 0.03) !important; }
    #cockpit-page .unit-name { font-weight: 700; color: var(--text) !important; }
    #cockpit-page .progress-bar-wrap {
        background: #e2e8f0 !important;
        border-radius: 999px;
        height: 8px;
        overflow: hidden;
        min-width: 100px;
        max-width: 160px;
        display: inline-block;
        vertical-align: middle;
        margin-right: 8px;
    }
    #cockpit-page .progress-bar-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--dark-lilac), var(--brand-gold)) !important;
        transition: width .4s ease;
    }
    #cockpit-page .progress-pct {
        font-weight: 700;
        color: var(--dark-lilac) !important;
        font-size: 0.85rem;
    }
    #cockpit-page .num-highlight {
        font-weight: 800;
        color: var(--dark-lilac) !important;
    }
    #cockpit-page .loading-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--muted) !important;
    }
    #cockpit-page .loading-state i {
        font-size: 2rem;
        color: var(--dark-lilac) !important;
        margin-bottom: 12px;
        display: block;
    }
    #cockpit-page .cockpit-footer {
        margin-top: 40px;
        padding: 22px 28px;
        background: #ffffff !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(91, 53, 217, 0.08);
        text-align: center;
        position: relative;
        z-index: 2;
    }
    #cockpit-page .cockpit-footer-line {
        margin: 0;
        font-size: 0.88rem;
        color: #475569 !important;
        line-height: 1.55;
    }
    #cockpit-page .cockpit-footer-line strong {
        color: #312e81 !important;
        font-weight: 800;
    }
    #cockpit-page .cockpit-footer-gestor {
        margin: 12px 0 0;
        font-size: 0.92rem;
        font-weight: 600;
        color: #312e81 !important;
        line-height: 1.4;
    }
    @media (max-width: 640px) {
        #cockpit-page .units-table thead { display: none; }
        #cockpit-page .units-table tr {
            display: block;
            margin-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }
        #cockpit-page .units-table td {
            display: flex;
            justify-content: space-between;
            padding: 10px 16px;
        }
        #cockpit-page .units-table td::before {
            content: attr(data-label);
            font-weight: 700;
            font-size: 0.72rem;
            text-transform: uppercase;
            color: var(--muted);
        }
    }
</style>

<div id="cockpit-page">
    <div class="cockpit-wrap">
        <header class="cockpit-header">
            <div class="cockpit-header-text">
                <span class="cockpit-eyebrow">Padrão Holding · Multi-Tier BI</span>
                <h1>Visão Consolidada da Rede</h1>
                <p id="subtitulo-rede">Carregando panorama da rede...</p>
            </div>
            <div class="cockpit-actions">
                <span id="badge-rede" class="badge-rede">—</span>
                <span id="badge-mock" class="badge-mock"><i class="fas fa-flask"></i> Dados demonstrativos</span>
            </div>
        </header>

        <div id="aviso-rede" class="aviso-rede" role="status">
            <i class="fas fa-info-circle"></i>
            <span id="aviso-rede-texto"></span>
        </div>

        <div id="loading" class="loading-state">
            <div><i class="fas fa-spinner fa-spin"></i></div>
            <p>Consolidando métricas das unidades...</p>
        </div>

        <div id="conteudo" style="display:none;">
            <div class="kpi-grid">
                <div class="kpi-card">
                    <div class="kpi-icon"><i class="fas fa-flag-checkered"></i></div>
                    <div class="kpi-label">Sprints Concluídas</div>
                    <div class="kpi-value" id="kpi-sprints">—</div>
                    <div class="kpi-unit">total na rede</div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="kpi-label">Maturidade Média</div>
                    <div class="kpi-value" id="kpi-maturidade">—</div>
                    <div class="kpi-unit">progresso geral (%)</div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon"><i class="fas fa-lightbulb"></i></div>
                    <div class="kpi-label">Inovações Geradas</div>
                    <div class="kpi-value" id="kpi-inovacoes">—</div>
                    <div class="kpi-unit">teses estruturadas</div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon"><i class="fas fa-school"></i></div>
                    <div class="kpi-label">Unidades Ativas</div>
                    <div class="kpi-value" id="kpi-unidades">—</div>
                    <div class="kpi-unit">escolas na rede</div>
                </div>
            </div>

            <div class="section-title">Comparativo entre Unidades</div>
            <div class="units-panel">
                <table class="units-table">
                    <thead>
                        <tr>
                            <th>Unidade</th>
                            <th>Progresso de Maturidade</th>
                            <th>Sprints Concluídas</th>
                            <th>Inovações</th>
                        </tr>
                    </thead>
                    <tbody id="tabela-unidades"></tbody>
                </table>
            </div>
        </div>

        <footer class="cockpit-footer">
            <p class="cockpit-footer-line">
                <strong>MudaEdu</strong> · Camada de Inteligência Consolidada · Metodologia CTDI
            </p>
            <% if (typeof user !== 'undefined' && user && user.nome) { %>
            <p class="cockpit-footer-gestor">Gestor: <%= user.nome %></p>
            <% } %>
        </footer>
    </div>
</div>

<script>
    const ID_REDE = '<%= typeof id_rede !== "undefined" ? (id_rede || "") : "" %>'.trim().toUpperCase();

    function mostrarAviso(msg) {
        const box = document.getElementById('aviso-rede');
        const texto = document.getElementById('aviso-rede-texto');
        if (!msg) {
            box.style.display = 'none';
            texto.textContent = '';
            return;
        }
        texto.textContent = msg;
        box.style.display = 'flex';
    }

    async function resolverIdRede() {
        if (ID_REDE) return ID_REDE;
        const params = new URLSearchParams(window.location.search);
        const fromUrl = (params.get('rede') || params.get('id_rede') || '').trim().toUpperCase();
        if (fromUrl) return fromUrl;
        try {
            const res = await fetch('/api/holding/redes');
            const data = await res.json();
            if (data.success && Array.isArray(data.redes) && data.redes.length) {
                const comUnidades = data.redes.find(r => Number(r.qtd_unidades) > 0);
                return (comUnidades || data.redes[0]).id_rede;
            }
        } catch (e) {
            console.warn('Não foi possível listar redes:', e);
        }
        return '';
    }

    function renderBar(pct) {
        const v = Math.min(100, Math.max(0, pct));
        return `<span class="progress-bar-wrap"><span class="progress-bar-fill" style="width:${v}%"></span></span>
                <span class="progress-pct">${v.toFixed(1)}%</span>`;
    }

    function renderTabela(unidades) {
        const tbody = document.getElementById('tabela-unidades');
        if (!unidades || unidades.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:#64748b;padding:32px;">Nenhuma unidade vinculada a esta rede.</td></tr>';
            return;
        }
        tbody.innerHTML = unidades.map(u => `
            <tr>
                <td data-label="Unidade"><span class="unit-name">${u.nome_clie}</span></td>
                <td data-label="Maturidade">${renderBar(u.progresso_maturidade)}</td>
                <td data-label="Sprints"><span class="num-highlight">${u.sprints_concluidas}</span></td>
                <td data-label="Inovações"><span class="num-highlight">${u.inovacoes_geradas}</span></td>
            </tr>
        `).join('');
    }

    function aplicarDados(data) {
        const c = data.consolidado || {};
        document.getElementById('kpi-sprints').textContent = c.total_sprints_concluidas ?? '—';
        document.getElementById('kpi-maturidade').textContent =
            c.media_progresso_maturidade != null ? c.media_progresso_maturidade.toFixed(1) : '—';
        document.getElementById('kpi-inovacoes').textContent = c.total_inovacoes ?? '—';
        document.getElementById('kpi-unidades').textContent = c.total_unidades ?? '—';

        document.getElementById('badge-rede').textContent = data.nome_rede || data.id_rede || 'Rede';
        document.getElementById('subtitulo-rede').textContent =
            `Panorama executivo de ${c.total_unidades || 0} unidade(s) · somente leitura`;

        if (data.mock) {
            document.getElementById('badge-mock').style.display = 'inline-flex';
        } else {
            document.getElementById('badge-mock').style.display = 'none';
        }

        mostrarAviso(data.aviso || null);

        renderTabela(data.unidades);
        document.getElementById('loading').style.display = 'none';
        document.getElementById('conteudo').style.display = 'block';
    }

    async function carregarPanorama() {
        try {
            const idRede = await resolverIdRede();
            const params = new URLSearchParams();
            if (idRede) params.set('id_rede', idRede);
            const qs = params.toString();
            const res = await fetch('/api/holding/panorama' + (qs ? '?' + qs : ''));
            const data = await res.json();
            if (data.success) {
                aplicarDados(data);
            } else {
                throw new Error(data.error || 'Falha ao carregar panorama');
            }
        } catch (e) {
            console.error(e);
            document.getElementById('loading').innerHTML =
                '<p style="color:#b91c1c;">Não foi possível carregar o panorama. Tente recarregar a página.</p>';
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', carregarPanorama);
    } else {
        carregarPanorama();
    }
</script>
</div>

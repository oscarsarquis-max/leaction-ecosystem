# =====================================================================
# PanelDX Frontend/BFF (Node/Express) — PRODUÇÃO
# Copie para LeAction_Sys_FE/.env.production (build da imagem Docker)
# ou configure nas variaveis da task ECS do frontend.
# =====================================================================

NODE_ENV=production
PORT=3000

# URL publica do BFF (usuario final)
# BACKEND_URL e usado pelo browser em alguns fluxos; o proxy interno usa FLASK_API_URL.
BACKEND_URL=https://mudaedu.com.br
FLASK_API_URL=http://paneldx-backend-service:5000
# Em ECS: use o nome do servico/backend na rede interna do cluster.
# Ex.: http://paneldx-backend-service:5000 ou URL do service discovery.

SESSION_SECRET=[GERE_SEGREDO_FORTE_DIFERENTE_DO_FLASK]

# --- PostgreSQL (Gatekeeper / system_config) ---
DB_HOST=paneldx-db-host
DB_PORT=5432
DB_NAME=LeAction_SysF
DB_USER=postgres
DB_PASS=[SENHA_DO_BANCO]
DB_SSLMODE=require

# Chave mestra para bypass/unlock/lock em homologação produtiva (NUNCA commitar valor real)
PRODUCTION_MASTER_KEY=[GERE_CHAVE_FORTE_UNICA]
# Cache do system_locked no middleware (ms) — padrão 15000
# SYSTEM_CONFIG_CACHE_MS=15000

# --- Action Hub (checkout / webhook proxy) ---
HUB_JWT_SECRET=[MESMO_VALOR_DO_JWT_SECRET_DO_ACTION_HUB]
HUB_API_URL=https://api.actionhub.com.br
HUB_PUBLIC_URL=https://actionhub.com.br
HUB_WEBHOOK_URL=https://mudaedu.com.br/api/hub/payment-webhook
HUB_GATEWAY_INTERNAL_URL=https://api.actionhub.com.br

ADMIN_EMAIL=sysadmin@leaction.com.br

# Timeout chamadas ao Flask (ms)
# FLASK_HTTP_TIMEOUT_MS=60000

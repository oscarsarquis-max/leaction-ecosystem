# =====================================================================
# PanelDX — Exemplo de Variáveis de Ambiente
# Copie este arquivo para os locais corretos e preencha com valores reais:
#   - Backend Flask:  LeAction_SysF/.env
#   - Frontend/BFF:   LeAction_Sys_FE/.env.development  (ou .env.production)
# NUNCA faça commit dos arquivos .env preenchidos.
# =====================================================================

# ---------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)  — usado pelo backend Flask
# ---------------------------------------------------------------------
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=LeAction_SysF
DB_USER=postgres
DB_PASS=sua_senha_do_banco
# disable (local) | require (produção/RDS)
DB_SSLMODE=disable

# ---------------------------------------------------------------------
# AWS (Bedrock para IA, SES para e-mail, S3 para arquivos)
# ---------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIA_sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_access_key
AWS_DEFAULT_REGION=us-east-1
# Região e modelo do Bedrock (sobrescrevem os defaults do app)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ---------------------------------------------------------------------
# PORTAS DOS SERVIÇOS
# ---------------------------------------------------------------------
# Porta do backend Flask (5002 evita conflito com outros apps locais)
FLASK_PORT=5002
# Porta do frontend Node/Express (3000 local, 80 em produção)
PORT=3000

# ---------------------------------------------------------------------
# COMUNICAÇÃO ENTRE SERVIÇOS (Frontend/BFF -> Backend)
# ---------------------------------------------------------------------
# URL que o Node usa para alcançar o Flask. Ordem de prioridade no server.js:
#   FLASK_API_URL > BACKEND_URL > http://127.0.0.1:5000 (fallback local)
# Em Docker/compose: http://backend:5000  (nome do serviço na rede interna)
FLASK_API_URL=http://127.0.0.1:5000
# Mantido para compatibilidade com o setup local atual (Flask em 5002)
BACKEND_URL=http://localhost:5002
# Microsserviço de cálculo (opcional)
CALC_MICROSERVICE_URL=http://localhost:5001

# ---------------------------------------------------------------------
# CHAVES DE SESSÃO / SEGREDOS DA APLICAÇÃO
# ---------------------------------------------------------------------
# Segredo de sessão do Flask (gere um valor aleatório forte em produção)
FLASK_SECRET_KEY=troque_por_um_valor_aleatorio_forte
# Segredo de sessão do Express (gere um valor aleatório forte em produção)
SESSION_SECRET=troque_por_um_valor_aleatorio_forte

# ---------------------------------------------------------------------
# E-MAIL (SES / SMTP) — remetente verificado no AWS SES (domínio ou e-mail)
# ---------------------------------------------------------------------
MAIL_USERNAME=no-reply@mudaedu.com.br
EMAIL_SENDER=consultant@mudaedu.com.br

# ---------------------------------------------------------------------
# INTEGRAÇÃO ACTION HUB (leaction-platform)
# ---------------------------------------------------------------------
# Mesmo segredo usado no gateway-api (services/gateway-api/server.js)
HUB_JWT_SECRET=super-secret-hub-key-2026
# URL do gateway-api (POST /v1/payments)
HUB_API_URL=http://localhost:4001
HUB_GATEWAY_INTERNAL_URL=http://localhost:4001
# Opcional: mesmo valor no gateway ActionHub (header X-PanelDX-Vitrine-Sync)
# VITRINE_SYNC_SECRET=
# URL publica do Action Hub (redirect pos-pagamento)
HUB_PUBLIC_URL=http://localhost:4000
# Webhook que o Hub chama após pagamento (Flask direto em dev)
HUB_WEBHOOK_URL=http://localhost:5002/api/hub/payment-webhook

# E-mail tratado como administrador (God Mode) no BFF
ADMIN_EMAIL=sysadmin@seudominio.com.br

# ---------------------------------------------------------------------
# FRONTEND BFF — Gatekeeper / homologação produtiva (LeAction_Sys_FE/.env.production)
# ---------------------------------------------------------------------
# Chave mestra para liberar bypass de homologação e unlock global do sistema
PRODUCTION_MASTER_KEY=UmaChaveMuitoForteGeradaPorMim
# O BFF consulta system_config diretamente no PostgreSQL quando NODE_ENV=production
# DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS — mesmos valores do backend Flask

# ---------------------------------------------------------------------
# TELEMETRIA BASE MOBILE (eSIM) — webhook → Mesa de Inovação preditiva
# ---------------------------------------------------------------------
# Segredo opcional no header X-Basemobile-Secret (omitir em dev)
BASEMOBILE_WEBHOOK_SECRET=
# Materializar alertas como post-it na Mesa Org (true/false, default true)
BASEMOBILE_MATERIALIZAR_MESA=true
# Rate limit do webhook (requisições por IP por janela)
BASEMOBILE_RATE_LIMIT_PER_MINUTE=60
BASEMOBILE_RATE_LIMIT_WINDOW_S=60
# CloudWatch — logs estruturados + dead-letter Bedrock (1=ativo, 0=desliga em dev)
BASEMOBILE_CLOUDWATCH_ENABLED=1
BASEMOBILE_CW_LOG_GROUP=/paneldx/basemobile
BASEMOBILE_CW_REGION=us-east-1

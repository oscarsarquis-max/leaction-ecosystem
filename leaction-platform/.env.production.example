# =============================================================================
# Action Hub — variáveis de PRODUÇÃO (gateway-api + raiz do monorepo)
# =============================================================================
# No servidor EC2:
#   cp .env.production.example .env
#   nano .env   # preencha os valores reais
#
# O gateway-api carrega este arquivo via dotenv (../../.env a partir de services/gateway-api).
# O JWT_SECRET deve ser IDÊNTICO ao HUB_JWT_SECRET do PanelDX em produção.
# =============================================================================

# --- AWS RDS PostgreSQL (paneldx-database) ---
DATABASE_URL=postgresql://[USER_RDS]:[PASSWORD_RDS]@[ENDPOINT_RDS_PANELDX_DATABASE]:5432/leaction_hub?sslmode=no-verify

# --- URLs públicas ---
ACTION_HUB_PUBLIC_URL=https://actionhub.com.br
GATEWAY_PORT=4001

# --- Segredo compartilhado com PanelDX (webhook JWT pós-pagamento) ---
JWT_SECRET=[GERE_UM_SEGREDO_FORTE_IGUAL_AO_HUB_JWT_SECRET_DO_PANELDX]

# --- Admin nativo Action Hub (seed: node scripts/seed-hub-admin.js) ---
HUB_ADMIN_EMAILS=admin@actionhub.com.br
# HUB_ADMIN_PASSWORD=[SENHA_FORTE]  # só no seed; não precisa no runtime do gateway

# Webhook outbox → apps satélites (sobrescreve app_registry.webhook_url em produção)
# APP_WEBHOOK_URL_INOVE4US=https://inove4us.com.br/api/webhooks/actionhub

# --- Mercado Pago — PRODUÇÃO (substituir chaves TEST-...) ---
# Painel: https://www.mercadopago.com.br/developers/panel/app → Credenciais de produção
# Checklist: docs/MP-PRODUCAO-CHAVES.md
# Webhook MP: https://actionhub.com.br/webhooks/mercadopago
MP_ACCESS_TOKEN=APP_USR-[SEU_ACCESS_TOKEN_PRODUCAO]
MP_PUBLIC_KEY=APP_USR-[SUA_PUBLIC_KEY_PRODUCAO]
# Simulação local OFF em produção (não defina ALLOW_PAYMENT_SIMULATION=1)
ALLOW_PAYMENT_SIMULATION=0

# Assinatura recorrente (preapproval)
MP_SUBSCRIPTION_REASON=Assinatura Mensal - Leaction Hub
MP_SUBSCRIPTION_AMOUNT=99
MP_SUBSCRIPTION_CURRENCY=BRL
MP_SUBSCRIPTION_FREQUENCY=1
MP_SUBSCRIPTION_FREQUENCY_TYPE=months

# Checkout: card = pagamento único | subscription = preapproval recorrente
MP_CHECKOUT_MODE=card
MP_PANELDX_PAYMENT_AMOUNT=1

# Remover ou deixar vazio em produção (apenas sandbox)
# MP_SANDBOX_PAYER_CPF=

# Gatekeeper (lock/unlock/bypass) — mesmo secret do PanelDX/mudaedu
PRODUCTION_MASTER_KEY=

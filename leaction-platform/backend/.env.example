# Plugin Marketplace — Mercado Livre (porta 4012)
MARKETPLACE_PORT=4012
FLASK_DEBUG=1

# --- Amazon Product Advertising API (opcional) ---
# Chaves AWS: reutilizadas automaticamente do PanelDX (LeAction_SysF/.env).
# PANELDX_ENV_FILE=C:\Projetos\PanelDX\LeAction_SysF\.env
# AMAZON_PARTNER_TAG=seu-tag-associates-20
# AMAZON_REGION=us-east-1
# AMAZON_MARKETPLACE=www.amazon.com.br

# --- Mercado Livre OAuth (busca live /sites/MLB/search) ---
# App ID e Secret Key: https://developers.mercadolivre.com.br/
# Aliases: ML_CLIENT_ID → ML_APP_ID, ML_CLIENT_SECRET / MP_CLIENT_SECRET → ML_SECRET_KEY
ML_APP_ID=
ML_SECRET_KEY=

# Redirect OAuth — HTTPS obrigatório (ML rejeita http://localhost).
# Produção Action Hub:
ML_PUBLIC_BASE_URL=https://actionhub.com.br
# Cadastre no painel ML: https://actionhub.com.br/marketplace-api/ml/callback
# Login OAuth: https://actionhub.com.br/marketplace-api/ml/login
#
# Dev: cloudflared tunnel --url http://127.0.0.1:4012 → ML_PUBLIC_BASE_URL=https://SEU-TUNEL...

# Opcional: token/refresh pré-existentes (bootstrap antes do fluxo /ml/login)
# ML_ACCESS_TOKEN=
# ML_REFRESH_TOKEN=

# ML_SITE_ID=MLB

# Tokens OAuth persistidos automaticamente em backend/.ml_tokens.json após /ml/login

# Proxy Next.js (next.config.ts): MARKETPLACE_INTERNAL_URL=http://127.0.0.1:4012

# PostgreSQL — curadoria dinâmica
# MARKETPLACE_DATABASE_URL=postgresql://admin:password123@localhost:5433/leaction_hub

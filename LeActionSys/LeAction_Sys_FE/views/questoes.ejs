<div class="main-content">
    <div class="header-section">
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 20px;">
            <div>
                <h1><i class="fas fa-question-circle"></i> Questões TD (Engine)</h1>
                <p style="color: #666; margin-top: 5px;">Configuração das perguntas do Diagnóstico.</p>
            </div>
            <button class="btn blue-btn" onclick="abrirModal()">
                <i class="fas fa-plus"></i> Nova Questão
            </button>
        </div>
    </div>

    <div class="search-box-container" style="margin-bottom: 20px;">
        <div style="position: relative; max-width: 500px;">
            <i class="fas fa-search" style="position: absolute; left: 15px; top: 12px; color: #bdc3c7;"></i>
            <input type="text" id="global-search-questoes" onkeyup="filtrarQuestoes()"
                   placeholder="Buscar em enunciados, dimensões ou domínios..."
                   style="width: 100%; padding: 10px 10px 10px 40px; border: 1px solid #ddd; border-radius: 25px; outline: none; transition: border 0.3s;">
        </div>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th style="width: 50px;">ID</th>
                    <th>Texto da Questão</th>
                    <th style="width: 180px;">Dimensão/Domínio</th>
                    <th style="width: 180px;">Aplicável (Contexto)</th>
                    <th style="text-align: center; width: 100px;">Ações</th>
                </tr>
            </thead>
            <tbody id="table-body-questoes">
            </tbody>
        </table>
    </div>
</div>

<div id="modal-form-questoes" class="modal">
    <div class="modal-content" style="width: 900px; max-width: 95%; border-top: 5px solid #8e44ad; padding: 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
        <span class="close" onclick="fecharModal()">&times;</span>

        <h2 id="modal-title" style="color: #2980b9; margin-bottom: 30px; text-align: center; font-weight: 700;">
            <i class="fas fa-microchip" style="color: #8e44ad;"></i> Configuração da Questão
        </h2>

        <form id="form-ques" onsubmit="salvarRegistro(event)">
            <input type="hidden" id="id_ques">

            <!-- 1. ESTRATÉGIA COMERCIAL (LILÁS) -->
            <div style="display: flex; justify-content: space-between; align-items: center; background: #f4f4fb; padding: 18px; border-radius: 8px; margin-bottom: 25px; border: 1px solid #dcdde1; width: 85%; margin-left: auto; margin-right: auto;">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <i class="fas fa-rocket" style="color: #8e44ad; font-size: 1.4em;"></i>
                    <div>
                        <label style="font-weight: bold; color: #2c3e50; margin-bottom: 0; display: block;">Pré-Avaliação (Compõe a Amostra)</label>
                        <span style="font-size: 0.85em; color: #7f8c8d;">Questão integrante da amostragem representativa de pré-venda.</span>
                    </div>
                </div>
                <input type="checkbox" id="presurvey_ques" style="width: 24px; height: 24px; cursor: pointer; accent-color: #8e44ad;">
            </div>

            <!-- 2. CONTEXTO DE MATURIDADE E SETOR (NOVO - VERDE) -->
            <div style="width: 85%; margin: 0 auto 25px auto; display: flex; gap: 20px; background: #f1f8f1; padding: 18px; border-radius: 8px; border: 1px solid #c8e6c9;">
                <div style="flex: 1;">
                    <label style="color: #27ae60; font-weight: bold; display: block; margin-bottom: 8px; text-align: center;">
                        <i class="fas fa-clock"></i> Momento da Avaliação (P/F)
                    </label>
                    <select id="prefu_ques" required style="width: 100%; padding: 12px; border: 1px solid #a5d6a7; border-radius: 4px; background: white; cursor: pointer;">
                        <option value="P">Presente (Maturidade Atual)</option>
                        <option value="F">Futuro (Nível Desejado)</option>
                    </select>
                </div>
                <div style="flex: 1;">
                    <label style="color: #27ae60; font-weight: bold; display: block; margin-bottom: 8px; text-align: center;">
                        <i class="fas fa-industry"></i> Setor de Aplicação
                    </label>
                    <select id="setor_ques" required style="width: 100%; padding: 12px; border: 1px solid #a5d6a7; border-radius: 4px; background: white; cursor: pointer;">
                        <option value="GERAL">Mercado Geral (Empresas/Indústria)</option>
                        <option value="EDUCACAO">Instituições de Ensino (Acadêmico)</option>
                    </select>
                </div>
            </div>

            <!-- 3. CLASSIFICAÇÃO (CENTRALIZADO - AZUL SUAVE) -->
            <div style="width: 85%; margin: 0 auto 25px auto; display: flex; gap: 20px; background: #f0f7ff; padding: 20px; border-radius: 8px; border: 1px solid #d1e1f5;">
                <div style="flex: 1;">
                    <label style="color: #2980b9; font-weight: bold; display: block; margin-bottom: 8px; text-align: center;">Dimensão Acadêmica *</label>
                    <select id="id_dime_select" required style="width: 100%; padding: 12px; border: 1px solid #b3d7ff; border-radius: 4px; background: white; cursor: pointer;"></select>
                </div>
                <div style="flex: 1;">
                    <label style="color: #2980b9; font-weight: bold; display: block; margin-bottom: 8px; text-align: center;">Domínio Estratégico *</label>
                    <select id="id_doma_select" required style="width: 100%; padding: 12px; border: 1px solid #b3d7ff; border-radius: 4px; background: white; cursor: pointer;"></select>
                </div>
            </div>

            <!-- 4. ENUNCIADO (LARGURA TOTAL) -->
            <div style="width: 85%; margin: 0 auto 25px auto;">
                <label style="color: #2c3e50; font-weight: bold; display: block; margin-bottom: 8px;">Enunciado da Pergunta *</label>
                <textarea id="desc_ques" rows="3" required
                    style="width: 100%; border: 1px solid #dcdde1; border-radius: 4px; padding: 12px; box-sizing: border-box; font-size: 1.05em;"
                    placeholder="Ex: Como a instituição governa seus ativos digitais?"></textarea>
            </div>

            <!-- 5. MECANISMO DE RESPOSTAS -->
            <div style="width: 95%; margin: 0 auto 25px auto; background: #fff; padding: 20px; border: 1px solid #eee; border-radius: 12px; box-shadow: inset 0 0 10px rgba(0,0,0,0.02);">
                <h5 style="color: #2c3e50; border-bottom: 2px solid #8e44ad; padding-bottom: 10px; margin-bottom: 20px; font-weight: bold;">
                    <i class="fas fa-tasks" style="color: #8e44ad;"></i> Mecanismo de Respostas
                </h5>
                <div style="display: flex; gap: 30px;">
                    <!-- Rubricas -->
                    <div style="flex: 2;">
                        <h6 style="font-size: 0.85em; color: #2980b9; text-transform: uppercase; margin-bottom: 15px; font-weight: bold;">Rubricas de Graduação (0-5)</h6>
                        <div id="container-rubricas">
                            <% [0,1,2,3,4,5].forEach(grad => { %>
                                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                                    <span style="min-width: 65px; background: #2980b9; color: white; padding: 5px; border-radius: 4px; font-size: 0.8em; text-align: center; font-weight: bold;">Valor: <%= grad %></span>
                                    <input type="text" class="form-control-sm" style="flex: 1; padding: 8px; border: 1px solid #dcdde1; border-radius: 4px;"
                                           placeholder="Rótulo" id="label_<%= grad %>">
                                    <textarea class="form-control-sm" style="flex: 2; padding: 8px; border: 1px solid #dcdde1; border-radius: 4px;"
                                              placeholder="Descrição" id="desc_<%= grad %>" rows="1"></textarea>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                    <!-- Aberta -->
                    <div style="flex: 1; border-left: 2px solid #f4f4fb; padding-left: 20px;">
                        <h6 style="font-size: 0.85em; color: #8e44ad; text-transform: uppercase; margin-bottom: 15px; font-weight: bold;">Resposta Aberta</h6>
                        <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                            <input type="checkbox" id="permite_aberta" style="width: 18px; height: 18px; cursor: pointer; accent-color: #8e44ad;">
                            <label for="permite_aberta" style="font-size: 0.9em; cursor: pointer; color: #2c3e50;">Habilitar campo qualitativo</label>
                        </div>
                        <textarea id="quali_ques_def" style="width: 100%; border: 1px solid #dcdde1; border-radius: 4px; padding: 12px; height: 250px; font-size: 0.9em; background: #fcfaff;"
                                  placeholder="Orientações de preenchimento..."></textarea>
                    </div>
                </div>
            </div>

            <!-- 6. TARGET CONTEXT -->
            <div style="width: 85%; margin: 0 auto 30px auto; padding: 20px; background: #f8fbff; border: 1px solid #d1e1f5; border-radius: 8px;">
                <label style="font-weight: bold; display: block; margin-bottom: 15px; color: #2980b9; text-align: center; text-transform: uppercase; font-size: 0.9em;">
                    <i class="fas fa-bullseye"></i> Contexto Alvo (Segmentos de Ensino)
                </label>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; background: #fff; padding: 15px; border: 1px solid #d1e1f5; border-radius: 4px; width: fit-content; margin: 0 auto;">
                    <% ['K12', 'SUPERIOR', 'TECNICO', 'IDIOMAS', 'CORPORATIVO', 'GERAL'].forEach(segmento => { %>
                        <label style="font-weight: normal; font-size: 0.85em; display: flex; align-items: center; gap: 10px; cursor: pointer; min-width: 120px;">
                            <input type="checkbox" name="target_item" value="<%= segmento %>" style="width: 16px; height: 16px; accent-color: #2980b9;"> <%= segmento %>
                        </label>
                    <% }) %>
                </div>
            </div>

            <!-- 7. INSIGHT CHAVE -->
            <div style="width: 85%; margin: 0 auto 35px auto; padding: 20px; border: 2px solid #8e44ad; border-radius: 12px; background-color: #fcfaff;">
                <label style="color: #8e44ad; font-weight: bold; display: block; margin-bottom: 15px; text-transform: uppercase; font-size: 0.9em; text-align: center;">
                    <i class="fas fa-compass"></i> Bússola de Orientação (Direcionamentos)
                </label>

            <div class="form-group" style="margin-bottom: 15px; position: relative;">
                <label style="font-size: 0.85em; color: #2c3e50; font-weight: bold;">CATEGORIA (Escopo de Análise MASTER)</label>
                <input type="text" id="bussola_categoria"
                       oninput="filtrarSugestoesCategoria(this.value)"
                       autocomplete="off"
                       style="width: 100%; border: 1px solid #8e44ad; border-radius: 4px; padding: 10px;"
                       placeholder="Comece a digitar para filtrar categorias...">

                <div id="lista_suspensa_categorias" style="display: none; position: absolute; z-index: 1001; width: 100%; background: white; border: 1px solid #ddd; max-height: 200px; overflow-y: auto; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                </div>
            </div>

                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="font-size: 0.85em; color: #2c3e50; font-weight: bold;">DIAGNÓSTICO (O que a IA deve buscar no qualitativo)</label>
                    <textarea id="bussola_diagnostico" rows="2"
                              style="width: 100%; border: 1px solid #dcdde1; border-radius: 4px; padding: 10px; font-style: italic;"
                              placeholder="Ex: [Gestão de Mudança]; [Patrocínio Executivo]"></textarea>
                </div>

                <div class="form-group">
                    <label style="font-size: 0.85em; color: #2c3e50; font-weight: bold;">ÂNCORAS (Incipiente vs Sistêmico)</label>
                    <textarea id="bussola_ancoras" rows="2"
                              style="width: 100%; border: 1px solid #dcdde1; border-radius: 4px; padding: 10px; font-style: italic;"
                              placeholder="Ex: [Incipiente: Ações isoladas]; [Sistêmico: Cultura consolidada]"></textarea>
                </div>

                <input type="hidden" id="insight_chave">
            </div>

            <!-- BOTÕES -->
            <div style="display: flex; justify-content: center; gap: 20px; padding-top: 25px; border-top: 1px solid #eee;">
                <button type="button" style="background: #bdc3c7; color: white; padding: 14px 40px; border-radius: 6px; border: none; cursor: pointer; font-weight: bold; transition: 0.3s;" onclick="fecharModal()">Cancelar</button>
                <button type="submit" style="background: #8e44ad; color: white; padding: 14px 60px; border-radius: 6px; border: none; cursor: pointer; font-weight: bold; box-shadow: 0 4px 15px rgba(142, 68, 173, 0.3); transition: 0.3s;">
                    <i class="fas fa-save"></i> Salvar Questão
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .table-container { background: white; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); overflow: hidden; border: 1px solid #eee; }
    table { width: 100%; border-collapse: collapse; }
    th { background-color: #f8f9fa; color: #7f8c8d; font-weight: bold; text-transform: uppercase; padding: 15px; border-bottom: 2px solid #eee; text-align: left; }
    td { padding: 15px; border-bottom: 1px solid #eee; color: #2c3e50; }

    #global-search-questoes:focus { border-color: #3498db; box-shadow: 0 0 8px rgba(52,152,219,0.2); }

    .action-btn { border: none; background: none; cursor: pointer; font-size: 1.1em; padding: 5px; transition: transform 0.2s; }
    .action-btn:hover { transform: scale(1.1); }
    .btn-edit { color: #f39c12; }
    .btn-delete { color: #e74c3c; }
    .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); backdrop-filter: blur(2px); }
    .modal-content { background-color: white; margin: 5% auto; padding: 30px; border-radius: 8px; animation: slideDown 0.3s ease; }
    @keyframes slideDown { from { transform: translateY(-50px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .close { float: right; font-size: 24px; cursor: pointer; color: #999; }
    .form-row { display: flex; gap: 15px; }
    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
    .modal-buttons { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; border-top: 1px solid #eee; padding-top: 20px; }
    .btn { padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }
    .blue-btn { background-color: #3498db; color: white; }
    .cancel-btn { background-color: #ecf0f1; color: #7f8c8d; }
</style>

<script>
    const API_QUES = "<%= API_BASE_URL %>/ctdi_quest";
    const API_DIME = "<%= API_BASE_URL %>/leaf_dime";
    const API_DOMA = "<%= API_BASE_URL %>/leaf_doma";

    let localQuestoes = []; // Nosso cache para busca instantânea

    async function carregarTudo() {
        try {
            const [resDime, resDoma, resQues] = await Promise.all([
                fetch(API_DIME), fetch(API_DOMA), fetch(API_QUES)
            ]);

            const dimes = await resDime.json();
            const domas = await resDoma.json();
            localQuestoes = await resQues.json();

            document.getElementById('id_dime_select').innerHTML = dimes.map(d => `<option value="${d.id_dime}">${d.name_dime}</option>`).join('');
            document.getElementById('id_doma_select').innerHTML = domas.map(d => `<option value="${d.id_doma}">${d.name_doma}</option>`).join('');

            renderQuestTable(localQuestoes);
        } catch (error) { console.error("Erro ao carregar dados:", error); }
    }

function renderQuestTable(dados) {
    const tbody = document.getElementById('table-body-questoes');
    tbody.innerHTML = '';

    // Ordenação garantida pelo ID (Crescente)
    const dadosOrdenados = [...dados].sort((a, b) => a.id_ques - b.id_ques);

    dadosOrdenados.forEach(item => {
        const tr = document.createElement('tr');

        // Formatação dos qualificadores (Target Context)
        const aplicabilidade = item.target_context
            ? item.target_context.split(';').join(', ')
            : 'GERAL';

        // Badge para identificar o Freemium (Pre-survey)
        const badgePreSurvey = item.presurvey_ques
            ? `<span style="margin-left: 8px; color: #8e44ad; font-size: 0.8em;" title="Incluso no Freemium"><i class="fas fa-rocket"></i></span>`
            : '';

        tr.innerHTML = `
            <td style="color: #7f8c8d; font-size: 0.85em; text-align: center;">#${item.id_ques}</td>
            <td style="font-size: 0.95em;">
                <div style="display: flex; align-items: center;">
                    <strong>${item.desc_ques}</strong>
                    ${badgePreSurvey}
                </div>
            </td>
            <td>
                <div style="font-size: 0.75em; color: #2980b9; font-weight: bold;">D: ${item.name_dime_text || '---'}</div>
                <div style="font-size: 0.75em; color: #8e44ad; font-weight: bold;">M: ${item.name_doma_text || '---'}</div>
            </td>
            <td style="font-size: 0.85em; color: #666;">
                <i class="fas fa-bullseye" style="font-size: 0.8em; color: #bdc3c7;"></i> ${aplicabilidade}
            </td>
            <td style="text-align: center;">
                <button class="action-btn" style="color: #2980b9;" onclick="editarQuestao(${item.id_ques})" title="Editar Questão e Bússola">
                    <i class="fas fa-edit"></i>
                </button>
                <button class="action-btn" style="color: #e74c3c;" onclick="deletarQuestao(${item.id_ques})" title="Excluir">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </td>
        `;
        tbody.appendChild(tr);
    });
}

    // FUNÇÃO DE BUSCA GLOBAL (IGUAL AOS ENTREGÁVEIS)
    function filtrarQuestoes() {
        const termo = document.getElementById('global-search-questoes').value.toLowerCase();
        const filtrados = localQuestoes.filter(item => {
            const enunciado = item.desc_ques ? item.desc_ques.toLowerCase() : "";
            const dimensão = item.name_dime_text ? item.name_dime_text.toLowerCase() : "";
            const dominio = item.name_doma_text ? item.name_doma_text.toLowerCase() : "";

            return enunciado.includes(termo) || dimensão.includes(termo) || dominio.includes(termo);
        });
        renderQuestTable(filtrados);
    }

    function abrirModal(limpar = true) {
        if (limpar) {
            document.getElementById('form-ques').reset();
            document.getElementById('id_ques').value = '';
            document.getElementById('presurvey_ques').checked = false;
            document.getElementById('insight_chave').value = '';
            document.querySelectorAll('input[name="target_item"]').forEach(cb => cb.checked = false);
            document.getElementById('modal-title').innerText = "Nova Questão";
        }
        document.getElementById('modal-form-questoes').style.display = 'block';
    }

    function fecharModal() { document.getElementById('modal-form-questoes').style.display = 'none'; }

    function editarQuestao(id) {
        // Procura no cache local alimentado pelo JOIN do Python
        const item = localQuestoes.find(q => q.id_ques === id);
        if (!item) return;

        abrirModal(false);
        document.getElementById('modal-title').innerHTML = '<i class="fas fa-edit"></i> Edição da Questão #' + id;

        // 1. Campos Básicos e Novos Campos (P/F e Setor) - PRESERVADOS
        document.getElementById('id_ques').value = item.id_ques;
        document.getElementById('desc_ques').value = item.desc_ques;
        document.getElementById('id_dime_select').value = item.id_dime;
        document.getElementById('id_doma_select').value = item.id_doma;
        document.getElementById('presurvey_ques').checked = item.presurvey_ques || false;

        // Recuperando os campos de cálculo
        document.getElementById('prefu_ques').value = item.prefu_ques || 'P';
        document.getElementById('setor_ques').value = item.setor_ques || 'GERAL';

        // 2. Campo Qualitativo - PRESERVADO
        document.getElementById('quali_ques_def').value = item.quali_ques || '';
        document.getElementById('permite_aberta').checked = !!item.quali_ques;

        // 3. LÓGICA DA BÚSSOLA (INSIGHT CHAVE) - MODIFICADA PARA OS 3 CAMPOS
        const rawInsight = item.insight_chave || '';

        // Reset preventivo dos campos da bússola
        document.getElementById('bussola_categoria').value = '';
        document.getElementById('bussola_diagnostico').value = '';
        document.getElementById('bussola_ancoras').value = '';

        // Seta o hidden principal (para consistência)
        if(document.getElementById('insight_chave')) {
            document.getElementById('insight_chave').value = rawInsight;
        }

        if (rawInsight.includes('|')) {
            const partes = rawInsight.split('|');

            // Atribuição baseada na posição e limpeza dos rótulos
            partes.forEach(parte => {
                const p = parte.trim();
                if (p.startsWith('CATEGORIA:')) {
                    document.getElementById('bussola_categoria').value = p.replace('CATEGORIA:', '').trim();
                } else if (p.startsWith('DIAGNÓSTICO:')) {
                    document.getElementById('bussola_diagnostico').value = p.replace('DIAGNÓSTICO:', '').trim();
                } else if (p.startsWith('ÂNCORAS:')) {
                    document.getElementById('bussola_ancoras').value = p.replace('ÂNCORAS:', '').trim();
                }
            });
        } else {
            // Fallback para questões antigas: joga tudo no diagnóstico
            document.getElementById('bussola_diagnostico').value = rawInsight;
        }

        // 4. Target Context - PRESERVADO
        const targets = item.target_context ? item.target_context.split(';') : [];
        document.querySelectorAll('input[name="target_item"]').forEach(cb => {
            cb.checked = targets.includes(cb.value);
        });

        // 5. Rubricas - PRESERVADO
        for(let i=0; i<=5; i++) {
            document.getElementById(`label_${i}`).value = '';
            document.getElementById(`desc_${i}`).value = '';
        }

        if (item.rubricas && Array.isArray(item.rubricas)) {
            item.rubricas.forEach(r => {
                if (document.getElementById(`label_${r.grad_rubr}`)) {
                    document.getElementById(`label_${r.grad_rubr}`).value = r.label_rubr;
                    document.getElementById(`desc_${r.grad_rubr}`).value = r.desc_rubr;
                }
            });
        }
    }
    async function salvarRegistro(event) {
        event.preventDefault();

        try {
            const id_field = document.getElementById('id_ques');
            const id = id_field ? id_field.value : null;

            const getVal = (id) => {
                const el = document.getElementById(id);
                return el ? el.value : '';
            };

            // Captura Rubricas
            const rubricas = [];
            for(let i=0; i<=5; i++) {
                const lb = getVal(`label_${i}`);
                const ds = getVal(`desc_${i}`);
                if(lb.trim() || ds.trim()) {
                    rubricas.push({ grad_rubr: i, label_rubr: lb, desc_rubr: ds });
                }
            }

            // Captura Targets
            const targets = Array.from(document.querySelectorAll('input[name="target_item"]:checked'))
                .map(cb => cb.value)
                .join(';');

            // Montagem do Payload corrigida
            const payload = {
                desc_ques: getVal('desc_ques'),
                id_dime: parseInt(getVal('id_dime_select')) || 0,
                id_doma: parseInt(getVal('id_doma_select')) || 0,
                presurvey_ques: document.getElementById('presurvey_ques')?.checked || false,
                quali_ques: getVal('quali_ques_def'),
                insight_chave: getVal('insight_chave'),
                target_context: targets,
                rubricas: rubricas,
                // ANTES: Estava "P" e "GERAL" fixos. AGORA: Captura do modal.
                prefu_ques: getVal('prefu_ques'),
                setor_ques: getVal('setor_ques')
            };

            const url = id ? `/api/ctdi_quest/${id}` : '/api/ctdi_quest';

            const response = await fetch(url, {
                method: id ? 'PUT' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                const errorText = await response.text();
                throw new Error(`Erro ${response.status}: Servidor recusou a gravação.`);
            }

            alert("Configuração Master salva!");
            location.reload();

        } catch (error) {
            console.error("Erro detalhado:", error);
            alert(error.message);
        }
    }
    async function deletarQuestao(id) {
        if(confirm("Confirma exclusão desta Questão MASTER e todos os seus vínculos?")) {
            try {
                const response = await fetch(`${API_QUES}/${id}`, {
                    method: 'DELETE'
                });

                const result = await response.json(); // Aqui capturamos o JSON do Python

                if (response.ok) {
                    // EXIBE A MENSAGEM: "Registro e dependências removidos com sucesso."
                    alert(result.message);
                    carregarTudo(); // Atualiza a lista na tela
                } else {
                    alert("Erro ao excluir: " + (result.error || "Falha desconhecida"));
                }
            } catch (error) {
                console.error("Erro na comunicação de deleção:", error);
                alert("Erro de conexão com o servidor.");
            }
        }
    }


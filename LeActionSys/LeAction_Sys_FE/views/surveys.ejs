<div id="surveys-page">
    <h1>Gerenciar Questionários TD</h1>

    <h2>Adicionar Nova Questão</h2>
    <form id="surveys-form">
        <div class="form-group">
            <label for="id_matu">Maturidade:</label>
            <input type="text" id="id_matu" name="id_matu" required>
        </div>
        <div class="form-group">
            <label for="id_dime">Dimensão:</label>
            <input type="text" id="id_dime" name="id_dime" required>
        </div>
        <div class="form-group">
            <label for="id_doma">Domínio:</label>
            <input type="text" id="id_doma" name="id_doma" required>
        </div>
        <div class="form-group">
            <label for="id_phase">Fase:</label>
            <input type="text" id="id_phase" name="id_phase" required>
        </div>
        <div class="form-group">
            <label for="id_ques">Questão:</label>
            <input type="text" id="id_ques" name="id_ques" required>
        </div>
        <div class="form-group">
            <label for="grad_ques">Nota Questão:</label>
            <input type="text" id="grad_ques" name="grad_ques" required>
        </div>

        <button type="submit" id="saveOrAddButton">Adicionar</button>

    </form>

    <h2>Buscar Questionários(<i>Surveys</i>)</h2>
    <div class="search-container">
        <input type="text" id="search-input" placeholder="Digite 5+ caracteres para buscar...">
        <button id="search-btn">Buscar</button>
    </div>

    <h2>Lista de Questões</h2>
    <table id="surveys-table">
        <thead>
        <tr>
            <th>ID</th>
            <th>Cliente</th>
            <th>Dimensão</th>
            <th>Domínio</th>
            <th>Questão</th>
            <th>Grau</th>s
            <th>Ações</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td colspan="5">Use a busca acima para encontrar questionários.</td>
        </tr>
        </tbody>
    </table>
</div>

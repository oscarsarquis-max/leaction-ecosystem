<style>
    /* ==================================================================
       🎨 MANUAL DE IDENTIDADE VISUAL: BLACK, WHITE & LILAC (STRICT)
       ================================================================== */
    :root {
        --pure-white: #ffffff;
        --pure-black: #000000;
        --dark-lilac: #4A2E80;
        --light-lilac: #F4F2FF;
        --border-lilac: #E2D9FF;
        --text-dark: #1A1A1A;
        --text-gray: #666666;
    }

    /* Layout Geral do Kanban */
    .kanban-header {
        background: var(--pure-white); padding: 25px; border-radius: 12px;
        border-left: 6px solid var(--dark-lilac); box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;
        border: 1px solid #eee;
    }
    .kanban-title h2 { margin: 0; color: var(--pure-black); font-size: 1.6em; font-weight: 900; letter-spacing: -0.5px; }
    .kanban-title p { margin: 4px 0 0 0; color: var(--text-gray); font-size: 0.9em; }

    .kanban-board { display: flex; gap: 20px; align-items: flex-start; padding-bottom: 20px; overflow-x: auto; }

    /* Colunas do Quadro */
    .kanban-column {
        flex: 1; background: #fafafa; border-radius: 14px; min-width: 330px;
        min-height: 75vh; padding: 18px; display: flex; flex-direction: column; border: 1px solid #eee;
    }
    .kanban-column h3 {
        font-size: 0.85em; text-transform: uppercase; color: var(--text-dark);
        margin-bottom: 18px; display: flex; align-items: center; gap: 10px; padding: 0 5px; font-weight: 800;
    }

    /* Cards Dinâmicos */
    .task-card {
        background: var(--pure-white); border-radius: 10px; box-shadow: 0 2px 6px rgba(0,0,0,0.03);
        margin-bottom: 15px; transition: transform 0.2s, box-shadow 0.2s; border: 1px solid #f0f0f0;
        border-left: 6px solid var(--text-gray); overflow: hidden;
    }
    .task-card:hover { transform: translateY(-3px); box-shadow: 0 6px 15px rgba(0,0,0,0.08); }

    /* 🎯 ESTILOS DO CARD DA MESA DE INOVAÇÃO (DX) */
    .card-inovacao { border-left-color: #f97316 !important; background: #fffdfa; }
    .badge-dx { background: #4f46e5; color: white; padding: 3px 6px; border-radius: 4px; font-size: 0.8em; font-weight: 900; letter-spacing: 1px; margin-right: 5px; }

    .card-backlog { border-left-color: #e74c3c; }
    .card-andamento { border-left-color: var(--dark-lilac); }
    .card-concluido { border-left-color: #27ae60; }

    .task-header { padding: 18px; border-bottom: 1px solid #fcfcfc; }
    .task-title { font-weight: 800; font-size: 1.05em; color: var(--pure-black); line-height: 1.3; }

    .dod-list { padding: 12px 18px; background: #fafafa; border-top: 1px solid #f5f5f5; }
    .dod-text { font-size: 0.85em; color: var(--text-gray); line-height: 1.4; display: block; }
    .task-actions { padding: 12px 18px; background: var(--pure-white); border-top: 1px solid #eee; text-align: center; }

    /* Botões Customizados */
    .btn-action {
        width: 100%; padding: 10px; border-radius: 6px; border: none;
        font-weight: 700; cursor: pointer; display: flex; align-items: center;
        justify-content: center; gap: 8px; font-size: 0.85em; transition: 0.2s;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    .btn-purple-dark { background: var(--pure-black); color: var(--pure-white); }
    .btn-purple-dark:hover { background: var(--dark-lilac); }
    .btn-purple-light { background: var(--light-lilac); color: var(--dark-lilac); border: 1px solid var(--border-lilac); }
    .btn-purple-light:hover { background: var(--border-lilac); }

    /* Layout do Modal (Dashboard Assimétrico Grid) */
    .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.65); backdrop-filter: blur(4px); }
    .modal-content {
        background: var(--pure-white); margin: 2vh auto; padding: 30px; border-radius: 16px;
        width: 96%; max-width: 1550px; max-height: 96vh; overflow-y: auto; box-shadow: 0 15px 40px rgba(0,0,0,0.25);
    }
    .close { float: right; font-size: 32px; cursor: pointer; color: #bbb; transition: 0.2s; font-weight: 300; }
    .close:hover { color: var(--pure-black); }

    .sprint-governance-grid {
        display: grid; grid-template-columns: 1.62fr 0.88fr; gap: 30px; align-items: start; width: 100%;
    }

    /* Bloco Estacionário da IA e Metas (Coluna Direita) */
    .modulador-sticky-sidebar {
        position: sticky; top: 10px; background: var(--light-lilac); border: 1px solid var(--border-lilac);
        border-radius: 14px; padding: 25px; display: flex; flex-direction: column; gap: 20px;
        max-height: 86vh; overflow-y: auto; box-shadow: inset 0 0 10px rgba(74,46,128,0.02);
    }

    /* Widget de Progresso da Meta */
    .meta-progress-widget {
        background: var(--pure-black); color: var(--pure-white); padding: 22px; border-radius: 10px; text-align: center;
    }
    .meta-progress-value { font-size: 2.6em; font-weight: 900; color: var(--pure-white); line-height: 1; }

    /* Console de Comunicação Permanente */
    .modulador-live-console {
        background: var(--pure-white); border: 1px solid var(--border-lilac); border-radius: 8px;
        padding: 15px; font-size: 0.9em; line-height: 1.5; color: var(--text-dark); max-height: 320px; overflow-y: auto;
    }

    /* Vetores da Operação (Coluna Esquerda) */
    fieldset.vector-fieldset {
        border: 1px solid #e2e8f0; padding: 22px; border-radius: 12px; margin-bottom: 20px; background: var(--pure-white);
    }
    fieldset.vector-fieldset legend {
        padding: 0 15px; font-weight: 900; color: var(--dark-lilac); font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.5px;
    }

    .form-group label { display: block; margin-bottom: 6px; font-weight: 700; font-size: 0.85em; color: var(--text-dark); }
    input, select, textarea { width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 6px; font-size: 0.9em; color: var(--text-dark); background: var(--pure-white); }
    input:focus, select:focus, textarea:focus { border-color: var(--dark-lilac); outline: none; }

    .framework-guide { background: #fdfdfd; border-radius: 10px; padding: 15px; margin-bottom: 25px; border: 1px solid #eee; border-left: 5px solid var(--dark-lilac); }
    .metric-range-box { background: #fafafa; border: 1px solid #f0f0f0; border-radius: 8px; padding: 15px; }

    /* Sliders */
    .metric-range { -webkit-appearance: none; width: 100%; height: 8px; border-radius: 4px; background: #e0e0e0; outline: none; }
    .metric-range::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%; background: var(--dark-lilac); cursor: pointer; transition: 0.1s; }
    .metric-range::-webkit-slider-thumb:hover { transform: scale(1.15); }

    /* Animação de Pulso para o Microfone Ativo */
    @keyframes mic-pulse {
        0% { color: var(--dark-lilac); transform: scale(1); }
        50% { color: #e74c3c; transform: scale(1.15); opacity: 0.8; }
        100% { color: var(--dark-lilac); transform: scale(1); }
    }
    .mic-ativo {
        animation: mic-pulse 1.3s infinite ease-in-out;
    }
</style>

<%
    // --- CONSOLIDAÇÃO DE ESTRUTURA HORIZONTAL ---
    let todasAsSprints = [];
    if (locals.journey && journey.length > 0) {
        journey.forEach(onda => {
            if (onda.sprints) {
                onda.sprints.forEach(s => {
                    s.nome_onda = onda.nome;
                    todasAsSprints.push(s);
                });
            }
        });
    }
%>

<div class="kanban-header">
    <div class="kanban-title">
        <h2>Quadro de Controle das Sprints (Kanban)</h2>
        <p>Cliente: <strong><%= lead.nome %></strong></p>
    </div>
    <div style="font-size: 0.85em; font-weight: bold; color: var(--dark-lilac);">
        ID MATURIDADE: #<%= lead.id_matu %>
    </div>
</div>

<div class="kanban-board">

    <!-- 🎯 NOVA COLUNA: INOVAÇÃO (EM ANÁLISE) -->
    <div class="kanban-column" style="background: #fffaf5; border-color: #fdba74;">
        <h3 style="color: #ea580c;"><i class="fas fa-lightbulb" style="color: #f97316;"></i> Inovação (Em Análise)</h3>

        <button onclick="iniciarImportacaoDX()" class="btn-action" style="background: white; color: #ea580c; border: 2px dashed #fdba74; margin-bottom: 15px; padding: 12px; border-radius: 8px; font-weight: bold; width: 100%; transition: all 0.2s;" onmouseover="this.style.background='#ffedd5'" onmouseout="this.style.background='white'">
            <i class="fas fa-file-import"></i> Importar Sprint (JSON)
        </button>

        <%
           const inovacao = todasAsSprints.filter(s => {
               const st = (s.stat_sprn || s.status || '').toLowerCase().trim();
               return st === 'em analise' || st === 'em_analise';
           });
           if (inovacao.length === 0) { %>
               <p style="text-align:center; color:#ea580c; font-size:0.8em; margin-top:20px; font-style: italic; opacity: 0.7;">
                   <i class="fas fa-box-open" style="font-size: 2em; margin-bottom: 10px; display: block;"></i>
                   Aguardando importação da Mesa DX.
               </p>
           <% } else {
               inovacao.forEach((s) => { renderCardInovacao(s); });
           }
        %>
    </div>

    <div class="kanban-column">
        <h3><i class="fas fa-pause-circle" style="color: #64748b;"></i> Planejada (Backlog)</h3>
        <%
           const backlog = todasAsSprints.filter(s => {
               const st = (s.stat_sprn || s.status || 'planejada').toLowerCase().trim();
               return ['pendente', 'agendada', 'agendado', 'planejada', 'planejado', ''].includes(st);
           });
           if (backlog.length === 0) { %>
               <p style="text-align:center; color:#999; font-size:0.8em; margin-top:20px;">Nenhuma sprint no backlog.</p>
           <% } else { backlog.forEach((s) => { renderCard(s, 'card-backlog', false); }); }
        %>
    </div>

    <div class="kanban-column" style="background: var(--light-lilac); border-color: var(--border-lilac);">
        <h3><i class="fas fa-play-circle" style="color: var(--dark-lilac);"></i> Em Andamento</h3>
        <%
           const andamento = todasAsSprints.filter(s => ['ativa', 'em_progresso', 'executando'].includes((s.stat_sprn || s.status || '').toLowerCase().trim()));
           andamento.forEach((s) => { renderCard(s, 'card-andamento', true); });
        %>
    </div>

    <div class="kanban-column">
        <h3><i class="fas fa-check-circle" style="color: #27ae60;"></i> Concluído</h3>
        <%
           const concluido = todasAsSprints.filter(s => ['concluida', 'concluido', 'finalizada'].includes((s.stat_sprn || s.status || '').toLowerCase().trim()));
           concluido.forEach((s) => { renderCard(s, 'card-concluido', true); });
        %>
    </div>
</div>

<%
// 🎯 FUNÇÃO DE RENDERIZAÇÃO EXCLUSIVA PARA OS CARDS DX
function renderCardInovacao(sprint) {
    const sprintId = sprint.id_sprn || sprint.id || '';
%>
    <div class="task-card card-inovacao">
        <div class="task-header">
            <div style="display: flex; align-items: center; justify-content: space-between;">
                <small style="color: #ea580c; font-weight:800; font-size:0.7em; text-transform: uppercase; display: flex; align-items: center;">
                    <span class="badge-dx">DX</span> MESA DE INOVAÇÃO
                </small>
                <span style="font-size: 0.65em; color: #ea580c; font-weight: bold; background: #ffedd5; padding: 3px 6px; border-radius: 4px;">EM ANÁLISE</span>
            </div>
            <div class="task-title" style="margin-top: 10px;"><%= sprint.name_sprn || sprint.nome %></div>
            <div style="font-size: 0.75em; color: #ea580c; margin-top: 8px; font-weight: 600;">
                <i class="fas fa-tools"></i> Planejamento Pendente
            </div>
        </div>
        <div class="dod-list" style="background: #fffaf5; border-top-color: #ffedd5;">
            <span class="dod-text" style="color: #9a3412;"><%= sprint.desc_sprn || sprint.objetivo || 'Aguardando detalhamento e acoplamento estratégico.' %></span>
        </div>
        <div class="task-actions" style="border-top-color: #ffedd5; background: #fffaf5;">
            <button class="btn-action" style="background: var(--pure-white); border: 1px solid #fdba74; color: #ea580c;" onclick="abrirPlanejamentoInovacao('<%= sprintId %>')">
                <i class="fas fa-calendar-plus"></i> Planejar Sprint
            </button>
        </div>
    </div>
<% } %>

<%
function renderCard(sprint, colorClass, showButton) {
    const sprintId = sprint.id_sprn || sprint.id || '';
    const statusLimpo = (sprint.stat_sprn || sprint.status || '').toLowerCase().trim();
    const isConcluida = ['concluida', 'concluido', 'finalizada'].includes(statusLimpo);
%>
    <div class="task-card <%= colorClass %>">
        <div class="task-header">
            <small style="color: var(--dark-lilac); font-weight:800; font-size:0.7em; text-transform: uppercase;"><%= sprint.nome_onda %></small>
            <div class="task-title" style="margin-top: 2px;"><%= sprint.name_sprn || sprint.nome %></div>
            <div style="font-size: 0.75em; color: var(--text-gray); margin-top: 6px;">
                <i class="far fa-calendar-alt"></i> <%= isConcluida ? 'Finalizada em' : 'Início' %>: <%= sprint.dtini_sprn || sprint.dt_inic_sprn || 'A definir' %>
            </div>
        </div>
        <div class="dod-list">
            <span class="dod-text"><%= sprint.desc_sprn || sprint.objetivo || 'Foco em evolução de maturidade.' %></span>
        </div>
        <% if (showButton) { %>
            <div class="task-actions">
                <button class="btn-action <%= isConcluida ? 'btn-purple-light' : 'btn-purple-dark' %>" onclick="abrirPainelSprint('<%= sprintId %>')">
                    <i class="fas <%= isConcluida ? 'fa-eye' : 'fa-rocket' %>"></i> <%= isConcluida ? 'Detalhes da Execução' : 'Gerenciar Execução' %>
                </button>
            </div>
        <% } %>
    </div>
<% } %>

<div id="modal-sprint-exec" class="modal">
    <div class="modal-content">
        <span class="close" onclick="fecharModalSprint()">&times;</span>

        <div style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
            <h2 style="color: var(--pure-black); font-weight: 900; margin: 0; font-size: 1.6em;"><i class="fas fa-cubes" style="color: var(--dark-lilac);"></i> Painel de Execução Unificada</h2>
            <p id="sprint-subtitle" style="color: var(--dark-lilac); font-weight: 700; margin: 4px 0 0 0; font-size: 0.95em;"></p>
        </div>

        <div class="sprint-governance-grid">

            <div class="left-execution-engine">

                <div class="framework-guide">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                        <div><small style="font-weight: 900; color: var(--pure-black); font-size: 0.7em; text-transform: uppercase;">Definição do Entregável</small><div id="guide-defi" style="font-size: 0.9em; color: var(--text-dark); margin-top: 4px;"></div></div>
                        <div><small style="font-weight: 900; color: var(--pure-black); font-size: 0.7em; text-transform: uppercase;">Composição Metodológica Exigida</small><div id="guide-comp" style="font-size: 0.9em; white-space: pre-wrap; color: var(--text-dark); margin-top: 4px;"></div></div>
                    </div>
                </div>

                <fieldset class="vector-fieldset">
                    <legend><i class="fas fa-file-signature"></i> Vetor 1: Comprovação Documental / Relato Verbal</legend>
                    <div style="display: flex; align-items: flex-end; gap: 15px; background: var(--light-lilac); padding: 15px; border-radius: 8px; border: 1px solid var(--border-lilac); margin-bottom: 15px;">
                        <div style="flex: 1.5;">
                            <label style="font-weight: bold; color: var(--dark-lilac); font-size: 0.85em;"><i class="fas fa-link"></i> Link da Evidência (Drive/Sharepoint)</label>
                            <input type="url" id="evid_url" placeholder="https://..." style="margin-top: 5px;">
                        </div>
                        <div style="flex: 1;">
                            <label style="font-weight: bold; color: var(--dark-lilac); font-size: 0.85em;"><i class="fas fa-puzzle-piece"></i> Componente Vinculado</label>
                            <select id="evid_componente" style="margin-top: 5px;"></select>
                        </div>
                        <button type="button" class="btn-action btn-purple-dark" style="width: 140px; height: 40px;" onclick="adicionarEvidencia()">
                            <i class="fas fa-plus"></i> Vincular
                        </button>
                    </div>
                    <div style="width: 100%; background: var(--pure-white); border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 0.9em;">
                            <thead style="background: var(--light-lilac); color: var(--dark-lilac);">
                                <tr>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid var(--border-lilac);">Componente</th>
                                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid var(--border-lilac);">Link</th>
                                    <th style="padding: 12px; text-align: center; border-bottom: 2px solid var(--border-lilac);">Status Modulador</th>
                                    <th style="padding: 12px; text-align: center; border-bottom: 2px solid var(--border-lilac);">Ação</th>
                                </tr>
                            </thead>
                            <tbody id="lista-evidencias-corpo"></tbody>
                        </table>
                    </div>
                </fieldset>

                <fieldset class="vector-fieldset">
                    <legend><i class="fas fa-tasks"></i> Vetor 2: Atividades Táticas da Sprint</legend>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <small style="color: var(--text-gray);">Ações operacionais atreladas aos KRs estratégicos para execução do bloco.</small>
                        <button type="button" class="btn-action btn-purple-dark" onclick="abrirSubModalAtividade()" style="width: auto; padding: 6px 15px; font-size: 0.8rem;">
                            <i class="fas fa-plus"></i> Nova Atividade
                        </button>
                    </div>
                    <div id="lista-atividades-sprint" style="display: grid; grid-template-columns: 1fr; gap: 8px; max-height: 220px; overflow-y: auto; padding: 2px;"></div>
                </fieldset>

                <fieldset class="vector-fieldset">
                    <legend><i class="fas fa-comments"></i> Vetor 3: Ritos, Cerimônias e Alinhamentos Coletivos</legend>
                    <div style="display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 25px; width: 100%;">
                        <div>
                            <div style="display: flex; gap: 15px; margin-bottom: 15px;">
                                <div style="flex: 1;">
                                    <label>Tipo de Rito</label>
                                    <select id="cerm_tipo" style="padding: 9px;">
                                        <option value="Daily">Daily (Diária)</option>
                                        <option value="Planning">Planning (Planejamento)</option>
                                        <option value="Review">Review (Revisão)</option>
                                        <option value="Retrospectiva">Retrospectiva</option>
                                    </select>
                                </div>
                                <div style="flex: 0.8;">
                                    <label>Data</label>
                                    <input type="date" id="cerm_data" value="<%= new Date().toISOString().split('T')[0] %>" style="padding: 9px;">
                                </div>
                            </div>

                            <div class="form-group" style="margin-bottom: 15px;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                                    <label style="margin: 0; font-weight: 700; font-size: 0.85em; color: var(--text-dark);">
                                        Notas e Deliberações do Rito (Input Verbal/Ata)
                                    </label>
                                    <button type="button" id="btn-voice-cerm" onclick="alternarVozRito()" style="background: none; border: none; color: var(--dark-lilac); cursor: pointer; display: flex; align-items: center; gap: 6px; padding: 5px 10px; border-radius: 20px; background: #fff; border: 1px solid var(--border-lilac);">
                                        <i class="fas fa-microphone" id="mic-icon-cerm"></i>
                                        <small id="mic-status-cerm" style="font-weight: 800; text-transform: uppercase; font-size: 0.7em; color: var(--text-gray);">Ditado Desligado</small>
                                    </button>
                                </div>
                                <textarea id="cerm_note" rows="4" placeholder="Clique no microfone para ditar ou digite as notas do rito..." style="border-radius: 6px; padding: 12px; line-height: 1.4; transition: 0.3s;"></textarea>
                            </div>

                            <div style="display: flex; gap: 15px;">
                                <button type="button" id="btn-cerm-save" class="btn-action btn-purple-dark" style="flex: 2; height: 42px;" onclick="salvarApenasCerimonia()">
                                    <i class="fas fa-save"></i> Registrar Este Rito
                                </button>
                                <button type="button" id="btn-cerm-cancel" class="btn-action" style="background: #94a3b8; color: white; flex: 1; display: none; height: 42px;" onclick="limparFormCerimonia()">
                                    <i class="fas fa-undo"></i> Desistir
                                </button>
                            </div>
                            <input type="hidden" id="edit_id_cermls">
                        </div>
                        <div style="background: #fafafa; border-radius: 8px; padding: 15px; border: 1px solid #eee; display: flex; flex-direction: column;">
                            <small style="font-weight: 900; color: var(--dark-lilac); font-size: 0.75em; text-transform: uppercase; display: block; margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 5px;">
                                <i class="fas fa-history"></i> Linha do Tempo
                            </small>
                            <div id="timeline-cerimonias" style="max-height: 240px; overflow-y: auto; flex-grow: 1;"></div>
                        </div>
                    </div>
                </fieldset>

                <fieldset class="vector-fieldset">
                    <legend><i class="fas fa-sliders-h"></i> Métricas de Qualidade Associadas à Execução</legend>
                    <div id="container-metrics-dynamic" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;" class="metric-range-box"></div>
                </fieldset>
            </div>

            <div class="modulador-sticky-sidebar">

                <div class="meta-progress-widget">
                    <small style="text-transform: uppercase; font-size: 0.72em; font-weight: 800; letter-spacing: 0.5px; color: var(--border-lilac); display: block; margin-bottom: 6px;">Progresso Qualitativo do Bloco</small>
                    <div id="progress-label" class="meta-progress-value">0%</div>
                    <div style="background: #222; height: 10px; border-radius: 5px; margin-top: 15px; border: 1px solid #333; overflow: hidden;">
                        <div id="progress-bar-exec" style="background: var(--pure-white); width: 0%; height: 100%; border-radius: 5px; transition: 0.4s;"></div>
                    </div>

        async function deletarRotinaAtiva() {
            const id = selectRotina.value; if(!id) return alert("Selecione uma aula.");
            if(!confirm("Deseja apagar?")) return;
            try {
                const res = await fetch(`/inovador/api/rotinas?id_rotina=${id}`, { method: 'DELETE' });
                if((await res.json()).status === 'success') inicializarDashboard();

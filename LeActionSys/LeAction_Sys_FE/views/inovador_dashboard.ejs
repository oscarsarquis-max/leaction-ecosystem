        function selecionarProblemaCMUPorId(idProb) {
            const itemEncontrado = cacheResultadosCMU.find(item => item.id_prob === idProb);
            if (!itemEncontrado) return;
            cmuSelecionadoLocal = itemEncontrado;
            document.getElementById('dropdown-resultados-cmu').classList.add('hidden');
            document.getElementById('txt-busca-cmu').value = itemEncontrado.categoria_prob;

            mostrarCmuNoPainelBusca(itemEncontrado);
            if (!document.getElementById('ia-result-panel').classList.contains('hidden')) {
                exibirCardCMUAcoplado();
            }

            try {
                fetch('/inovador/api/cmu/sessao', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cmu: itemEncontrado })
                });
            } catch(err) { console.error(err); }
        }

        function exibirCardCMUAcoplado() {
            if (!cmuSelecionadoLocal) return;
            const card = document.getElementById('card-cmu-selecionado');
            card.classList.remove('hidden');
            document.getElementById('lbl-cmu-grupo-cat').innerText = `${cmuSelecionadoLocal.grupo_prob} / ${cmuSelecionadoLocal.categoria_prob}`;
            document.getElementById('lbl-cmu-sintoma').innerText = `Sintoma: ${cmuSelecionadoLocal.desc_prob}`;
            document.getElementById('lbl-cmu-remedio').innerHTML = `<strong>Estratégia CMU:</strong> ${cmuSelecionadoLocal.solucoes_prob}`;

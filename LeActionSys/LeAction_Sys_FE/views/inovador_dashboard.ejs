        async function executarBuscaMetodologia(termo) {
            const dropdown = document.getElementById('dropdown-resultados-metodo');
            if (termo.trim().length < 2) { dropdown.classList.add('hidden'); cacheMetodologiasAtivas = []; return; }
            try {
                const res = await fetch(`/inovador/api/metodologias/buscar?q=${encodeURIComponent(termo)}`);
                const resData = await res.json();
                if (resData.status === 'success' && resData.data.length > 0) {
                    cacheMetodologiasAtivas = resData.data;
                    dropdown.classList.remove('hidden');
                    dropdown.innerHTML = resData.data.map(item => `
                        <div onclick="selecionarMetodologiaAtivaPorId(${item.id_meta})" class="p-2 border-b border-slate-800 hover:bg-slate-800 cursor-pointer text-left transition-all">
                            <div class="text-[10px] text-fuchsia-400 font-bold uppercase"><i class="fa-solid fa-graduation-cap mr-1"></i>${item.cate_metodo}</div>
                            <div class="text-xs text-slate-200 mt-0.5 font-semibold">${item.prop_pratico}</div>
                        </div>
                    `).join('');
                } else {
                    dropdown.classList.remove('hidden');
                    dropdown.innerHTML = '<div class="p-2 text-xs text-slate-500 italic">Nenhum catálogo encontrado.</div>';
                }
            } catch(e) { console.error(e); }
        }

        async function selecionarMetodologiaAtivaPorId(idMeta) {
            const meta = cacheMetodologiasAtivas.find(m => m.id_meta === idMeta);
            if (!meta) return;

            document.getElementById('dropdown-resultados-metodo').classList.add('hidden');
            document.getElementById('txt-busca-metodo').value = meta.cate_metodo;

            try {
                const res = await fetch(`/inovador/api/metodologias/praticas?id_meta=${idMeta}`);
                const resData = await res.json();
                if (resData.status === 'success' && resData.data.length > 0) {
                    cachePraticasAtivas = resData.data;
                    const selectPratica = document.getElementById('select-pratica-ativa');

                    selectPratica.innerHTML = '<option value="">-- Escolha uma Prática Ativa --</option>' +
                        resData.data.map(p => `<option value="${p.id_prat}">${p.estra_pratica}</option>`).join('');

                    document.getElementById('wrapper-select-pratica').classList.remove('hidden');
                }
            } catch(e) { console.error(e); }
        }

        function configurarPlaceholdersPraticaAtiva() {
            const idPrat = parseInt(document.getElementById('select-pratica-ativa').value);
            if (!idPrat) return;
            const pratica = cachePraticasAtivas.find(p => p.id_prat === idPrat);
            if (!pratica) return;

            document.getElementById('txt-hipo-espex').innerText = `Hipótese: O impacto de aplicar a estratégia "${pratica.estra_pratica}" no aprendizado...`;
            document.getElementById('txt-desc-espex').innerText = `Passos de Implementação da Prática: ${pratica.meca_func}`;
            document.getElementById('txt-result-espex').innerText = `Resultados e Recursos Alvo: ${pratica.recursos_impacto}`;

            document.getElementById('txt-hipo-espex').setAttribute('data-placeholder', `Hipótese: O impacto de aplicar a estratégia "${pratica.estra_pratica}" no aprendizado...`);
            document.getElementById('txt-desc-espex').setAttribute('data-placeholder', `Passos de Implementação da Prática: ${pratica.meca_func}`);
            document.getElementById('txt-result-espex').setAttribute('data-placeholder', `Resultados e Recursos Alvo: ${pratica.recursos_impacto}`);

            const jaExiste = rotasMetodologicasSalvas.some(r => r.id_prat === idPrat);
            if (!jaExiste) rotasMetodologicasSalvas.push({ "id_meta": pratica.id_meta, "id_prat": idPrat });
        }

        // 🎯 FUNÇÕES DE GERENCIAMENTO DA LISTA DE SUBTASKS
        function renderizarSubtasksLocais() {
            const container = document.getElementById('lista-subtasks-adicionadas');
            if (!container) return;
            if (listaSubtasksLocais.length === 0) {
                container.innerHTML = '<div class="text-[9px] text-slate-500 italic mt-1">Nenhuma subtask vinculada no momento.</div>';
                return;
            }
            container.innerHTML = listaSubtasksLocais.map((st, idx) => `
                <div class="flex justify-between items-center p-2 bg-slate-950 border border-amber-900/30 rounded shadow-sm">
                    <div class="text-[10px] text-slate-300 leading-tight pr-2"><strong class="text-amber-500 uppercase">[${st.pilar_subtask.replace('item_','P')}]</strong> ${st.desc_subtask}</div>
                    <button type="button" onclick="removerSubtaskLocal(${idx})" class="text-rose-500 hover:text-rose-400 px-2 flex-shrink-0 transition-colors" title="Excluir subtask"><i class="fa-solid fa-trash-can"></i></button>
                </div>
            `).join('');
        }

        function adicionarSubtaskNaLista() {
            if (listaSubtasksLocais.length >= 4) return alert("O limite máximo de planejamento é de 4 subtasks.");
            const txtEl = document.getElementById('txt-nova-subtask');
            const texto = txtEl.innerText.trim();
            if (!texto) return alert("Por favor, descreva a subtask antes de tentar vinculá-la.");

            const radioPilar = document.querySelector('input[name="rd_pilar_subtask"]:checked');
            const pilarVal = radioPilar ? radioPilar.value : 'item_1';

            listaSubtasksLocais.push({ pilar_subtask: pilarVal, desc_subtask: texto });
            txtEl.innerText = ''; // Limpa a caixa após adicionar
            renderizarSubtasksLocais();
        }

        function removerSubtaskLocal(idx) {
            listaSubtasksLocais.splice(idx, 1);
            renderizarSubtasksLocais();
        }


        async function carregarHistoricoExperimentos(idAcao) {
            const container = document.getElementById('container-experimentos-lista');
            if(!container) return; container.innerHTML = '<div class="text-[11px] text-slate-500 italic">Atualizando laboratório...</div>';
            try {
                const res = await fetch(`/inovador/api/experimentos?id_acao=${idAcao}`);
                const resData = await res.json();
                if (resData.status === 'success' && resData.data && resData.data.length > 0) {
                    cacheExperimentosLocais = resData.data;
                    container.innerHTML = resData.data.map(exp => `
                        <div onclick="carregarExperimentoParaEdicao(${exp.id_espex})" class="p-2 bg-slate-950/40 border border-slate-800 rounded-md flex justify-between items-center cursor-pointer hover:bg-slate-800 transition-all" title="Clique para editar">
                            <span class="text-xs text-slate-300 truncate"><i class="fa-solid fa-flask text-fuchsia-400 mr-2"></i>Exp: ${exp.hipo_espex.substring(0, 50)}...</span>
                            <span class="text-[10px] text-cyan-400"><i class="fa-solid fa-pen"></i></span>
                        </div>
                    `).join('');
                } else {
                    cacheExperimentosLocais = [];
                    container.innerHTML = '<div class="text-[11px] text-slate-500 italic">Nenhum experimento registrado.</div>';
                }
            } catch(e) { console.error(e); }
        }

        function carregarExperimentoParaEdicao(idEspex) {
            const exp = cacheExperimentosLocais.find(e => e.id_espex === idEspex);
            if(!exp) return;
            document.getElementById('hdn-id-espex').value = exp.id_espex;
            document.getElementById('txt-hipo-espex').innerText = exp.hipo_espex;
            document.getElementById('txt-desc-espex').innerText = exp.desc_espex;
            document.getElementById('txt-result-espex').innerText = exp.result_espex;
            document.getElementById('btn-salvar-experimento').innerText = "Atualizar Experimento";
        }

        async function adicionarExperimentoDescritivo() {
            const idAcao = document.getElementById('hdn-id-acao').value;
            if(!idAcao) return alert("Lance a Sprint ou selecione uma ação incubada antes!");

            const idEspexEdicao = document.getElementById('hdn-id-espex').value;
            const hipo = document.getElementById('txt-hipo-espex').innerText.trim();
            const desc = document.getElementById('txt-desc-espex').innerText.trim();
            const result = document.getElementById('txt-result-espex').innerText.trim();

            if(!hipo || !desc || !result) return alert("Preencha todos os campos do experimento!");

            try {
                const metodo = idEspexEdicao ? 'PUT' : 'POST';
                const payload = { id_acao: parseInt(idAcao), hipo_espex: hipo, desc_espex: desc, result_espex: result };
                if(idEspexEdicao) payload.id_espex = parseInt(idEspexEdicao);

                const response = await fetch('/inovador/api/experimentos', {
                    method: metodo, headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if((await response.json()).status === 'success') {
                    document.getElementById('hdn-id-espex').value = '';
                    document.getElementById('txt-hipo-espex').innerText = '';
                    document.getElementById('txt-desc-espex').innerText = '';
                    document.getElementById('txt-result-espex').innerText = '';
                    document.getElementById('btn-salvar-experimento').innerText = "Adicionar Experimento";
                    carregarHistoricoExperimentos(parseInt(idAcao));
                }
            } catch(e) { console.error(e); }
        }

        async function dispararLançamentoOuAtualizacao(idAcaoOpcional = null, blocoForcado = null) {
            const bloco = blocoForcado || document.getElementById('select-bloco').value;
            let pilaresFinais = {};
            document.querySelectorAll('.pilar-editavel').forEach(el => { pilaresFinais[el.getAttribute('data-key')] = el.innerText.trim(); });
            const selecionadas = Array.from(document.querySelectorAll('.chk-nota:checked')).map(cb => parseInt(cb.value));
            const schoolsInput = document.getElementById('txt-escolas-ref');
            const codigosEsf = schoolsInput ? schoolsInput.value.trim() : "";

            try {
                const response = await fetch('/inovador/api/acoes/salvar', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id_acao: idAcaoOpcional,
                        id_clie: idClieReal,
                        bloco_leaction: bloco,
                        ids_notas: selecionadas,
                        nome_acao: document.getElementById('res-titulo').innerText.trim(),
                        justificativa_pedagogica: document.getElementById('res-justificativa').innerText.trim(),
                        impacto_negocio: document.getElementById('res-impacto').innerText.trim(),
                        composicao_estruturada: pilaresFinais,
                        codigos_escolas_ref: codigosEsf,
                        id_prob: cmuSelecionadoLocal ? cmuSelecionadoLocal.id_prob : null,
                        rotas_metodologicas: rotasMetodologicasSalvas,
                        subtasks_list: listaSubtasksLocais // Apenas o vetor da nova tabela é enviado
                    })
                });
                if((await response.json()).status === 'success') {
                    alert("Operação realizada com sucesso!");
                    window.location.reload();
                }
            } catch(e) { console.error(e); }
        }

        async function editarRotinaAtiva() {

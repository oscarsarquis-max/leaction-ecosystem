            const novoTitulo = prompt("Refine o título:", textoAtual); if(!novoTitulo) return;
            try {
                const res = await fetch('/inovador/api/rotinas', {
                    method: 'PUT', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id_rotina: parseInt(id), titulo_atividade: novoTitulo })
                });
                if((await res.json()).status === 'success') inicializarDashboard();
            } catch(e) { console.error(e); }

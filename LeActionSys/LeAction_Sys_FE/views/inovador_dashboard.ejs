<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PanelDX - QG do Inovador</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); min-height: 100vh; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .pulse-mic { animation: pulse 1.5s infinite; }
        @keyframes pulse {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

        [contenteditable][data-placeholder]:empty:before {
            content: attr(data-placeholder);
            color: #475569;
        }
    </style>

</head>
<body class="text-slate-100 font-sans">

    <header class="border-b border-slate-800 bg-slate-900/50 backdrop-blur px-8 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <div class="p-2 bg-indigo-600 rounded-lg text-xl font-bold text-white">DX</div>
            <div>
                <h1 class="text-lg font-bold bg-gradient-to-r from-cyan-400 to-fuchsia-500 bg-clip-text text-transparent">Oficina do Inovador</h1>
                <p class="text-xs text-slate-400">Sandbox de Captura e Operação Pedagógica</p>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <div class="text-xs px-3 py-1 rounded bg-slate-800 border border-slate-700 text-slate-300">
                Cliente Ativo ID: <strong id="lbl-cliente-id">{{ id_clie }}</strong>
            </div>
            <button onclick="executarLogout()" class="text-rose-400 hover:text-rose-300 transition-colors text-lg p-2 rounded-xl bg-slate-900/60 border border-slate-800 hover:border-rose-500/30 shadow-md" title="Sair da Oficina e voltar ao PanelDX">
                <i class="fa-solid fa-right-from-bracket"></i>
            </button>
        </div>
    </header>

    <main class="max-w-7xl mx-auto p-6 grid grid-cols-1 lg:grid-cols-12 gap-6">

        <section class="lg:col-span-5 flex flex-col gap-6">
            <div class="glass-panel rounded-2xl p-5 shadow-xl space-y-4">
                <div class="flex justify-between items-center">
                    <h2 class="text-sm font-semibold tracking-wide text-slate-400 uppercase"><i class="fa-solid fa-calendar-day text-cyan-400 mr-2"></i>1. Rotina Contextual</h2>
                    <div class="flex gap-1">
                        <button onclick="editarRotinaAtiva()" class="text-slate-400 hover:text-cyan-400 text-xs p-1"><i class="fa-solid fa-pen"></i></button>
                        <button onclick="deletarRotinaAtiva()" class="text-slate-400 hover:text-rose-400 text-xs p-1"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </div>
                <select id="select-rotina" class="w-full bg-slate-900 border border-slate-700 rounded-xl p-2.5 text-xs text-slate-200 focus:outline-none focus:border-cyan-500">
                    <option value="">Carregando suas aulas...</option>
                </select>
                <div class="flex gap-2 border-t border-slate-800 pt-3">
                    <input type="text" id="txt-nova-rotina" class="flex-1 bg-slate-900/60 border border-slate-700 rounded-xl p-2 text-xs text-slate-200 focus:outline-none placeholder-slate-600" placeholder="Nova Aula (Ex: 3º Ano - Física)">
                    <button id="btn-add-rotina" class="bg-cyan-600 hover:bg-cyan-500 text-slate-950 font-bold px-3 rounded-xl text-xs"><i class="fa-solid fa-plus"></i></button>
                </div>
            </div>

            <div class="glass-panel rounded-2xl p-5 shadow-xl">
                <h2 class="text-sm font-semibold tracking-wide text-slate-400 uppercase mb-4"><i class="fa-solid fa-microphone-lines text-cyan-400 mr-2"></i>2. Desabafo de Campo</h2>
                <div class="flex flex-col items-center justify-center p-3 bg-slate-900/40 rounded-xl border border-slate-800 mb-3">
                    <button id="btn-mic" class="w-14 h-14 bg-gradient-to-tr from-cyan-500 to-blue-600 rounded-full flex items-center justify-center text-white text-xl shadow-lg transition-all hover:scale-105">
                        <i class="fa-solid fa-microphone" id="mic-icon"></i>
                    </button>
                    <p id="mic-status" class="text-[10px] text-slate-500 mt-2 text-center">Clique para ditar insights ou gargalos</p>
                </div>
                <div class="space-y-2">
                    <textarea id="txt-nota" rows="3" class="w-full bg-slate-900/60 border border-slate-700/60 rounded-xl p-3 text-sm text-slate-200 focus:outline-none focus:border-cyan-500" placeholder="Escreva ou dite the problem ocorrido na aula..."></textarea>
                    <button id="btn-salvar-nota" class="w-full bg-cyan-600 hover:bg-cyan-500 text-slate-950 py-2.5 rounded-xl text-xs font-bold tracking-wide">Registrar no Diário de Bordo</button>
                </div>
            </div>

            <div class="glass-panel rounded-2xl p-5 shadow-xl flex-1 flex flex-col">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-sm font-semibold tracking-wide text-slate-400 uppercase"><i class="fa-solid fa-palette text-indigo-400 mr-2"></i>Mural de Afinidades</h2>
                    <span id="contador-notas" class="text-xs bg-slate-800 px-2.5 py-0.5 rounded-full text-slate-300 font-bold">0</span>
                </div>
                <div id="container-notas" class="grid grid-cols-2 gap-3 max-h-[350px] overflow-y-auto p-1 flex-1"></div>
            </div>
        </section>

        <section class="lg:col-span-7 glass-panel rounded-2xl p-6 shadow-xl flex flex-col">
            <h2 class="text-sm font-semibold tracking-wide text-slate-400 uppercase mb-4"><i class="fa-solid fa-flask-vial text-fuchsia-400 mr-2"></i>Mesa de Lapidação Inteligente</h2>

            <div class="bg-slate-900/60 border border-slate-800 rounded-xl p-4 mb-4 relative">
                <span class="text-[10px] uppercase text-cyan-400 font-bold block mb-1.5"><i class="fa-solid fa-graduation-cap mr-1"></i> Classificação Científica CMU (Referencial Teórico)</span>
                <div class="relative">
                    <input type="text" id="txt-busca-cmu" oninput="executarBuscaCMU(this.value)" class="w-full bg-slate-950 border border-slate-700 rounded-lg p-2.5 pl-9 text-xs text-slate-200 focus:outline-none focus:border-cyan-500" placeholder="Digite um termo para classificar o problema (Ex: falta, tecnologia, nota)...">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-3.5 text-slate-500 text-xs"></i>
                </div>
                <div id="dropdown-resultados-cmu" class="hidden absolute left-4 right-4 top-[68px] bg-slate-900 border border-slate-700 rounded-xl shadow-2xl z-50 max-h-[220px] overflow-y-auto"></div>

                <div id="bloco-exibicao-cmu" class="hidden mt-3 p-3 bg-slate-950/60 border border-slate-800 rounded-xl space-y-2 text-xs">
                    <div><strong class="text-cyan-400"><i class="fa-solid fa-triangle-exclamation mr-1"></i> Descrição do Problema:</strong> <p id="lbl-cmu-desc" class="text-slate-200 mt-0.5 leading-relaxed"></p></div>
                    <div><strong class="text-cyan-400"><i class="fa-solid fa-code-fork mr-1"></i> Razões Causa-Raiz:</strong> <p id="lbl-cmu-razoes" class="text-slate-300 mt-0.5 leading-relaxed"></p></div>
                    <div><strong class="text-cyan-400"><i class="fa-solid fa-lightbulb mr-1"></i> Soluções Mapeadas:</strong> <p id="lbl-cmu-solucoes" class="text-slate-300 mt-0.5 leading-relaxed"></p></div>
                </div>
            </div>

            <div class="bg-slate-900/40 border border-slate-800 rounded-xl p-4 mb-6">
                <select id="select-bloco" class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm text-slate-200 focus:outline-none">
                    <option value="Aprendizagem_Experiencial">Aprendizagem Experiencial (Framework de Programa Baseado em Experiência)</option>
                    <option value="Aprendizagem_Digital">Aprendizagem Digital (Plano LXD - Design de Experiência do Aprendiz)</option>
                    <option value="Testes_Exames">Testes e Exames (Sistema de Avaliação Digital Formativa/Somativa)</option>
                </select>
            </div>

            <div class="flex-1 flex flex-col border border-dashed border-slate-700/60 rounded-xl p-4 bg-slate-900/20 relative min-h-[300px]">
                <div id="ia-empty-state" class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center">
                    <div class="w-12 h-12 rounded-full bg-fuchsia-500/10 flex items-center justify-center text-fuchsia-400 mb-2 text-xl"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
                    <p class="text-xs text-slate-400">Clique em um post-it já <strong>Incubado</strong> para leitura ou selecione os <strong>Pendentes</strong> para lapidar com a IA.</p>
                </div>

                <div id="ia-result-panel" class="hidden space-y-4 text-sm flex-1 overflow-y-auto max-h-[420px] pr-1">
                    <input type="hidden" id="hdn-id-acao" value="">

                    <div id="card-cmu-selecionado" class="hidden p-3 bg-cyan-950/20 border border-cyan-500/20 rounded-xl space-y-1.5">
                        <div class="flex justify-between items-center">
                            <span class="text-[9px] uppercase bg-cyan-900/50 px-2 py-0.5 rounded text-cyan-300 font-bold" id="lbl-cmu-grupo-cat"></span>
                            <button onclick="removerClassificacaoCMU()" class="text-slate-500 hover:text-rose-400 text-[10px]"><i class="fa-solid fa-xmark"></i> Remover</button>
                        </div>
                        <p class="text-xs text-slate-200 font-semibold" id="lbl-cmu-sintoma"></p>
                        <div class="text-[11px] text-slate-400 border-t border-cyan-500/10 pt-1" id="lbl-cmu-remedio"></div>
                    </div>

                    <div class="p-3 bg-gradient-to-r from-fuchsia-950/40 to-indigo-950/40 border border-fuchsia-500/30 rounded-xl">
                        <span class="text-[9px] uppercase tracking-wider font-bold text-fuchsia-400 block mb-1">Título do Projeto (Clique para editar)</span>
                        <h4 id="res-titulo" contenteditable="true" class="font-bold text-slate-200 text-base focus:outline-none"></h4>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800">
                            <span class="text-[9px] uppercase text-slate-400 block font-medium mb-1">Justificativa Pedagógica</span>
                            <p id="res-justificativa" contenteditable="true" class="text-xs text-slate-300 focus:outline-none p-1"></p>
                        </div>
                        <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800">
                            <span class="text-[9px] uppercase text-slate-400 block font-medium mb-1">Impacto no Negócio (ROI/ESG)</span>
                            <p id="res-impacto" contenteditable="true" class="text-xs text-slate-300 focus:outline-none p-1"></p>
                        </div>
                    </div>
                    <div class="p-4 bg-slate-900/80 rounded-xl border border-slate-800 space-y-3">
                        <span class="text-xs font-semibold text-indigo-400 block uppercase tracking-wider">Composição do Artefato Metodológico</span>
                        <div id="res-composicao" class="space-y-2 text-xs text-slate-400"></div>
                    </div>

                    <div id="panel-experimentacao" class="hidden border-t border-slate-800 pt-4 space-y-4">
                        <span class="text-xs font-semibold text-fuchsia-400 block uppercase tracking-wider">
                            <i class="fa-solid fa-vial-circle-check mr-1"></i> Laboratório de Experimentação Ativa
                        </span>

                        <div id="form-novo-experimento" class="p-3 bg-slate-900/80 border border-slate-800 rounded-xl space-y-3 relative">
                            <span class="text-[10px] uppercase text-fuchsia-400 font-bold block"><i class="fa-solid fa-magnifying-glass-chart mr-1"></i> Ancorar Metodologia Ativa de Referência</span>

                            <div class="relative">
                                <input type="text" id="txt-busca-metodo" oninput="executarBuscaMetodologia(this.value)" class="w-full bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-slate-200 focus:outline-none placeholder-slate-600" placeholder="Pesquisar Metodologia (Ex: Ágeis, Imersivas, Analíticas)...">
                                <div id="dropdown-resultados-metodo" class="hidden absolute left-0 right-0 top-9 bg-slate-900 border border-slate-700 rounded-xl shadow-2xl z-50 max-h-[180px] overflow-y-auto"></div>
                            </div>

                            <div id="wrapper-select-pratica" class="hidden space-y-1">
                                <label class="text-[9px] text-slate-400 uppercase font-bold block">Prática Pedagógica Co-Autora Alvo</label>
                                <select id="select-pratica-ativa" onchange="configurarPlaceholdersPraticaAtiva()" class="w-full bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-slate-200 focus:outline-none"></select>
                            </div>

                            <span class="text-[10px] uppercase text-slate-400 font-bold block pt-2 border-t border-slate-800/60">Registrar Evidência de Campo</span>

                            <div class="space-y-2">
                                <input type="hidden" id="hdn-id-espex" value="">

                                <div id="txt-hipo-espex" contenteditable="true" data-placeholder="Hipótese Empírica (O que você acreditava que iria acontecer?)" class="w-full bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-slate-200 focus:outline-none min-h-[40px]"></div>
                                <div id="txt-desc-espex" contenteditable="true" data-placeholder="Descrição da Experimentação Ativa (O que foi executado na prática?)" class="w-full bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-slate-200 focus:outline-none min-h-[60px]"></div>
                                <div id="txt-result-espex" contenteditable="true" data-placeholder="Resultados Alcançados (Qual foi o impacto observado?)" class="w-full bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-slate-200 focus:outline-none min-h-[60px]"></div>

                                <!-- O CAMPO ANTIGO DE SUBTASK FOI TOTALMENTE REMOVIDO DAQUI -->

                                <button type="button" id="btn-salvar-experimento" onclick="adicionarExperimentoDescritivo()" class="w-full bg-fuchsia-700 hover:bg-fuchsia-600 text-white font-bold py-1.5 rounded-lg text-[11px] uppercase tracking-wide transition-all">Adicionar Experimento</button>
                            </div>
                        </div>

                        <div id="container-experimentos-lista" class="space-y-2 max-h-[220px] overflow-y-auto pr-1"></div>

                        <!-- 🎯 NOVO GERENCIADOR MÚLTIPLO DE SUBTASKS (ISOLADO DOS EXPERIMENTOS) -->
                        <div class="p-4 bg-slate-900/60 rounded-xl border border-amber-500/30 mt-4 space-y-3">
                            <span class="text-[10px] uppercase text-amber-400 font-bold block mb-2"><i class="fa-solid fa-list-check mr-1"></i> Planejamento de Subtasks (Máx 4)</span>

                            <div class="flex flex-col gap-2 bg-slate-900/40 p-2 rounded-lg border border-amber-700/30">
                                <div id="txt-nova-subtask" contenteditable="true" data-placeholder="Descreva a subtask (Ex: Configurar ambiente...)" class="w-full bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-amber-100 focus:outline-none min-h-[40px]"></div>

                                <div class="flex justify-between items-center border-t border-slate-800/60 pt-2">
                                    <div class="flex gap-3">
                                        <label class="flex items-center gap-1 text-[9px] text-slate-300 uppercase cursor-pointer hover:text-amber-400">
                                            <input type="radio" name="rd_pilar_subtask" value="item_1" class="accent-amber-500"> Pilar 1
                                        </label>
                                        <label class="flex items-center gap-1 text-[9px] text-slate-300 uppercase cursor-pointer hover:text-amber-400">
                                            <input type="radio" name="rd_pilar_subtask" value="item_2" class="accent-amber-500" checked> Pilar 2
                                        </label>
                                        <label class="flex items-center gap-1 text-[9px] text-slate-300 uppercase cursor-pointer hover:text-amber-400">
                                            <input type="radio" name="rd_pilar_subtask" value="item_3" class="accent-amber-500"> Pilar 3
                                        </label>
                                        <label class="flex items-center gap-1 text-[9px] text-slate-300 uppercase cursor-pointer hover:text-amber-400">
                                            <input type="radio" name="rd_pilar_subtask" value="item_4" class="accent-amber-500"> Pilar 4
                                        </label>
                                    </div>
                                    <button type="button" onclick="adicionarSubtaskNaLista()" class="bg-amber-600 hover:bg-amber-500 text-slate-950 font-bold px-2 py-1 rounded text-[9px] uppercase transition-colors">Vincular</button>
                                </div>
                            </div>
                            <div id="lista-subtasks-adicionadas" class="space-y-1 mt-2"></div>
                        </div>
                    </div>

                    <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 mt-4">
                        <span class="text-[10px] uppercase text-indigo-400 block font-bold mb-1">
                            <i class="fa-solid fa-network-wired mr-1"></i> Integração Projeto Escola (cód. ref.)
                        </span>
                        <input type="text" id="txt-escolas-ref" class="bg-slate-950 border border-slate-700 rounded-lg p-2.5 text-xs text-slate-200 focus:outline-none focus:border-indigo-500 w-full" placeholder="Ex: 71, 85, 104 (separe por vírgula para espalhar em mais de uma)">
                        <span class="text-[9px] text-slate-500 block mt-1">Esta inovação será distribuída de forma assíncrona para o Kanban de todas as escolas listadas.</span>
                    </div>

                    <div class="p-4 bg-slate-900/80 rounded-xl border border-slate-700/50 mt-4 space-y-3">
                        <span class="text-[10px] uppercase text-amber-400 block font-bold">
                            <i class="fa-solid fa-file-export mr-1"></i> Exportação Híbrida de Sprint (Agile Delivery)
                        </span>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="text-[10px] text-slate-400 block mb-1">Nome do Arquivo JSON</label>
                                <input type="text" id="txt-nome-arquivo-export" class="bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-slate-200 focus:outline-none focus:border-amber-500 w-full" placeholder="sprint_backlog_pedagogico">
                            </div>
                            <div>
                                <label class="text-[10px] text-slate-400 block mb-1">Formato / Destino Alvo</label>
                                <select id="combo-formato-destino" class="bg-slate-950 border border-slate-700 rounded-lg p-2 text-xs text-slate-200 focus:outline-none focus:border-amber-500 w-full">
                                    <option value="Universal">Universal (Agnóstico / Envelope Puro)</option>
                                    <option value="Jira">Jira Cloud (Scrum Native / Issue Stories)</option>
                                    <option value="Trello">Trello Workspace (Kanban Pure / Board Lists)</option>
                                </select>
                            </div>
                        </div>
                        <button type="button" id="btn-exportar-json" class="w-full bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-400 hover:to-orange-400 text-slate-950 font-bold py-2 rounded-xl text-xs uppercase tracking-wide transition-all shadow-md">
                            <i class="fa-solid fa-download mr-1"></i> Compilar e Baixar Arquivo
                        </button>
                    </div>
                </div>
            </div>

            <div class="mt-6 pt-4 border-t border-slate-800/80 flex gap-4">
                <button id="btn-incubar" class="flex-1 bg-gradient-to-r from-fuchsia-600 to-indigo-600 hover:from-fuchsia-500 hover:to-indigo-500 text-white text-xs font-bold uppercase tracking-wider py-3 rounded-xl shadow-lg shadow-fuchsia-600/20">Lapidar com IA Co-Autora</button>
                <button id="btn-sprint" disabled class="bg-amber-600/20 border border-amber-500/30 text-amber-500/40 text-xs font-bold uppercase tracking-wider px-6 rounded-xl transition-all cursor-not-allowed">Lançar Sprint</button>
            </div>
        </section>
    </main>

    <script>

        const idClieReal = parseInt("{{ id_clie }}") || 999;
        let notasLocais = [];
        let cmuSelecionadoLocal = null;
        let cacheResultadosCMU = [];

        let cacheMetodologiasAtivas = [];
        let cachePraticasAtivas = [];
        let rotasMetodologicasSalvas = [];
        let cacheExperimentosLocais = [];

        // 🎯 NOVO VETOR GLOBAL PARA GERENCIAR AS SUBTASKS ANTES DE SALVAR/EXPORTAR
        let listaSubtasksLocais = [];

        const selectRotina = document.getElementById('select-rotina');
        const txtNovaRotina = document.getElementById('txt-nova-rotina');
        const containerNotas = document.getElementById('container-notas');
        const txtNota = document.getElementById('txt-nota');
        const btnMic = document.getElementById('btn-mic');
        const micIcon = document.getElementById('mic-icon');
        const micStatus = document.getElementById('mic-status');
        const btnIncubar = document.getElementById('btn-incubar');
        const btnSprint = document.getElementById('btn-sprint');

        async function inicializarDashboard() {
            try {
                const lblId = document.getElementById('lbl-cliente-id');
                if (lblId) lblId.innerText = idClieReal;

                const resRotinas = await fetch(`/inovador/api/rotinas?id_clie=${idClieReal}`);
                const dataRotinas = await resRotinas.json();
                if (dataRotinas.status === 'success' && dataRotinas.data.length > 0) {
                    selectRotina.innerHTML = dataRotinas.data.map(r => `<option value="${r.id_rotina}">${r.titulo_atividade}</option>`).join('');
                } else {
                    selectRotina.innerHTML = `<option value="">Crie uma aula abaixo para começar</option>`;
                }

                const resNotas = await fetch(`/inovador/api/notas?id_clie=${idClieReal}`);
                const dataNotas = await resNotas.json();
                notasLocais = dataNotas.status === 'success' ? dataNotas.data : [];
                renderizarNotas();

                const resCmuSessao = await fetch('/inovador/api/cmu/sessao');
                const dataCmuSessao = await resCmuSessao.json();
                if (dataCmuSessao.status === 'success' && dataCmuSessao.data) {
                    cmuSelecionadoLocal = dataCmuSessao.data;
                    document.getElementById('txt-busca-cmu').value = cmuSelecionadoLocal.categoria_prob;
                    mostrarCmuNoPainelBusca(cmuSelecionadoLocal);
                }
            } catch (err) { console.error("Erro no carregamento do painel:", err); }
        }

        function mostrarCmuNoPainelBusca(item) {
            const bloco = document.getElementById('bloco-exibicao-cmu');
            if (!item) { bloco.classList.add('hidden'); return; }
            bloco.classList.remove('hidden');
            document.getElementById('lbl-cmu-desc').innerText = item.desc_prob || '';
            document.getElementById('lbl-cmu-razoes').innerText = item.razoes_prob || '';
            document.getElementById('lbl-cmu-solucoes').innerText = item.solucoes_prob || '';
        }

        async function executarBuscaCMU(termo) {
            const dropdown = document.getElementById('dropdown-resultados-cmu');
            if (termo.trim().length < 2) { dropdown.classList.add('hidden'); cacheResultadosCMU = []; return; }
            try {
                const res = await fetch(`/inovador/api/cmu/buscar?q=${encodeURIComponent(termo)}`);
                const resData = await res.json();
                if (resData.status === 'success' && resData.data.length > 0) {
                    cacheResultadosCMU = resData.data; dropdown.classList.remove('hidden');
                    dropdown.innerHTML = resData.data.map(item => `
                        <div onclick="selecionarProblemaCMUPorId(${item.id_prob})" class="p-3 border-b border-slate-800 hover:bg-slate-800 cursor-pointer transition-all text-left">
                            <div class="text-[9px] text-cyan-400 font-bold uppercase tracking-wider mb-1">${item.grupo_prob} › ${item.categoria_prob}</div>
                            <div class="text-xs text-slate-200 font-bold leading-tight"><i class="fa-solid fa-triangle-exclamation text-amber-500 mr-1"></i>${item.desc_prob}</div>
                            <div class="text-[11px] text-slate-400 font-medium mt-1 pl-4 border-l border-slate-700 bg-slate-950/20 py-0.5"><strong>Causa:</strong> ${item.razoes_prob}</div>
                        </div>
                    `).join('');
                } else { dropdown.classList.remove('hidden'); dropdown.innerHTML = '<div class="p-3 text-xs text-slate-500 italic">Sem correspondência diagnóstica.</div>'; }

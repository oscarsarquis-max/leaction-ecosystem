# Diário de Obra API — porta exclusiva 6010 (não conflita com Gateway/Marketplace/Chamelleon)
PORT=6010
FLASK_DEBUG=1

# PostgreSQL dedicado — base `diario-obra` no mesmo servidor
DATABASE_URL=postgresql://admin:password123@localhost:5433/diario-obra

# Alternativa por variáveis (opcional):
# DB_HOST=localhost
# DB_PORT=5433
# DB_USER=admin
# DB_PASSWORD=password123
# DB_NAME=diario-obra

INTEGRATION_API_KEY=change-me-diario-obra-integration-key
CORS_ORIGINS=http://localhost:4000,http://localhost:5010,http://localhost:6173
